{
	"compatibility_date": "2026-06-05",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "civic-commons",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "cvc",
			"database_name": "civic_commons",
			"database_id": "07975d00-e3c9-4d30-96ac-c311ea31b67c"
		}
	]
}