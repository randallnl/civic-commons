{
	"compatibility_date": "2026-06-05",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "nhdb-api",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"r2_buckets": [
		{
			"binding": "organization-assets",
			"bucket_name": "organization-assets"
		}
	],
	"observability": {
		"enabled": true
	}
}
