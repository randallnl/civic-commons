{
	"compatibility_date": "2026-06-05",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "nhdb-api",
	"main": "src/worker/nhdb-api.js",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "civic_commons",
			"database_id": "07975d00-e3c9-4d30-96ac-c311ea31b67c"
		}
	],
	"r2_buckets": [
		{
			"binding": "LEGISLATOR_PHOTOS",
			"bucket_name": "legislator-photos"
		}
	]
}
