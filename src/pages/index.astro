---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import BillPositionSummary from "../components/BillPositionSummary.astro";
import headingBanner from "../assets/heading_banner.png";
import profileIcon from "../assets/profile icon.png";
import { articleDetailPath, articlePublishDate, articleSourceName, getArticles } from "../lib/articlesApi";
import { billDetailPath, getBills, getBillSummaries } from "../lib/billsApi";
import { isFreeStater } from "../lib/civicTags";
import { getRepresentatives, repName, repSlug } from "../lib/repsApi";
import { cleanText } from "../lib/text";
import { enrichArticlesWithPreviews } from "../lib/articlePreviews";
import { getOrganizations, organizationPath } from "../lib/organizationsApi";
import {
  communityUpdateDate,
  getRecentApprovedCommunityUpdates,
} from "../lib/communityUpdates";
import {
  getTrackedBills,
  normalizeBillCode,
  representativeOnlineTestimonyVotePreviews,
  representativeOnlineTestimonyVoteStance,
  representativeGradeFor,
  trackedBillForVote,
} from "../lib/trackedBills";
import { getSpotlightLegislators } from "../lib/spotlightTracker";
import { profilePhotoUrl } from "../lib/photos";

let recentArticles = [];
let recentBills = [];
let recentPeople = [];
let organizationComments = [];
let recentCommunityUpdates = [];
let trackedBills = new Map();
let billSummaries = new Map();
const howToStepImages = [
  organizationAssetUrl("capital dome.png"),
  organizationAssetUrl("portsmouth.png"),
  organizationAssetUrl("nh chamber.jpg"),
  organizationAssetUrl("community.png"),
];

try {
  const [
    articleResult,
    billResult,
    repResult,
    trackedBillResult,
    billSummaryResult,
    spotlightResult,
    organizationResult,
    communityUpdatesResult,
  ] = await Promise.allSettled([
    getArticles({ include: "relations", limit: 5 }),
    getBills({ limit: 6 }),
    getRepresentatives({ limit: 8 }),
    getTrackedBills(),
    getBillSummaries(),
    getSpotlightLegislators({ limit: 8 }),
    getOrganizations(),
    getRecentApprovedCommunityUpdates({ limit: 6 }),
  ]);

  const articleData = articleResult.status === "fulfilled" ? articleResult.value : {};
  const billData = billResult.status === "fulfilled" ? billResult.value : {};
  const repData = repResult.status === "fulfilled" ? repResult.value : {};
  trackedBills = trackedBillResult.status === "fulfilled" ? trackedBillResult.value : new Map();
  billSummaries = billSummaryResult.status === "fulfilled" ? billSummaryResult.value : new Map();
  const spotlightPeople = spotlightResult.status === "fulfilled" ? spotlightResult.value : [];
  const organizations = organizationResult.status === "fulfilled" ? organizationResult.value : [];
  recentCommunityUpdates = communityUpdatesResult.status === "fulfilled" ? communityUpdatesResult.value : [];

  recentArticles = articleData.articles || [];
  recentBills = billData.bills || [];
  recentPeople = spotlightPeople.length ? spotlightPeople : repData.representatives || [];
  organizationComments = organizations
    .flatMap((organization) =>
      (organization.comments || []).map((comment) => ({ ...comment, organization })),
    )
    .filter((comment) => trackedBillForCode(comment.bill || comment.billLabel))
    .slice(0, 4);
} catch (error) {
  console.error(error?.message || "Unable to load homepage API data.");
}

recentArticles = await enrichArticlesWithPreviews(recentArticles, { limit: 5 });

function trackedBillFor(bill = {}) {
  return trackedBills.get(normalizeBillCode(bill.condensedbillno || bill.bill_number));
}

function trackedBillForCode(code = "") {
  const normalized = normalizeBillCode(code);
  if (!normalized) return null;
  if (trackedBills.has(normalized)) return trackedBills.get(normalized);

  for (const [key, bill] of trackedBills.entries()) {
    if (String(key).startsWith(`${normalized}::`)) return bill;
  }

  return null;
}

function organizationAssetUrl(filename = "") {
  return `/api/organization-assets/${String(filename)
    .split("/")
    .map((part) => encodeURIComponent(part))
    .join("/")}`;
}

function previewText(text = "", maxLength = 150) {
  const normalized = cleanText(text).replace(/\s+/g, " ").trim();
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trim()}...`;
}

function instagramPreview(value = "") {
  try {
    const url = new URL(value);
    const host = url.hostname.replace(/^www\./, "").toLowerCase();
    if (!["instagram.com", "instagr.am"].includes(host)) return null;

    const parts = url.pathname.split("/").filter(Boolean);
    const first = parts[0]?.toLowerCase() || "";
    const labels = {
      p: "Instagram post",
      reel: "Instagram reel",
      reels: "Instagram reel",
      tv: "Instagram video",
      stories: "Instagram story",
    };
    const label = labels[first] || "Instagram profile";
    const handle =
      first === "stories"
        ? parts[1]
        : labels[first]
          ? ""
          : parts[0] || "";

    return { label, handle, host };
  } catch {
    return null;
  }
}

function legislativeBody(person = {}) {
  const value = String(person.chamber || person.legislativebody || person.body || "").toLowerCase();
  if (value === "h" || value === "house") return "House";
  if (value === "s" || value === "senate") return "Senate";
  return person.chamber || "";
}

function districtLabel(person = {}) {
  const district = person.district || person.raw_district || "";
  const body = legislativeBody(person);
  if (!district) return body;
  if (body === "House") return `NH House District ${district}`;
  if (body === "Senate") return `NH Senate District ${district}`;
  return `District ${district}`;
}

function locationLabel(person = {}) {
  return cleanText(
    person.location_text ||
      person.locationText ||
      person.towns_represented ||
      person.townsRepresented ||
      "",
  );
}

function trackedVotesFor(person = {}, limit = 3) {
  return representativeOnlineTestimonyVotePreviews(person, billSummaries, { limit });
}

function billPreviewTitle(billSummary = {}, trackedBill = {}) {
  return cleanText(
    billSummary?.name ||
      billSummary?.title ||
      billSummary?.headline ||
      trackedBill?.name ||
      trackedBill?.title ||
      billSummary?.expandedbillno ||
      billSummary?.description ||
      "Bill details",
  );
}

function billPreviewSummary(billSummary = {}, trackedBill = {}) {
  return previewText(
    billSummary?.summary ||
      billSummary?.description ||
      trackedBill?.summary ||
      trackedBill?.impact ||
      "",
    180,
  );
}

function compactBillTitle(code = "", title = "") {
  const billCode = normalizeBillCode(code);
  const cleanedTitle = cleanText(title);
  if (!billCode) return cleanedTitle || "Bill details";
  if (!cleanedTitle || cleanedTitle === "Bill details") return billCode;

  const deDuplicated = cleanText(
    cleanedTitle
      .replace(new RegExp(`^${billCode}\\s*[:\\-–—]?\\s*`, "i"), "")
      .trim(),
  );

  return deDuplicated ? `${billCode}: ${deDuplicated}` : billCode;
}

function positionClass(position = "") {
  const value = String(position).toLowerCase();
  if (value.includes("support") || value.includes("favor")) return "support";
  if (value.includes("oppose") || value.includes("against")) return "oppose";
  return "neutral";
}

function billCommentTitle(trackedBill = {}, fallbackCode = "") {
  const code = normalizeBillCode(trackedBill.code || fallbackCode);
  const name = cleanText(trackedBill.name || trackedBill.title || "");
  if (!name) return code;

  const title = cleanText(
    name
      .replace(new RegExp(`^${code}\\s*[:\\-–—]?\\s*`, "i"), "")
      .trim(),
  ) || name;

  return [code, title].filter(Boolean).join(": ");
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>NH Deserves Better</title>
    <meta name="description" content="A community-powered civic directory for New Hampshire." />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <section class="hero">
        <img
          class="hero-banner"
          src={headingBanner.src}
          alt="NH Deserves Better"
          width="2000"
          height="500"
        />
        <div class="hero-copy">
          <p class="eyebrow">Community-powered civic information</p>
          <h1>Know your State Representatives, State Senator, and who wants the job next.</h1>
          <p class="lede">
            NH Deserves Better is a public directory focused on New Hampshire
            State Representatives, State Senators, and candidates for those
            offices, with legislative districts, bills, testimony, and civic
            coverage connected to them.
          </p>
        </div>
      </section>

      <section class="rep-preview">
        <div>
          <p class="eyebrow">Representative Lookup</p>
          <h2>Start with an address. See the right districts.</h2>
          <p>
            The tool identifies ward-specific House districts, Senate districts,
            State Representative and State Senator cards, contact details,
            and recent vote summaries.
          </p>
          <a href="/my-state-rep">Open My State Rep</a>
        </div>

        <div class="preview-panel">
          <span>Example result</span>
          <strong>72 Concord St, Manchester</strong>
          <ul>
            <li>Ward 3</li>
            <li>Senate District 20</li>
            <li>House HIL 23 + HIL 40</li>
          </ul>
        </div>
      </section>

      <section class="pathway">
        <div class="section-intro">
          <p class="eyebrow">How to use NH Deserves Better</p>
          <h2>Explore the tools on the site.</h2>
          <p>
            NH Deserves Better helps neighbors connect representatives,
            candidates, bills, testimony, local updates, articles, and
            community profiles in one place.
          </p>
        </div>

        <div class="feature-grid">
          <a class="feature-card" href="/my-state-rep">
            <img class="step-photo" src={howToStepImages[0]} alt="" loading="lazy" />
            <div>
              <span>Address lookup</span>
              <h3>Find My State Rep</h3>
              <p>Enter an address to find current State Representatives, State Senators, districts, candidates, and vote summaries.</p>
            </div>
          </a>

          <a class="feature-card" href="/communities">
            <img class="step-photo" src={howToStepImages[1]} alt="" loading="lazy" />
            <div>
              <span>Town and county profiles</span>
              <h3>Explore Communities</h3>
              <p>Search towns, counties, and districts to see legislators, candidates, articles, and updates tied to a place.</p>
            </div>
          </a>

          <a class="feature-card" href="/bills">
            <img class="step-photo" src={howToStepImages[2]} alt="" loading="lazy" />
            <div>
              <span>Bills and votes</span>
              <h3>Track Legislation</h3>
              <p>Review bill summaries, public testimony, roll calls, vote labels, and legislator vote alignment.</p>
            </div>
          </a>

          <a class="feature-card" href="/articles">
            <img class="step-photo" src={howToStepImages[3]} alt="" loading="lazy" />
            <div>
              <span>Community context</span>
              <h3>Share Updates</h3>
              <p>Submit articles, profile corrections, local updates, photos, and context for moderation.</p>
            </div>
          </a>
        </div>
      </section>

      <section class="homepage-stack">
        <div class="homepage-panel">
          <h2>Representative Profiles</h2>
          <ul class="list stacked-list">
            {recentPeople.length === 0 ? (
              <li>No legislators returned yet.</li>
            ) : recentPeople.map((person) => {
              const photoUrl = profilePhotoUrl(person.photo || person.photo_url);
              const grade = representativeGradeFor(person, trackedBills, billSummaries);
              const votes = trackedVotesFor(person, 3);

              return (
                <li class="person-preview">
                  <div class="person-preview-link">
                    <a class="person-photo-link" href={`/people/${repSlug(person)}`}>
                      <img
                        class:list={[!photoUrl && "profile-icon"]}
                        src={photoUrl || profileIcon.src}
                        alt={photoUrl ? `Photo of ${repName(person)}` : ""}
                        loading="lazy"
                      />
                    </a>
                    <div class="person-preview-copy">
                      <a href={`/people/${repSlug(person)}`}>
                        <strong>{repName(person)}</strong>
                      </a>
                      <small>
                        {[
                          person.party || "No party listed",
                          districtLabel(person),
                        ].filter(Boolean).join(" - ")}
                      </small>
                      {locationLabel(person) && <em>{locationLabel(person)}</em>}
                      {isFreeStater(person) && (
                        <a
                          class="free-stater-inline"
                          href="/free-staters"
                          title="What is a Free Stater?"
                          aria-label="What is a Free Stater?"
                        >
                          Free Stater
                        </a>
                      )}
                    </div>
                    <a
                      class:list={["mini-grade", grade.className]}
                      href="/vote-grades"
                      title="How do we determine this?"
                      aria-label={`How do we determine this? ${grade.label}`}
                    >
                      <strong>{grade.letter}</strong>
                      <small>Grade</small>
                    </a>
                  </div>
                  {votes.length > 0 && (
                    <div class="person-vote-list">
                      <span>Online Testimony Alignment</span>
                      {votes.map((preview) => {
                        const vote = preview.vote;
                        const billSummary = preview.billSummary;
                        const trackedBill = trackedBillForVote(trackedBills, vote);
                        const voteStance = representativeOnlineTestimonyVoteStance(vote, billSummary);
                        const billCode = billSummary?.condensedbillno || trackedBill?.code || vote.condensedbillno;
                        const billTitle = billPreviewTitle(billSummary, trackedBill);
                        const billSummaryText = billPreviewSummary(billSummary, trackedBill);
                        const billYear = billSummary?.sessionyear || vote.sessionyear;

                        return (
                          <div class:list={["person-vote-preview", voteStance.className]}>
                            <div class="person-vote-main">
                              <div class="person-vote-heading">
                                <a href={billDetailPath(billCode, billYear)}>
                                  {compactBillTitle(billCode, billTitle)}
                                </a>
                                {billSummaryText && <p>{billSummaryText}</p>}
                              </div>
                              <div class="person-vote-copy">
                                <div class:list={["vote-interpretation", voteStance.className]}>
                                  <strong>Vote</strong>
                                  <a
                                    class:list={["person-vote-pill", voteStance.className]}
                                    href="/vote-interpretations"
                                    title="How do we determine this?"
                                    aria-label={`How do we determine this? ${voteStance.label}`}
                                  >
                                    {voteStance.label}
                                  </a>
                                </div>
                              </div>
                              {billSummary && (
                                <div class="vote-pill-stack">
                                  <BillPositionSummary bill={billSummary} compact={true} />
                                </div>
                              )}
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  )}
                </li>
              );
            })}
          </ul>
        </div>

        <div class="homepage-panel">
          <h2>Then: Track Bills and Votes</h2>
          <div class="bill-preview-grid">
            {recentBills.length === 0 ? (
              <p class="empty-note">No bills added yet.</p>
            ) : (
              recentBills.map((bill) => {
                const trackedBill = trackedBillFor(bill);

                return (
                  <article class="bill-preview-card">
                    <a href={billDetailPath(bill.condensedbillno || bill.bill_number, bill.sessionyear || bill.session_year)}>
                      {bill.name || bill.title || trackedBill?.name || bill.condensedbillno || bill.bill_number}
                    </a>
                    <p>
                      {previewText(
                        bill.summary ||
                          trackedBill?.summary ||
                          bill.description ||
                          bill.title ||
                          "No tracker summary available yet.",
                      )}
                    </p>
                    <BillPositionSummary bill={bill} compact={true} />
                  </article>
                );
              })
            )}
          </div>
        </div>

        <div class="homepage-panel">
          <h2>Finally: Read Community Updates</h2>
          <ul class="list stacked-list">
            {recentArticles.length === 0 ? (
              <li>No articles added yet.</li>
            ) : (
              recentArticles.map((article) => (
                <li class:list={["article-update", article.preview?.imageUrl && "has-image"]}>
                  {article.preview?.imageUrl && (
                    <a class="article-thumb" href={articleDetailPath(article)} tabindex="-1" aria-hidden="true">
                      <img src={article.preview.imageUrl} alt="" loading="lazy" />
                    </a>
                  )}
                  <div>
                    <a href={articleDetailPath(article)}>{cleanText(article.preview?.title || article.title)}</a>
                    <div class="article-meta-inline">
                      {articleSourceName(article) && <em>Source: {articleSourceName(article)}</em>}
                      {articlePublishDate(article) && <em>Published: {articlePublishDate(article)}</em>}
                    </div>
                    <span>
                      {previewText(
                        article.preview?.description ||
                          article.summary ||
                          article.publisher ||
                          article.resource_type ||
                          "Community update",
                        170,
                      )}
                    </span>
                  </div>
                </li>
              ))
            )}
          </ul>
        </div>

        <div class="homepage-panel">
          <div class="section-intro">
            <p class="eyebrow">Community Updates</p>
            <h2>Recent profile updates from the community.</h2>
            <p>
              Approved community updates help add local context to legislator,
              candidate, and bill profiles. These are submitted by residents
              and reviewed before publication.
            </p>
          </div>

          <div class="comment-list stacked-comment-list">
            {recentCommunityUpdates.length ? (
              recentCommunityUpdates.map((update) => (
                <article class:list={["comment-card", "community-update-card", update.photoUrl && "has-photo"]}>
                  {update.photoUrl && (
                    <a class="community-update-thumb" href={update.pageUrl || update.linkUrl || "/articles"} aria-label={`Open ${update.entityName || "community update"}`}>
                      <img src={update.photoUrl} alt="" loading="lazy" />
                      <span>Photo update</span>
                    </a>
                  )}
                  <div class="community-update-copy">
                    <div class="comment-topline">
                      <a href={update.pageUrl || update.linkUrl || "/articles"}>
                        {update.entityName || "Community update"}
                      </a>
                      <span class="position-pill neutral">
                        {cleanText(update.entityType || "Profile")}
                      </span>
                    </div>
                    <p>{previewText(update.comment || update.linkUrl || "Community-submitted context.", 210)}</p>
                    <div class="article-meta-inline">
                      <em>{cleanText(update.displayName || "Community member")}</em>
                      {communityUpdateDate(update.createdAt) && <em>{communityUpdateDate(update.createdAt)}</em>}
                    </div>
                    {update.linkUrl && (
                      instagramPreview(update.linkUrl) ? (
                        <a class="instagram-preview-card compact" href={update.linkUrl}>
                          <span class="instagram-icon" aria-hidden="true">IG</span>
                          <span>
                            <strong>{instagramPreview(update.linkUrl)?.label}</strong>
                            <small>
                              {instagramPreview(update.linkUrl)?.handle
                                ? `@${instagramPreview(update.linkUrl)?.handle}`
                                : instagramPreview(update.linkUrl)?.host}
                            </small>
                          </span>
                          <em>Open</em>
                        </a>
                      ) : (
                        <a class="bill-comment-link" href={update.linkUrl}>Open submitted link</a>
                      )
                    )}
                  </div>
                </article>
              ))
            ) : (
              <article class="comment-card placeholder">
                <span>Community updates</span>
                <strong>No approved updates yet</strong>
                <p>Recent community updates to legislator, candidate, and bill profiles will appear here after review.</p>
              </article>
            )}
          </div>
        </div>

        <div class="homepage-panel">
          <div class="section-intro">
          <p class="eyebrow">Community Comments</p>
          <h2>Pair public experience with organized civic analysis.</h2>
          <p>
            This space will bring together resident comments and published
            organizational comments on tracked bills so visitors can see both
            personal impact and policy analysis in one place. The goal is to
            help neighbors understand the local context behind votes,
            legislation, and public accountability.
          </p>
          </div>

          <div class="comment-list stacked-comment-list">
              {organizationComments.length ? (
                organizationComments.map((item) => {
                  const trackedBill = trackedBillForCode(item.bill || item.billLabel);
                  const billCode = trackedBill?.code || normalizeBillCode(item.bill || item.billLabel);
                  const billTitle = billCommentTitle(trackedBill, billCode);

                  return (
                    <article class="comment-card">
                      <div class="comment-topline">
                        <div class="organization-comment-source">
                          {item.organization.logoUrl && (
                            <a class="organization-comment-logo" href={organizationPath(item.organization)} tabindex="-1" aria-hidden="true">
                              <img src={item.organization.logoUrl} alt="" loading="lazy" />
                            </a>
                          )}
                          <a href={organizationPath(item.organization)}>
                            {item.organization.name}
                          </a>
                        </div>
                        {item.position && (
                          <span class:list={["position-pill", positionClass(item.position)]}>
                            {item.position}
                          </span>
                        )}
                      </div>
                      <a class="bill-comment-link" href={`/bills/${billCode}`}>
                        {billTitle}
                      </a>
                      <p>{previewText(item.comment, 190)}</p>
                    </article>
                  );
                })
              ) : (
                <article class="comment-card placeholder">
                  <span>Organizational comments</span>
                  <strong>No tracked bill comments yet</strong>
                  <p>Published organization comments for bills in the tracker will appear here automatically.</p>
                </article>
              )}
          </div>
        </div>
      </section>

      <section class="cta">
        <h2>Help keep civic information accurate and useful.</h2>
        <p>
          New Hampshire has one of the largest legislatures in the country, and
          transparency at that scale takes community participation. Help us keep
          the data correct and up to date, and help your neighbors understand
          the context of this work by sharing articles, social posts, images,
          profile updates, and bill context for review.
        </p>
        <a href="/suggest-update">Suggest an update</a>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 0 0 48px;
  }

  .hero {
    align-items: end;
    display: grid;
    margin: 0 calc(50% - 50vw) 40px;
    min-height: clamp(220px, 30vw, 320px);
    overflow: hidden;
    padding: clamp(32px, 5vw, 56px) 0 clamp(24px, 4vw, 40px);
    position: relative;
    width: 100vw;
  }

  .hero::after {
    background:
      linear-gradient(90deg, rgba(17, 24, 39, 0.82), rgba(17, 24, 39, 0.55) 48%, rgba(17, 24, 39, 0.2)),
      linear-gradient(0deg, rgba(17, 24, 39, 0.58), rgba(17, 24, 39, 0.1));
    content: "";
    inset: 0;
    position: absolute;
    z-index: 1;
  }

  .hero-banner {
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
    z-index: 0;
  }

  .hero-copy {
    color: #fefce8;
    margin: 0 auto;
    position: relative;
    width: min(1120px, calc(100% - 32px));
    z-index: 2;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    font-weight: 700;
    color: #6b4f2a;
    margin-bottom: 16px;
  }

  .hero .eyebrow {
    color: #fde68a;
  }

  h1 {
    max-width: 900px;
    font-size: clamp(2.15rem, 5.25vw, 4.2rem);
    line-height: 0.95;
    margin: 0;
  }

  .hero h1 {
    color: #fffaf1;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.35);
  }

  .lede {
    max-width: 760px;
    font-size: 1.25rem;
    line-height: 1.6;
    margin: 24px 0 0;
    color: #4b5563;
  }

  .hero .lede {
    color: #f8fafc;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.35);
  }

  .cta a {
    border: 2px solid #1f2933;
    background: #1f2933;
    color: white;
    padding: 16px 22px;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
  }

  .pathway,
  .rep-preview,
  .community-comments,
  .homepage-panel,
  .cta {
