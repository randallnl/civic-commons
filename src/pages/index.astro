---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import headingBanner from "../assets/heading_banner.png";
import { getArticles } from "../lib/articlesApi";
import { billDetailPath, getBills } from "../lib/billsApi";
import { isFreeStater } from "../lib/civicTags";
import { getRepresentatives, repName, repSlug } from "../lib/repsApi";
import { cleanText } from "../lib/text";
import { enrichArticlesWithPreviews } from "../lib/articlePreviews";
import { getTrackedBills, normalizeBillCode } from "../lib/trackedBills";
import { getSpotlightLegislators } from "../lib/spotlightTracker";

let recentArticles = [];
let recentBills = [];
let recentPeople = [];
let trackedBills = new Map();

try {
  const [articleResult, billResult, repResult, trackedBillResult, spotlightResult] = await Promise.allSettled([
    getArticles({ include: "relations", limit: 5 }),
    getBills({ limit: 6 }),
    getRepresentatives({ limit: 8 }),
    getTrackedBills(),
    getSpotlightLegislators({ limit: 8 }),
  ]);

  const articleData = articleResult.status === "fulfilled" ? articleResult.value : {};
  const billData = billResult.status === "fulfilled" ? billResult.value : {};
  const repData = repResult.status === "fulfilled" ? repResult.value : {};
  trackedBills = trackedBillResult.status === "fulfilled" ? trackedBillResult.value : new Map();
  const spotlightPeople = spotlightResult.status === "fulfilled" ? spotlightResult.value : [];

  recentArticles = articleData.articles || [];
  recentBills = billData.bills || [];
  recentPeople = spotlightPeople.length ? spotlightPeople : repData.representatives || [];
} catch (error) {
  console.error(error?.message || "Unable to load homepage API data.");
}

recentArticles = await enrichArticlesWithPreviews(recentArticles, { limit: 5 });

function trackedBillFor(bill = {}) {
  return trackedBills.get(normalizeBillCode(bill.condensedbillno || bill.bill_number));
}

function previewText(text = "", maxLength = 150) {
  const normalized = cleanText(text).replace(/\s+/g, " ").trim();
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trim()}...`;
}
---

<html lang="en">
  <head>
    <title>Civic Commons</title>
    <meta name="description" content="A community-powered civic directory for New Hampshire." />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <section class="hero">
        <img
          class="hero-banner"
          src={headingBanner.src}
          alt="Civic Commons"
          width="2000"
          height="500"
        />
        <div class="hero-copy">
          <p class="eyebrow">Community-powered civic information</p>
          <h1>Know who represents you and what's happening in your community.</h1>
          <p class="lede">
            Civic Commons is a public directory of elected officials, candidates,
            legislative districts, bills, public testimony, and civic coverage.
          </p>
        </div>
      </section>

      <section class="rep-preview">
        <div>
          <p class="eyebrow">Representative Lookup</p>
          <h2>Start with an address. See the right districts.</h2>
          <p>
            The tool identifies ward-specific House districts, Senate districts,
            legislator cards, contact details, and recent vote summaries.
          </p>
          <a href="/my-state-rep">Open My State Rep</a>
        </div>

        <div class="preview-panel">
          <span>Example result</span>
          <strong>72 Concord St, Manchester</strong>
          <ul>
            <li>Ward 3</li>
            <li>Senate District 20</li>
            <li>House HIL 23 + HIL 40</li>
          </ul>
        </div>
      </section>

      <section class="pathway">
        <div class="section-intro">
          <p class="eyebrow">How to use Civic Commons</p>
          <h2>Start with representation. Then follow the local picture.</h2>
          <p>
            Civic information is easier to understand when you move in order:
            identify who represents you, learn the districts and communities
            they serve, then connect votes, bills, testimony, and coverage.
          </p>
        </div>

        <ol class="steps">
          <li>
            <span>1</span>
            <div>
              <h3>Find your current representatives</h3>
              <p>Use your address to see your Senate district, House districts, ward-specific representation, candidates, contact information, and vote summaries.</p>
              <a href="/my-state-rep">Start with My State Rep</a>
            </div>
          </li>

          <li>
            <span>2</span>
            <div>
              <h3>Understand your community profile</h3>
              <p>Look at the towns, wards, counties, and districts that shape who represents your community and what coverage is attached to it.</p>
              <a href="/communities">Explore communities</a>
            </div>
          </li>

          <li>
            <span>3</span>
            <div>
              <h3>Follow votes, bills, and testimony</h3>
              <p>See how representatives voted on tracked bills, compare those votes to the preferred stance, and review remote testimony summaries.</p>
              <a href="/bills">Track legislation</a>
            </div>
          </li>

          <li>
            <span>4</span>
            <div>
              <h3>Read the local context</h3>
              <p>Use articles and organizational comments to understand what is happening around a bill, town, district, or elected official.</p>
              <a href="/articles">Read articles</a>
            </div>
          </li>
        </ol>
      </section>

      <section class="content-grid">
        <div>
          <h2>Next: Understand Your Community</h2>
          <ul class="list">
            <li>
              <a href="/communities">Community Profiles</a>
              <span>Start with counties, towns, House districts, and Senate districts</span>
            </li>
            <li>
              <a href="/communities?q=Manchester">Manchester Communities</a>
              <span>Search districts by towns represented</span>
            </li>
            {recentArticles.slice(0, 3).map((article) => (
              <li>
                <a href={`/articles?town=${encodeURIComponent(article.towns?.[0]?.town || article.towns?.[0]?.name || "")}`}>
                  {article.towns?.[0]?.town || article.towns?.[0]?.name || "Community articles"}
                </a>
                <span>{cleanText(article.preview?.title || article.title)}</span>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h2>Representative Profiles</h2>
          <ul class="list">
            {recentPeople.length === 0 ? (
              <li>No legislators returned yet.</li>
            ) : recentPeople.map((person) => (
              <li>
                <a href={`/people/${repSlug(person)}`}>
                  {repName(person)}
                </a>
                <span>{person.party || "No party listed"}</span>
                {isFreeStater(person) && (
                  <a
                    class="free-stater-inline"
                    href="/free-staters"
                    title="What is a Free Stater?"
                    aria-label="What is a Free Stater?"
                  >
                    Free Stater
                  </a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h2>Then: Track Bills and Votes</h2>
          <ul class="list">
            {recentBills.length === 0 ? (
              <li>No bills added yet.</li>
            ) : (
              recentBills.map((bill) => {
                const trackedBill = trackedBillFor(bill);

                return (
                  <li>
                    <a href={billDetailPath(bill.condensedbillno || bill.bill_number, bill.sessionyear || bill.session_year)}>
                      {trackedBill?.name || bill.condensedbillno || bill.bill_number}
                    </a>
                    <span>
                      {previewText(
                        trackedBill?.summary ||
                          bill.description ||
                          bill.title ||
                          "No tracker summary available yet.",
                      )}
                    </span>
                  </li>
                );
              })
            )}
          </ul>
        </div>

        <div>
          <h2>Finally: Read Community Updates</h2>
          <ul class="list">
            {recentArticles.length === 0 ? (
              <li>No articles added yet.</li>
            ) : (
              recentArticles.map((article) => (
                <li class:list={["article-update", article.preview?.imageUrl && "has-image"]}>
                  {article.preview?.imageUrl && (
                    <a class="article-thumb" href={article.url} tabindex="-1" aria-hidden="true">
                      <img src={article.preview.imageUrl} alt="" loading="lazy" />
                    </a>
                  )}
                  <div>
                    <a href={article.url}>{cleanText(article.preview?.title || article.title)}</a>
                    <span>
                      {previewText(
                        article.preview?.description ||
                          article.summary ||
                          article.publisher ||
                          article.resource_type ||
                          "Community update",
                        170,
                      )}
                    </span>
                  </div>
                </li>
              ))
            )}
          </ul>
        </div>
      </section>

      <section class="cta">
        <h2>Help keep civic information accurate.</h2>
        <p>
          Found an outdated polling place, missing candidate, wrong contact info,
          or a useful source? Submit an update for review.
        </p>
        <a href="/suggest-update">Suggest an update</a>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 0 0 48px;
  }

  .hero {
    align-items: end;
    display: grid;
    margin: 0 calc(50% - 50vw) 40px;
    min-height: clamp(300px, 38vw, 440px);
    overflow: hidden;
    padding: clamp(48px, 7vw, 84px) 0 clamp(32px, 5vw, 56px);
    position: relative;
    width: 100vw;
  }

  .hero::after {
    background:
      linear-gradient(90deg, rgba(17, 24, 39, 0.82), rgba(17, 24, 39, 0.55) 48%, rgba(17, 24, 39, 0.2)),
      linear-gradient(0deg, rgba(17, 24, 39, 0.58), rgba(17, 24, 39, 0.1));
    content: "";
    inset: 0;
    position: absolute;
    z-index: 1;
  }

  .hero-banner {
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
    z-index: 0;
  }

  .hero-copy {
    color: #fffaf1;
    margin: 0 auto;
    position: relative;
    width: min(1120px, calc(100% - 32px));
    z-index: 2;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    font-weight: 700;
    color: #6b4f2a;
    margin-bottom: 16px;
  }

  .hero .eyebrow {
    color: #fde68a;
  }

  h1 {
    max-width: 900px;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0;
  }

  .hero h1 {
    color: #fffaf1;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.35);
  }

  .lede {
    max-width: 760px;
    font-size: 1.25rem;
    line-height: 1.6;
    margin: 24px 0 0;
    color: #4b5563;
  }

  .hero .lede {
    color: #f8fafc;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.35);
  }

  .cta a {
    border: 2px solid #1f2933;
    background: #1f2933;
    color: white;
    padding: 16px 22px;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
  }

  .pathway,
  .rep-preview,
  .content-grid > div,
  .cta {
    background: rgba(255, 255, 255, 0.75);
    border: 2px solid #1f2933;
    border-radius: 24px;
    box-shadow: 6px 6px 0 #1f2933;
  }

  .section-intro {
    max-width: 760px;
  }

  .section-intro h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1;
    margin: 0;
  }

  .section-intro p:last-child {
    color: #4b5563;
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 18px 0 0;
  }

  .rep-preview {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    gap: 24px;
    margin: 40px 0;
    padding: 32px;
  }

  .rep-preview h2 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
    margin: 0;
    max-width: 760px;
  }

  .rep-preview p {
    color: #4b5563;
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 700px;
  }

  .rep-preview a {
    border: 2px solid #1f2933;
    background: #1f2933;
    color: white;
    display: inline-block;
    padding: 14px 20px;
    border-radius: 999px;
    font-weight: 800;
    text-decoration: none;
  }

  .preview-panel {
    align-self: stretch;
    background: #fffaf1;
    border: 2px solid #1f2933;
    border-radius: 18px;
    display: grid;
    gap: 12px;
    padding: 20px;
  }

  .preview-panel span {
    color: #6b4f2a;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .preview-panel strong {
    font-size: 1.35rem;
    line-height: 1.1;
  }

  .preview-panel ul {
    display: grid;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .preview-panel li {
    border-top: 1px solid #d1d5db;
    color: #1f2933;
    font-weight: 800;
    padding-top: 8px;
  }

  .pathway {
    display: grid;
    gap: 24px;
    margin: 40px 0;
    padding: 32px;
  }

  .steps {
    display: grid;
    gap: 14px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .steps li {
    align-items: start;
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    display: grid;
    gap: 16px;
    grid-template-columns: 52px 1fr;
    padding: 18px;
  }

  .steps li > span {
    align-items: center;
    background: #1f2933;
    border-radius: 999px;
    color: white;
    display: inline-flex;
    font-size: 1.35rem;
    font-weight: 950;
    height: 52px;
    justify-content: center;
    width: 52px;
  }

  .steps h3 {
    font-size: 1.25rem;
    line-height: 1.15;
    margin: 0;
  }

  .steps p {
    color: #4b5563;
    line-height: 1.55;
    margin: 8px 0 12px;
  }

  .steps a {
    color: #1f2933;
    font-weight: 900;
    text-decoration: none;
  }

  .steps a:hover {
    text-decoration: underline;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin: 40px 0;
  }

  .content-grid > div {
    padding: 24px;
  }

  .content-grid h2 {
    margin-top: 0;
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list li {
    padding: 14px 0;
    border-top: 1px solid #d1d5db;
  }

  .list li:first-child {
    border-top: 0;
  }

  .list .article-update {
    display: grid;
    gap: 12px;
  }

  .list .article-update.has-image {
    grid-template-columns: 88px minmax(0, 1fr);
  }

  .article-thumb {
    display: block;
  }

  .article-thumb img {
    aspect-ratio: 4 / 3;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    display: block;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .list a {
    display: block;
    color: #1f2933;
    font-weight: 800;
  }

  .list span {
    display: block;
    margin-top: 4px;
    color: #6b7280;
  }

  .list .free-stater-inline {
    background: #7f1d1d;
    border: 1px solid #111827;
    border-radius: 999px;
    box-shadow: 2px 2px 0 #111827;
    color: white;
    display: inline-block;
    font-size: 0.74rem;
    margin-top: 8px;
    padding: 4px 8px;
    text-decoration: none;
  }

  .list .free-stater-inline:hover {
    background: #450a0a;
  }

  .cta {
    padding: 36px;
    margin-top: 48px;
  }

  .cta p {
    max-width: 720px;
    color: #4b5563;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  @media (max-width: 900px) {
    .rep-preview,
    .content-grid {
      grid-template-columns: 1fr 1fr;
    }

  }

  @media (max-width: 600px) {
    .rep-preview,
    .content-grid {
      grid-template-columns: 1fr;
    }

    .page {
      padding: 24px 0;
    }

    .hero {
      min-height: 340px;
      padding-top: 40px;
    }

    .pathway,
    .rep-preview {
      padding: 22px;
    }

    .steps li {
      grid-template-columns: 42px 1fr;
      padding: 14px;
    }

    .steps li > span {
      font-size: 1.1rem;
      height: 42px;
      width: 42px;
    }

    .list .article-update.has-image {
      grid-template-columns: 72px minmax(0, 1fr);
    }
  }
</style>
