---
export const prerender = false;

import TopNav from "../../components/TopNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const path = Astro.params.path || "";
const currentSlug = path.split("/").filter(Boolean).at(-1) || "";
const label = currentSlug
  .split("-")
  .filter(Boolean)
  .map((part) => part.slice(0, 1).toUpperCase() + part.slice(1))
  .join(" ");
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/NH%20DB%20Logo.svg" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.svg" />
    <title>{label || "Communities"} | NH Deserves Better</title>
    <meta
      name="description"
      content="Explore New Hampshire communities using live NH Deserves Better API data."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/communities">Back to communities</a>

      <section class="panel">
        <p class="eyebrow">Communities</p>
        <h1>{label || "New Hampshire Communities"}</h1>
        <p>
          Community and district data now comes from the NH Deserves Better API. Use
          the community explorer to search House districts by towns represented,
          or browse related articles for a town.
        </p>

        <div class="actions">
          <a href={`/communities?q=${encodeURIComponent(label)}`}>Search communities</a>
          {label && <a href={`/articles?town=${encodeURIComponent(label)}`}>Town articles</a>}
        </div>
      </section>
    </main>
    <SiteFooter />
  </body>
</html>

<style>
  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .panel {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    box-shadow: none;
    margin-top: 36px;
    padding: 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.15rem, 5.25vw, 3.9rem);
    line-height: 0.95;
    margin: 0 0 18px;
  }

  p {
    color: #4b5563;
    line-height: 1.6;
    max-width: 680px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .actions a {
    background: #1f2933;
    border: 1px solid #e2e8f0;
    border-radius: 999px;
    color: white;
    padding: 12px 16px;
    text-decoration: none;
  }
</style>
