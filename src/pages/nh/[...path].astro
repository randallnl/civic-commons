---
export const prerender = false;

import TopNav from "../../components/TopNav.astro";

const path = Astro.params.path || "";
const currentSlug = path.split("/").filter(Boolean).at(-1) || "";
const label = currentSlug
  .split("-")
  .filter(Boolean)
  .map((part) => part.slice(0, 1).toUpperCase() + part.slice(1))
  .join(" ");
---

<html lang="en">
  <head>
    <title>{label || "Communities"} | Civic Commons</title>
    <meta
      name="description"
      content="Explore New Hampshire communities using live Civic Commons API data."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/communities">Back to communities</a>

      <section class="panel">
        <p class="eyebrow">Communities</p>
        <h1>{label || "New Hampshire Communities"}</h1>
        <p>
          Community and district data now comes from the Civic Commons API. Use
          the community explorer to search House districts by towns represented,
          or browse related articles for a town.
        </p>

        <div class="actions">
          <a href={`/communities?q=${encodeURIComponent(label)}`}>Search communities</a>
          {label && <a href={`/articles?town=${encodeURIComponent(label)}`}>Town articles</a>}
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(900px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .panel {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    margin-top: 36px;
    padding: 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 0.95;
    margin: 0 0 18px;
  }

  p {
    color: #4b5563;
    line-height: 1.6;
    max-width: 680px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .actions a {
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    padding: 12px 16px;
    text-decoration: none;
  }
</style>
