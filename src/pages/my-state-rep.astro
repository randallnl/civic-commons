---
export const prerender = false;

import CandidateCard from "../components/CandidateCard.astro";
import FilterBar from "../components/FilterBar.astro";
import RepresentativeCard from "../components/RepresentativeCard.astro";
import TopNav from "../components/TopNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import profileIcon from "../assets/profile icon.png";
import { getBillDetail, getBillSummaries } from "../lib/billsApi";
import { getCandidates, isLegislativeCandidate } from "../lib/candidatesApi";
import { enrichCandidatesWithLegislators } from "../lib/candidateLegislators";
import { civicApiBase, civicApiFetch } from "../lib/civicApi";
import { isFreeStater } from "../lib/civicTags";
import { profilePhotoUrl } from "../lib/photos";
import { getRepresentative, getRepresentatives, repName, repSlug } from "../lib/repsApi";
import { getSpotlightLegislators } from "../lib/spotlightTracker";
import { cleanText } from "../lib/text";
import {
  normalizeBillCode,
  getTrackedBills,
  representativeGradeFor,
  representativeVoteStance,
  trackedBillForVote,
} from "../lib/trackedBills";

const API_BASE = civicApiBase();
const WARD_COMMUNITY_COUNTS = new Map([
  ["berlin", 4],
  ["claremont", 3],
  ["concord", 10],
  ["dover", 6],
  ["franklin", 3],
  ["keene", 5],
  ["laconia", 6],
  ["lebanon", 3],
  ["manchester", 12],
  ["nashua", 9],
  ["portsmouth", 5],
  ["rochester", 6],
  ["somersworth", 5],
]);

const address = Astro.url.searchParams.get("address")?.trim() || "";
const selectedWard = normalizeWardNumber(Astro.url.searchParams.get("ward") || "");
const filters = {
  body: Astro.url.searchParams.get("body")?.trim() || "",
  name: Astro.url.searchParams.get("name")?.trim() || "",
  town: Astro.url.searchParams.get("town")?.trim() || "",
  county: Astro.url.searchParams.get("county")?.trim() || "",
};
const normalizedBodyFilter = normalizeBodyFilter(filters.body);
const hasDirectoryFilters = Object.values(filters).some(Boolean);
const countyOptions = [
  "Belknap",
  "Carroll",
  "Cheshire",
  "Coos",
  "Grafton",
  "Hillsborough",
  "Merrimack",
  "Rockingham",
  "Strafford",
  "Sullivan",
];

let lookupData = null;
let lookupError = "";
let randomLegislators = [];
let previewCandidates = [];
let directoryReps = [];
let directoryCandidates = [];
let nameOptions = [];
let townOptions = [];
let trackedBills = new Map();
let billSummaries = new Map();
let directoryError = "";

if (address) {
  try {
    const response = await civicApiFetch(`${API_BASE}/reps/lookup`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ address }),
    });

    const data = await response.json();

    if (!response.ok) {
      throw new Error(data.error || "Something went wrong.");
    }

    lookupData = data;
  } catch (error) {
    lookupError =
      error?.message || "Unable to look up representatives.";
  }
}

try {
  const [spotlightPeople, candidateData, repOptionData] = await Promise.all([
    getSpotlightLegislators({ limit: 8 }),
    getCandidates({ electionYear: 2026, limit: 8 }),
    getRepresentatives({ limit: 600 }),
  ]);
  randomLegislators = shuffle(spotlightPeople).slice(0, 6);
  previewCandidates = (candidateData.candidates || []).filter(isLegislativeCandidate).slice(0, 6);
  const optionReps = repOptionData.representatives || [];
  nameOptions = uniqueOptions(optionReps.map(repName));
  townOptions = uniqueOptions(optionReps.flatMap(townsForOption));
} catch (error) {
  console.error(error?.message || "Unable to load preview profiles.");
}

if (!address && hasDirectoryFilters) {
  try {
    const [repData, candidateData] = await Promise.all([
      getRepresentatives({
        body: normalizedBodyFilter,
        q: filters.name || filters.town,
        county: filters.county,
        limit: 600,
      }),
      getCandidates({
        q: filters.name,
        county: filters.county,
        office: bodyFilterToCandidateOffice(normalizedBodyFilter),
        electionYear: 2026,
        limit: 200,
      }),
    ]);

    directoryReps = await hydrateVotePreviewDetails(
      (repData.representatives || []).filter((rep) => matchesDirectoryFilters(rep, filters)),
    );
    directoryCandidates = await enrichCandidatesWithLegislators(
      (candidateData.candidates || [])
        .filter(isLegislativeCandidate)
        .filter((candidate) => matchesCandidateFilters(candidate, filters)),
    );
  } catch (error) {
    directoryError = error?.message || "Unable to load filtered profiles.";
  }
}

if (lookupData || randomLegislators.length > 0 || directoryReps.length > 0) {
  try {
    trackedBills = await getTrackedBills();
    billSummaries = await getBillSummaries();
  } catch (error) {
    console.error(error?.message || "Unable to load bill summaries.");
  }
}

const senateReps = lookupData?.groups?.senate || [];
const houseRepsRaw = lookupData?.groups?.house || [];
const allReps = lookupData?.representatives || [];
const candidateGroups = lookupData?.groups?.candidates || {};
const allCandidates = lookupData?.candidates?.length
  ? lookupData.candidates
  : [
      ...(candidateGroups.senate || []),
      ...(candidateGroups.house || []),
    ];
let senateCandidates =
  candidateGroups.senate?.length
    ? candidateGroups.senate
    : allCandidates.filter((candidate) => isSenateCandidate(candidate));
let houseCandidates =
  candidateGroups.house?.length
    ? candidateGroups.house
    : allCandidates.filter((candidate) => isHouseCandidate(candidate));
const civic = lookupData?.civic || {};
const matchedDistricts = lookupData?.matchedDistricts || [];
const normalizedInput = lookupData?.normalizedInput || {};
const prettyAddress = formatAddress(normalizedInput);
const place = civic.place?.name || normalizedInput.city || "";
const wardOptions = wardOptionsFor(place);
const isWardedCommunity = wardOptions.length > 0;
const wardNumber = isWardedCommunity
  ? selectedWard || normalizeWardNumber(civic.ward?.number || "")
  : normalizeWardNumber(civic.ward?.number || "");
const ward = wardNumber ? `Ward ${wardNumber}` : "";
const houseReps = isWardedCommunity && selectedWard
  ? houseRepsRaw.filter((rep) => representsWard(rep, selectedWard))
  : houseRepsRaw;
let filteredHouseCandidates = isWardedCommunity && selectedWard
  ? houseCandidates.filter((candidate) => representsWard(candidate, selectedWard))
  : houseCandidates;
const senateDistrict =
  civic.senate?.districtLabel || civic.senate?.district || "";
const houseDistricts = matchedDistricts
  .filter((district) => district.body === "H")
  .filter((district) => !isWardedCommunity || !selectedWard || representsWard(district, selectedWard))
  .map((district) => district.district_label)
  .filter(Boolean);

if (lookupData && trackedBills.size) {
  await hydrateMissingBillSummaries(allReps, trackedBills, billSummaries);
}

if (lookupData) {
  [senateCandidates, filteredHouseCandidates] = await Promise.all([
    enrichCandidatesWithLegislators(senateCandidates),
    enrichCandidatesWithLegislators(filteredHouseCandidates),
  ]);
}

async function hydrateVotePreviewDetails(reps = []) {
  const previewLimit = 80;
  const previewReps = reps.slice(0, previewLimit);
  const hydrated = await Promise.all(
    previewReps.map(async (rep) => {
      const slugOrId = rep.personid || rep.id || rep.slug || repName(rep);
      if (!slugOrId) return rep;

      try {
        const data = await getRepresentative(slugOrId);
        return {
          ...rep,
          ...(data.representative || data.rep || data.person || data),
          voteHistory: data.voteHistory || data.votes || data.representative?.voteHistory || rep.voteHistory || [],
        };
      } catch (error) {
        console.error(error?.message || "Unable to hydrate representative vote preview.");
        return rep;
      }
    }),
  );

  return [...hydrated, ...reps.slice(previewLimit)];
}

function shuffle(items = []) {
  return [...items].sort(() => Math.random() - 0.5);
}

function normalizeBodyFilter(value = "") {
  const normalized = String(value || "").trim().toLowerCase();
  if (normalized === "house" || normalized === "h") return "house";
  if (normalized === "senate" || normalized === "s") return "senate";
  return "";
}

function bodyFilterToCandidateOffice(value = "") {
  if (value === "house") return "State Representative";
  if (value === "senate") return "State Senate";
  return "";
}

function matchesDirectoryFilters(rep = {}, values = {}) {
  return (
    matchesBody(rep, values.body) &&
    matchesText(repName(rep), values.name) &&
    matchesText(locationLabel(rep), values.town) &&
    matchesCounty(rep, values.county)
  );
}

function matchesCandidateFilters(candidate = {}, values = {}) {
  return (
    matchesCandidateBody(candidate, values.body) &&
    matchesText(candidate.name || `${candidate.candidateFirstName || ""} ${candidate.candidateLastName || ""}`, values.name) &&
    matchesText(candidate.county, values.county) &&
    (!values.town || matchesText(recordText(candidate), values.town))
  );
}

function matchesBody(rep = {}, query = "") {
  const normalized = normalizeBodyFilter(query);
  if (!normalized) return true;
  return legislativeBody(rep).toLowerCase() === (normalized === "house" ? "house" : "senate");
}

function matchesCandidateBody(candidate = {}, query = "") {
  const normalized = normalizeBodyFilter(query);
  if (!normalized) return true;
  if (normalized === "house") return isHouseCandidate(candidate);
  if (normalized === "senate") return isSenateCandidate(candidate);
  return true;
}

function matchesCounty(record = {}, query = "") {
  if (!query) return true;
  return matchesText([
    record.county,
    record.countyName,
    record.county_name,
    countyNameForCode(record.countycode),
    locationLabel(record),
  ].filter(Boolean).join(" "), query);
}

function matchesText(source = "", query = "") {
  if (!query) return true;
  return normalizeSearch(source).includes(normalizeSearch(query));
}

function normalizeSearch(value = "") {
  return String(value || "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, " ")
    .trim();
}

function countyNameForCode(code = "") {
  const counties = {
    "01": "Belknap",
    "02": "Carroll",
    "03": "Cheshire",
    "04": "Coos",
    "05": "Grafton",
    "06": "Hillsborough",
    "07": "Merrimack",
    "08": "Rockingham",
    "09": "Strafford",
    "10": "Sullivan",
  };
  return counties[String(code || "").padStart(2, "0")] || "";
}

function isSenateCandidate(candidate = {}) {
  return /senate/i.test(`${candidate.office || ""} ${candidate.officeType || ""}`);
}

function isHouseCandidate(candidate = {}) {
  return /representative|house/i.test(
    `${candidate.office || ""} ${candidate.officeType || ""}`,
  );
}

function normalizeWardNumber(value = "") {
  const match = String(value || "").match(/\d+/);
  return match ? String(Number(match[0])) : "";
}

function normalizedTownName(value = "") {
  return String(value || "").trim().toLowerCase().replace(/\s+/g, " ");
}

function wardOptionsFor(town = "") {
  const count = WARD_COMMUNITY_COUNTS.get(normalizedTownName(town)) || 0;
  return Array.from({ length: count }, (_, index) => String(index + 1));
}

function representsWard(record = {}, wardValue = "") {
  const wardNumber = normalizeWardNumber(wardValue);
  if (!wardNumber) return true;

  const text = recordText(record);
  const directWard = new RegExp(`\\bward(?:s)?\\s*${escapeRegExp(wardNumber)}\\b`, "i");
  if (directWard.test(text)) return true;

  for (const match of text.matchAll(/\bwards?\s+(\d{1,2})\s*(?:-|–|—|to|through)\s*(\d{1,2})\b/gi)) {
    const start = Number(match[1]);
    const end = Number(match[2]);
    const selected = Number(wardNumber);
    if (selected >= Math.min(start, end) && selected <= Math.max(start, end)) return true;
  }

  return false;
}

function recordText(record = {}) {
  return [
    record.location_text,
    record.locationText,
    record.towns_represented,
    record.townsRepresented,
    record.towns,
    record.town,
    record.city,
    record.district_label,
    record.districtLabel,
    record.name,
    record.office,
    record.district,
    record.raw_district,
  ].flatMap(stringifyValue).filter(Boolean).join(" ");
}

function stringifyValue(value) {
  if (!value) return [];
  if (Array.isArray(value)) return value.flatMap(stringifyValue);
  if (typeof value === "object") {
    return [value.town, value.name, value.label, value.location_text, value.locationText].flatMap(stringifyValue);
  }
  return [String(value)];
}

function townsForOption(rep = {}) {
  return stringifyValue(
    rep.location_text ||
      rep.locationText ||
      rep.towns_represented ||
      rep.townsRepresented ||
      rep.towns ||
      "",
  )
    .flatMap((value) => String(value).split(/[,;|]/))
    .map((value) => value.replace(/\s*-\s*Ward\s+\d+$/i, "").trim())
    .filter(Boolean);
}

function uniqueOptions(values = []) {
  return [...new Set(values.flat().map((value) => String(value || "").trim()).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b));
}

function escapeRegExp(value = "") {
  return String(value).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

function legislativeBody(person = {}) {
  const value = String(person.chamber || person.legislativebody || person.body || "").toLowerCase();
  if (value === "h" || value === "house") return "House";
  if (value === "s" || value === "senate") return "Senate";
  return person.chamber || "";
}

function districtLabel(person = {}) {
  const district = person.district || person.raw_district || "";
  const body = legislativeBody(person);
  if (!district) return body;
  if (body === "House") return `NH House District ${district}`;
  if (body === "Senate") return `NH Senate District ${district}`;
  return `District ${district}`;
}

function locationLabel(person = {}) {
  const value =
    person.location_text ||
    person.locationText ||
    person.towns_represented ||
    person.townsRepresented ||
    "";
  if (Array.isArray(value)) return value.join(", ");
  return value;
}

function trackedVotesFor(person = {}, limit = 3) {
  const votes = Array.isArray(person.voteHistory) ? person.voteHistory : [];
  return votes.filter((vote) => trackedBillForVote(trackedBills, vote)).slice(0, limit);
}

function billSummaryForVote(vote = {}) {
  return billSummaries.get(normalizeBillCode(vote.condensedbillno || vote.bill_number));
}

function billPreviewTitle(billSummary = {}, trackedBill = {}) {
  return cleanText(
    billSummary?.name ||
      billSummary?.title ||
      trackedBill?.name ||
      trackedBill?.title ||
      "Tracked Bill",
  );
}

function formatAddress(normalized = {}) {
  return [
    normalized.line1,
    normalized.city,
    normalized.state,
    normalized.zip,
  ]
    .filter(Boolean)
    .join(", ");
}

async function hydrateMissingBillSummaries(reps, tracked, summaries) {
  const missingBills = new Map();

  for (const rep of reps) {
    for (const vote of rep.voteHistory || []) {
      const code = normalizeBillCode(vote.condensedbillno);
      if (
        !code ||
        !trackedBillForVote(tracked, vote) ||
        summaries.has(code) ||
        missingBills.has(code)
      ) {
        continue;
      }
      missingBills.set(code, vote.sessionyear);
    }
  }

  await Promise.all(
    [...missingBills].map(async ([code, year]) => {
      try {
        const detail = await getBillDetail(code, { year });
        if (detail.bill) summaries.set(code, detail.bill);
      } catch (error) {
        console.error(error?.message || "Unable to load bill summary.");
      }
    }),
  );
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/NH%20DB%20Logo.svg" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.svg" />
    <title>My Legislator | NH Deserves Better</title>
    <meta
      name="description"
      content="Find your New Hampshire state legislators by address."
    />
  </head>

  <body>
    <TopNav />
    <main class="page" x-data="nhdbFuzzyFilter({ itemSelector: '.rep-card[data-fuzzy-item]' })">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">My Legislator</p>
        <h1>Find your New Hampshire state legislators.</h1>
        <p class="lede">
          Enter your address to identify your State Senator, your ward-based
          House district, and any floterial House districts connected to your
          community.
        </p>

        <form class="address-lookup" action="/my-state-rep#rep-results" method="get" data-results-form>
          <label for="address">Find your current State Representatives and State Senator</label>

          <div class="address-row">
            <input
              id="address"
              name="address"
              type="text"
              value={address}
              placeholder="72 Concord St, Manchester, NH"
              autocomplete="street-address"
              required
            />

            <button type="submit">Find My Legislators</button>
          </div>
        </form>

        <FilterBar
          action="/my-state-rep#rep-results"
          submitLabel="Filter current legislators"
          clearHref={hasDirectoryFilters ? "/my-state-rep#rep-results" : ""}
          dataResultsForm={true}
        >
          <label>
            <span>Name</span>
            <input
              type="search"
              name="name"
              value={filters.name}
              list="legislatorNameOptions"
              placeholder="Start typing a legislator"
              autocomplete="off"
              data-fuzzy-search
            />
            <datalist id="legislatorNameOptions">
              {nameOptions.map((option) => <option value={option} />)}
            </datalist>
          </label>
          <label>
            <span>County</span>
            <select name="county" data-fuzzy-filter-field data-fuzzy-field="county" data-fuzzy-match="exact">
              <option value="">All counties</option>
              {countyOptions.map((option) => (
                <option value={option} selected={filters.county.toLowerCase() === option.toLowerCase()}>
                  {option}
                </option>
              ))}
            </select>
          </label>
          <label>
            <span>Body / office</span>
            <select name="body" data-fuzzy-filter-field data-fuzzy-field="body" data-fuzzy-match="exact">
              <option value="">House and Senate</option>
              <option value="house" selected={normalizedBodyFilter === "house"}>House</option>
              <option value="senate" selected={normalizedBodyFilter === "senate"}>Senate</option>
            </select>
          </label>
          <label>
            <span>Town</span>
            <input
              type="search"
              name="town"
              value={filters.town}
              list="legislatorTownOptions"
              placeholder="Start typing a town"
              autocomplete="off"
              data-fuzzy-filter-field
              data-fuzzy-field="town"
            />
            <datalist id="legislatorTownOptions">
              {townOptions.map((option) => <option value={option} />)}
            </datalist>
          </label>
        </FilterBar>

        <p class="help-text">
          Address lookups and filters focus on current New Hampshire State
          Representatives and State Senators. Candidate previews appear as
          supporting election context.
        </p>
      </section>

      <div id="rep-results" data-results-region>
      {lookupError && (
        <div class="status-message" aria-live="polite">
          {lookupError}
        </div>
      )}

      {address && !lookupError && allReps.length === 0 && allCandidates.length === 0 && (
        <div class="status-message" aria-live="polite">
          No State Representatives, State Senators, or legislative candidates found for that address.
        </div>
      )}

      {!address && !hasDirectoryFilters && randomLegislators.length > 0 && (
        <section class="sample-legislators">
          <div class="group-header">
            <h2>Current Legislator Profiles</h2>
            <p>
              Preview legislator profiles, vote grades, and recent tracked bill
              votes. Enter your address above to see the legislators who
              represent you, or use the filters to browse current State House
              and State Senate profiles.
            </p>
          </div>

          <div class="sample-grid">
            {randomLegislators.map((rep) => {
              const photoUrl = profilePhotoUrl(rep.photo || rep.photo_url);
              const grade = representativeGradeFor(rep, trackedBills, billSummaries);
              const votes = trackedVotesFor(rep, 3);

              return (
                <article class="sample-card">
                  <div class="sample-profile-row">
                    <a class="sample-photo-link" href={`/people/${repSlug(rep)}`}>
                      <img
                        class:list={[!photoUrl && "sample-fallback"]}
                        src={photoUrl || profileIcon.src}
                        alt={photoUrl ? `Photo of ${repName(rep)}` : ""}
                        loading="lazy"
                      />
                    </a>

                    <div class="sample-copy">
                      <a href={`/people/${repSlug(rep)}`}><strong>{repName(rep)}</strong></a>
                      <small>
                        {[
                          rep.party || "No party listed",
                          districtLabel(rep),
                        ].filter(Boolean).join(" - ")}
                      </small>
                      {locationLabel(rep) && <em>{locationLabel(rep)}</em>}
                      {isFreeStater(rep) && (
                      <a
                        class="free-stater-pill"
                        href="/free-staters"
                        title="What is a Free Stater?"
                        aria-label="What is a Free Stater?"
                      >
                        Free Stater
                      </a>
                      )}
                    </div>

                    <a
                      class:list={["mini-grade", grade.className]}
                      href="/vote-grades"
                      title="How do we determine this?"
                      aria-label={`How do we determine this? ${grade.label}`}
                    >
                      <strong>{grade.letter}</strong>
                      <small>Grade</small>
                    </a>
                  </div>

                  {votes.length > 0 && (
                    <div class="sample-vote-list">
                      <span>Bill Tracker Votes</span>
                      {votes.map((vote) => {
                        const trackedBill = trackedBillForVote(trackedBills, vote);
                        const billSummary = billSummaryForVote(vote);
                        const voteStance = representativeVoteStance(vote, trackedBill);
                        const billCode = billSummary?.condensedbillno || trackedBill?.code || vote.condensedbillno;
                        const billTitle = billPreviewTitle(billSummary, trackedBill);

                        return (
                          <div class:list={["sample-vote-preview", voteStance.className]}>
                            <strong>{billCode}: {billTitle}</strong>
                            <small>{voteStance.label}</small>
                          </div>
                        );
                      })}
                    </div>
                  )}
                </article>
              );
            })}
          </div>
        </section>
      )}

      {!address && !hasDirectoryFilters && previewCandidates.length > 0 && (
        <section class="candidate-results secondary-preview">
          <div class="group-header">
            <h2>2026 Candidate Context</h2>
            <p>
              Candidate cards are included as election context, but this page
              stays centered on current legislators and their voting records.
            </p>
          </div>
          <div class="candidate-grid">
            {previewCandidates.map((candidate) => (
              <CandidateCard candidate={candidate} />
            ))}
          </div>
        </section>
      )}

      {!address && hasDirectoryFilters && (
        <section class="filtered-directory">
          <div class="results-heading">
            <div>
              <p class="eyebrow">Filtered Current Legislators</p>
              <h2><span data-fuzzy-count>{directoryReps.length}</span> Representatives and Senators</h2>
            </div>
            <a class="secondary-link" href="/my-state-rep#rep-results">Clear filters</a>
          </div>

          {directoryError ? (
            <p class="status-message">{directoryError}</p>
          ) : directoryReps.length ? (
            <>
              <div class="rep-grid">
                {directoryReps.map((rep) => (
                  <RepresentativeCard
                    rep={rep}
                    trackedBills={trackedBills}
                    billSummaries={billSummaries}
                  />
                ))}
              </div>
              <p class="status-message" data-fuzzy-empty hidden>
                No current legislators matched those filters. Try a broader town,
                county, or name search.
              </p>
            </>
          ) : (
            <p class="status-message">
              No current legislators matched those filters. Try a broader town,
              county, or name search.
            </p>
          )}

          {directoryCandidates.length > 0 && (
            <section class="candidate-results secondary-preview">
              <div class="group-header">
                <h2>Related 2026 Candidates</h2>
                <p>
                  These candidate previews match the same filter context where
                  possible.
                </p>
              </div>
              <div class="candidate-grid">
                {directoryCandidates.map((candidate) => (
                  <CandidateCard candidate={candidate} />
                ))}
              </div>
            </section>
          )}
        </section>
      )}

      {lookupData && (allReps.length > 0 || allCandidates.length > 0) && (
        <>
          <section class="district-summary">
            <div class="summary-card panel">
              <div>
                <p class="summary-label">Showing results for</p>
                <h2>{prettyAddress || lookupData.address || "This address"}</h2>

                {isWardedCommunity && (
                  <form class:list={["ward-filter", !wardNumber && "needs-ward"]} action="/my-state-rep#rep-results" method="get" data-results-form>
                    <input type="hidden" name="address" value={address} />
                    <div class="ward-filter-copy">
                      <label for="ward">Select your ward</label>
                      <p>
                        {wardNumber
                          ? "Confirm or change your ward to narrow State House representatives and candidates."
                          : "This city has ward-based districts, but the address lookup did not return a ward. Select your ward so the results are not town-wide."}
                      </p>
                    </div>
                    <div class="ward-filter-controls">
                      <select id="ward" name="ward">
                        <option value="">Use address result</option>
                        {wardOptions.map((option) => (
                          <option value={option} selected={selectedWard === option}>
                            Ward {option}
                          </option>
                        ))}
                      </select>
                      <button type="submit">Apply</button>
                    </div>
                  </form>
                )}
              </div>

              <div class="summary-grid">
                {place && (
                  <div class="summary-item">
                    <span>Community</span>
                    <strong>{place}</strong>
                  </div>
                )}

                {ward && (
                  <div class="summary-item">
                    <span>Ward</span>
                    <strong>{ward}</strong>
                  </div>
                )}

                {senateDistrict && (
                  <div class="summary-item">
                    <span>State Senate</span>
                    <strong>District {senateDistrict}</strong>
                  </div>
                )}

                {houseDistricts.length > 0 && (
                  <div class="summary-item">
                    <span>State House</span>
                    <strong>{houseDistricts.join(", ")}</strong>
                  </div>
                )}
              </div>
            </div>
          </section>

          <section class="results">
            {senateReps.length > 0 && (
              <section class="rep-group">
                <div class="group-header">
                  <h2>State Senate</h2>
                  <p>
                    Your State Senator represents a larger district in the New
                    Hampshire Senate.
                  </p>
                </div>

                <div class="rep-grid">
                  {senateReps.map((rep) => (
                    <RepresentativeCard
                      rep={rep}
                      trackedBills={trackedBills}
                      billSummaries={billSummaries}
                    />
                  ))}
                </div>
              </section>
            )}

            {houseReps.length > 0 && (
              <section class="rep-group">
                <div class="group-header">
                  <h2>State House</h2>
                  <p>
                    Your House representatives may include your ward or town
                    district plus a floterial district.
                  </p>
                </div>

                <div class="rep-grid">
                  {houseReps.map((rep) => (
                    <RepresentativeCard
                      rep={rep}
                      trackedBills={trackedBills}
                      billSummaries={billSummaries}
                    />
                  ))}
                </div>
              </section>
            )}

            {(senateCandidates.length > 0 || filteredHouseCandidates.length > 0) && (
              <section class="candidate-results">
                <div class="group-header">
                  <h2>2026 Legislative Candidates</h2>
                  <p>
                    State House and State Senate candidates returned for the
                    same address lookup, grouped by legislative body.
                  </p>
                </div>

                {senateCandidates.length > 0 && (
                  <section class="candidate-group">
                    <h3>State Senate Candidates</h3>
                    <div class="candidate-grid">
                      {senateCandidates.map((candidate) => (
                        <CandidateCard candidate={candidate} />
                      ))}
                    </div>
                  </section>
                )}

                {filteredHouseCandidates.length > 0 && (
                  <section class="candidate-group">
                    <h3>State House Candidates</h3>
                    <div class="candidate-grid">
                      {filteredHouseCandidates.map((candidate) => (
                        <CandidateCard candidate={candidate} />
                      ))}
                    </div>
                  </section>
                )}
              </section>
            )}
          </section>
        </>
      )}
      </div>
    </main>
    <script>
      const resultsRegion = document.querySelector("[data-results-region]");
      document.addEventListener("submit", async (event) => {
        const form = event.target;
        if (!(form instanceof HTMLFormElement) || !form.matches("[data-results-form]") || !resultsRegion) {
          return;
        }

          event.preventDefault();

          const submitButton = form.querySelector("button[type='submit']");
          const originalText = submitButton?.textContent || "";
          const formData = new FormData(form);
          const params = new URLSearchParams();

          for (const [key, value] of formData.entries()) {
            const text = String(value || "").trim();
            if (text) params.set(key, text);
          }

          const url = `/my-state-rep${params.toString() ? `?${params}` : ""}`;
          if (submitButton) {
            submitButton.disabled = true;
            submitButton.textContent = "Loading...";
          }

          try {
            const response = await fetch(url, { headers: { "x-requested-with": "fetch" } });
            if (!response.ok) throw new Error("Unable to load results.");

            const html = await response.text();
            const doc = new DOMParser().parseFromString(html, "text/html");
            const nextResults = doc.querySelector("[data-results-region]");
            if (!nextResults) throw new Error("Unable to load results.");

            resultsRegion.innerHTML = nextResults.innerHTML;
            window.Alpine?.$data?.(document.querySelector("main[x-data]"))?.refresh?.();
            window.history.pushState({}, "", `${url}#rep-results`);
            resultsRegion.scrollIntoView({ behavior: "smooth", block: "start" });
          } catch (error) {
            window.location.href = `${url}#rep-results`;
          } finally {
            if (submitButton) {
              submitButton.disabled = false;
              submitButton.textContent = originalText;
            }
          }
      });
    </script>
    <SiteFooter />
  </body>
</html>

