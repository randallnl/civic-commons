    color: #4b5563;
    font-size: 1.1rem;
    font-weight: 800;
    min-height: 1.5rem;
  }

  .district-summary {
    margin-top: 24px;
  }

  .summary-card {
    padding: 24px;
  }

  .summary-card h2 {
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    margin: 0;
  }

  .ward-filter {
    align-items: end;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .ward-filter label {
    color: #6b7280;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin: 0 2px 0 0;
    text-transform: uppercase;
  }

  .ward-filter select {
    background: white;
    border: 1px solid #9ca3af;
    border-radius: 999px;
    color: #1f2933;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 800;
    min-height: 38px;
    padding: 7px 34px 7px 12px;
  }

  .ward-filter button {
    border-width: 1px;
    font-size: 0.86rem;
    min-height: 38px;
    padding: 8px 12px;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
