---
export const prerender = false;

import CandidateCard from "../components/CandidateCard.astro";
import RepresentativeCard from "../components/RepresentativeCard.astro";
import TopNav from "../components/TopNav.astro";
import profileIcon from "../assets/profile icon.png";
import { getBillDetail, getBillSummaries } from "../lib/billsApi";
import { civicApiBase, civicApiFetch } from "../lib/civicApi";
import { isFreeStater } from "../lib/civicTags";
import { profilePhotoUrl } from "../lib/photos";
import { repName, repSlug } from "../lib/repsApi";
import { getSpotlightLegislators } from "../lib/spotlightTracker";
import {
  normalizeBillCode,
  getTrackedBills,
  representativeGrade,
  representativeVoteStance,
  trackedBillForVote,
} from "../lib/trackedBills";

const API_BASE = civicApiBase();
const WARD_COMMUNITY_COUNTS = new Map([
  ["claremont", 3],
  ["concord", 10],
  ["dover", 6],
  ["franklin", 3],
  ["keene", 5],
  ["laconia", 6],
  ["lebanon", 3],
  ["manchester", 12],
  ["nashua", 9],
  ["portsmouth", 5],
  ["rochester", 6],
  ["somersworth", 5],
]);

const address = Astro.url.searchParams.get("address")?.trim() || "";
const selectedWard = normalizeWardNumber(Astro.url.searchParams.get("ward") || "");

let lookupData = null;
let lookupError = "";
let randomLegislators = [];
let trackedBills = new Map();
let billSummaries = new Map();

if (address) {
  try {
    const response = await civicApiFetch(`${API_BASE}/reps/lookup`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ address }),
    });

    const data = await response.json();

    if (!response.ok) {
      throw new Error(data.error || "Something went wrong.");
    }

    lookupData = data;
  } catch (error) {
    lookupError =
      error?.message || "Unable to look up representatives.";
  }
}

try {
  randomLegislators = shuffle(await getSpotlightLegislators({ limit: 8 })).slice(0, 6);
} catch (error) {
  console.error(error?.message || "Unable to load legislator preview.");
}

if (lookupData || randomLegislators.length > 0) {
  try {
    trackedBills = await getTrackedBills();
    if (lookupData) {
      billSummaries = await getBillSummaries();
    }
  } catch (error) {
    console.error(error?.message || "Unable to load bill summaries.");
  }
}

const senateReps = lookupData?.groups?.senate || [];
const houseRepsRaw = lookupData?.groups?.house || [];
const allReps = lookupData?.representatives || [];
const candidateGroups = lookupData?.groups?.candidates || {};
const allCandidates = lookupData?.candidates?.length
  ? lookupData.candidates
  : [
      ...(candidateGroups.senate || []),
      ...(candidateGroups.house || []),
    ];
const senateCandidates =
  candidateGroups.senate?.length
    ? candidateGroups.senate
    : allCandidates.filter((candidate) => isSenateCandidate(candidate));
const houseCandidates =
  candidateGroups.house?.length
    ? candidateGroups.house
    : allCandidates.filter((candidate) => isHouseCandidate(candidate));
const civic = lookupData?.civic || {};
const matchedDistricts = lookupData?.matchedDistricts || [];
const normalizedInput = lookupData?.normalizedInput || {};
const prettyAddress = formatAddress(normalizedInput);
const place = civic.place?.name || normalizedInput.city || "";
const wardOptions = wardOptionsFor(place);
const isWardedCommunity = wardOptions.length > 0;
const wardNumber = isWardedCommunity
  ? selectedWard || normalizeWardNumber(civic.ward?.number || "")
  : normalizeWardNumber(civic.ward?.number || "");
const ward = wardNumber ? `Ward ${wardNumber}` : "";
const houseReps = isWardedCommunity && selectedWard
  ? houseRepsRaw.filter((rep) => representsWard(rep, selectedWard))
  : houseRepsRaw;
const filteredHouseCandidates = isWardedCommunity && selectedWard
  ? houseCandidates.filter((candidate) => representsWard(candidate, selectedWard))
  : houseCandidates;
const senateDistrict =
  civic.senate?.districtLabel || civic.senate?.district || "";
const houseDistricts = matchedDistricts
  .filter((district) => district.body === "H")
  .filter((district) => !isWardedCommunity || !selectedWard || representsWard(district, selectedWard))
  .map((district) => district.district_label)
  .filter(Boolean);

if (lookupData && trackedBills.size) {
  await hydrateMissingBillSummaries(allReps, trackedBills, billSummaries);
}

function shuffle(items = []) {
  return [...items].sort(() => Math.random() - 0.5);
}

function isSenateCandidate(candidate = {}) {
  return /senate/i.test(`${candidate.office || ""} ${candidate.officeType || ""}`);
}

function isHouseCandidate(candidate = {}) {
  return /representative|house/i.test(
    `${candidate.office || ""} ${candidate.officeType || ""}`,
  );
}

function normalizeWardNumber(value = "") {
  const match = String(value || "").match(/\d+/);
  return match ? String(Number(match[0])) : "";
}

function normalizedTownName(value = "") {
  return String(value || "").trim().toLowerCase().replace(/\s+/g, " ");
}

function wardOptionsFor(town = "") {
  const count = WARD_COMMUNITY_COUNTS.get(normalizedTownName(town)) || 0;
  return Array.from({ length: count }, (_, index) => String(index + 1));
}

function representsWard(record = {}, wardValue = "") {
  const wardNumber = normalizeWardNumber(wardValue);
  if (!wardNumber) return true;

  const text = recordText(record);
  const directWard = new RegExp(`\\bward(?:s)?\\s*${escapeRegExp(wardNumber)}\\b`, "i");
  if (directWard.test(text)) return true;

  for (const match of text.matchAll(/\bwards?\s+(\d{1,2})\s*(?:-|–|—|to|through)\s*(\d{1,2})\b/gi)) {
    const start = Number(match[1]);
    const end = Number(match[2]);
    const selected = Number(wardNumber);
    if (selected >= Math.min(start, end) && selected <= Math.max(start, end)) return true;
  }

  return false;
}

function recordText(record = {}) {
  return [
    record.location_text,
    record.locationText,
    record.towns_represented,
    record.townsRepresented,
    record.towns,
    record.town,
    record.city,
    record.district_label,
    record.districtLabel,
    record.name,
    record.office,
    record.district,
    record.raw_district,
  ].flatMap(stringifyValue).filter(Boolean).join(" ");
}

function stringifyValue(value) {
  if (!value) return [];
  if (Array.isArray(value)) return value.flatMap(stringifyValue);
  if (typeof value === "object") {
    return [value.town, value.name, value.label, value.location_text, value.locationText].flatMap(stringifyValue);
  }
  return [String(value)];
}

function escapeRegExp(value = "") {
  return String(value).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

function legislativeBody(person = {}) {
  const value = String(person.chamber || person.legislativebody || person.body || "").toLowerCase();
  if (value === "h" || value === "house") return "House";
  if (value === "s" || value === "senate") return "Senate";
  return person.chamber || "";
}

function districtLabel(person = {}) {
  const district = person.district || person.raw_district || "";
  const body = legislativeBody(person);
  if (!district) return body;
  if (body === "House") return `NH House District ${district}`;
  if (body === "Senate") return `NH Senate District ${district}`;
  return `District ${district}`;
}

function locationLabel(person = {}) {
  const value =
    person.location_text ||
    person.locationText ||
    person.towns_represented ||
    person.townsRepresented ||
    "";
  if (Array.isArray(value)) return value.join(", ");
  return value;
}

function trackedVotesFor(person = {}, limit = 3) {
  const votes = Array.isArray(person.voteHistory) ? person.voteHistory : [];
  return votes.filter((vote) => trackedBillForVote(trackedBills, vote)).slice(0, limit);
}

function formatAddress(normalized = {}) {
  return [
    normalized.line1,
    normalized.city,
    normalized.state,
    normalized.zip,
  ]
    .filter(Boolean)
    .join(", ");
}

async function hydrateMissingBillSummaries(reps, tracked, summaries) {
  const missingBills = new Map();

  for (const rep of reps) {
    for (const vote of rep.voteHistory || []) {
      const code = normalizeBillCode(vote.condensedbillno);
      if (
        !code ||
        !trackedBillForVote(tracked, vote) ||
        summaries.has(code) ||
        missingBills.has(code)
      ) {
        continue;
      }
      missingBills.set(code, vote.sessionyear);
    }
  }

  await Promise.all(
    [...missingBills].map(async ([code, year]) => {
      try {
        const detail = await getBillDetail(code, { year });
        if (detail.bill) summaries.set(code, detail.bill);
      } catch (error) {
        console.error(error?.message || "Unable to load bill summary.");
      }
    }),
  );
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>My State Rep | NH Deserves Better</title>
    <meta
      name="description"
      content="Find your New Hampshire state legislators by address."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">My State Rep</p>
        <h1>Find your New Hampshire state legislators.</h1>
        <p class="lede">
          Enter your address to identify your State Senator, your ward-based
          House district, and any floterial House districts connected to your
          community.
        </p>

        <form class="lookup-card" action="/my-state-rep" method="get">
          <label for="address">Your full address</label>

          <div class="form-row">
            <input
              id="address"
              name="address"
              type="text"
              value={address}
              placeholder="72 Concord St, Manchester, NH"
              autocomplete="street-address"
              required
            />

            <button type="submit">Find My Reps</button>
          </div>

          <p class="help-text">
            Your address is used to identify your voting districts. It is not
            stored by this website.
          </p>
        </form>
      </section>

      {lookupError && (
        <div class="status-message" aria-live="polite">
          {lookupError}
        </div>
      )}

      {address && !lookupError && allReps.length === 0 && allCandidates.length === 0 && (
        <div class="status-message" aria-live="polite">
          No representatives or candidates found for that address.
        </div>
      )}

      {!address && randomLegislators.length > 0 && (
        <section class="sample-legislators">
          <div class="group-header">
            <h2>Representative Profiles</h2>
            <p>
              Preview legislator profiles, vote grades, and recent tracked bill
              votes. Enter your address above to see the legislators who represent you.
            </p>
          </div>

          <div class="sample-grid">
            {randomLegislators.map((rep) => {
              const photoUrl = profilePhotoUrl(rep.photo || rep.photo_url);
              const grade = representativeGrade(rep.voteHistory || [], trackedBills);
              const votes = trackedVotesFor(rep, 3);

              return (
                <article class="sample-card">
                  <div class="sample-profile-row">
                    <a class="sample-photo-link" href={`/people/${repSlug(rep)}`}>
                      <img
                        class:list={[!photoUrl && "sample-fallback"]}
                        src={photoUrl || profileIcon.src}
                        alt={photoUrl ? `Photo of ${repName(rep)}` : ""}
                        loading="lazy"
                      />
                    </a>

                    <div class="sample-copy">
                      <a href={`/people/${repSlug(rep)}`}><strong>{repName(rep)}</strong></a>
                      <small>
                        {[
                          rep.party || "No party listed",
                          districtLabel(rep),
                        ].filter(Boolean).join(" - ")}
                      </small>
                      {locationLabel(rep) && <em>{locationLabel(rep)}</em>}
                      {isFreeStater(rep) && (
                      <a
                        class="free-stater-pill"
                        href="/free-staters"
                        title="What is a Free Stater?"
                        aria-label="What is a Free Stater?"
                      >
                        Free Stater
                      </a>
                      )}
                    </div>

                    <span class:list={["mini-grade", grade.className]} title={grade.label}>
                      <strong>{grade.letter}</strong>
                      <small>Grade</small>
                    </span>
                  </div>

                  {votes.length > 0 && (
                    <div class="sample-vote-list">
                      <span>Bill Tracker Votes</span>
                      {votes.map((vote) => {
                        const trackedBill = trackedBillForVote(trackedBills, vote);
                        const voteStance = representativeVoteStance(vote, trackedBill);

                        return (
                          <div class:list={["sample-vote-preview", voteStance.className]}>
                            <strong>{trackedBill.code}: {trackedBill.name || "Tracked Bill"}</strong>
                            <small>{voteStance.label}</small>
                          </div>
                        );
                      })}
                    </div>
                  )}
                </article>
              );
            })}
          </div>
        </section>
      )}

      {lookupData && (allReps.length > 0 || allCandidates.length > 0) && (
        <>
          <section class="district-summary">
            <div class="summary-card panel">
              <div>
                <p class="summary-label">Showing results for</p>
                <h2>{prettyAddress || lookupData.address || "This address"}</h2>

                {isWardedCommunity && (
                  <form class="ward-filter" action="/my-state-rep" method="get">
                    <input type="hidden" name="address" value={address} />
                    <label for="ward">Ward</label>
                    <select id="ward" name="ward">
                      <option value="">Use address result</option>
                      {wardOptions.map((option) => (
                        <option value={option} selected={selectedWard === option}>
                          Ward {option}
                        </option>
                      ))}
                    </select>
                    <button type="submit">Apply</button>
                  </form>
                )}
              </div>

              <div class="summary-grid">
                {place && (
                  <div class="summary-item">
                    <span>Community</span>
                    <strong>{place}</strong>
                  </div>
                )}

                {ward && (
                  <div class="summary-item">
                    <span>Ward</span>
                    <strong>{ward}</strong>
                  </div>
                )}

                {senateDistrict && (
                  <div class="summary-item">
                    <span>State Senate</span>
                    <strong>District {senateDistrict}</strong>
                  </div>
                )}

                {houseDistricts.length > 0 && (
                  <div class="summary-item">
                    <span>State House</span>
                    <strong>{houseDistricts.join(", ")}</strong>
                  </div>
                )}
              </div>
            </div>
          </section>

          <section class="results">
            {senateReps.length > 0 && (
              <section class="rep-group">
                <div class="group-header">
                  <h2>State Senate</h2>
                  <p>
                    Your State Senator represents a larger district in the New
                    Hampshire Senate.
                  </p>
                </div>

                <div class="rep-grid">
                  {senateReps.map((rep) => (
                    <RepresentativeCard
                      rep={rep}
                      trackedBills={trackedBills}
                      billSummaries={billSummaries}
                    />
                  ))}
                </div>
              </section>
            )}

            {houseReps.length > 0 && (
              <section class="rep-group">
                <div class="group-header">
                  <h2>State House</h2>
                  <p>
                    Your House representatives may include your ward or town
                    district plus a floterial district.
                  </p>
                </div>

                <div class="rep-grid">
                  {houseReps.map((rep) => (
                    <RepresentativeCard
                      rep={rep}
                      trackedBills={trackedBills}
                      billSummaries={billSummaries}
                    />
                  ))}
                </div>
              </section>
            )}

            {(senateCandidates.length > 0 || filteredHouseCandidates.length > 0) && (
              <section class="candidate-results">
                <div class="group-header">
                  <h2>2026 Candidates</h2>
                  <p>
                    Candidates returned for the same address lookup, grouped by
                    legislative body.
                  </p>
                </div>

                {senateCandidates.length > 0 && (
                  <section class="candidate-group">
                    <h3>State Senate Candidates</h3>
                    <div class="candidate-grid">
                      {senateCandidates.map((candidate) => (
                        <CandidateCard candidate={candidate} />
                      ))}
                    </div>
                  </section>
                )}

                {filteredHouseCandidates.length > 0 && (
                  <section class="candidate-group">
                    <h3>State House Candidates</h3>
                    <div class="candidate-grid">
                      {filteredHouseCandidates.map((candidate) => (
                        <CandidateCard candidate={candidate} />
                      ))}
                    </div>
                  </section>
                )}
              </section>
            )}
          </section>
        </>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 40px 0 64px;
  }

  .back {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 48px 0 24px;
  }

  .eyebrow,
  .summary-label,
  .summary-item span {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .eyebrow,
  .summary-label {
    color: #6b4f2a;
    margin-bottom: 16px;
  }

  h1 {
    max-width: 900px;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0;
  }

  .lede {
    max-width: 760px;
    font-size: 1.2rem;
    line-height: 1.6;
    margin: 24px 0 0;
    color: #4b5563;
  }

  .panel,
  .lookup-card {
    background: rgba(255, 255, 255, 0.75);
    border: 2px solid #1f2933;
    border-radius: 24px;
    box-shadow: 6px 6px 0 #1f2933;
  }

