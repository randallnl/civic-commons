  .sample-photo-link img,
  .sample-fallback {
    aspect-ratio: 4 / 5;
    border: 2px solid #1f2933;
    border-radius: 10px;
    display: block;
    height: 80px;
    object-fit: cover;
    object-position: center top;
    width: 64px;
  }

  .sample-photo-link img.sample-fallback {
    background: transparent;
    box-sizing: border-box;
    object-fit: cover;
    padding: 0;
  }

  .sample-copy {
    min-width: 0;
  }

  .sample-copy > a {
    display: block;
    text-decoration: none;
  }

  .sample-copy strong,
  .sample-copy small,
  .sample-copy em {
    display: block;
  }

  .sample-copy strong {
    font-size: 1rem;
    line-height: 1.2;
  }

  .sample-copy small {
    color: #4b5563;
    font-size: 0.86rem;
    font-weight: 750;
    line-height: 1.35;
    margin-top: 4px;
  }

  .sample-copy em {
    color: #6b7280;
    font-size: 0.82rem;
    font-style: normal;
    font-weight: 600;
    line-height: 1.35;
    margin-top: 3px;
  }

  .mini-grade {
    border: 1px solid #1f2933;
    border-radius: 8px;
    box-shadow: 2px 2px 0 #1f2933;
    color: #fefce8;
    display: grid;
    min-width: 52px;
    padding: 7px 8px;
    text-align: center;
  }

