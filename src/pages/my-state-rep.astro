    border: 2px solid #1f2933;
    background: #1f2933;
    color: white;
    padding: 16px 22px;
    border-radius: 999px;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  button:hover {
    background: #374151;
  }

  .help-text {
    color: #4b5563;
    line-height: 1.5;
    margin: 14px 0 0;
  }

