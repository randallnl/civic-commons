    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, 1fr);
    margin-top: 22px;
  }

  .sample-card {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 16px;
    box-shadow: 4px 4px 0 #1f2933;
    color: inherit;
    display: grid;
    gap: 10px;
    padding: 14px;
