---
export const prerender = false;

import RepresentativeCard from "../components/RepresentativeCard.astro";

const API_BASE =
  import.meta.env.REP_LOOKUP_API_BASE ||
  "https://api.nhdeservesbetter.com";

const address = Astro.url.searchParams.get("address")?.trim() || "";

let lookupData = null;
let lookupError = "";

if (address) {
  try {
    const response = await fetch(`${API_BASE}/reps/lookup`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ address }),
    });

    const data = await response.json();

    if (!response.ok) {
      throw new Error(data.error || "Something went wrong.");
    }

    lookupData = data;
  } catch (error) {
    lookupError =
      error?.message || "Unable to look up representatives.";
  }
}

const senateReps = lookupData?.groups?.senate || [];
const houseReps = lookupData?.groups?.house || [];
const allReps = lookupData?.representatives || [];
const civic = lookupData?.civic || {};
const matchedDistricts = lookupData?.matchedDistricts || [];
const normalizedInput = lookupData?.normalizedInput || {};
const prettyAddress = formatAddress(normalizedInput);
const place = civic.place?.name || normalizedInput.city || "";
const ward = civic.ward?.number ? `Ward ${civic.ward.number}` : "";
const senateDistrict =
  civic.senate?.districtLabel || civic.senate?.district || "";
const houseDistricts = matchedDistricts
  .filter((district) => district.body === "H")
  .map((district) => district.district_label)
  .filter(Boolean);

function formatAddress(normalized = {}) {
  return [
    normalized.line1,
    normalized.city,
    normalized.state,
    normalized.zip,
  ]
    .filter(Boolean)
    .join(", ");
}
---

<html lang="en">
  <head>
    <title>My State Rep | Civic Commons</title>
    <meta
      name="description"
      content="Find your New Hampshire state legislators by address."
    />
  </head>

  <body>
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">My State Rep</p>
        <h1>Find your New Hampshire state legislators.</h1>
        <p class="lede">
          Enter your address to identify your State Senator, your ward-based
          House district, and any floterial House districts connected to your
          community.
        </p>

        <form class="lookup-card" action="/my-state-rep" method="get">
          <label for="address">Your full address</label>

          <div class="form-row">
            <input
              id="address"
              name="address"
              type="text"
              value={address}
              placeholder="82 Bobcat Way, Manchester, NH"
              autocomplete="street-address"
              required
            />

            <button type="submit">Find My Reps</button>
          </div>

          <p class="help-text">
            Your address is used to identify your voting districts. It is not
            stored by this website.
          </p>
        </form>
      </section>

      {lookupError && (
        <div class="status-message" aria-live="polite">
          {lookupError}
        </div>
      )}

      {address && !lookupError && allReps.length === 0 && (
        <div class="status-message" aria-live="polite">
          No representatives found for that address.
        </div>
      )}

      {lookupData && allReps.length > 0 && (
        <>
          <section class="district-summary">
            <div class="summary-card panel">
              <div>
                <p class="summary-label">Showing results for</p>
                <h2>{prettyAddress || lookupData.address || "This address"}</h2>
              </div>

              <div class="summary-grid">
                {place && (
                  <div class="summary-item">
                    <span>Community</span>
                    <strong>{place}</strong>
                  </div>
                )}

                {ward && (
                  <div class="summary-item">
                    <span>Ward</span>
                    <strong>{ward}</strong>
                  </div>
                )}

                {senateDistrict && (
                  <div class="summary-item">
                    <span>State Senate</span>
                    <strong>District {senateDistrict}</strong>
                  </div>
                )}

                {houseDistricts.length > 0 && (
                  <div class="summary-item">
                    <span>State House</span>
                    <strong>{houseDistricts.join(", ")}</strong>
                  </div>
                )}
              </div>
            </div>
          </section>

          <section class="results">
            {senateReps.length > 0 && (
              <section class="rep-group">
                <div class="group-header">
                  <h2>State Senate</h2>
                  <p>
                    Your State Senator represents a larger district in the New
                    Hampshire Senate.
                  </p>
                </div>

                <div class="rep-grid">
                  {senateReps.map((rep) => (
                    <RepresentativeCard rep={rep} />
                  ))}
                </div>
              </section>
            )}

            {houseReps.length > 0 && (
              <section class="rep-group">
                <div class="group-header">
                  <h2>State House</h2>
                  <p>
                    Your House representatives may include your ward or town
                    district plus a floterial district.
                  </p>
                </div>

                <div class="rep-grid">
                  {houseReps.map((rep) => (
                    <RepresentativeCard rep={rep} />
                  ))}
                </div>
              </section>
            )}
          </section>
        </>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 40px 0 64px;
  }

  .back {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 48px 0 24px;
  }

  .eyebrow,
  .summary-label,
  .summary-item span {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .eyebrow,
  .summary-label {
    color: #6b4f2a;
    margin-bottom: 16px;
  }

  h1 {
    max-width: 900px;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0;
  }

  .lede {
    max-width: 760px;
    font-size: 1.2rem;
    line-height: 1.6;
    margin: 24px 0 0;
    color: #4b5563;
  }

  .panel,
  .lookup-card {
    background: rgba(255, 255, 255, 0.75);
    border: 2px solid #1f2933;
    border-radius: 24px;
    box-shadow: 6px 6px 0 #1f2933;
  }

  .lookup-card {
    margin-top: 32px;
    padding: 24px;
  }

  label {
    display: block;
    font-weight: 800;
    margin-bottom: 10px;
  }

  .form-row {
    display: flex;
    gap: 12px;
  }

  input {
    flex: 1;
    min-width: 0;
    padding: 16px 18px;
    border: 2px solid #1f2933;
    border-radius: 999px;
    font: inherit;
    background: white;
  }

  button {
    border: 2px solid #1f2933;
    background: #1f2933;
    color: white;
    padding: 16px 22px;
    border-radius: 999px;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  button:hover {
    background: #374151;
  }

  .help-text {
    color: #4b5563;
    line-height: 1.5;
    margin: 14px 0 0;
  }

  .status-message {
    color: #4b5563;
    font-size: 1.1rem;
    font-weight: 800;
    min-height: 1.5rem;
  }

  .district-summary {
    margin-top: 24px;
  }

  .summary-card {
    padding: 24px;
  }

  .summary-card h2 {
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    margin: 0;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-top: 20px;
  }

  .summary-item {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 16px;
    padding: 16px;
  }

  .summary-item span {
    display: block;
    color: #6b7280;
    margin-bottom: 6px;
  }

  .results {
    margin-top: 48px;
  }

  .rep-group + .rep-group {
    margin-top: 48px;
  }

  .group-header h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1;
    margin: 0;
  }

  .group-header p {
    color: #4b5563;
    line-height: 1.5;
    max-width: 720px;
    margin-top: 12px;
  }

  .rep-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
    margin-top: 24px;
  }

  @media (max-width: 900px) {
    .summary-grid,
    .rep-grid {
      grid-template-columns: 1fr;
    }

    .form-row {
      flex-direction: column;
    }

    button {
      width: 100%;
    }
  }

  @media (max-width: 520px) {
    .page {
      padding: 24px 0 48px;
    }

    .hero {
      padding-top: 32px;
    }
  }
</style>
