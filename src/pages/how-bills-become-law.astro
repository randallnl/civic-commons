---
export const prerender = false;

import TopNav from "../components/TopNav.astro";

const examples = [
  {
    eyebrow: "Example 1",
    title: "HB 155: A bill that needed a Committee of Conference",
    description:
      "HB 155 shows how a bill can slow down, change in the second chamber, and then need House and Senate negotiators to work out one final version.",
    billHref: "/bills/HB155",
    steps: [
      ["Introduced in the House", "HB 155 was introduced on January 8, 2025 and sent to House Ways and Means."],
      ["House Hearing", "The committee held a public hearing on January 28, 2025."],
      ["Retained in Committee", "Instead of moving right away, the House committee kept the bill for more work."],
      ["House Committee Report", "The committee later recommended Ought to Pass with Amendment, with a minority report recommending ITL."],
      ["House Vote", "On January 8, 2026, the House adopted the amendment and passed the bill 189-165."],
      ["Senate Review", "The Senate sent HB 155 to Ways and Means, held hearings, and added Senate amendments."],
      ["Senate Finance", "After passing with amendments, the bill was referred to Senate Finance under Rule 4-5."],
      ["House Non-Concurs", "The House did not agree to the Senate version and requested a Committee of Conference."],
      ["Committee of Conference", "House and Senate conferees met to negotiate one final version of the bill."],
      ["Conference Report Adopted", "On June 4, 2026, both chambers adopted the conference committee report."],
    ],
    teaches: [
      "Bills can be retained for more work before they ever reach a chamber vote.",
      "A second chamber can amend a bill enough that the first chamber refuses to concur.",
      "A Committee of Conference is used when the House and Senate need to negotiate a final shared version.",
    ],
  },
  {
    eyebrow: "Example 2",
    title: "A bill voted Inexpedient to Legislate",
    description:
      "Many bills end early. When a committee recommends Inexpedient to Legislate, or ITL, it is recommending that the bill not move forward.",
    steps: [
      ["Bill Introduced", "A legislator files the proposal."],
      ["Committee Hearing", "The public can testify for or against the bill."],
      ["Committee Recommends ITL", "The committee recommends killing the bill."],
      ["House Vote", "The House accepts the ITL recommendation."],
      ["Bill Dies", "The bill goes no further."],
    ],
    teaches: [
      "Most bills never become law.",
      "Committee recommendations carry significant weight.",
      "A bill can end very early in the process.",
    ],
  },
  {
    eyebrow: "Example 3",
    title: "A bill that follows the standard path",
    description:
      "This is the simplest textbook route. The second chamber passes the same version it received, so the bill does not need to return to the first chamber.",
    steps: [
      ["Bill Introduced", "A bill is filed and assigned to a chamber."],
      ["House Committee", "The committee studies it and recommends action."],
      ["House Vote", "The full House passes the bill."],
      ["Senate Committee", "The Senate committee reviews it."],
      ["Senate Vote", "The full Senate passes it without changes."],
      ["Governor", "The Governor signs it."],
      ["Becomes Law", "The bill becomes part of state law."],
    ],
    teaches: [
      "This is the simplest route through the legislature.",
      "Because the Senate did not change anything, the bill did not need to return to the House.",
    ],
  },
];

const detours = [
  ["Pass as written", "Both chambers approve the same language."],
  ["Be amended", "A committee or chamber changes the bill."],
  ["Return to the other chamber", "The first chamber must review changes made by the second chamber."],
  ["Go to Committee of Conference", "Negotiators try to resolve differences between House and Senate versions."],
  ["Be voted ITL", "The bill is killed as Inexpedient to Legislate."],
  ["Be retained", "A committee keeps the bill for more work."],
  ["Be signed or vetoed", "The Governor decides whether the bill becomes law."],
];
---

<html lang="en">
  <head>
    <title>How Bills Move Through the NH Legislature | Civic Commons</title>
    <meta
      name="description"
      content="A plain-language guide to how bills move through the New Hampshire House, Senate, committees, amendments, ITL votes, and the Governor."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Civic Basics</p>
        <h1>How bills move through the New Hampshire Legislature.</h1>
        <p class="lede">
          A bill rarely moves in a perfectly straight line. Committees hear
          testimony, chambers vote, amendments can send a bill back across the
          State House, and many proposals never become law.
        </p>
        <div class="hero-actions">
          <a class="primary-link" href="/bills">Browse tracked bills</a>
          <a class="secondary-link" href="/my-state-rep">Find my representatives</a>
        </div>
      </section>

      <section class="overview panel">
        <div>
          <p class="eyebrow">The Basic Idea</p>
          <h2>Both chambers have to agree.</h2>
          <p>
            New Hampshire has two legislative chambers: the House and the
            Senate. A bill usually starts in one chamber, goes through a
            committee, receives a vote, then moves to the other chamber. Before
            it can become law, both chambers must agree to the same final text.
          </p>
        </div>
        <aside>
          <strong>Where the public has power</strong>
          <p>
            Committee hearings are where residents can submit testimony, contact
            legislators, and shape how lawmakers understand a bill before it
            reaches a full chamber vote.
          </p>
        </aside>
      </section>

      <section class="examples">
        <div class="section-heading">
          <p class="eyebrow">Three Real Paths</p>
          <h2>Not every bill travels the same route.</h2>
          <p>
            These examples show why a bill's history can look different from one
            proposal to another.
          </p>
        </div>

        <div class="example-stack">
          {examples.map((example) => (
            <article class="example-card">
              <div class="example-intro">
                <p class="eyebrow">{example.eyebrow}</p>
                <h3>{example.title}</h3>
                <p>{example.description}</p>
                {example.billHref && <a href={example.billHref}>Open bill details</a>}
              </div>

              <ol class="flow" aria-label={`${example.title} steps`}>
                {example.steps.map(([title, detail], index) => (
                  <li>
                    <span>{index + 1}</span>
                    <div>
                      <strong>{title}</strong>
                      <p>{detail}</p>
                    </div>
                  </li>
                ))}
              </ol>

              <div class="teaches">
                <strong>What this teaches</strong>
                <ul>
                  {example.teaches.map((lesson) => (
                    <li>{lesson}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="detours panel">
        <div>
          <p class="eyebrow">Possible Detours</p>
          <h2>A bill can take a turn at several points.</h2>
          <p>
            When you look at a bill profile, pay attention to committee
            recommendations, amendments, roll call votes, and whether both
            chambers agreed on the same language.
          </p>
        </div>

        <div class="detour-grid">
          {detours.map(([title, detail]) => (
            <article>
              <strong>{title}</strong>
              <p>{detail}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="next-step">
        <h2>Use this when reading bill profiles.</h2>
        <p>
          The bill tracker connects summaries, testimony, roll calls, and
          legislator votes so you can see which path a specific bill followed.
        </p>
        <a class="primary-link" href="/bills">Go to bills</a>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 80px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 850;
  }

  .hero {
    padding: 48px 0 36px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 6.25rem);
    letter-spacing: 0;
    line-height: 0.92;
    margin-bottom: 20px;
    max-width: 980px;
  }

  h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1;
    margin-bottom: 14px;
  }

  h3 {
    font-size: clamp(1.45rem, 3vw, 2.2rem);
    line-height: 1.05;
    margin-bottom: 12px;
  }

  .lede {
    color: #4b5563;
    font-size: 1.2rem;
    line-height: 1.65;
    max-width: 820px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .primary-link,
  .secondary-link {
    border: 2px solid #1f2933;
    border-radius: 999px;
    display: inline-block;
    padding: 14px 18px;
    text-decoration: none;
  }

  .primary-link {
    background: #1f2933;
    color: white;
  }

  .secondary-link {
    background: white;
  }

  .panel,
  .example-card,
  .next-step {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
  }

  .overview {
    align-items: start;
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 320px;
    margin: 16px 0 48px;
    padding: 28px;
  }

  .overview p,
  .section-heading p,
  .detours > div > p,
  .next-step p {
    color: #4b5563;
    line-height: 1.65;
  }

  .overview aside {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 18px;
  }

  .overview aside strong {
    display: block;
    font-size: 1.05rem;
    margin-bottom: 8px;
  }

  .section-heading {
    max-width: 820px;
  }

  .example-stack {
    display: grid;
    gap: 24px;
    margin-top: 24px;
  }

  .example-card {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.2fr) minmax(220px, 0.7fr);
    padding: 24px;
  }

  .example-intro p {
    color: #4b5563;
    line-height: 1.55;
  }

  .flow {
    counter-reset: step;
    display: grid;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .flow li {
    align-items: start;
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    display: grid;
    gap: 12px;
    grid-template-columns: 38px minmax(0, 1fr);
    padding: 12px;
    position: relative;
  }

  .flow li + li::before {
    background: #1f2933;
    content: "";
    height: 10px;
    left: 30px;
    position: absolute;
    top: -11px;
    width: 2px;
  }

  .flow li > span {
    align-items: center;
    background: #1f2933;
    border-radius: 999px;
    color: white;
    display: inline-flex;
    font-weight: 950;
    height: 34px;
    justify-content: center;
    width: 34px;
  }

  .flow strong,
  .teaches > strong,
  .detour-grid strong {
    display: block;
  }

  .flow p {
    color: #4b5563;
    font-size: 0.92rem;
    line-height: 1.4;
    margin: 4px 0 0;
  }

  .teaches {
    background: #eef6ff;
    border: 1px solid #93c5fd;
    border-radius: 8px;
    padding: 16px;
  }

  .teaches ul {
    display: grid;
    gap: 8px;
    margin: 10px 0 0;
    padding-left: 18px;
  }

  .teaches li {
    color: #374151;
    line-height: 1.45;
  }

  .detours {
    display: grid;
    gap: 24px;
    grid-template-columns: 0.7fr 1.3fr;
    margin-top: 48px;
    padding: 28px;
  }

  .detour-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .detour-grid article {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 14px;
  }

  .detour-grid p {
    color: #4b5563;
    font-size: 0.92rem;
    line-height: 1.45;
    margin: 6px 0 0;
  }

  .next-step {
    margin-top: 48px;
    padding: 28px;
  }

  @media (max-width: 920px) {
    .overview,
    .example-card,
    .detours {
      grid-template-columns: 1fr;
    }

    .detour-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .page {
      padding: 28px 0 56px;
    }

    .hero {
      padding-top: 32px;
    }

    .example-card,
    .overview,
    .detours,
    .next-step {
      padding: 18px;
    }
  }
</style>
