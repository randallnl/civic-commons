---
export const prerender = false;

import TopNav from "../../components/TopNav.astro";
import {
  candidateName,
  candidateSlug,
  getCandidates,
  isLegislativeCandidate,
} from "../../lib/candidatesApi";
import { cleanText } from "../../lib/text";

const submitted = Astro.url.searchParams.get("submitted") === "1";
const error = Astro.url.searchParams.get("error") || "";
const requestedCandidate = Astro.url.searchParams.get("candidate") || "";
let candidates = [];

try {
  const data = await getCandidates({
    officeType: "General Court",
    electionYear: 2026,
    limit: 1000,
  });
  candidates = (data.candidates || [])
    .filter(isLegislativeCandidate)
    .sort((a, b) => candidateName(a).localeCompare(candidateName(b)));
} catch (error) {
  console.error(error?.message || "Unable to load candidate selector.");
}

const candidateOptions = candidates.map((candidate) => {
  const slug = candidateSlug(candidate);
  const name = candidateName(candidate);
  const officeParts = [
    candidate.office,
    candidate.county,
    candidate.district ? `District ${candidate.district}` : "",
  ].filter(Boolean);
  const label = [name, officeParts.join(" - ")].filter(Boolean).join(" | ");

  return {
    label,
    value: label,
    name,
    slug,
    office: candidate.office || "",
    district: [candidate.county, candidate.district ? `District ${candidate.district}` : ""]
      .filter(Boolean)
      .join(", "),
    electionYear: String(candidate.electionYear || 2026),
  };
});

const selectedOption = candidateOptions.find((option) =>
  [option.slug, option.name, option.label]
    .map((value) => String(value || "").toLowerCase())
    .includes(String(requestedCandidate || "").toLowerCase()),
);
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>Submit an Endorsement | NH Deserves Better</title>
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href={selectedOption ? `/candidates/${selectedOption.slug}` : "/candidates"}>
        Back to candidates
      </a>

      <section class="hero">
        <p class="eyebrow">Community Submissions</p>
        <h1>Share an organization endorsement.</h1>
        <p class="lede">
          Submit endorsements from advocacy organizations, unions, community
          groups, or other public organizations. Submissions are reviewed before
          they appear on candidate profiles.
        </p>
      </section>

      {submitted && (
        <p class="status-message success">
          Thanks. The endorsement was submitted for review.
        </p>
      )}
      {error && <p class="status-message error">{cleanText(error)}</p>}

      <section class="panel">
        <form class="endorsement-form" action="/api/endorsements/submit" method="post">
          <input type="hidden" name="redirectTo" value="/endorsements/submit" />
          <input id="candidateSlug" type="hidden" name="candidateSlug" value={selectedOption?.slug || ""} />
          <input id="candidateName" type="hidden" name="candidateName" value={selectedOption?.name || ""} />
          <input id="candidateOffice" type="hidden" name="office" value={selectedOption?.office || ""} />
          <input id="candidateDistrict" type="hidden" name="district" value={selectedOption?.district || ""} />
          <input id="candidateElectionYear" type="hidden" name="electionYear" value={selectedOption?.electionYear || "2026"} />

          <div class="form-grid two">
            <label>
              Organization name
              <input name="organizationName" placeholder="Organization name" required />
            </label>
            <label>
              Organization website
              <input name="organizationWebsite" type="url" placeholder="https://example.org" />
            </label>
          </div>

          <label>
            Candidate
            <input
              id="candidateSearch"
              list="candidateOptions"
              value={selectedOption?.label || ""}
              placeholder="Start typing a candidate name"
              autocomplete="off"
              required
            />
            <datalist id="candidateOptions">
              {candidateOptions.map((option) => (
                <option value={option.value} />
              ))}
            </datalist>
          </label>

          <div class="form-grid three">
            <label>
              Position
              <select name="position">
                <option value="Endorsed">Endorsed</option>
                <option value="Recommended">Recommended</option>
                <option value="Opposed">Opposed</option>
                <option value="Supported">Supported</option>
              </select>
            </label>
            <label>
              Endorsement date
              <input name="date" type="date" />
            </label>
            <label>
              Organization contact email
              <input name="organizationEmail" type="email" />
            </label>
          </div>

          <label>
            Notes or endorsement text
            <textarea name="statement" rows="5" placeholder="Paste the endorsement language or explain where it was published."></textarea>
          </label>

          <div class="form-grid two">
            <label>
              Your name
              <input name="submitterName" />
            </label>
            <label>
              Your email
              <input name="submitterEmail" type="email" />
            </label>
          </div>

          <button type="submit">Submit for Review</button>
        </form>
      </section>
    </main>

    <script define:vars={{ candidateOptions }}>
      const candidateSearch = document.getElementById("candidateSearch");
      const fields = {
        slug: document.getElementById("candidateSlug"),
        name: document.getElementById("candidateName"),
        office: document.getElementById("candidateOffice"),
        district: document.getElementById("candidateDistrict"),
        electionYear: document.getElementById("candidateElectionYear"),
      };
      const optionMap = new Map(candidateOptions.map((option) => [option.value, option]));

      function syncCandidate() {
        const selected = optionMap.get(candidateSearch?.value || "");
        fields.slug.value = selected?.slug || "";
        fields.name.value = selected?.name || "";
        fields.office.value = selected?.office || "";
        fields.district.value = selected?.district || "";
        fields.electionYear.value = selected?.electionYear || "2026";
      }

      candidateSearch?.addEventListener("input", syncCandidate);
      candidateSearch?.form?.addEventListener("submit", syncCandidate);
    </script>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(980px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 850;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.2rem, 5.5vw, 4.15rem);
    line-height: 0.95;
    margin: 0;
  }

  .lede {
    color: #4b5563;
    font-size: clamp(1.08rem, 2vw, 1.28rem);
    font-weight: 750;
    line-height: 1.5;
    margin: 20px 0 0;
    max-width: 780px;
  }

  .panel,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 16px;
    box-shadow: 5px 5px 0 #1f2933;
    padding: clamp(20px, 4vw, 28px);
  }

  .status-message.success {
    background: #ecfdf5;
    color: #065f46;
  }

  .status-message.error {
    background: #fef2f2;
    color: #991b1b;
  }

  .endorsement-form,
  label {
    display: grid;
    gap: 8px;
  }

  .endorsement-form {
    gap: 16px;
  }

  label {
    color: #374151;
    font-size: 0.86rem;
    font-weight: 900;
  }

  input,
  select,
  textarea {
    border: 1px solid #9ca3af;
    border-radius: 10px;
    color: #1f2933;
    font: inherit;
    font-weight: 650;
    padding: 11px 12px;
  }

  textarea {
    line-height: 1.45;
  }

  .form-grid {
    display: grid;
    gap: 14px;
  }

  .form-grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .form-grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  button {
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    cursor: pointer;
    font: inherit;
    font-weight: 950;
    justify-self: start;
    padding: 12px 18px;
  }

  @media (max-width: 760px) {
    .form-grid.two,
    .form-grid.three {
      grid-template-columns: 1fr;
    }
  }
</style>
