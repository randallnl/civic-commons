---
export const prerender = false;

import ArticleList from "../../components/ArticleList.astro";
import TopNav from "../../components/TopNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getArticles } from "../../lib/articlesApi";

const q = Astro.url.searchParams.get("q")?.trim() || "";
const bill = Astro.url.searchParams.get("bill")?.trim() || "";
const town = Astro.url.searchParams.get("town")?.trim() || "";
const requestedLimit = Number(Astro.url.searchParams.get("limit") || 20);
const articleLimit = Number.isFinite(requestedLimit)
  ? Math.min(Math.max(Math.trunc(requestedLimit), 20), 100)
  : 20;
const submitted = Astro.url.searchParams.get("submitted") === "1";
const submitError = Astro.url.searchParams.get("error") || "";

let articles = [];
let meta = {};
let error = "";

try {
  const data = await getArticles({
    q,
    bill,
    town,
    include: "relations",
    limit: articleLimit,
  });
  articles = data.articles || [];
  meta = data.meta || {};
} catch (loadError) {
  error = loadError?.message || "Unable to load articles.";
}

const nextLimit = Math.min(articleLimit + 20, 100);
const totalArticles = Number(meta.count ?? meta.total ?? 0);
const hasMoreArticles =
  totalArticles > articles.length ||
  (!totalArticles && articles.length >= articleLimit && articleLimit < 100);
const seeMoreParams = new URLSearchParams();
if (q) seeMoreParams.set("q", q);
if (bill) seeMoreParams.set("bill", bill);
if (town) seeMoreParams.set("town", town);
seeMoreParams.set("limit", String(nextLimit));
const seeMoreHref = `/articles?${seeMoreParams.toString()}`;
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/NH%20DB%20Logo.svg" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.svg" />
    <title>Articles | NH Deserves Better</title>
    <meta
      name="description"
      content="Browse civic articles by bill, legislator, and represented town."
    />
  </head>

  <body>
    <TopNav />
    <main class="page" x-data="nhdbFuzzyFilter({ itemSelector: '.article-card[data-fuzzy-item]' })">
      <section class="hero">
        <p class="eyebrow">Articles</p>
        <h1>Read civic coverage by bill, legislator, or town.</h1>

        <form class="filters" action="/articles" method="get">
          <label>
            <span>Search</span>
            <input type="search" name="q" value={q} placeholder="housing, schools..." data-fuzzy-search />
          </label>
          <label>
            <span>Bill</span>
            <input type="text" name="bill" value={bill} placeholder="HB155" data-fuzzy-filter-field data-fuzzy-field="bill" />
          </label>
          <label>
            <span>Town</span>
            <input type="text" name="town" value={town} placeholder="Manchester" data-fuzzy-filter-field data-fuzzy-field="town" />
          </label>
          <button type="submit">Filter</button>
        </form>
      </section>

      {submitted && (
        <p class="status-message success">
          Thanks. The article was submitted for review and will appear after moderation.
        </p>
      )}
      {submitError && <p class="status-message error">{submitError}</p>}

      <details class="submit-disclosure">
        <summary>
          <span>
            <strong>Suggest coverage</strong>
            <small>Submit an article for review</small>
          </span>
          <b>+</b>
        </summary>

        <section class="panel submit-panel">
          <div class="submit-heading">
            <div>
              <p class="eyebrow">Suggest Coverage</p>
              <h2>Submit an article for review</h2>
            </div>
            <p>
              We will scan submitted coverage for mentioned bills, legislators,
              candidates, and communities before it is approved.
            </p>
          </div>

          <form class="article-submit-form" action="/api/articles/submit" method="post">
            <label class="url-field">
              <span>Article URL</span>
              <input type="url" name="url" placeholder="https://example.com/story" required />
            </label>
            <label>
              <span>Title</span>
              <input name="title" placeholder="Optional" />
            </label>
            <label>
              <span>Source</span>
              <input name="publisher" placeholder="Optional" />
            </label>
            <label class="summary-field">
              <span>Summary or note</span>
              <textarea name="summary" rows="3" placeholder="Optional context to help with review"></textarea>
            </label>
            <label>
              <span>Your name</span>
              <input name="submitterName" autocomplete="name" placeholder="Optional" />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="submitterEmail" autocomplete="email" placeholder="Used for moderation only" />
            </label>
            <button type="submit">Submit Article</button>
          </form>
        </section>
      </details>

      {error ? (
        <p class="status-message">{error}</p>
      ) : (
        <section class="panel">
          <div class="results-heading">
            <h2>Recent Articles <span class="inline-count">(<span data-fuzzy-count>{articles.length}</span>)</span></h2>
            {(q || bill || town) && <a href="/articles">Clear filters</a>}
          </div>
          <ArticleList articles={articles} />
          <p class="status-message" data-fuzzy-empty hidden>No articles matched those filters.</p>
          {hasMoreArticles && (
            <div class="see-more-row">
              <a class="see-more-button" href={seeMoreHref}>See more articles</a>
            </div>
          )}
        </section>
      )}
    </main>
    <SiteFooter />
  </body>
</html>

<style>
  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    margin-bottom: 32px;
    padding: 32px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.15rem, 5.25vw, 4rem);
    line-height: 0.95;
    margin: 0 0 24px;
    max-width: 940px;
  }

  .filters {
    align-items: end;
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(220px, 1.4fr) minmax(160px, 0.8fr) minmax(160px, 0.8fr) auto;
  }

  label {
    display: grid;
    gap: 6px;
  }

  label span {
    color: #6b7280;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  input,
  button {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    box-sizing: border-box;
    font: inherit;
    font-weight: 800;
    min-height: 48px;
    padding: 10px 12px;
  }

  button {
    background: #1f2933;
    color: white;
    cursor: pointer;
  }

  .panel,
  .status-message {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    box-shadow: none;
    padding: 20px;
  }

  .status-message {
    margin: 0 0 18px;
  }

  .status-message.success {
    border-color: #15803d;
    box-shadow: none;
  }

  .status-message.error {
    border-color: #991b1b;
    box-shadow: none;
  }

  .submit-panel {
    border-top: 0;
    margin-bottom: 20px;
    margin-top: 0;
  }

  .submit-disclosure {
    margin: 32px 0 20px;
  }

  .submit-disclosure summary {
    align-items: center;
    background: #f8fafc;
    border: 1px solid #9ca3af;
    border-radius: 8px;
    color: #1f2933;
    cursor: pointer;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    list-style: none;
    padding: 12px 14px;
  }

  .submit-disclosure summary::-webkit-details-marker {
    display: none;
  }

  .submit-disclosure summary span {
    display: grid;
    gap: 2px;
  }

  .submit-disclosure summary strong {
    font-size: 0.95rem;
    line-height: 1.2;
  }

  .submit-disclosure summary small {
    color: #6b7280;
    font-size: 0.8rem;
    font-weight: 800;
    line-height: 1.25;
  }

  .submit-disclosure summary b {
    align-items: center;
    background: #1f2933;
    border-radius: 999px;
    color: #ffffff;
    display: inline-flex;
    flex: 0 0 auto;
    font-size: 1rem;
    height: 26px;
    justify-content: center;
    line-height: 1;
    width: 26px;
  }

  .submit-disclosure[open] summary {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  .submit-disclosure[open] summary b {
    transform: rotate(45deg);
  }

  .submit-disclosure[open] .submit-panel {
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    box-shadow: none;
  }

  .submit-heading {
    align-items: end;
    display: grid;
    gap: 16px;
    grid-template-columns: minmax(0, 0.48fr) minmax(0, 1fr);
    margin-bottom: 16px;
  }

  .submit-heading h2 {
    font-size: 1.45rem;
    margin: 0;
  }

  .submit-heading p:not(.eyebrow) {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 0;
  }

  .article-submit-form {
    align-items: end;
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(220px, 1.4fr) minmax(160px, 0.8fr) minmax(140px, 0.7fr);
  }

  .url-field,
  .summary-field {
    grid-column: span 3;
  }

  textarea {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    box-sizing: border-box;
    font: inherit;
    font-weight: 800;
    letter-spacing: 0;
    padding: 10px 12px;
    resize: vertical;
    text-transform: none;
    width: 100%;
  }

  .results-heading {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .results-heading h2 {
    font-size: 1.6rem;
    margin: 0;
  }

  .see-more-row {
    display: flex;
    justify-content: center;
    margin-top: 22px;
  }

  .see-more-button {
    background: #1f2933;
    border-radius: 999px;
    color: white;
    display: inline-flex;
    font-weight: 900;
    padding: 12px 18px;
    text-decoration: none;
  }

  .see-more-button:hover {
    background: #dc4d09;
  }

  @media (max-width: 860px) {
    .filters,
    .article-submit-form,
    .submit-heading {
      grid-template-columns: 1fr;
    }

    .url-field,
    .summary-field {
      grid-column: auto;
    }
  }
</style>
