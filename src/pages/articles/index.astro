---
export const prerender = false;

import ArticleList from "../../components/ArticleList.astro";
import TopNav from "../../components/TopNav.astro";
import { getArticles } from "../../lib/articlesApi";

const q = Astro.url.searchParams.get("q")?.trim() || "";
const bill = Astro.url.searchParams.get("bill")?.trim() || "";
const town = Astro.url.searchParams.get("town")?.trim() || "";
const personid = Astro.url.searchParams.get("personid")?.trim() || "";

let articles = [];
let meta = {};
let error = "";

try {
  const data = await getArticles({
    q,
    bill,
    town,
    personid,
    include: "relations",
    limit: 50,
  });
  articles = data.articles || [];
  meta = data.meta || {};
} catch (loadError) {
  error = loadError?.message || "Unable to load articles.";
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>Articles | NH Deserves Better</title>
    <meta
      name="description"
      content="Browse civic articles by bill, legislator, and represented town."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Articles</p>
        <h1>Read civic coverage by bill, legislator, or town.</h1>

        <form class="filters" action="/articles" method="get">
          <label>
            <span>Search</span>
            <input type="search" name="q" value={q} placeholder="housing, schools..." />
          </label>
          <label>
            <span>Bill</span>
            <input type="text" name="bill" value={bill} placeholder="HB155" />
          </label>
          <label>
            <span>Town</span>
            <input type="text" name="town" value={town} placeholder="Manchester" />
          </label>
          <label>
            <span>Person ID</span>
            <input type="number" name="personid" value={personid} placeholder="11206" />
          </label>
          <button type="submit">Filter</button>
        </form>
      </section>

      {error ? (
        <p class="status-message">{error}</p>
      ) : (
        <section class="panel">
          <div class="results-heading">
            <h2>{meta.count ?? articles.length} Articles</h2>
            {(q || bill || town || personid) && <a href="/articles">Clear filters</a>}
          </div>
          <ArticleList articles={articles} />
        </section>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.6rem, 7vw, 5.25rem);
    line-height: 0.95;
    margin: 0 0 24px;
    max-width: 940px;
  }

  .filters {
    align-items: end;
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(180px, 1fr) 120px 160px 140px auto;
  }

  label {
    display: grid;
    gap: 6px;
  }

  label span {
    color: #6b7280;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  input,
  button {
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-sizing: border-box;
    font: inherit;
    font-weight: 800;
    min-height: 48px;
    padding: 10px 12px;
  }

  button {
    background: #1f2933;
    color: white;
    cursor: pointer;
  }

  .panel,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 20px;
  }

  .results-heading {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .results-heading h2 {
    font-size: 1.6rem;
    margin: 0;
  }

  @media (max-width: 860px) {
    .filters {
      grid-template-columns: 1fr;
    }
  }
</style>
