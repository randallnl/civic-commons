---
export const prerender = false;

import TopNav from "../../components/TopNav.astro";
import profileIcon from "../../assets/profile icon.png";
import { enrichArticlesWithPreviews } from "../../lib/articlePreviews";
import { currentAdminSession } from "../../lib/adminAuth";
import {
  articlePublishDate,
  articleSourceName,
  getArticle,
} from "../../lib/articlesApi";
import { billDetailPath, getBills } from "../../lib/billsApi";
import {
  candidatePath,
} from "../../lib/candidatesApi";
import { cleanText, joinClean } from "../../lib/text";
import { getPeopleLinkOptions } from "../../lib/unifiedPeople";
import { profilePhotoUrl } from "../../lib/photos";

const { id } = Astro.params;

let article = null;
let error = "";
const adminSession = await currentAdminSession(Astro.request);
const message = Astro.url.searchParams.get("message") || "";
const actionError = Astro.url.searchParams.get("error") || "";
let billOptions = [];
let peopleOptions = [];

try {
  const data = await getArticle(id);
  [article] = await enrichArticlesWithPreviews([data.article], { limit: 1 });
} catch (loadError) {
  error = loadError?.message || "Unable to load article.";
}

if (!article && !error) {
  return Astro.redirect("/404");
}

if (adminSession) {
  try {
    const [billData, peopleData] = await Promise.all([
      getBills({ limit: 300 }),
      getPeopleLinkOptions({ limit: 900 }),
    ]);

    billOptions = billData.bills || [];
    peopleOptions = peopleData || [];
  } catch (optionError) {
    console.error(optionError?.message || "Unable to load article link options.");
  }
}

const title = cleanText(article?.preview?.title || article?.title || "Article");
const description = cleanText(article?.preview?.description || article?.summary || "");
const source = article ? articleSourceName(article) : "";
const published = article ? articlePublishDate(article) : "";

function legislatorName(person = {}) {
  return cleanText(person.matched_name || person.legislator_name_raw || person.name || "");
}

function legislatorPath(person = {}) {
  const key = person.personid || person.employeeno || legislatorName(person);
  return `/people/${encodeURIComponent(String(key))}`;
}

function candidateLabel(candidate = {}) {
  return cleanText(candidate.name || candidate.candidate_name_raw || "");
}

function candidateProfilePath(candidate = {}) {
  if (candidate.slug) return `/candidates/${encodeURIComponent(candidate.slug)}`;
  return candidatePath({
    filerEntityNumber: candidate.filer_entity_number,
    candidateFirstName: candidate.candidate_first_name,
    candidateLastName: candidate.candidate_last_name,
  });
}

function legislatorMeta(person = {}) {
  return joinClean([person.party, person.chamber]);
}

function legislatorDistrict(person = {}) {
  const district = person.district || person.raw_district || "";
  if (!district) return "";
  const chamber = String(person.chamber || "").toLowerCase();
  if (chamber === "senate") return `NH Senate District ${district}`;
  if (chamber === "house") return `NH House District ${district}`;
  return `District ${district}`;
}

function candidateMeta(candidate = {}) {
  return joinClean([
    candidate.office,
    candidate.county,
    candidate.district && `District ${candidate.district}`,
  ]);
}

function candidateParty(candidate = {}) {
  return cleanText(candidate.politicalParty || candidate.political_party || "");
}

function candidatePhoto(candidate = {}) {
  return profilePhotoUrl(candidate.photoUrl || candidate.photo_url || candidate.photo);
}

function legislatorPhoto(person = {}) {
  return profilePhotoUrl(person.photo || person.photo_url);
}

function townPath(town = {}) {
  const townName = town.town || town.name || town;
  return `/communities/towns/${encodeURIComponent(townName)}`;
}

function billOptionValue(bill = {}) {
  return bill.condensedbillno || bill.bill_number || "";
}

function billOptionLabel(bill = {}) {
  return [
    billOptionValue(bill),
    cleanText(bill.name || bill.title || bill.description || ""),
    bill.sessionyear || bill.year,
  ].filter(Boolean).join(" - ");
}

---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>{title} | NH Deserves Better</title>
    <meta name="description" content={description || "Civic article details and related New Hampshire entities."} />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/articles">Back to articles</a>

      {error ? (
        <p class="status-message">{error}</p>
      ) : (
        <>
          {message && <p class="status-message success">{message}</p>}
          {actionError && <p class="status-message error">{actionError}</p>}

          <section class="article-hero">
            <div class="article-copy">
              <p class="eyebrow">Article Details</p>
              <h1>{title}</h1>
              <div class="article-meta">
                {source && <span>Source: {source}</span>}
                {published && <span>Published: {published}</span>}
                {article.resource_type && <span>{cleanText(article.resource_type)}</span>}
              </div>
              {description && <p class="lede">{description}</p>}
              {article.url && <a class="primary-link" href={article.url}>Read original article</a>}
            </div>

            {article.preview?.imageUrl && (
              <img class="preview-image" src={article.preview.imageUrl} alt="" loading="lazy" />
            )}
          </section>

          <section class="detail-grid">
            <section class="panel">
              <div class="section-heading">
                <p class="eyebrow">Mentioned Bills</p>
                <h2>Bills</h2>
              </div>
              {article.bills?.length ? (
                <div class="relation-list">
                  {article.bills.map((bill) => (
                    <a href={billDetailPath(bill.condensedbillno, bill.sessionyear)}>
                      <strong>{bill.condensedbillno}</strong>
                      {bill.description && <span>{cleanText(bill.description)}</span>}
                    </a>
                  ))}
                </div>
              ) : (
                <p class="empty">No bill mentions are linked yet.</p>
              )}
            </section>

            <section class="panel">
              <div class="section-heading">
                <p class="eyebrow">Mentioned People</p>
                <h2>Legislators</h2>
              </div>
              {article.legislators?.length ? (
                <div class="person-relation-list">
                  {article.legislators.map((person) => {
                    const photoUrl = legislatorPhoto(person);

                    return (
                      <a class="person-relation-card" href={legislatorPath(person)}>
                        <img
                          class:list={[!photoUrl && "profile-icon"]}
                          src={photoUrl || profileIcon.src}
                          alt={photoUrl ? `Photo of ${legislatorName(person)}` : ""}
                          loading="lazy"
                        />
                        <div>
                          <strong>{legislatorName(person)}</strong>
                          <span>{legislatorMeta(person)}</span>
                          {legislatorDistrict(person) && <small>{legislatorDistrict(person)}</small>}
                        </div>
                      </a>
                    );
                  })}
                </div>
              ) : (
                <p class="empty">No legislator mentions are linked yet.</p>
              )}
            </section>

            <section class="panel">
              <div class="section-heading">
                <p class="eyebrow">Mentioned Candidates</p>
                <h2>Candidates</h2>
              </div>
              {article.candidates?.length ? (
                <div class="person-relation-list">
                  {article.candidates.map((candidate) => {
                    const photoUrl = candidatePhoto(candidate);

                    return (
                      <a class="person-relation-card" href={candidateProfilePath(candidate)}>
                        <img
                          class:list={[!photoUrl && "profile-icon"]}
                          src={photoUrl || profileIcon.src}
                          alt={photoUrl ? `Photo of ${candidateLabel(candidate)}` : ""}
                          loading="lazy"
                        />
                        <div>
                          <strong>{candidateLabel(candidate)}</strong>
                          <span>{candidateMeta(candidate)}</span>
                          {candidateParty(candidate) && <small>{candidateParty(candidate)}</small>}
                        </div>
                      </a>
                    );
                  })}
                </div>
              ) : (
                <p class="empty">No candidate mentions are linked yet.</p>
              )}
            </section>

            <section class="panel">
              <div class="section-heading">
                <p class="eyebrow">Community</p>
                <h2>Towns and Topics</h2>
              </div>
              <div class="chip-list">
                {(article.towns || []).map((town) => (
                  <a href={townPath(town)}>{cleanText(town.town || town.name || town)}</a>
                ))}
                {(article.issueAreas || []).map((issue) => (
                  <span>{cleanText(issue.issue_area || issue.name)}</span>
                ))}
                {(article.impactTypes || []).map((impact) => (
                  <span>{cleanText(impact.impact_type || impact.name)}</span>
                ))}
              </div>
              {!(article.towns?.length || article.issueAreas?.length || article.impactTypes?.length) && (
                <p class="empty">No community or topic links are attached yet.</p>
              )}
            </section>
          </section>

          {adminSession && (
            <section class="panel admin-link-panel">
              <div class="section-heading">
                <p class="eyebrow">Admin</p>
                <h2>Add article links</h2>
                <p>
                  Add comma-separated bills or people to this article. Start
                  typing to choose from the dropdown options, or paste known
                  IDs directly.
                </p>
              </div>

              <form class="admin-link-form" action="/api/admin/article-links" method="post">
                <input type="hidden" name="articleId" value={article.article_id || article.articleId} />
                <input type="hidden" name="redirectTo" value={Astro.url.pathname} />

                <label>
                  Bills
                  <input name="bills" list="article-bill-options" placeholder="HB155, SB2" />
                  <small class="field-help">Use bill codes from the dropdown; comma-separate multiple bills.</small>
                </label>
                <label>
                  People
                  <input name="people" list="article-people-options" placeholder="person id, name, filer number, or GC id" />
                  <small class="field-help">Use one field for legislators and candidates; comma-separate multiple people.</small>
                </label>

                <datalist id="article-bill-options">
                  {billOptions.map((bill) => (
                    <option value={billOptionValue(bill)} label={billOptionLabel(bill)} />
                  ))}
                </datalist>

                <datalist id="article-people-options">
                  {peopleOptions.map((person) => (
                    <option value={person.value} label={person.label} />
                  ))}
                </datalist>

                <button type="submit">Add Links</button>
              </form>
            </section>
          )}
        </>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 850;
  }

  .article-hero {
    align-items: center;
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(1.85rem, 3.8vw, 3.35rem);
    letter-spacing: 0;
    line-height: 1.06;
    margin: 0;
  }

  h2 {
    font-size: 1.55rem;
    margin: 0;
  }

  .article-meta,
  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .article-meta span,
  .chip-list a,
  .chip-list span {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.8rem;
    font-weight: 900;
    padding: 6px 9px;
    text-decoration: none;
  }

  .lede {
    color: #4b5563;
    font-size: 1.08rem;
    font-weight: 750;
    line-height: 1.55;
    margin: 20px 0 0;
  }

  .primary-link {
    background: #1f2933;
    border-radius: 999px;
    color: #ffffff;
    display: inline-flex;
    margin-top: 22px;
    padding: 12px 16px;
    text-decoration: none;
  }

  .preview-image {
    aspect-ratio: 16 / 10;
    background: white;
    border: 2px solid #1f2933;
    border-radius: 10px;
    box-shadow: 5px 5px 0 #1f2933;
    object-fit: cover;
    width: 100%;
  }

  .detail-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .panel,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 10px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 20px;
  }

  .section-heading {
    margin-bottom: 14px;
  }

  .section-heading p:not(.eyebrow) {
    color: #4b5563;
    font-weight: 750;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  .admin-link-panel {
    margin-top: 18px;
  }

  .admin-link-form {
    align-items: end;
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(180px, 0.7fr) minmax(260px, 1.3fr) auto;
  }

  .admin-link-form label {
    color: #374151;
    display: grid;
    font-size: 0.78rem;
    font-weight: 900;
    gap: 7px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .admin-link-form input,
  .admin-link-form select {
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    box-sizing: border-box;
    color: #1f2933;
    font: inherit;
    letter-spacing: 0;
    min-height: 46px;
    padding: 11px 12px;
    text-transform: none;
    width: 100%;
  }

  .field-help {
    color: #6b7280;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.35;
    text-transform: none;
  }

  .admin-link-form button {
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    cursor: pointer;
    font: inherit;
    font-weight: 900;
    min-height: 46px;
    padding: 11px 15px;
  }

  .relation-list {
    display: grid;
    gap: 10px;
  }

  .person-relation-list {
    display: grid;
    gap: 12px;
  }

  .relation-list a {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    display: grid;
    gap: 4px;
    padding: 12px;
    text-decoration: none;
  }

  .person-relation-card {
    align-items: stretch;
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    color: inherit;
    display: grid;
    gap: 12px;
    grid-template-columns: 74px minmax(0, 1fr);
    padding: 10px;
    text-decoration: none;
  }

  .person-relation-card:hover strong {
    text-decoration: underline;
  }

  .person-relation-card img {
    aspect-ratio: 4 / 5;
    background: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .person-relation-card img.profile-icon {
    object-fit: cover;
  }

  .person-relation-card > div {
    align-content: center;
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .person-relation-card strong {
    color: #1f2933;
    font-size: 1rem;
    line-height: 1.2;
  }

  .relation-list span,
  .person-relation-card span,
  .person-relation-card small,
  .empty {
    color: #4b5563;
    font-weight: 750;
    line-height: 1.45;
  }

  .person-relation-card span {
    font-size: 0.88rem;
  }

  .person-relation-card small {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
  }

  .empty {
    margin: 0;
  }

  .status-message {
    margin-bottom: 18px;
  }

  .status-message.error {
    background: #fee2e2;
    color: #7f1d1d;
  }

  .status-message.success {
    background: #dcfce7;
    color: #14532d;
  }

  @media (max-width: 820px) {
    .article-hero,
    .detail-grid,
    .admin-link-form {
      grid-template-columns: 1fr;
    }
  }
</style>
