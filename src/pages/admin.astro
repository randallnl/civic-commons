            <form class="stack-form organization-admin-form" action="/api/admin/organizations" method="post">
              <input type="hidden" name="action" value="save" />
              <input type="hidden" name="redirectTo" value="/admin" />

              <div class="organization-toolbar">
                <label>
                  Load Existing Organization
                  <input
                    id="organizationAdminSearch"
                    list="organizationAdminOptions"
                    placeholder="Start typing a slug or organization name"
                    autocomplete="off"
                  />
                </label>
                <a id="organizationAdminProfileLink" class="secondary-link" href="/organizations">Open profile</a>
              </div>

              <div class="form-grid two">
                <label>
                  Name
                  <input id="organizationAdminName" name="name" placeholder="Organization name" required />
                </label>
                <label>
                  Slug
                  <input id="organizationAdminSlug" name="slug" list="organizationAdminOptions" placeholder="existing-or-new-slug" />
                </label>
