          </section>

          <section id="database-tools" class="panel caution-panel">
            <div class="panel-heading">
              <p class="eyebrow">D1 Database</p>
              <h2>Run a data update</h2>
              <p>
                Use parameterized SQL for updates when possible. Parameters must
                be a JSON array, like <code>["HB699", 2025]</code>.
              </p>
            </div>
            <details class="danger-disclosure">
              <summary>
                <span>Open SQL runner</span>
                <strong>Advanced</strong>
              </summary>
            <form class="stack-form" action="/api/admin/sql" method="post">
              <label for="sql">SQL</label>
              <textarea
                id="sql"
                name="sql"
                rows="8"
                placeholder="UPDATE bills SET summary = ? WHERE condensedbillno = ?"
                required
              ></textarea>

              <label for="params">Parameters JSON <span>Optional</span></label>
              <textarea
                id="params"
                name="params"
                rows="3"
                placeholder='["New summary", "HB699"]'
              ></textarea>

              <button type="submit">Run SQL</button>
            </form>
            </details>
          </section>

          <section id="asset-upload" class="panel">
            <div class="panel-heading">
              <p class="eyebrow">R2 Storage</p>
              <h2>Upload an image</h2>
              <p>
                Upload legislator and candidate photos, or organization logos.
                Organization logos go to the organization-assets R2 bucket and
                update the organization profile logo field.
              </p>
            </div>
            <form class="stack-form" action="/api/admin/upload" method="post" enctype="multipart/form-data">
              <label for="entityType">Update profile <span>Optional</span></label>
              <select id="entityType" name="entityType">
                <option value="">Just upload to R2</option>
                <option value="representative">Legislator</option>
                <option value="candidate">Candidate</option>
                <option value="organization-logo">Organization logo</option>
              </select>

              <label for="entityKey">Profile identifier <span>Optional</span></label>
              <input
                id="entityKey"
                name="entityKey"
                type="text"
                placeholder="personid, filer number, organization slug, or organization name"
              />

              <label for="key">R2 key</label>
              <input id="key" name="key" type="text" placeholder="organizations/logos/example-logo.png" />

              <label for="file">Image file</label>
              <input id="file" name="file" type="file" accept="image/*" required />

              <button type="submit">Upload image</button>
            </form>

            {imageUrl && (
              <p class="asset-link">
                Uploaded asset:
                <a href={imageUrl}>{imageUrl}</a>
              </p>
            )}
          </section>
        </div>
      )}
    </main>
    <script define:vars={{ organizationAdminData, candidateEndorsementOptions, billCommentOptions, billAdminData }}>
      const profileSearch = document.getElementById("gapProfileSearch");
      const profileValue = document.getElementById("gapProfileValue");
      const profileOptions = Array.from(
        document.querySelectorAll("#gapProfileOptions option"),
      );
      const profileOptionMap = new Map(
        profileOptions.map((option) => [
          option.value,
          option.dataset.profileValue || "",
        ]),
      );

      function syncProfileFilterValue() {
        if (!profileSearch || !profileValue) return;
        profileValue.value = profileOptionMap.get(profileSearch.value) || "";
      }

      profileSearch?.addEventListener("input", syncProfileFilterValue);
      profileSearch?.form?.addEventListener("submit", syncProfileFilterValue);

      const billAdminSelect = document.getElementById("billAdminSelect");
      const billAdminSearch = document.getElementById("billAdminSearch");
      const billAdminCode = document.getElementById("billAdminCode");
      const billAdminYear = document.getElementById("billAdminYear");
      const billAdminTitle = document.getElementById("billAdminTitle");
      const billAdminSummary = document.getElementById("billAdminSummary");
      const billAdminDescription = document.getElementById("billAdminDescription");
      const billAdminPreviewLink = document.getElementById("billAdminPreviewLink");
      const billAdminMap = new Map();

      billAdminData.forEach((bill) => {
        billAdminMap.set(`${bill.year}:${bill.code}`, bill);
        billAdminMap.set(bill.label, bill);
        billAdminMap.set(bill.code, bill);
        billAdminMap.set(`${bill.code} ${bill.year}`, bill);
      });

      function hydrateBillAdminForm(value, { syncSearch = false, syncSelect = false } = {}) {
        const rawValue = value || "";
        const code = normalizeBillInput(rawValue);
        const bill = billAdminMap.get(rawValue) || billAdminMap.get(code);
        if (!bill) {
          if (billAdminCode && code) billAdminCode.value = code;
          return;
        }
        const billKey = `${bill.year}:${bill.code}`;
        if (syncSearch && billAdminSearch) billAdminSearch.value = bill.label || bill.code || "";
        if (syncSelect && billAdminSelect) billAdminSelect.value = billKey;
        if (billAdminCode) billAdminCode.value = bill.code || "";
        if (billAdminYear) billAdminYear.value = bill.year || "2026";
        if (billAdminTitle) billAdminTitle.value = bill.title || "";
        if (billAdminSummary) billAdminSummary.value = bill.summary || "";
        if (billAdminDescription) billAdminDescription.value = bill.description || "";
        if (billAdminPreviewLink) {
          billAdminPreviewLink.href = bill.href || `/bills/${bill.code}?year=${bill.year || 2026}`;
          billAdminPreviewLink.textContent = `Open ${bill.code}`;
        }
      }

      billAdminSelect?.addEventListener("change", () => {
        hydrateBillAdminForm(billAdminSelect.value, { syncSearch: true });
      });
      billAdminSearch?.addEventListener("change", () => {
        hydrateBillAdminForm(billAdminSearch.value, { syncSelect: true });
      });
      billAdminSearch?.addEventListener("input", () => {
        hydrateBillAdminForm(billAdminSearch.value);
      });

      const reviewForms = document.querySelectorAll("[data-profile-review-form]");

      reviewForms.forEach((form) => {
        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          const button = form.querySelector("button[type='submit']");
          const row = form.closest("[data-profile-gap-row]");
          const originalText = button?.textContent || "";

          if (button) {
            button.disabled = true;
            button.textContent = "Saving...";
          }

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: new FormData(form),
              credentials: "same-origin",
              redirect: "manual",
            });

            if (!response.ok && response.type !== "opaqueredirect") {
              throw new Error("Unable to mark reviewed.");
            }

            row?.classList.add("is-reviewed");
            window.setTimeout(() => row?.remove(), 180);
          } catch (error) {
            if (button) {
              button.disabled = false;
              button.textContent = originalText;
            }
            window.alert(error?.message || "Unable to mark reviewed.");
          }
        });
      });

      const organizationSearch = document.getElementById("organizationAdminSearch");
      const organizationProfileLink = document.getElementById("organizationAdminProfileLink");
      const organizationForm = document.querySelector(".organization-admin-form");
      const organizationLogoEntityKey = document.getElementById("organizationLogoEntityKey");
      const organizationLogoKey = document.getElementById("organizationLogoKey");
      const organizationCommentSlug = document.getElementById("organizationCommentSlug");
      const organizationCommentName = document.getElementById("organizationCommentName");
      const organizationCommentBillSearch = document.getElementById("organizationCommentBillSearch");
      const organizationCommentAddBill = document.getElementById("organizationCommentAddBill");
      const organizationCommentBillCodes = document.getElementById("organizationCommentBillCodes");
      const organizationCommentBillSelections = document.getElementById("organizationCommentBillSelections");
      const organizationCommentSelectedBills = document.getElementById("organizationCommentSelectedBills");
      const organizationMap = new Map();

      organizationAdminData.forEach((organization) => {
        organizationMap.set(organization.slug, organization);
        organizationMap.set(organization.name, organization);
      });

      function setOrganizationField(name, value) {
        const field = organizationForm?.elements?.[name];
        if (!field) return;
        if (field.type === "checkbox") {
          field.checked = Boolean(value);
          return;
        }
        field.value = value || "";
      }

      function hydrateOrganizationForm() {
        if (!organizationSearch || !organizationForm) return;
        const organization = organizationMap.get(organizationSearch.value);
        if (!organization) return;

        [
          "name",
          "slug",
          "type",
          "issueArea",
          "shortDescription",
          "mission",
          "website",
          "email",
          "phone",
          "city",
          "town",
          "state",
          "serviceArea",
          "logoUrl",
          "bannerImageUrl",
          "facebook",
          "instagram",
          "bluesky",
          "foundedYear",
          "notes",
        ].forEach((fieldName) => setOrganizationField(fieldName, organization[fieldName]));
        setOrganizationField("approved", organization.approved);

        if (organizationProfileLink) {
          organizationProfileLink.href = organization.profilePath || "/organizations";
          organizationProfileLink.textContent = "Open selected profile";
        }

        hydrateOrganizationLogoUpload(organization);
        hydrateOrganizationCommentForm(organization);
      }

      function hydrateOrganizationLogoUpload(organization) {
        if (!organization) return;
        const organizationKey = organization.slug || organization.name || "";
        if (organizationLogoEntityKey) organizationLogoEntityKey.value = organizationKey;
        if (organizationLogoKey && !organizationLogoKey.value) {
          organizationLogoKey.placeholder = `organizations/logos/${organizationKey || "organization"}-logo.png`;
        }
      }

      function hydrateOrganizationCommentForm(organization) {
        if (!organization) return;
        if (organizationCommentSlug) organizationCommentSlug.value = organization.slug || "";
        if (organizationCommentName) organizationCommentName.value = organization.name || "";
      }

      function hydrateOrganizationCommentFromSlug() {
        const organization = organizationMap.get(organizationCommentSlug?.value || "");
        if (!organization) return;
        hydrateOrganizationCommentForm(organization);
      }

      function syncOrganizationLogoUploadFromFields() {
        const slugField = organizationForm?.elements?.slug;
        const nameField = organizationForm?.elements?.name;
        const organizationKey = slugField?.value || nameField?.value || "";
        if (organizationLogoEntityKey && !organizationLogoEntityKey.value) {
          organizationLogoEntityKey.value = organizationKey;
        }
        if (organizationLogoKey) {
          organizationLogoKey.placeholder = `organizations/logos/${organizationKey || "organization"}-logo.png`;
        }
        if (organizationCommentSlug && !organizationCommentSlug.value) {
          organizationCommentSlug.value = slugField?.value || "";
        }
        if (organizationCommentName && !organizationCommentName.value) {
          organizationCommentName.value = nameField?.value || "";
        }
      }

      organizationSearch?.addEventListener("change", hydrateOrganizationForm);
      organizationSearch?.addEventListener("input", hydrateOrganizationForm);
      organizationCommentSlug?.addEventListener("change", hydrateOrganizationCommentFromSlug);
      organizationCommentSlug?.addEventListener("input", hydrateOrganizationCommentFromSlug);
      organizationForm?.elements?.slug?.addEventListener("input", syncOrganizationLogoUploadFromFields);
      organizationForm?.elements?.name?.addEventListener("input", syncOrganizationLogoUploadFromFields);

      const billOptionMap = new Map();
      const selectedBills = [];

      billCommentOptions.forEach((bill) => {
        billOptionMap.set(bill.label, bill);
        billOptionMap.set(bill.code, bill);
      });

      function normalizeBillInput(value = "") {
        const match = String(value || "").toUpperCase().match(/\b(?:HB|SB|CACR|HCR|HR|SR)\s*\d+[A-Z]?\b/);
        return (match ? match[0] : String(value || ""))
          .toUpperCase()
          .replace(/\s+/g, "");
      }

      function syncSelectedBillsFromText() {
        const codes = String(organizationCommentBillCodes?.value || "")
          .split(/[,;|\n]/)
          .map(normalizeBillInput)
          .filter(Boolean);
        selectedBills.splice(0, selectedBills.length);
        codes.forEach((code) => {
          const option = billOptionMap.get(code) || { code, label: code };
          selectedBills.push({
            code,
            label: option.label || code,
            name: option.name || "",
          });
        });
        renderSelectedBills();
      }

      function addSelectedBillFromSearch() {
        const rawValue = organizationCommentBillSearch?.value || "";
        const option = billOptionMap.get(rawValue);
        const code = option?.code || normalizeBillInput(rawValue);
        if (!code || selectedBills.some((bill) => bill.code === code)) return;
        selectedBills.push({
          code,
          label: option?.label || code,
          name: option?.name || "",
        });
        if (organizationCommentBillSearch) organizationCommentBillSearch.value = "";
        renderSelectedBills();
      }

      function removeSelectedBill(code) {
        const index = selectedBills.findIndex((bill) => bill.code === code);
        if (index >= 0) selectedBills.splice(index, 1);
        renderSelectedBills();
      }

      function renderSelectedBills() {
        if (organizationCommentBillCodes) {
          organizationCommentBillCodes.value = selectedBills.map((bill) => bill.code).join(", ");
        }
        if (organizationCommentBillSelections) {
          organizationCommentBillSelections.value = JSON.stringify(selectedBills);
        }
        if (!organizationCommentSelectedBills) return;
        organizationCommentSelectedBills.innerHTML = "";
        selectedBills.forEach((bill) => {
          const chip = document.createElement("button");
          chip.type = "button";
          chip.className = "selected-bill-chip";
          chip.textContent = bill.name ? `${bill.code} - ${bill.name}` : bill.code;
          chip.addEventListener("click", () => removeSelectedBill(bill.code));
          organizationCommentSelectedBills.append(chip);
        });
      }

      organizationCommentAddBill?.addEventListener("click", addSelectedBillFromSearch);
      organizationCommentBillSearch?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          addSelectedBillFromSearch();
        }
      });
      organizationCommentBillCodes?.addEventListener("change", syncSelectedBillsFromText);
      organizationCommentBillCodes?.form?.addEventListener("submit", () => {
        if (!selectedBills.length) syncSelectedBillsFromText();
      });

      const endorsementOrganizationSearch = document.getElementById("endorsementOrganizationSearch");
      const endorsementOrganizationName = document.getElementById("endorsementOrganizationName");
      const endorsementOrganizationWebsite = document.getElementById("endorsementOrganizationWebsite");
      const endorsementOrganizationEmail = document.getElementById("endorsementOrganizationEmail");

      function hydrateEndorsementOrganization() {
        const organization = organizationMap.get(endorsementOrganizationSearch?.value || "");
        if (!organization) return;
        if (endorsementOrganizationName) endorsementOrganizationName.value = organization.name || "";
        if (endorsementOrganizationWebsite) endorsementOrganizationWebsite.value = organization.website || "";
        if (endorsementOrganizationEmail) endorsementOrganizationEmail.value = organization.email || "";
      }

      endorsementOrganizationSearch?.addEventListener("change", hydrateEndorsementOrganization);
      endorsementOrganizationSearch?.addEventListener("input", hydrateEndorsementOrganization);

      const endorsementCandidateSearch = document.getElementById("endorsementCandidateSearch");
      const endorsementCandidateFields = {
        slug: document.getElementById("endorsementCandidateSlug"),
        name: document.getElementById("endorsementCandidateName"),
        office: document.getElementById("endorsementCandidateOffice"),
        district: document.getElementById("endorsementCandidateDistrict"),
        electionYear: document.getElementById("endorsementCandidateElectionYear"),
      };
      const endorsementCandidateMap = new Map(
        candidateEndorsementOptions.map((option) => [option.value, option]),
      );

      function syncEndorsementCandidate() {
        const selected = endorsementCandidateMap.get(endorsementCandidateSearch?.value || "");
        endorsementCandidateFields.slug.value = selected?.slug || "";
        endorsementCandidateFields.name.value = selected?.name || "";
        endorsementCandidateFields.office.value = selected?.office || "";
        endorsementCandidateFields.district.value = selected?.district || "";
        endorsementCandidateFields.electionYear.value = selected?.electionYear || "2026";
      }

      endorsementCandidateSearch?.addEventListener("input", syncEndorsementCandidate);
      endorsementCandidateSearch?.form?.addEventListener("submit", syncEndorsementCandidate);
    </script>
  </body>
</html>

