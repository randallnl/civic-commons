            <form class="stack-form endorsement-admin-form" action="/api/admin/endorsements" method="post">
              <input type="hidden" name="action" value="save" />
              <input type="hidden" name="redirectTo" value="/admin#organizations-admin" />
              <input id="endorsementCandidateSlug" type="hidden" name="candidateSlug" />
              <input id="endorsementCandidateName" type="hidden" name="candidateName" />
              <input id="endorsementCandidateOffice" type="hidden" name="office" />
              <input id="endorsementCandidateDistrict" type="hidden" name="district" />
              <input id="endorsementCandidateElectionYear" type="hidden" name="electionYear" value="2026" />

              <div class="panel-heading compact-subheading">
                <p class="eyebrow">Endorsements</p>
