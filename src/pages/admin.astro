              <div class="form-grid two">
                <label>
                  Organization website
                  <input id="endorsementOrganizationWebsite" name="organizationWebsite" type="url" />
                </label>
                <label>
                  Organization email
                  <input id="endorsementOrganizationEmail" name="organizationEmail" type="email" />
                </label>
              </div>

              <label>
                Candidate
                <input
                  id="endorsementCandidateSearch"
                  list="endorsementCandidateOptions"
                  placeholder="Start typing a candidate name"
                  autocomplete="off"
                  required
                />
              </label>

              <div class="form-grid three">
                <label>
                  Position
                  <select name="position">
                    <option value="Endorsed">Endorsed</option>
                    <option value="Recommended">Recommended</option>
                    <option value="Opposed">Opposed</option>
                    <option value="Supported">Supported</option>
                  </select>
                </label>
                <label>
                  Date
                  <input name="date" type="date" />
