---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import { currentAdminSession } from "../lib/adminAuth";

const session = await currentAdminSession(Astro.request);
const sent = Astro.url.searchParams.get("sent") === "1";
const error = Astro.url.searchParams.get("error") || "";
const message = Astro.url.searchParams.get("message") || "";
const imageUrl = Astro.url.searchParams.get("imageUrl") || "";
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>Admin | NH Deserves Better</title>
    <meta name="robots" content="noindex" />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Admin</p>
        <h1>Update site data and assets.</h1>
        <p class="lede">
          Sign in with a magic link to run D1 updates and upload images to R2.
        </p>
      </section>

      {error && <p class="status-message error">{error}</p>}
      {message && <p class="status-message success">{message}</p>}
      {sent && (
        <p class="status-message success">
          Check your email for a login link. It expires in 15 minutes.
        </p>
      )}

      {!session ? (
        <form class="panel login-panel" action="/api/admin/request-login" method="post">
          <label for="email">Admin email</label>
          <input
            id="email"
            name="email"
            type="email"
            placeholder="you@example.com"
            autocomplete="email"
            required
          />
          <button type="submit">Send magic link</button>
        </form>
      ) : (
        <div class="admin-grid">
          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Session</p>
              <h2>Signed in</h2>
            </div>
            <p class="session-email">{session.email}</p>
            <form action="/api/admin/logout" method="post">
              <button type="submit" class="secondary">Log out</button>
            </form>
          </section>

          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">D1 Database</p>
              <h2>Run a data update</h2>
              <p>
                Use parameterized SQL for updates when possible. Parameters must
                be a JSON array, like <code>["HB699", 2025]</code>.
              </p>
            </div>
            <form class="stack-form" action="/api/admin/sql" method="post">
              <label for="sql">SQL</label>
              <textarea
                id="sql"
                name="sql"
                rows="8"
                placeholder="UPDATE bills SET summary = ? WHERE condensedbillno = ?"
                required
              ></textarea>

              <label for="params">Parameters JSON <span>Optional</span></label>
              <textarea
                id="params"
                name="params"
                rows="3"
                placeholder='["New summary", "HB699"]'
              ></textarea>

              <button type="submit">Run SQL</button>
            </form>
          </section>

          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">R2 Storage</p>
              <h2>Upload an image</h2>
              <p>
                Uploads go to the bound R2 bucket. Use a filename/key that the
                site can reference later.
              </p>
            </div>
            <form class="stack-form" action="/api/admin/upload" method="post" enctype="multipart/form-data">
              <label for="key">R2 key</label>
              <input id="key" name="key" type="text" placeholder="logos/example.png" required />

              <label for="file">Image file</label>
              <input id="file" name="file" type="file" accept="image/*" required />

              <button type="submit">Upload image</button>
            </form>

            {imageUrl && (
              <p class="asset-link">
                Uploaded asset:
                <a href={imageUrl}>{imageUrl}</a>
              </p>
            )}
          </section>
        </div>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 850;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0;
    max-width: 980px;
  }

  h2 {
    font-size: clamp(1.45rem, 3vw, 2.2rem);
    line-height: 1;
    margin: 0;
  }

  .lede,
  .panel-heading p,
  .asset-link,
  .session-email {
    color: #4b5563;
    font-weight: 750;
    line-height: 1.5;
  }

  .lede {
    font-size: clamp(1.12rem, 2.2vw, 1.35rem);
    margin: 22px 0 0;
    max-width: 760px;
  }

  .admin-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(260px, 0.36fr) minmax(0, 1fr);
  }

  .admin-grid .panel:nth-child(2),
  .admin-grid .panel:nth-child(3) {
    grid-column: 2;
  }

  .panel,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 16px;
    box-shadow: 5px 5px 0 #1f2933;
    padding: clamp(20px, 4vw, 28px);
  }

  .login-panel,
  .stack-form {
    display: grid;
    gap: 14px;
  }

  .panel-heading {
    margin-bottom: 18px;
  }

  label {
    font-size: 0.82rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  label span {
    color: #6b7280;
    font-size: 0.74rem;
    letter-spacing: 0;
    text-transform: none;
  }

  input,
  textarea {
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    box-sizing: border-box;
    color: #1f2933;
    font: inherit;
    padding: 13px 14px;
    width: 100%;
  }

  textarea {
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    resize: vertical;
  }

  button {
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    cursor: pointer;
    font: inherit;
    font-weight: 900;
    justify-self: start;
    padding: 13px 18px;
  }

  button.secondary {
    background: white;
    color: #1f2933;
  }

  .status-message {
    margin: 0 0 18px;
  }

  .status-message.error {
    background: #fee2e2;
    color: #7f1d1d;
  }

  .status-message.success {
    background: #dcfce7;
    color: #14532d;
  }

  code {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 2px 5px;
  }

  @media (max-width: 840px) {
    .admin-grid {
      grid-template-columns: 1fr;
    }

    .admin-grid .panel:nth-child(2),
    .admin-grid .panel:nth-child(3) {
      grid-column: auto;
    }
  }
</style>
