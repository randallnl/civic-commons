---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import { getBills, normalizeBillCodeForUrl } from "../lib/billsApi";
import { currentAdminSession } from "../lib/adminAuth";
import { getProfileGaps } from "../lib/adminProfileGaps";
import {
  articleSubmissionDate,
  getPendingArticleSubmissions,
} from "../lib/articleSubmissions";
import { communityUpdateDate, getPendingCommunityUpdates } from "../lib/communityUpdates";
import {
  getOrganizations,
  getPendingOrganizationEndorsements,
} from "../lib/organizationsApi";
import {
  candidateName,
  candidateSlug,
  getLegislativeCandidates,
} from "../lib/candidatesApi";
import { cleanText } from "../lib/text";
import { getPeopleLinkOptions } from "../lib/unifiedPeople";

const session = await currentAdminSession(Astro.request);
const sent = Astro.url.searchParams.get("sent") === "1";
const error = Astro.url.searchParams.get("error") || "";
const message = Astro.url.searchParams.get("message") || "";
const imageUrl = Astro.url.searchParams.get("imageUrl") || "";
const gapType = Astro.url.searchParams.get("gapType") || "all";
const gapMissing = Astro.url.searchParams.get("gapMissing") || "any";
const gapOffice = Astro.url.searchParams.get("gapOffice") || "";
const gapProfile = Astro.url.searchParams.get("gapProfile") || "";
const gapReview = Astro.url.searchParams.get("gapReview") || "needs-review";
const gapOfficeOptions = [
  { value: "", label: "All offices" },
  { value: "State Representative", label: "State Representative" },
  { value: "State Senate", label: "State Senate" },
];
const gapReviewOptions = [
  { value: "needs-review", label: "Hide recently reviewed" },
  { value: "all", label: "Include reviewed" },
  { value: "recent", label: "Recently reviewed only" },
];
let pendingCommunityUpdates = [];
let pendingArticleSubmissions = [];
let profileGaps = { results: [], counts: {} };
let gapProfileLabel = "";
let peopleOptions = [];
let organizations = [];
let organizationAdminData = [];
let pendingOrganizationEndorsements = [];
let candidateEndorsementOptions = [];
let billCommentOptions = [];
let billAdminData = [];

if (session) {
  try {
    pendingCommunityUpdates = await getPendingCommunityUpdates({ limit: 50 });
  } catch (error) {
    console.error(error?.message || "Unable to load pending community updates.");
  }

  try {
    pendingArticleSubmissions = await getPendingArticleSubmissions({ limit: 50 });
  } catch (error) {
    console.error(error?.message || "Unable to load pending article submissions.");
  }

  try {
    peopleOptions = await getPeopleLinkOptions({ limit: 900 });
  } catch (error) {
    console.error(error?.message || "Unable to load people link options.");
  }

  try {
    organizations = await getOrganizations({ includeUnapproved: true });
    organizationAdminData = organizations.map((organization) => ({
      name: organization.name || "",
      slug: organization.slug || "",
      type: organization.type || "",
      issueArea: organization.issueArea || "",
      shortDescription: organization.shortDescription || "",
      mission: organization.mission || "",
      website: organization.website || "",
      email: organization.email || "",
      phone: organization.phone || "",
      city: organization.city || "",
      town: organization.town || "",
      state: organization.state || "NH",
      serviceArea: organization.serviceArea || "",
      logoUrl: organization.logoUrl || "",
      bannerImageUrl: organization.bannerImageUrl || "",
      facebook: organization.facebook || "",
      instagram: organization.instagram || "",
      bluesky: organization.bluesky || "",
      foundedYear: organization.foundedYear || "",
      approved: Boolean(organization.approved),
      notes: organization.notes || "",
      profilePath: `/organizations/${organization.slug}`,
    }));
  } catch (error) {
    console.error(error?.message || "Unable to load organization admin options.");
  }

  try {
    pendingOrganizationEndorsements = await getPendingOrganizationEndorsements({ limit: 50 });
  } catch (error) {
    console.error(error?.message || "Unable to load pending organization endorsements.");
  }

  try {
    const candidates = await getLegislativeCandidates({ electionYear: 2026 });
    candidateEndorsementOptions = candidates
      .map((candidate) => {
        const slug = candidateSlug(candidate);
        const name = candidateName(candidate);
        const officeParts = [
          candidate.office,
          candidate.county,
          candidate.district ? `District ${candidate.district}` : "",
        ].filter(Boolean);
        const label = [name, officeParts.join(" - ")].filter(Boolean).join(" | ");

        return {
          label,
          value: label,
          name,
          slug,
          office: candidate.office || "",
          district: [candidate.county, candidate.district ? `District ${candidate.district}` : ""]
            .filter(Boolean)
            .join(", "),
          electionYear: String(candidate.electionYear || 2026),
        };
      });
  } catch (error) {
    console.error(error?.message || "Unable to load endorsement candidate options.");
  }

  try {
    const billData = await getBills({ year: 2026, limit: 1000 });
    billCommentOptions = (billData.bills || [])
      .map((bill) => {
        const code = normalizeBillCodeForUrl(bill.condensedbillno || bill.bill || bill.code || "");
        const title = cleanText(bill.name || bill.title || bill.summary || "");
        const label = [code, title].filter(Boolean).join(" | ");
        return {
          code,
          label: label || code,
          name: title,
          year: String(bill.sessionyear || bill.year || 2026),
        };
      })
      .filter((bill) => bill.code)
      .filter((bill, index, bills) =>
        bills.findIndex((item) => item.code === bill.code) === index,
      )
      .sort((a, b) => a.code.localeCompare(b.code, undefined, { numeric: true }));
    billAdminData = (billData.bills || [])
      .map((bill) => {
        const code = normalizeBillCodeForUrl(bill.condensedbillno || bill.bill || bill.code || "");
        const title = cleanText(bill.name || bill.title || bill.summary || "");
        const label = [code, title || bill.description].filter(Boolean).join(" | ");
        return {
          code,
          label: label || code,
          title,
          summary: cleanText(bill.summary || ""),
          description: cleanText(bill.description || ""),
          year: String(bill.sessionyear || bill.year || 2026),
          href: `/bills/${code}?year=${bill.sessionyear || bill.year || 2026}`,
        };
      })
      .filter((bill) => bill.code)
      .filter((bill, index, bills) =>
        bills.findIndex((item) => `${item.year}:${item.code}` === `${bill.year}:${bill.code}`) === index,
      )
      .sort((a, b) =>
        a.code.localeCompare(b.code, undefined, { numeric: true }) ||
        b.year.localeCompare(a.year),
      );
  } catch (error) {
    console.error(error?.message || "Unable to load bill comment options.");
  }

  try {
    profileGaps = await getProfileGaps({
      profileType: gapType,
      missing: gapMissing,
      office: gapOffice,
      profile: gapProfile,
      review: gapReview,
      limit: 100,
    });
  } catch (error) {
    console.error(error?.message || "Unable to load profile gaps.");
  }

  gapProfileLabel = (profileGaps.nameOptions || [])
    .find((option) => option.value === gapProfile)?.label || "";
}

function reviewDate(value = "") {
  if (!value) return "";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return "";
  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(date);
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>Admin | NH Deserves Better</title>
    <meta name="robots" content="noindex" />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Admin</p>
        <h1>Update site data and assets.</h1>
        <p class="lede">
          Sign in with a magic link to run D1 updates and upload images to R2.
        </p>
      </section>

      {error && <p class="status-message error">{error}</p>}
      {message && <p class="status-message success">{message}</p>}
      {sent && (
        <p class="status-message success">
          Check your email for a login link. It expires in 15 minutes.
        </p>
      )}

      {!session ? (
        <form class="panel login-panel" action="/api/admin/request-login" method="post">
          <label for="email">Admin email</label>
          <input
            id="email"
            name="email"
            type="email"
            placeholder="you@example.com"
            autocomplete="email"
            required
          />
          <button type="submit">Send magic link</button>
        </form>
      ) : (
        <div class="admin-grid">
          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Session</p>
              <h2>Signed in</h2>
            </div>
            <p class="session-email">{session.email}</p>
            <form action="/api/admin/logout" method="post">
              <button type="submit" class="secondary">Log out</button>
            </form>
          </section>

          <section class="panel admin-toc">
            <div class="panel-heading">
              <p class="eyebrow">Admin Tools</p>
              <h2>Work queue</h2>
              <p>Start with moderation and profile cleanup, then use the data tools when you need to change source records.</p>
            </div>

            <div class="admin-metrics">
              <a href="#community-updates">
                <span>Community updates</span>
                <strong>{pendingCommunityUpdates.length}</strong>
              </a>
              <a href="#article-submissions">
                <span>Submitted articles</span>
                <strong>{pendingArticleSubmissions.length}</strong>
              </a>
              <a href="#endorsement-submissions">
                <span>Endorsements</span>
                <strong>{pendingOrganizationEndorsements.length}</strong>
              </a>
              <a href="#profile-cleanup">
                <span>Profile cleanup</span>
                <strong>{profileGaps.counts.total || 0}</strong>
              </a>
              <a href="#organizations-admin">
                <span>Organizations</span>
                <strong>{organizations.length}</strong>
              </a>
            </div>

            <nav class="admin-links" aria-label="Admin sections">
              <a href="#profile-editing">Edit profiles</a>
              <a href="#bill-admin">Edit bills</a>
              <a href="#profile-cleanup">Profile cleanup</a>
              <a href="#community-updates">Community updates</a>
              <a href="#article-submissions">Submitted articles</a>
              <a href="#endorsement-submissions">Endorsements</a>
              <a href="#organizations-admin">Organizations</a>
              <a href="#asset-upload">Image uploads</a>
              <a href="#database-tools">D1 SQL</a>
            </nav>
          </section>

          <section id="profile-editing" class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Profiles</p>
              <h2>Edit candidates and legislators</h2>
              <p>
                Open a candidate or legislator profile while signed in. An admin
                editor appears on the page and saves updates directly to the
                source D1 tables used by the local API.
              </p>
            </div>
            <div class="profile-actions">
              <a href="/people">Find a legislator</a>
              <a href="/candidates">Find a candidate</a>
            </div>
          </section>

          <section id="bill-admin" class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Bills</p>
              <h2>Edit bill title and description</h2>
              <p>
                Save a readable bill title and summary for public bill previews
                and profiles. The latest action/source description field is
                optional; use it when the source description needs a correction.
              </p>
            </div>

            <datalist id="billAdminOptions">
              {billAdminData.map((bill) => (
                <option value={bill.label} />
              ))}
            </datalist>

            <form class="stack-form bill-admin-form" action="/api/admin/bills" method="post">
              <input type="hidden" name="redirectTo" value="/admin#bill-admin" />

              <label>
                Select existing bill
                <select id="billAdminSelect">
                  <option value="">Choose a bill to edit</option>
                  {billAdminData.map((bill) => (
                    <option value={`${bill.year}:${bill.code}`}>{bill.label}</option>
                  ))}
                </select>
              </label>

              <label>
                Or search bill
                <input
                  id="billAdminSearch"
                  list="billAdminOptions"
                  placeholder="Start typing HB155 or a bill title"
                  autocomplete="off"
                />
              </label>

              <div class="form-grid three">
                <label>
                  Bill code
                  <input id="billAdminCode" name="bill" placeholder="HB155" required />
                </label>
                <label>
                  Year
                  <input id="billAdminYear" name="sessionyear" type="number" value="2026" required />
                </label>
                <a id="billAdminPreviewLink" class="inline-action" href="/bills">Open bill</a>
              </div>

              <label>
                Public title
                <input
                  id="billAdminTitle"
                  name="title"
                  placeholder="HB155: Short public-facing title"
                />
              </label>

              <label>
                Public summary / description
                <textarea
                  id="billAdminSummary"
                  name="summary"
                  rows="5"
                  placeholder="Plain-language summary shown in previews and bill profiles."
                ></textarea>
              </label>

              <label>
                Latest action / source description <span>Optional</span>
                <textarea
                  id="billAdminDescription"
                  name="description"
                  rows="3"
                  placeholder="Use only when the D1 source description/latest action needs to be changed."
                ></textarea>
              </label>

              <button type="submit">Save Bill Text</button>
            </form>
          </section>

          <section id="profile-cleanup" class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Profile Cleanup</p>
              <h2>Missing profile info</h2>
              <p>
                Find candidates and legislators missing photos, emails, or
                websites. Legislator websites are not currently stored in the
                source D1 legislator table, so the website filter applies to
                candidates.
              </p>
            </div>

            <form class="gap-filters" action="/admin" method="get">
              <label>
                Profile type
                <select name="gapType">
                  <option value="all" selected={gapType === "all"}>All profiles</option>
                  <option value="representative" selected={gapType === "representative"}>Legislators</option>
                  <option value="candidate" selected={gapType === "candidate"}>Candidates</option>
                </select>
              </label>

              <label>
                Missing field
                <select name="gapMissing">
                  <option value="any" selected={gapMissing === "any"}>Any missing field</option>
                  <option value="photo" selected={gapMissing === "photo"}>Photo</option>
                  <option value="email" selected={gapMissing === "email"}>Email</option>
                  <option value="website" selected={gapMissing === "website"}>Website</option>
                </select>
              </label>

              <label>
                Office
                <select name="gapOffice">
                  {gapOfficeOptions.map((option) => (
                    <option value={option.value} selected={gapOffice === option.value}>
                      {option.label}
                    </option>
                  ))}
                </select>
              </label>

              <label>
                Review status
                <select name="gapReview">
                  {gapReviewOptions.map((option) => (
                    <option value={option.value} selected={gapReview === option.value}>
                      {option.label}
                    </option>
                  ))}
                </select>
              </label>

              <label>
                Name
                <input
                  id="gapProfileSearch"
                  name="gapProfileSearch"
                  list="gapProfileOptions"
                  value={cleanText(gapProfileLabel)}
                  placeholder="Start typing a name"
                  autocomplete="off"
                />
                <input id="gapProfileValue" type="hidden" name="gapProfile" value={gapProfile} />
                <datalist id="gapProfileOptions">
                  {(profileGaps.nameOptions || []).map((option) => (
                    <option value={cleanText(option.label)} data-profile-value={option.value} />
                  ))}
                </datalist>
              </label>

              <button type="submit">Filter</button>
            </form>

            <div class="gap-summary">
              <span><strong>{profileGaps.counts.total || 0}</strong> Results</span>
              <span><strong>{profileGaps.counts.representatives || 0}</strong> Legislators</span>
              <span><strong>{profileGaps.counts.candidates || 0}</strong> Candidates</span>
              <span><strong>{profileGaps.counts.missingPhoto || 0}</strong> Missing Photos</span>
              <span><strong>{profileGaps.counts.missingEmail || 0}</strong> Missing Emails</span>
              <span><strong>{profileGaps.counts.missingWebsite || 0}</strong> Missing Websites</span>
              <span>
                <strong>{profileGaps.counts.recentlyReviewed || 0}</strong>
                Reviewed in {profileGaps.counts.recentReviewDays || 30} days
              </span>
            </div>

            {profileGaps.results.length ? (
              <div class="profile-gap-list">
                {profileGaps.results.map((profile) => (
                  <article data-profile-gap-row>
                    <div>
                      <strong>{cleanText(profile.name || profile.key)}</strong>
                      <p>{cleanText(profile.subtitle || profile.type)}</p>
                    </div>
                    <div class="missing-chips">
                      {profile.missing.photo && <span>Missing photo</span>}
                      {profile.missing.email && <span>Missing email</span>}
                      {profile.missing.website && <span>Missing website</span>}
                      {profile.review?.reviewedAt && (
                        <span class="review-chip">Reviewed {reviewDate(profile.review.reviewedAt)}</span>
                      )}
                    </div>
                    <div class="gap-actions">
                      <a href={profile.profilePath}>Open profile</a>
                      <form action="/api/admin/profile" method="post" data-profile-review-form>
                        <input type="hidden" name="entityType" value={profile.type} />
                        <input type="hidden" name="entityKey" value={profile.key} />
                        <input type="hidden" name="profileAction" value="confirm-reviewed" />
                        <input type="hidden" name="redirectTo" value={Astro.url.pathname + Astro.url.search} />
                        <input
                          type="hidden"
                          name="reviewNote"
                          value="Reviewed from profile cleanup; no photo, website, or email update found."
                        />
                        <button class="secondary compact-button" type="submit">Confirm reviewed</button>
                      </form>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No profiles match these missing-info filters.</p>
            )}
          </section>

          <section id="community-updates" class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Moderation</p>
              <h2>Community updates</h2>
              <p>
                Review comments and photos before they appear on candidate and
                legislator profile pages.
              </p>
            </div>

            {pendingCommunityUpdates.length ? (
              <div class="moderation-list">
                {pendingCommunityUpdates.map((update) => (
                  <article>
                    <div class="moderation-topline">
                      <strong>{cleanText(update.entityName || update.entityKey)}</strong>
                      <span>{cleanText(update.entityType)}</span>
                    </div>

                    <p class="moderation-meta">
                      Submitted by {cleanText(update.displayName)}
                      {communityUpdateDate(update.createdAt) && ` on ${communityUpdateDate(update.createdAt)}`}
                    </p>

                    {update.pageUrl && <a href={update.pageUrl}>Open profile page</a>}
                    {update.comment && <p>{cleanText(update.comment)}</p>}
                    {update.mentions?.length > 0 && (
                      <div class="moderation-mentions">
                        <span>Tagged legislators</span>
                        {update.mentions.map((mention) => (
                          <a href={mention.path || `/people/${mention.personid}`}>
                            {cleanText(mention.name)}
                            {mention.chamber && <small>{cleanText(mention.chamber)}</small>}
                          </a>
                        ))}
                      </div>
                    )}
                    {update.linkUrl && <a href={update.linkUrl}>Open submitted link</a>}
                    {update.photoUrl && <img src={update.photoUrl} alt="" loading="lazy" />}

                    <div class="moderation-actions">
                      <form action="/api/admin/community-updates" method="post">
                        <input type="hidden" name="id" value={update.id} />
                        <input type="hidden" name="action" value="approve" />
                        <input type="hidden" name="redirectTo" value="/admin" />
                        <button type="submit">Approve</button>
                      </form>
                      <form action="/api/admin/community-updates" method="post">
                        <input type="hidden" name="id" value={update.id} />
                        <input type="hidden" name="action" value="reject" />
                        <input type="hidden" name="redirectTo" value="/admin" />
                        <button class="secondary danger" type="submit">Reject</button>
                      </form>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No community updates are waiting for review.</p>
            )}
          </section>

          <section id="article-submissions" class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Moderation</p>
              <h2>Submitted articles</h2>
              <p>
                Review suggested coverage and approve it into the article
                database with automatically detected bills, people, and towns.
              </p>
            </div>
            <datalist id="articlePeopleModerationOptions">
              {peopleOptions.map((person) => (
                <option value={person.value} label={person.label} />
              ))}
            </datalist>

            {pendingArticleSubmissions.length ? (
              <div class="moderation-list">
                {pendingArticleSubmissions.map((submission) => (
                  <article>
                    <div class="moderation-topline">
                      <strong>{cleanText(submission.title || submission.url)}</strong>
                      <span>{cleanText(submission.publisher || "Submitted article")}</span>
                    </div>

                    <p class="moderation-meta">
                      Submitted
                      {submission.submitterName && ` by ${cleanText(submission.submitterName)}`}
                      {articleSubmissionDate(submission.createdAt) &&
                        ` on ${articleSubmissionDate(submission.createdAt)}`}
                    </p>

                    <a href={submission.url}>Open original article</a>
                    {submission.summary && <p>{cleanText(submission.summary)}</p>}

                    <div class="detected-relations">
                      <strong>Detected links</strong>
                      <div>
                        {(submission.scan.bills || []).map((bill) => (
                          <span>{cleanText(bill.condensedbillno)}</span>
                        ))}
                        {(submission.scan.legislators || []).map((person) => (
                          <span>{cleanText(person.name)}</span>
                        ))}
                        {(submission.scan.candidates || []).map((candidate) => (
                          <span>{cleanText(candidate.name)}</span>
                        ))}
                        {(submission.scan.towns || []).map((town) => (
                          <span>{cleanText(town.town)}</span>
                        ))}
                      </div>
                    </div>

                    <div class="moderation-actions">
                      <form action="/api/admin/article-submissions" method="post">
                        <input type="hidden" name="id" value={submission.id} />
                        <input type="hidden" name="action" value="approve" />
                        <input type="hidden" name="redirectTo" value="/admin" />
                        <div class="manual-link-fields">
                          <label>
                            Bills
                            <input name="bills" placeholder="HB155, SB2" />
                          </label>
                          <label>
                            People
                            <input name="people" list="articlePeopleModerationOptions" placeholder="person id, name, filer number, or GC id" />
                          </label>
                        </div>
                        <button type="submit">Approve</button>
                      </form>
                      <form action="/api/admin/article-submissions" method="post">
                        <input type="hidden" name="id" value={submission.id} />
                        <input type="hidden" name="action" value="reject" />
                        <input type="hidden" name="redirectTo" value="/admin" />
                        <button class="secondary danger" type="submit">Reject</button>
                      </form>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No submitted articles are waiting for review.</p>
            )}
          </section>

          <section id="endorsement-submissions" class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Moderation</p>
              <h2>Organization endorsements</h2>
              <p>
                Review community-submitted endorsements before they appear on
                candidate profiles. Approving also creates a minimal
                organization profile when needed.
              </p>
            </div>

            {pendingOrganizationEndorsements.length ? (
              <div class="moderation-list">
                {pendingOrganizationEndorsements.map((endorsement) => (
                  <article>
                    <div class="moderation-topline">
                      <strong>{cleanText(endorsement.organization)}</strong>
                      <span>{cleanText(endorsement.position || "Endorsement")}</span>
                    </div>

                    <p class="moderation-meta">
                      {cleanText(endorsement.candidateName)}
                      {endorsement.office && ` - ${cleanText(endorsement.office)}`}
                      {endorsement.district && ` - ${cleanText(endorsement.district)}`}
                    </p>

                    {endorsement.organizationWebsite && (
                      <a href={endorsement.organizationWebsite}>Organization website</a>
                    )}
                    {endorsement.statement && <p>{cleanText(endorsement.statement)}</p>}
                    {(endorsement.submitterName || endorsement.submitterEmail) && (
                      <p class="moderation-meta">
                        Submitted by {cleanText(endorsement.submitterName || "Unknown")}
                        {endorsement.submitterEmail && ` (${endorsement.submitterEmail})`}
                      </p>
                    )}

                    <div class="moderation-actions">
                      <form action="/api/admin/endorsements" method="post">
                        <input type="hidden" name="id" value={endorsement.id} />
                        <input type="hidden" name="action" value="approve" />
                        <input type="hidden" name="redirectTo" value="/admin#endorsement-submissions" />
                        <button type="submit">Approve</button>
                      </form>
                      <form action="/api/admin/endorsements" method="post">
                        <input type="hidden" name="id" value={endorsement.id} />
                        <input type="hidden" name="action" value="reject" />
                        <input type="hidden" name="redirectTo" value="/admin#endorsement-submissions" />
                        <button class="secondary danger" type="submit">Reject</button>
                      </form>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No organization endorsements are waiting for review.</p>
            )}
          </section>

          <section id="organizations-admin" class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Organizations</p>
              <h2>Create and update organization profiles</h2>
              <p>
                Organization profiles, bill comments, and endorsements now live
                in D1. Import the existing Google Sheet once, then maintain
                organization profile data here.
              </p>
            </div>

            <form class="stack-form compact-action-form" action="/api/admin/organizations" method="post">
              <input type="hidden" name="action" value="import-sheets" />
              <input type="hidden" name="redirectTo" value="/admin" />
              <p class="form-help">
                Run this once after deployment, or again later if you need to
                re-sync the legacy Google Sheet into D1. Existing D1 rows are
                updated by slug.
              </p>
              <button type="submit">Import Google Sheet to D1</button>
            </form>

            <datalist id="organizationAdminOptions">
              {organizations.map((organization) => (
                <option value={organization.slug} label={organization.name} />
              ))}
            </datalist>
            <datalist id="endorsementCandidateOptions">
              {candidateEndorsementOptions.map((option) => (
                <option value={option.value} />
              ))}
            </datalist>
            <datalist id="organizationCommentBillOptions">
              {billCommentOptions.map((option) => (
                <option value={option.label} />
              ))}
