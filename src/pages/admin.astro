---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import { currentAdminSession } from "../lib/adminAuth";
import { getProfileGaps } from "../lib/adminProfileGaps";
import {
  articleSubmissionDate,
  getPendingArticleSubmissions,
} from "../lib/articleSubmissions";
import { communityUpdateDate, getPendingCommunityUpdates } from "../lib/communityUpdates";
import { cleanText } from "../lib/text";

const session = await currentAdminSession(Astro.request);
const sent = Astro.url.searchParams.get("sent") === "1";
const error = Astro.url.searchParams.get("error") || "";
const message = Astro.url.searchParams.get("message") || "";
const imageUrl = Astro.url.searchParams.get("imageUrl") || "";
const gapType = Astro.url.searchParams.get("gapType") || "all";
const gapMissing = Astro.url.searchParams.get("gapMissing") || "any";
const gapOffice = Astro.url.searchParams.get("gapOffice") || "";
const gapProfile = Astro.url.searchParams.get("gapProfile") || "";
const gapOfficeOptions = [
  { value: "", label: "All offices" },
  { value: "State Representative", label: "State Representative" },
  { value: "State Senate", label: "State Senate" },
];
let pendingCommunityUpdates = [];
let pendingArticleSubmissions = [];
let profileGaps = { results: [], counts: {} };

if (session) {
  try {
    pendingCommunityUpdates = await getPendingCommunityUpdates({ limit: 50 });
  } catch (error) {
    console.error(error?.message || "Unable to load pending community updates.");
  }

  try {
    pendingArticleSubmissions = await getPendingArticleSubmissions({ limit: 50 });
  } catch (error) {
    console.error(error?.message || "Unable to load pending article submissions.");
  }

  try {
    profileGaps = await getProfileGaps({
      profileType: gapType,
      missing: gapMissing,
      office: gapOffice,
      profile: gapProfile,
      limit: 100,
    });
  } catch (error) {
    console.error(error?.message || "Unable to load profile gaps.");
  }
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>Admin | NH Deserves Better</title>
    <meta name="robots" content="noindex" />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Admin</p>
        <h1>Update site data and assets.</h1>
        <p class="lede">
          Sign in with a magic link to run D1 updates and upload images to R2.
        </p>
      </section>

      {error && <p class="status-message error">{error}</p>}
      {message && <p class="status-message success">{message}</p>}
      {sent && (
        <p class="status-message success">
          Check your email for a login link. It expires in 15 minutes.
        </p>
      )}

      {!session ? (
        <form class="panel login-panel" action="/api/admin/request-login" method="post">
          <label for="email">Admin email</label>
          <input
            id="email"
            name="email"
            type="email"
            placeholder="you@example.com"
            autocomplete="email"
            required
          />
          <button type="submit">Send magic link</button>
        </form>
      ) : (
        <div class="admin-grid">
          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Session</p>
              <h2>Signed in</h2>
            </div>
            <p class="session-email">{session.email}</p>
            <form action="/api/admin/logout" method="post">
              <button type="submit" class="secondary">Log out</button>
            </form>
          </section>

          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Profiles</p>
              <h2>Edit candidates and legislators</h2>
              <p>
                Open a candidate or legislator profile while signed in. An admin
                editor appears on the page and saves updates directly to the
                source D1 tables used by the local API.
              </p>
            </div>
            <div class="profile-actions">
              <a href="/people">Find a legislator</a>
              <a href="/candidates">Find a candidate</a>
            </div>
          </section>

          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Profile Cleanup</p>
              <h2>Missing profile info</h2>
              <p>
                Find candidates and legislators missing photos, emails, or
                websites. Legislator websites are not currently stored in the
                source D1 legislator table, so the website filter applies to
                candidates.
              </p>
            </div>

            <form class="gap-filters" action="/admin" method="get">
              <label>
                Profile type
                <select name="gapType">
                  <option value="all" selected={gapType === "all"}>All profiles</option>
                  <option value="representative" selected={gapType === "representative"}>Legislators</option>
                  <option value="candidate" selected={gapType === "candidate"}>Candidates</option>
                </select>
              </label>

              <label>
                Missing field
                <select name="gapMissing">
                  <option value="any" selected={gapMissing === "any"}>Any missing field</option>
                  <option value="photo" selected={gapMissing === "photo"}>Photo</option>
                  <option value="email" selected={gapMissing === "email"}>Email</option>
                  <option value="website" selected={gapMissing === "website"}>Website</option>
                </select>
              </label>

              <label>
                Office
                <select name="gapOffice">
                  {gapOfficeOptions.map((option) => (
                    <option value={option.value} selected={gapOffice === option.value}>
                      {option.label}
                    </option>
                  ))}
                </select>
              </label>

              <label>
                Name
                <select name="gapProfile">
                  <option value="">All names</option>
                  {(profileGaps.nameOptions || []).map((option) => (
                    <option value={option.value} selected={gapProfile === option.value}>
                      {cleanText(option.label)}
                    </option>
                  ))}
                </select>
              </label>

              <button type="submit">Filter</button>
            </form>

            <div class="gap-summary">
              <span><strong>{profileGaps.counts.total || 0}</strong> Results</span>
              <span><strong>{profileGaps.counts.representatives || 0}</strong> Legislators</span>
              <span><strong>{profileGaps.counts.candidates || 0}</strong> Candidates</span>
              <span><strong>{profileGaps.counts.missingPhoto || 0}</strong> Missing Photos</span>
              <span><strong>{profileGaps.counts.missingEmail || 0}</strong> Missing Emails</span>
              <span><strong>{profileGaps.counts.missingWebsite || 0}</strong> Missing Websites</span>
            </div>

            {profileGaps.results.length ? (
              <div class="profile-gap-list">
                {profileGaps.results.map((profile) => (
                  <article>
                    <div>
                      <strong>{cleanText(profile.name || profile.key)}</strong>
                      <p>{cleanText(profile.subtitle || profile.type)}</p>
                    </div>
                    <div class="missing-chips">
                      {profile.missing.photo && <span>Missing photo</span>}
                      {profile.missing.email && <span>Missing email</span>}
                      {profile.missing.website && <span>Missing website</span>}
                    </div>
                    <a href={profile.profilePath}>Open profile</a>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No profiles match these missing-info filters.</p>
            )}
          </section>

          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Moderation</p>
              <h2>Community updates</h2>
              <p>
                Review comments and photos before they appear on candidate and
                legislator profile pages.
              </p>
            </div>

            {pendingCommunityUpdates.length ? (
              <div class="moderation-list">
                {pendingCommunityUpdates.map((update) => (
                  <article>
                    <div class="moderation-topline">
                      <strong>{cleanText(update.entityName || update.entityKey)}</strong>
                      <span>{cleanText(update.entityType)}</span>
                    </div>

                    <p class="moderation-meta">
                      Submitted by {cleanText(update.displayName)}
                      {communityUpdateDate(update.createdAt) && ` on ${communityUpdateDate(update.createdAt)}`}
                    </p>

                    {update.pageUrl && <a href={update.pageUrl}>Open profile page</a>}
                    {update.comment && <p>{cleanText(update.comment)}</p>}
                    {update.linkUrl && <a href={update.linkUrl}>Open submitted link</a>}
                    {update.photoUrl && <img src={update.photoUrl} alt="" loading="lazy" />}

                    <div class="moderation-actions">
                      <form action="/api/admin/community-updates" method="post">
                        <input type="hidden" name="id" value={update.id} />
                        <input type="hidden" name="action" value="approve" />
                        <input type="hidden" name="redirectTo" value="/admin" />
                        <button type="submit">Approve</button>
                      </form>
                      <form action="/api/admin/community-updates" method="post">
                        <input type="hidden" name="id" value={update.id} />
                        <input type="hidden" name="action" value="reject" />
                        <input type="hidden" name="redirectTo" value="/admin" />
                        <button class="secondary danger" type="submit">Reject</button>
                      </form>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No community updates are waiting for review.</p>
            )}
          </section>

          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">Moderation</p>
              <h2>Submitted articles</h2>
              <p>
                Review suggested coverage and approve it into the article
                database with automatically detected bills, people, and towns.
              </p>
            </div>

            {pendingArticleSubmissions.length ? (
              <div class="moderation-list">
                {pendingArticleSubmissions.map((submission) => (
                  <article>
                    <div class="moderation-topline">
                      <strong>{cleanText(submission.title || submission.url)}</strong>
                      <span>{cleanText(submission.publisher || "Submitted article")}</span>
                    </div>

                    <p class="moderation-meta">
                      Submitted
                      {submission.submitterName && ` by ${cleanText(submission.submitterName)}`}
                      {articleSubmissionDate(submission.createdAt) &&
                        ` on ${articleSubmissionDate(submission.createdAt)}`}
                    </p>

                    <a href={submission.url}>Open original article</a>
                    {submission.summary && <p>{cleanText(submission.summary)}</p>}

                    <div class="detected-relations">
                      <strong>Detected links</strong>
                      <div>
                        {(submission.scan.bills || []).map((bill) => (
                          <span>{cleanText(bill.condensedbillno)}</span>
                        ))}
                        {(submission.scan.legislators || []).map((person) => (
                          <span>{cleanText(person.name)}</span>
                        ))}
                        {(submission.scan.candidates || []).map((candidate) => (
                          <span>{cleanText(candidate.name)}</span>
                        ))}
                        {(submission.scan.towns || []).map((town) => (
                          <span>{cleanText(town.town)}</span>
                        ))}
                      </div>
                    </div>

                    <div class="moderation-actions">
                      <form action="/api/admin/article-submissions" method="post">
                        <input type="hidden" name="id" value={submission.id} />
                        <input type="hidden" name="action" value="approve" />
                        <input type="hidden" name="redirectTo" value="/admin" />
                        <div class="manual-link-fields">
                          <label>
                            Bills
                            <input name="bills" placeholder="HB155, SB2" />
                          </label>
                          <label>
                            Legislators
                            <input name="legislators" placeholder="personid, employeeno, or name" />
                          </label>
                          <label>
                            Candidates
                            <input name="candidates" placeholder="filer number, slug, or name" />
                          </label>
                        </div>
                        <button type="submit">Approve</button>
                      </form>
                      <form action="/api/admin/article-submissions" method="post">
                        <input type="hidden" name="id" value={submission.id} />
                        <input type="hidden" name="action" value="reject" />
                        <input type="hidden" name="redirectTo" value="/admin" />
                        <button class="secondary danger" type="submit">Reject</button>
                      </form>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No submitted articles are waiting for review.</p>
            )}
          </section>

          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">D1 Database</p>
              <h2>Run a data update</h2>
              <p>
                Use parameterized SQL for updates when possible. Parameters must
                be a JSON array, like <code>["HB699", 2025]</code>.
              </p>
            </div>
            <form class="stack-form" action="/api/admin/sql" method="post">
              <label for="sql">SQL</label>
              <textarea
                id="sql"
                name="sql"
                rows="8"
                placeholder="UPDATE bills SET summary = ? WHERE condensedbillno = ?"
                required
              ></textarea>

              <label for="params">Parameters JSON <span>Optional</span></label>
              <textarea
                id="params"
                name="params"
                rows="3"
                placeholder='["New summary", "HB699"]'
              ></textarea>

              <button type="submit">Run SQL</button>
            </form>
          </section>

          <section class="panel">
            <div class="panel-heading">
              <p class="eyebrow">R2 Storage</p>
              <h2>Upload an image</h2>
              <p>
                Uploads go to the bound profile-photo R2 bucket. Add a profile
                type and identifier to update D1 at the same time.
              </p>
            </div>
            <form class="stack-form" action="/api/admin/upload" method="post" enctype="multipart/form-data">
              <label for="entityType">Update profile <span>Optional</span></label>
              <select id="entityType" name="entityType">
                <option value="">Just upload to R2</option>
                <option value="representative">Legislator</option>
                <option value="candidate">Candidate</option>
              </select>

              <label for="entityKey">Profile identifier <span>Optional</span></label>
              <input
                id="entityKey"
                name="entityKey"
                type="text"
                placeholder="personid, employeeno, candidate filer number, or slug"
              />

              <label for="key">R2 key</label>
              <input id="key" name="key" type="text" placeholder="legislators/11462-victoria-sullivan.jpg" />

              <label for="file">Image file</label>
              <input id="file" name="file" type="file" accept="image/*" required />

              <button type="submit">Upload image</button>
            </form>

            {imageUrl && (
              <p class="asset-link">
                Uploaded asset:
                <a href={imageUrl}>{imageUrl}</a>
              </p>
            )}
          </section>
        </div>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 850;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0;
    max-width: 980px;
  }

  h2 {
    font-size: clamp(1.45rem, 3vw, 2.2rem);
    line-height: 1;
    margin: 0;
  }

  .lede,
  .panel-heading p,
  .asset-link,
  .session-email {
    color: #4b5563;
    font-weight: 750;
    line-height: 1.5;
  }

  .lede {
    font-size: clamp(1.12rem, 2.2vw, 1.35rem);
    margin: 22px 0 0;
    max-width: 760px;
  }

  .admin-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(260px, 0.36fr) minmax(0, 1fr);
  }

  .admin-grid .panel:nth-child(2),
  .admin-grid .panel:nth-child(3),
  .admin-grid .panel:nth-child(4),
  .admin-grid .panel:nth-child(5),
  .admin-grid .panel:nth-child(6),
  .admin-grid .panel:nth-child(7) {
    grid-column: 2;
  }

  .panel,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 16px;
    box-shadow: 5px 5px 0 #1f2933;
    padding: clamp(20px, 4vw, 28px);
  }

  .login-panel,
  .stack-form {
    display: grid;
    gap: 14px;
  }

  .panel-heading {
    margin-bottom: 18px;
  }

  .profile-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .gap-filters {
    align-items: end;
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(4, minmax(0, 1fr)) auto;
    margin-bottom: 18px;
  }

  .gap-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .gap-summary span,
  .missing-chips span {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #374151;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 7px 10px;
  }

  .gap-summary strong {
    color: #1f2933;
  }

  .profile-gap-list {
    display: grid;
    gap: 12px;
  }

  .profile-gap-list article {
    align-items: center;
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(0, 1.1fr) minmax(180px, 0.9fr) auto;
    padding: 14px;
  }

  .profile-gap-list strong {
    display: block;
    font-size: 1.02rem;
  }

  .profile-gap-list p {
    color: #4b5563;
    font-size: 0.9rem;
    font-weight: 750;
    line-height: 1.35;
    margin: 4px 0 0;
  }

  .profile-gap-list a {
    border: 2px solid #1f2933;
    border-radius: 999px;
    padding: 9px 12px;
    text-align: center;
    text-decoration: none;
    white-space: nowrap;
  }

  .missing-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .missing-chips span {
    background: #fee2e2;
    border-color: #fecaca;
    color: #7f1d1d;
  }

  .moderation-list {
    display: grid;
    gap: 14px;
  }

  .moderation-list article {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    padding: 14px;
  }

  .moderation-topline,
  .moderation-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: space-between;
  }

  .moderation-topline span {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 950;
    padding: 5px 8px;
    text-transform: capitalize;
  }

  .moderation-meta,
  .empty {
    color: #4b5563;
    font-weight: 800;
  }

  .moderation-list img {
    aspect-ratio: 16 / 9;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    display: block;
    margin-top: 12px;
    object-fit: cover;
    width: min(420px, 100%);
  }

  .moderation-actions {
    justify-content: flex-start;
    margin-top: 12px;
  }

  .moderation-actions form {
    margin: 0;
  }

  .moderation-actions form:has(.manual-link-fields) {
    display: grid;
    flex: 1 1 100%;
    gap: 12px;
  }

  .manual-link-fields {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    width: 100%;
  }

  .detected-relations {
    display: grid;
    gap: 8px;
    margin-top: 12px;
  }

  .detected-relations > strong {
    color: #374151;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .detected-relations div {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .detected-relations span {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 5px 8px;
  }

  .secondary.danger {
    border-color: #991b1b;
    color: #991b1b;
  }

  .profile-actions a {
    border: 2px solid #1f2933;
    border-radius: 999px;
    padding: 10px 14px;
    text-decoration: none;
  }

  label {
    font-size: 0.82rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  label span {
    color: #6b7280;
    font-size: 0.74rem;
    letter-spacing: 0;
    text-transform: none;
  }

  input,
  textarea,
  select {
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    box-sizing: border-box;
    color: #1f2933;
    font: inherit;
    padding: 13px 14px;
    width: 100%;
  }

  textarea {
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    resize: vertical;
  }

  button {
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    cursor: pointer;
    font: inherit;
    font-weight: 900;
    justify-self: start;
    padding: 13px 18px;
  }

  button.secondary {
    background: white;
    color: #1f2933;
  }

  .status-message {
    margin: 0 0 18px;
  }

  .status-message.error {
    background: #fee2e2;
    color: #7f1d1d;
  }

  .status-message.success {
    background: #dcfce7;
    color: #14532d;
  }

  code {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 2px 5px;
  }

  @media (max-width: 840px) {
    .admin-grid {
      grid-template-columns: 1fr;
    }

    .manual-link-fields {
      grid-template-columns: 1fr;
    }

    .gap-filters,
    .profile-gap-list article {
      grid-template-columns: 1fr;
    }

    .admin-grid .panel:nth-child(2),
    .admin-grid .panel:nth-child(3),
    .admin-grid .panel:nth-child(4),
    .admin-grid .panel:nth-child(5),
    .admin-grid .panel:nth-child(6),
    .admin-grid .panel:nth-child(7) {
      grid-column: auto;
    }
  }
</style>
