---
export const prerender = false;

import BillPositionSummary from "../../../components/BillPositionSummary.astro";
import TopNav from "../../../components/TopNav.astro";
import { billDetailPath, getBillDetail, getBillSummaries } from "../../../lib/billsApi";
import { getRepresentative, repName } from "../../../lib/repsApi";
import { cleanText } from "../../../lib/text";
import {
  getTrackedBills,
  normalizeBillCode,
  representativeVoteImpact,
  representativeVoteStance,
  trackedBillForVote,
} from "../../../lib/trackedBills";

const { slug } = Astro.params;

let apiData = null;
let trackedBills = new Map();
let billSummaries = new Map();
let error = "";

try {
  apiData = await getRepresentative(slug, { voteLimit: 500 });
} catch (loadError) {
  error = loadError?.message || "Unable to load representative.";
}

try {
  [trackedBills, billSummaries] = await Promise.all([
    getTrackedBills(),
    getBillSummaries(),
  ]);
} catch (loadError) {
  console.error(loadError?.message || "Unable to load tracked bill data.");
}

const representative = apiData?.representative || null;

if (!error && !representative) {
  return Astro.redirect("/404");
}

const representativeName = repName(representative || {}) || "Representative";
let trackedVotes = (apiData?.voteHistory || [])
  .map((vote) => normalizeVote(vote, trackedBills, billSummaries))
  .filter((vote) => vote.trackedBill);

trackedVotes = await Promise.all(
  trackedVotes.map(async (vote) => {
    if (vote.billSummary) return vote;

    try {
      const detail = await getBillDetail(vote.trackedBill.code, {
        year: vote.sessionyear,
      });
      return { ...vote, billSummary: detail.bill };
    } catch (detailError) {
      console.error(detailError?.message || "Unable to load bill summary.");
      return vote;
    }
  }),
);

function normalizeVote(vote = {}, bills = new Map(), summaries = new Map()) {
  const billNumber = vote.condensedbillno || vote.bill_number || "";
  const trackedBill = trackedBillForVote(bills, vote);
  const billSummary = summaries.get(normalizeBillCode(billNumber));

  return {
    ...vote,
    bill_number: billNumber,
    title: vote.title || vote.description || "",
    vote_date: vote.vote_date || vote.statusdate || "",
    motion: vote.motion || vote.question_motion || vote.description || "",
    vote_label: vote.vote_label || vote.vote || "Not listed",
    billSummary,
    trackedBill,
  };
}

function formatDate(value) {
  if (!value) return "";

  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(value));
}

function previewText(value = "", length = 260) {
  const text = cleanText(value).trim();
  if (text.length <= length) return text;
  return `${text.slice(0, length).trim()}...`;
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>Tracked votes for {representativeName} | NH Deserves Better</title>
    <meta
      name="description"
      content={`Tracked bill votes and public testimony summaries for ${representativeName}.`}
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href={`/people/${slug}`}>Back to profile</a>

      {error ? (
        <p class="status-message">{error}</p>
      ) : (
        <>
          <section class="hero">
            <p class="eyebrow">Tracked Vote History</p>
            <h1>{representativeName}</h1>
            <p>
              These are the tracked bill votes currently returned for this
              legislator. Each card includes the bill tracker summary, the
              recorded vote, and public testimony summary data where available.
            </p>
            <div class="hero-meta">
              <span>{trackedVotes.length} tracked votes</span>
              {representative?.chamber && <span>{representative.chamber}</span>}
              {representative?.district && <span>{representative.district}</span>}
            </div>
          </section>

          {trackedVotes.length ? (
            <section class="vote-grid">
              {trackedVotes.map((vote) => {
                const stance = representativeVoteStance(vote, vote.trackedBill);
                const voteImpact = representativeVoteImpact(vote, vote.trackedBill);
                const billYear = vote.billSummary?.sessionyear || vote.sessionyear;
                const summary =
                  vote.trackedBill.summary ||
                  vote.billSummary?.summary ||
                  vote.billSummary?.description ||
                  "";

                return (
                  <article class="vote-bill-card">
                    <div class="bill-topline">
                      <strong>
                        <a href={billDetailPath(vote.trackedBill.code, billYear)}>
                          {vote.trackedBill.code}
                        </a>
                      </strong>
                      {billYear && <span>{billYear}</span>}
                    </div>

                    <h2>
                      <a href={billDetailPath(vote.trackedBill.code, billYear)}>
                        {vote.trackedBill.name || vote.title || vote.trackedBill.code}
                      </a>
                    </h2>

                    {summary && <p>{previewText(summary)}</p>}

                    <div class:list={["vote-interpretation", stance.className]}>
                      <strong>Vote</strong>
                      <span class:list={["legislator-vote-pill", stance.className]}>
                        {stance.label}
                      </span>
                      {voteImpact && <p class="vote-impact">{cleanText(voteImpact)}</p>}
                    </div>

                    {vote.billSummary && <BillPositionSummary bill={vote.billSummary} />}

                    <div class="bill-meta">
                      {vote.motion && <span>{cleanText(vote.motion)}</span>}
                      {vote.vote_date && <span>{formatDate(vote.vote_date)}</span>}
                      {vote.trackedBill.issueArea && (
                        <span>{cleanText(vote.trackedBill.issueArea)}</span>
                      )}
                    </div>
                  </article>
                );
              })}
            </section>
          ) : (
            <p class="status-message">No tracked votes were returned.</p>
          )}
        </>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 24px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 10px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.92;
    margin: 0 0 18px;
  }

  .hero p {
    color: #4b5563;
    font-size: 1.08rem;
    line-height: 1.6;
    max-width: 780px;
  }

  .hero-meta,
  .bill-topline,
  .bill-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .hero-meta span,
  .bill-topline span,
  .bill-meta span {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .vote-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  }

  .vote-bill-card,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 18px;
  }

  .bill-topline {
    justify-content: space-between;
  }

  .bill-topline strong {
    font-size: 1.1rem;
  }

  .vote-bill-card h2 {
    font-size: 1.35rem;
    line-height: 1.15;
    margin: 14px 0 8px;
  }

  .vote-bill-card > p,
  .vote-impact {
    color: #4b5563;
    line-height: 1.55;
    margin: 0 0 14px;
  }

  .vote-interpretation {
    background: white;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    display: grid;
    gap: 8px;
    margin: 14px 0;
    padding: 8px;
  }

  .vote-interpretation > strong {
    color: #4b5563;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .legislator-vote-pill {
    border: 1px solid #d1d5db;
    border-radius: 999px;
    box-sizing: border-box;
    color: #1f2933;
    display: block;
    font-size: 0.78rem;
    font-weight: 900;
    line-height: 1.2;
    padding: 7px 10px;
    text-align: center;
    width: 100%;
  }

  .legislator-support {
    background: #dff0d8;
    border-color: #2f7d4f;
  }

  .legislator-oppose {
    background: #fde2de;
    border-color: #b42318;
  }

  .legislator-neutral {
    background: #dbeafe;
    border-color: #2563eb;
  }

  .vote-impact {
    font-weight: 500;
    margin: 0;
  }

  .bill-meta {
    margin-top: 14px;
  }

  @media (max-width: 640px) {
    .vote-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
