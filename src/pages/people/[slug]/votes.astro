---
export const prerender = false;

import BillPositionSummary from "../../../components/BillPositionSummary.astro";
import TopNav from "../../../components/TopNav.astro";
import { billDetailPath, getBillDetail, getBillSummaries } from "../../../lib/billsApi";
import { getRepresentative, repName } from "../../../lib/repsApi";
import { cleanText } from "../../../lib/text";
import {
  getTrackedBills,
  normalizeBillCode,
  representativeVoteImpact,
  representativeVoteStance,
  trackedBillForVote,
} from "../../../lib/trackedBills";

const { slug } = Astro.params;

let apiData = null;
let trackedBills = new Map();
let billSummaries = new Map();
let error = "";

try {
  apiData = await getRepresentative(slug, { voteLimit: 500 });
} catch (loadError) {
  error = loadError?.message || "Unable to load representative.";
}

try {
  [trackedBills, billSummaries] = await Promise.all([
    getTrackedBills(),
    getBillSummaries(),
  ]);
} catch (loadError) {
  console.error(loadError?.message || "Unable to load tracked bill data.");
}

const representative = apiData?.representative || null;

if (!error && !representative) {
  return Astro.redirect("/404");
}

const representativeName = repName(representative || {}) || "Representative";
let votes = (apiData?.voteHistory || []).map((vote) =>
  normalizeVote(vote, trackedBills, billSummaries),
);
const trackedVoteCount = votes.filter((vote) => vote.trackedBill).length;

votes = await Promise.all(
  votes.map(async (vote) => {
    if (vote.billSummary) return vote;

    try {
      const detail = await getBillDetail(vote.bill_number, {
        year: vote.sessionyear,
      });
      return { ...vote, billSummary: detail.bill };
    } catch (detailError) {
      console.error(detailError?.message || "Unable to load bill summary.");
      return vote;
    }
  }),
);

function normalizeVote(vote = {}, bills = new Map(), summaries = new Map()) {
  const billNumber = vote.condensedbillno || vote.bill_number || "";
  const trackedBill = trackedBillForVote(bills, vote);
  const billSummary = summaries.get(normalizeBillCode(billNumber));

  return {
    ...vote,
    bill_number: billNumber,
    title: vote.title || vote.description || "",
    vote_date: vote.vote_date || vote.statusdate || "",
    motion: vote.motion || vote.question_motion || vote.description || "",
    vote_label: displayVoteLabel(vote),
    billSummary,
    trackedBill,
  };
}

function displayVoteLabel(vote = {}) {
  const rawLabel = cleanText(vote.vote_label || "");
  if (rawLabel && !["N/A", "NA"].includes(rawLabel.toUpperCase())) return rawLabel;

  const voteValue = String(vote.vote || vote.vote_code || "").trim().toLowerCase();
  const labels = {
    "1": "Yea",
    yea: "Yea",
    yes: "Yea",
    "2": "Nay",
    nay: "Nay",
    no: "Nay",
    "3": "Absent",
    absent: "Absent",
    "4": "Present",
    present: "Present",
    "5": "Not voting",
    other_not_voting: "Not voting",
    "6": "Present not voting",
    "7": "Present not voting",
    other_present_not_voting: "Present not voting",
    "0": "Not counted",
    other_not_counted: "Not counted",
  };

  return labels[voteValue] || cleanText(vote.vote || "Not listed");
}

function voteClass(vote = {}) {
  const label = String(vote.vote_label || vote.vote || "").toLowerCase();
  if (label.includes("support") || label === "yea" || label === "yes") return "legislator-support";
  if (label.includes("against") || label.includes("oppose") || label === "nay" || label === "no") {
    return "legislator-oppose";
  }
  return "legislator-neutral";
}

function billCodeFor(vote = {}) {
  return vote.trackedBill?.code || vote.bill_number || vote.condensedbillno || "Bill";
}

function billTitleFor(vote = {}) {
  return (
    vote.trackedBill?.name ||
    vote.billSummary?.description ||
    vote.title ||
    billCodeFor(vote)
  );
}

function voteStanceFor(vote = {}) {
  if (vote.trackedBill) return representativeVoteStance(vote, vote.trackedBill);
  return {
    label: `Voted: ${displayVoteLabel(vote)}`,
    className: voteClass(vote),
  };
}

function voteImpactFor(vote = {}) {
  if (!vote.trackedBill) return "";
  return representativeVoteImpact(vote, vote.trackedBill);
}

function formatDate(value) {
  if (!value) return "";

  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(value));
}

function previewText(value = "", length = 260) {
  const text = cleanText(value).trim();
  if (text.length <= length) return text;
  return `${text.slice(0, length).trim()}...`;
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>Votes for {representativeName} | NH Deserves Better</title>
    <meta
      name="description"
      content={`Vote history and bill summaries for ${representativeName}.`}
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href={`/people/${slug}`}>Back to profile</a>

      {error ? (
        <p class="status-message">{error}</p>
      ) : (
        <>
          <section class="hero">
            <p class="eyebrow">Vote History</p>
            <h1>{representativeName}</h1>
            <p>
              These are all votes currently returned for this legislator. Votes
              connected to the bill tracker include tracker summaries,
              interpretations, and public testimony summary data where available.
            </p>
            <div class="hero-meta">
              <span>{votes.length} votes</span>
              <span>{trackedVoteCount} tracked</span>
              {representative?.chamber && <span>{representative.chamber}</span>}
              {representative?.district && <span>{representative.district}</span>}
            </div>
          </section>

          {votes.length ? (
            <section class="vote-grid">
              {votes.map((vote) => {
                const stance = voteStanceFor(vote);
                const voteImpact = voteImpactFor(vote);
                const billYear = vote.billSummary?.sessionyear || vote.sessionyear;
                const summary =
                  vote.trackedBill?.summary ||
                  vote.billSummary?.summary ||
                  vote.billSummary?.description ||
                  "";
                const billCode = billCodeFor(vote);

                return (
                  <article class="vote-bill-card">
                    <div class="bill-topline">
                      <strong>
                        <a href={billDetailPath(billCode, billYear)}>
                          {billCode}
                        </a>
                      </strong>
                      {billYear && <span>{billYear}</span>}
                      {vote.trackedBill ? (
                        <span class="tracker-pill">Tracked</span>
                      ) : (
                        <span>Untracked</span>
                      )}
                    </div>

                    <h2>
                      <a href={billDetailPath(billCode, billYear)}>
                        {billTitleFor(vote)}
                      </a>
                    </h2>

                    {summary && <p>{previewText(summary)}</p>}

                    <div class:list={["vote-interpretation", stance.className]}>
                      <strong>Vote</strong>
                      <span class:list={["legislator-vote-pill", stance.className]}>
                        {stance.label}
                      </span>
                      {voteImpact && <p class="vote-impact">{cleanText(voteImpact)}</p>}
                    </div>

                    {vote.billSummary ? (
                      <BillPositionSummary bill={vote.billSummary} />
                    ) : (
                      <div class="position-placeholder">
                        Public testimony summary not available.
                      </div>
                    )}

                    <div class="bill-meta">
                      {vote.motion && <span>{cleanText(vote.motion)}</span>}
                      {vote.vote_date && <span>{formatDate(vote.vote_date)}</span>}
                      {vote.trackedBill?.issueArea && (
                        <span>{cleanText(vote.trackedBill.issueArea)}</span>
                      )}
                    </div>
                  </article>
                );
              })}
            </section>
          ) : (
            <p class="status-message">No votes were returned.</p>
          )}
        </>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 24px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 10px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.92;
    margin: 0 0 18px;
  }

  .hero p {
    color: #4b5563;
    font-size: 1.08rem;
    line-height: 1.6;
    max-width: 780px;
  }

  .hero-meta,
  .bill-topline,
  .bill-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .hero-meta span,
  .bill-topline span,
  .bill-meta span {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .bill-topline .tracker-pill {
    background: #dbeafe;
    border-color: #60a5fa;
    color: #1d4ed8;
  }

  .vote-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  }

  .vote-bill-card,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 18px;
  }

  .bill-topline {
    justify-content: space-between;
  }

  .bill-topline strong {
    font-size: 1.1rem;
  }

  .vote-bill-card h2 {
    font-size: 1.35rem;
    line-height: 1.15;
    margin: 14px 0 8px;
  }

  .vote-bill-card > p,
  .vote-impact {
    color: #4b5563;
    line-height: 1.55;
    margin: 0 0 14px;
  }

  .vote-interpretation {
    background: white;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    display: grid;
    gap: 8px;
    margin: 14px 0;
    padding: 8px;
  }

  .vote-interpretation > strong {
    color: #4b5563;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .legislator-vote-pill {
    border: 1px solid #d1d5db;
    border-radius: 999px;
    box-sizing: border-box;
    color: #1f2933;
    display: block;
    font-size: 0.78rem;
    font-weight: 900;
    line-height: 1.2;
    padding: 7px 10px;
    text-align: center;
    width: 100%;
  }

  .legislator-support {
    background: #dff0d8;
    border-color: #2f7d4f;
  }

  .legislator-oppose {
    background: #fde2de;
    border-color: #b42318;
  }

  .legislator-neutral {
    background: #dbeafe;
    border-color: #2563eb;
  }

  .vote-impact {
    font-weight: 500;
    margin: 0;
  }

  .position-placeholder {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    color: #4b5563;
    font-size: 0.86rem;
    font-weight: 850;
    margin-top: 14px;
    padding: 12px;
  }

  .bill-meta {
    margin-top: 14px;
  }

  @media (max-width: 640px) {
    .vote-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
