---
export const prerender = false;

import ArticleList from "../../components/ArticleList.astro";
import BillPositionSummary from "../../components/BillPositionSummary.astro";
import TopNav from "../../components/TopNav.astro";
import profileIcon from "../../assets/profile icon.png";
import { getArticles } from "../../lib/articlesApi";
import { billDetailPath, getBillDetail, getBillSummaries } from "../../lib/billsApi";
import { isFreeStater } from "../../lib/civicTags";
import { profilePhotoUrl } from "../../lib/photos";
import { getRepresentative } from "../../lib/repsApi";
import {
  getTrackedBills,
  normalizeBillCode,
  representativeGradeFor,
  representativeVoteImpact,
  representativeVoteStance,
  trackedBillForVote,
} from "../../lib/trackedBills";

const { slug } = Astro.params;

let apiData = null;

try {
  apiData = await getRepresentative(slug);
} catch (error) {
  console.error(error?.message || "Unable to load representative profile.");
}

const representative = apiData?.representative || null;

if (!representative) {
  return Astro.redirect("/404");
}

const person = {
  id: representative?.personid || representative?.id,
  full_name: representative?.name || "Representative",
  slug,
  bio: representative?.notes || "",
  photo_url: representative?.photo || "",
  party: representative?.party || "",
  email: representative?.email || "",
  phone: representative?.phone || "",
  website_url: representative?.sourceUrls?.generalCourt || "",
};

const apiTerm = representativeToTerm(representative);
const officeTerms = [{ ...apiTerm, status: "current" }];
const currentOfficeTerms = officeTerms;
const candidacies = { results: [] };

let trackedBills = new Map();
let billSummaries = new Map();

try {
  [trackedBills, billSummaries] = await Promise.all([
    getTrackedBills(),
    getBillSummaries(),
  ]);
} catch (error) {
  console.error(error?.message || "Unable to load tracked bill data.");
}

const voteHistory = apiData?.voteHistory || [];
let trackedVotes = voteHistory
  .map((vote) => normalizeVote(vote, trackedBills, billSummaries))
  .filter((vote) => vote.trackedBill);
const voteGrade = representativeGradeFor(
  { ...representative, voteHistory },
  trackedBills,
);

trackedVotes = await Promise.all(
  trackedVotes.map(async (vote) => {
    if (vote.billSummary) return vote;

    try {
      const detail = await getBillDetail(vote.trackedBill.code, {
        year: vote.sessionyear,
      });
      return { ...vote, billSummary: detail.bill };
    } catch (error) {
      console.error(error?.message || "Unable to load bill summary.");
      return vote;
    }
  }),
);

const officeLabel = apiTerm.title || "Civic profile";
const bodyLabel = apiTerm.body || "New Hampshire";
const districtLabel = formatDistrictLabel(apiTerm);
const townServiceAreas = [];
if (representative?.towns_represented || representative?.location_text) {
  townServiceAreas.push({
    district: formatDistrictLabel(apiTerm),
    towns:
      parseTownsServed(representative.towns_represented).length > 0
        ? parseTownsServed(representative.towns_represented)
        : parseLocationText(representative.location_text),
  });
}
const sourceLinks = sourceUrlsToLinks(representative?.sourceUrls);
const portraitUrl = profilePhotoUrl(person.photo_url);
let relatedArticles =
  apiData?.relatedArticles ||
  representative?.relatedArticles ||
  [];

if (!relatedArticles.length && person.id) {
  try {
    const articleData = await getArticles({
      personid: person.id,
      include: "relations",
      limit: 6,
    });
    relatedArticles = articleData.articles || [];
  } catch (error) {
    console.error(error?.message || "Unable to load representative articles.");
  }
}
function formatParty(party) {
  if (!party) return "Party not listed";
  if (party === "R") return "Republican";
  if (party === "D") return "Democrat";
  if (party === "I") return "Independent";
  return party;
}

function partyClass(party) {
  if (party === "R") return "party-republican";
  if (party === "D") return "party-democrat";
  if (party === "I") return "party-independent";
  return "party-unknown";
}

function formatDistrictLabel(term = {}) {
  const divisionName = term?.division_name || "";
  const rawDistrict = term?.district || "";
  const district = formatDistrictNumber(rawDistrict);

  if (divisionName.startsWith("NH House District")) {
    return `NH House District ${formatDistrictNumber(
      divisionName.replace("NH House District", "").trim(),
    )}`;
  }

  if (divisionName.startsWith("NH Senate District")) {
    return `NH Senate District ${formatDistrictNumber(
      divisionName.replace("NH Senate District", "").trim(),
    )}`;
  }

  if (term?.body?.includes("House") && district) {
    return `NH House District ${district}`;
  }

  if (term?.body?.includes("Senate") && district) {
    return `NH Senate District ${district}`;
  }

  return divisionName || rawDistrict || "District not listed";
}

function formatDistrictNumber(value = "") {
  const district = String(value).trim();
  if (!district) return "";
  if (/^\d+$/.test(district)) return String(Number(district));
  return district;
}

function parseTownsServed(value = "") {
  if (Array.isArray(value)) {
    return value.map((town) => String(town).trim()).filter(Boolean);
  }

  return String(value)
    .split(/;|,/)
    .map((town) => town.trim())
    .filter(Boolean);
}

function parseLocationText(value = "") {
  const location = String(value).trim();
  if (!location) return [];
  if (/ward/i.test(location)) return [location];

  return location
    .split(/\s+and\s+|;/i)
    .map((town) => town.trim())
    .filter(Boolean);
}

function representativeToTerm(rep = {}) {
  if (!rep) return {};

  return {
    title:
      rep.chamber === "House"
        ? "State Representative"
        : rep.chamber === "Senate"
          ? "State Senator"
          : "State Legislator",
    body:
      rep.chamber === "House"
        ? "New Hampshire House of Representatives"
        : rep.chamber === "Senate"
          ? "New Hampshire Senate"
          : "New Hampshire General Court",
    district: rep.raw_district || rep.district || "",
    division_name: "",
  };
}

function normalizeVote(vote = {}, bills = new Map(), summaries = new Map()) {
  const billNumber = vote.condensedbillno || vote.bill_number || "";
  const trackedBill = trackedBillForVote(bills, vote);
  const billSummary = summaries.get(normalizeBillCode(billNumber));

  return {
    ...vote,
    bill_number: billNumber,
    title: vote.title || vote.description || "",
    vote_date: vote.vote_date || vote.statusdate || "",
    motion: vote.motion || vote.description || "",
    vote_label: vote.vote_label || vote.vote || "Not listed",
    general_court_url: vote.general_court_url || "",
    legiscan_url: vote.legiscan_url || "",
    billSummary,
    trackedBill,
  };
}

function sourceUrlsToLinks(sourceUrls = {}) {
  const links = [];

  if (sourceUrls.generalCourt) {
    links.push({
      title: "General Court Profile",
      link_type: "general_court",
      url: sourceUrls.generalCourt,
      publisher: "New Hampshire General Court",
    });
  }

  if (sourceUrls.photo) {
    links.push({
      title: "Photo Source",
      link_type: "photo",
      url: sourceUrls.photo,
      publisher: "NH Deserves Better",
    });
  }

  return links;
}

function formatDate(value) {
  if (!value) return "";

  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(value));
}

function contactHref(type, value) {
  if (!value) return "";
  if (type === "email") return `mailto:${value}`;
  if (type === "phone") return `tel:${value}`;
  return value;
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>{person.full_name} | NH Deserves Better</title>
    <meta
      name="description"
      content={`Profile, offices, links, and tracked votes for ${person.full_name}.`}
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="profile-hero">
        <div class="portrait-card">
          {portraitUrl ? (
            <img src={portraitUrl} alt={person.full_name} />
          ) : (
            <img class="portrait-fallback" src={profileIcon.src} alt="" />
          )}
        </div>

        <div class="hero-copy">
          <p class="eyebrow">{officeLabel}</p>
          <h1>{person.full_name}</h1>

          <div class="hero-meta">
            <span class:list={["meta-pill", "party-pill", partyClass(person.party)]}>
              {formatParty(person.party)}
            </span>
            {isFreeStater(representative) && (
              <a
                class="meta-pill free-stater-pill"
                href="/free-staters"
                title="What is a Free Stater?"
                aria-label="What is a Free Stater?"
              >
                Free Stater
              </a>
            )}
            <span class="meta-pill">{bodyLabel}</span>
            <span class="meta-pill district-pill">{districtLabel}</span>
          </div>

          <div class="profile-grade-row">
            <div class:list={["profile-grade", voteGrade.className]} title={voteGrade.label}>
              <span>{voteGrade.letter}</span>
              <small>Vote Grade</small>
            </div>
            <p>{voteGrade.label}</p>
          </div>

          {person.bio ? (
            <p class="bio">{person.bio}</p>
          ) : (
            <p class="bio">
              Profile details are being assembled from public civic records.
            </p>
          )}

          <div class="contact-actions">
            {person.email && (
              <a href={contactHref("email", person.email)}>Email</a>
            )}
            {person.phone && (
              <a href={contactHref("phone", person.phone)}>Call</a>
            )}
            {person.website_url && (
              <a href={contactHref("web", person.website_url)}>Website</a>
            )}
          </div>
        </div>
      </section>

      <section class="summary-strip">
        <article>
          <span>Current Offices</span>
          <strong>{currentOfficeTerms.length}</strong>
        </article>
        <article>
          <span>Tracked Votes</span>
          <strong>{trackedVotes.length}</strong>
        </article>
        <article>
          <span>Sources</span>
          <strong>{sourceLinks.length}</strong>
        </article>
      </section>

      <section class="content-grid">
        <div class="stack">
          <section class="panel">
            <div class="section-heading">
              <p class="eyebrow">Service</p>
              <h2>Current and Past Offices</h2>
            </div>

            {officeTerms.length ? (
              <div class="timeline-list">
                {officeTerms.map((term) => (
                  <article class="timeline-item">
                    <div>
                      <h3>{term.title}</h3>
                      <p>
                        {formatDistrictLabel(term)}
                      </p>
                    </div>
                    <span class:list={["status-pill", term.status]}>
                      {term.status}
                    </span>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No office history is listed yet.</p>
            )}
          </section>

          <section class="panel">
            <div class="section-heading">
              <p class="eyebrow">Vote History</p>
              <h2>Tracked Bill Votes</h2>
            </div>

            {trackedVotes.length ? (
              <div class="vote-list">
                {trackedVotes.map((vote) => {
                  const stance = representativeVoteStance(vote, vote.trackedBill);
                  const voteImpact = representativeVoteImpact(vote, vote.trackedBill);
                  const summary =
                    vote.trackedBill.summary ||
                    vote.billSummary?.summary ||
                    vote.billSummary?.description ||
                    "";

                  return (
                    <article class="vote-card">
                      <div class="vote-card-main">
                        <div class="vote-heading">
                          <div class="vote-topline">
                            <strong>
                              <a
                                href={billDetailPath(
                                  vote.trackedBill.code,
                                  vote.billSummary?.sessionyear || vote.sessionyear,
                                )}
                              >
                                {vote.trackedBill.code}
                              </a>
                            </strong>
                          </div>
                          <h3>
                            <a
                              href={billDetailPath(
                                vote.trackedBill.code,
                                vote.billSummary?.sessionyear || vote.sessionyear,
                              )}
                            >
                              {vote.trackedBill.name || vote.title}
                            </a>
                        </h3>
                          {summary && (
                            <div class="tracker-summary">
                              <span>Bill Tracker Summary</span>
                              <p>{summary}</p>
                            </div>
                          )}
                        </div>
                        <div class="vote-copy">
                          <div class:list={["vote-interpretation", stance.className]}>
                            <strong>Representative Vote</strong>
                            <span class:list={["legislator-vote-pill", stance.className]}>
                              {stance.label}
                            </span>
                            {voteImpact && (
                              <p class="vote-impact">{voteImpact}</p>
                            )}
                          </div>
                          <div class="vote-meta">
                            {vote.vote_date && <span>{formatDate(vote.vote_date)}</span>}
                            {vote.motion && <span>{vote.motion}</span>}
                            {vote.trackedBill.issueArea && (
                              <span>{vote.trackedBill.issueArea}</span>
                            )}
                          </div>
                          {(vote.trackedBill.moreInfoUrl ||
                            vote.legiscan_url ||
                            vote.general_court_url) && (
                            <a
                              class="text-link"
                              href={
                                vote.trackedBill.moreInfoUrl ||
                                vote.legiscan_url ||
                                vote.general_court_url
                              }
                            >
                              Bill details
                            </a>
                          )}
                        </div>
                        <div class="vote-pill-stack">
                          {vote.billSummary && (
                            <BillPositionSummary bill={vote.billSummary} />
                          )}
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            ) : (
              <p class="empty">
                No recorded votes currently match the bill tracker.
              </p>
            )}
          </section>
        </div>

        <aside class="stack">
          <section class="panel compact-panel">
            <div class="section-heading">
              <p class="eyebrow">Contact</p>
              <h2>Public Details</h2>
            </div>

            <dl class="detail-list">
              <div>
                <dt>Email</dt>
                <dd>
                  {person.email ? (
                    <a href={contactHref("email", person.email)}>{person.email}</a>
                  ) : (
                    "Not listed"
                  )}
                </dd>
              </div>

              <div>
                <dt>Phone</dt>
                <dd>
                  {person.phone ? (
                    <a href={contactHref("phone", person.phone)}>{person.phone}</a>
                  ) : (
                    "Not listed"
                  )}
                </dd>
              </div>

              <div>
                <dt>Website</dt>
                <dd>
                  {person.website_url ? (
                    <a href={person.website_url}>Open website</a>
                  ) : (
                    "Not listed"
                  )}
                </dd>
              </div>
            </dl>
          </section>

          <section class="panel compact-panel">
            <div class="section-heading">
              <p class="eyebrow">District</p>
              <h2>Towns Served</h2>
            </div>

            {townServiceAreas.length ? (
              <div class="towns-list">
                {townServiceAreas.map((area) => (
                  <article>
                    <h3>{area.district}</h3>
                    <div>
                      {area.towns.map((town) => (
                        <span>{town}</span>
                      ))}
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No towns served are listed yet.</p>
            )}
          </section>

          <section class="panel compact-panel">
            <div class="section-heading">
              <p class="eyebrow">Articles</p>
              <h2>Relevant Coverage</h2>
            </div>

            <ArticleList
              articles={relatedArticles}
              compact={true}
              emptyText="No related articles returned."
            />

            {person.id && (
              <a
                class="text-link"
                href={`/articles?personid=${person.id}&include=relations`}
              >
                Browse all articles
              </a>
            )}
          </section>

          <section class="panel compact-panel">
            <div class="section-heading">
              <p class="eyebrow">Elections</p>
              <h2>Candidacies</h2>
            </div>

            {candidacies.results.length ? (
              <div class="side-list">
                {candidacies.results.map((race) => (
                  <article>
                    <h3>{race.position_title}</h3>
                    <p>{race.election_name}</p>
                    <span>
                      {race.election_date && `${formatDate(race.election_date)} - `}
                      {race.status}
                    </span>
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No candidacy records are listed yet.</p>
            )}
          </section>

          <section class="panel compact-panel">
            <div class="section-heading">
              <p class="eyebrow">Sources</p>
              <h2>Links</h2>
            </div>

            {sourceLinks.length ? (
              <div class="side-list">
                {sourceLinks.map((link) => (
                  <article>
                    <h3>
                      <a href={link.url}>{link.title || link.link_type}</a>
                    </h3>
                    {link.publisher && <p>{link.publisher}</p>}
                  </article>
                ))}
              </div>
            ) : (
              <p class="empty">No source links are listed yet.</p>
            )}
          </section>
        </aside>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .profile-hero {
    align-items: end;
    display: grid;
    gap: 32px;
    grid-template-columns: minmax(180px, 260px) 1fr;
    padding: 40px 0 24px;
  }

  .portrait-card {
    aspect-ratio: 4 / 5;
    background: #d8cfc0;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 8px 8px 0 #1f2933;
    overflow: hidden;
    width: 100%;
  }

  .portrait-card img,
  .portrait-fallback {
    height: 100%;
    width: 100%;
  }

  .portrait-card img {
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  .portrait-card img.portrait-fallback {
    background: transparent;
    box-sizing: border-box;
    object-fit: cover;
    padding: 0;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 10px;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 6.25rem);
    letter-spacing: 0;
    line-height: 0.92;
    margin-bottom: 18px;
  }

  .hero-meta,
  .contact-actions,
  .vote-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .meta-pill,
  .contact-actions a,
  .status-pill,
  .vote-topline span,
  .vote-meta span {
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 7px 10px;
  }

  .meta-pill,
  .vote-meta span {
    background: #fffaf1;
  }

  .party-pill {
    border-color: transparent;
    color: white;
  }

  .party-republican {
    background: #b42318;
  }

  .party-democrat {
    background: #1d4ed8;
  }

  .party-independent {
    background: #5b616e;
  }

  .party-unknown {
    background: #6b4f2a;
  }

  .district-pill {
    border-color: #1f2933;
  }

  .profile-grade-row {
    align-items: center;
    display: flex;
    gap: 14px;
    margin-top: 18px;
  }

  .profile-grade-row p {
    color: #4b5563;
    font-weight: 850;
    line-height: 1.4;
    margin: 0;
  }

  .profile-grade {
    border: 2px solid #1f2933;
    border-radius: 14px;
    box-shadow: 3px 3px 0 #1f2933;
    color: #fefce8;
    display: grid;
    min-width: 82px;
    padding: 10px 12px;
    text-align: center;
  }

  .profile-grade span {
    font-size: 3rem;
    font-weight: 950;
    line-height: 1;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .profile-grade small {
    font-size: 0.66rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    margin-top: 4px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
    text-transform: uppercase;
  }

  .grade-a {
    background: #166534;
  }

  .grade-b {
    background: #65a30d;
  }

  .grade-c {
    background: #ca8a04;
  }

  .grade-d {
    background: #ea580c;
  }

  .grade-f {
    background: #b42318;
  }

  .grade-unknown {
    background: #5b616e;
  }

  .free-stater-pill {
    background: #7f1d1d;
    border-color: #111827;
    box-shadow: 2px 2px 0 #111827;
    color: white;
  }

  .free-stater-pill:hover {
    background: #450a0a;
  }

  .bio {
    color: #4b5563;
    font-size: 1.08rem;
    line-height: 1.65;
    margin: 20px 0 0;
    max-width: 720px;
  }

  .contact-actions {
    margin-top: 22px;
  }

  .contact-actions a {
    background: #1f2933;
    color: white;
    text-decoration: none;
  }

  .summary-strip {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(3, 1fr);
    margin: 18px 0 28px;
  }

  .summary-strip article,
  .panel {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
  }

  .summary-strip article {
    padding: 18px;
  }

  .summary-strip span,
  .detail-list dt {
    color: #6b7280;
    display: block;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .summary-strip strong {
    font-size: 2.2rem;
    line-height: 1;
  }

  .content-grid {
    align-items: start;
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) 360px;
  }

  .stack {
    display: grid;
    gap: 24px;
  }

  .panel {
    padding: 24px;
  }

  .compact-panel {
    padding: 20px;
  }

  .section-heading h2 {
    font-size: 1.55rem;
    line-height: 1.1;
    margin-bottom: 18px;
  }

  .timeline-list,
  .vote-list,
  .side-list,
  .detail-list,
  .towns-list {
    display: grid;
    gap: 12px;
    margin: 0;
  }

  .timeline-item,
  .vote-card,
  .side-list article,
  .detail-list div,
  .towns-list article {
