---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import { getRepresentatives, repName } from "../lib/repsApi";

const q = Astro.url.searchParams.get("q")?.trim() || "";

let houseDistricts = [];
let loadError = "";

try {
  const data = await getRepresentatives({
    q,
    chamber: "House",
    include: "districts",
    limit: 400,
  });
  houseDistricts = groupHouseDistricts(data.representatives || [], q);
} catch (error) {
  loadError = cleanApiError(error?.message) || "Unable to load communities.";
}

function groupHouseDistricts(representatives = [], search = "") {
  const districts = new Map();

  for (const rep of representatives.filter((item) => item.chamber === "House")) {
    const district = rep.raw_district || rep.district || "District not listed";
    const county = rep.county || rep.countycode || "";
    const name = rep.district_label || `NH House District ${formatDistrictNumber(district)}`;
    const key = `${county}-${district}`;
    const towns = townsFor(rep);

    if (!districts.has(key)) {
      districts.set(key, {
        key,
        county,
        district,
        name,
        towns: new Set(),
        reps: [],
      });
    }

    const districtRecord = districts.get(key);
    for (const town of towns) districtRecord.towns.add(town);
    districtRecord.reps.push(rep);
  }

  const needle = search.toLowerCase();
  return [...districts.values()]
    .map((district) => ({
      ...district,
      towns: [...district.towns].sort((a, b) => a.localeCompare(b)),
    }))
    .filter((district) => {
      if (!needle) return true;
      return [
        district.name,
        district.county,
        district.district,
        ...district.towns,
        ...district.reps.map((rep) => repName(rep)),
      ]
        .filter(Boolean)
        .some((value) => String(value).toLowerCase().includes(needle));
    })
    .sort((a, b) => String(a.name).localeCompare(String(b.name), undefined, {
      numeric: true,
    }));
}

function townsFor(rep = {}) {
  const value = rep.towns_represented || rep.townsRepresented || rep.location_text || "";
  if (Array.isArray(value)) return value.map(cleanTown).filter(Boolean);

  return String(value)
    .split(/;|,/)
    .map(cleanTown)
    .filter(Boolean);
}

function cleanTown(value = "") {
  return String(value).trim();
}

function formatDistrictNumber(value = "") {
  const district = String(value).trim();
  if (!district) return "";
  if (/^\d+$/.test(district)) return String(Number(district));
  return district;
}

function cleanApiError(message = "") {
  if (/internal error/i.test(message)) return "Representative directory is temporarily unavailable.";
  return message;
}
---

<html lang="en">
  <head>
    <title>Communities | Civic Commons</title>
    <meta
      name="description"
      content="Search New Hampshire House districts by towns represented."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Communities</p>
        <h1>Explore House districts by towns represented.</h1>

        <form class="search" action="/communities" method="get">
          <input
            type="search"
            name="q"
            value={q}
            placeholder="Search town, county, or district"
          />
          <button type="submit">Search</button>
        </form>
      </section>

      <section class="results">
        <div class="results-heading">
          <h2>{houseDistricts.length} House Districts</h2>
          {q && <a href="/communities">Clear search</a>}
        </div>

        {loadError ? (
          <p class="status-message">{loadError}</p>
        ) : houseDistricts.length ? (
          <div class="district-grid">
            {houseDistricts.map((district) => (
              <article class="district-card">
                <div class="topline">
                  <span>{district.county || "NH"}</span>
                  <span>{district.reps.length} reps</span>
                </div>
                <h3>{district.name}</h3>
                <div class="towns">
                  {district.towns.map((town) => (
                    <a href={`/articles?town=${encodeURIComponent(town)}`}>{town}</a>
                  ))}
                </div>
                <p>
                  {district.reps.map((rep) => repName(rep)).filter(Boolean).join(", ")}
                </p>
              </article>
            ))}
          </div>
        ) : (
          <p class="status-message">No districts found.</p>
        )}
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0 0 24px;
    max-width: 920px;
  }

  .search {
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(0, 1fr) auto;
    max-width: 720px;
  }

  input,
  button {
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-sizing: border-box;
    font: inherit;
    font-weight: 800;
    min-height: 48px;
    padding: 10px 12px;
  }

  button {
    background: #1f2933;
    color: white;
    cursor: pointer;
  }

  .results-heading {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .results-heading h2 {
    font-size: 1.6rem;
    margin: 0;
  }

  .district-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .district-card,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 18px;
  }

  .topline,
  .towns {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .topline span,
  .towns a {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 6px 9px;
    text-decoration: none;
  }

  .district-card h3 {
    font-size: 1.3rem;
    margin: 14px 0 12px;
  }

  .district-card p {
    color: #4b5563;
    font-weight: 800;
    margin: 14px 0 0;
  }

  @media (max-width: 640px) {
    .search {
      grid-template-columns: 1fr;
    }
  }
</style>
