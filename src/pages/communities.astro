---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import {
  communityPath,
  getCountyCommunity,
} from "../lib/communitiesApi";
import { countyImageUrl } from "../lib/communityImages";
import { repName } from "../lib/repsApi";
import { cleanText } from "../lib/text";

const COUNTY_NAMES = [
  "Belknap",
  "Carroll",
  "Cheshire",
  "Coos",
  "Grafton",
  "Hillsborough",
  "Merrimack",
  "Rockingham",
  "Strafford",
  "Sullivan",
];

const q = Astro.url.searchParams.get("q")?.trim() || "";
const articleLimit = Number(Astro.url.searchParams.get("articleLimit") || 3);

let countyGroups = [];
let meta = {};
let loadError = "";

try {
  const data = await getCountyGroups({
    q,
    articleLimit,
  });
  countyGroups = data.counties || [];
  meta = data.meta || {};
} catch (error) {
  loadError = cleanApiError(error?.message) || "Unable to load communities.";
}

async function getCountyGroups({
  q = "",
  articleLimit = 3,
} = {}) {
  const countyResults = await Promise.allSettled(
    COUNTY_NAMES.map(async (county) => {
      const data = await getCountyCommunity(county, {
        body: "house",
        articleLimit,
      });
      return normalizeCountyGroup(data, county);
    }),
  );

  let counties = countyResults
    .filter((result) => result.status === "fulfilled")
    .map((result) => result.value)
    .filter(Boolean);

  if (q) counties = counties.filter((county) => countyMatchesQuery(county, q));

  return {
    counties,
    meta: {
      total: counties.length,
    },
  };
}

function normalizeCountyGroup(data = {}, fallbackCounty = "") {
  const county =
    data.counties?.[0] ||
    data.county ||
    data.community ||
    data.result ||
    data;
  const rawCommunities =
    county.communities ||
    county.districts ||
    county.results ||
    data.communities ||
    data.districts ||
    [];
  const communities = rawCommunities.map((community) => ({
    ...community,
    county: community.county || county.name || county.county || fallbackCounty,
  }));
  const towns =
    county.townsRepresented ||
    county.towns ||
    county.towns_represented ||
    [];
  const representatives =
    county.representatives ||
    county.reps ||
    county.legislators ||
    [];
  const articles =
    county.relatedArticles ||
    county.articles ||
    data.relatedArticles ||
    data.articles ||
    [];

  return {
    county: county.name || county.county || fallbackCounty,
    slug: county.slug || slugify(county.name || county.county || fallbackCounty),
    districtCount: county.districtCount || communities.length,
    representativeCount: county.representativeCount || representatives.length,
    communities,
    towns: new Set([
      ...normalizeTowns(towns),
      ...communities.flatMap((community) => townsFor(community)),
    ]),
    representatives: new Map(
      [
        ...representatives,
        ...communities.flatMap((community) => representativesFor(community)),
      ]
        .filter(Boolean)
        .map((rep) => [rep.personid || rep.id || repName(rep), rep])
        .filter(([key]) => key),
    ),
    articles: [...articles, ...communities.flatMap((community) => articlesFor(community))]
      .filter(Boolean)
      .slice(0, articleLimit),
  };
}

function townsFor(community = {}) {
  const value =
    community.towns ||
    community.towns_represented ||
    community.townsRepresented ||
    community.location_text ||
    "";
  if (Array.isArray(value)) return value.map(cleanTown).filter(Boolean);

  return String(value)
    .split(/;|,/)
    .map(cleanTown)
    .filter(Boolean);
}

function normalizeTowns(value = []) {
  if (Array.isArray(value)) return value.map(cleanTown).filter(Boolean);

  return String(value)
    .split(/;|,/)
    .map(cleanTown)
    .filter(Boolean);
}

function cleanTown(value = "") {
  if (typeof value === "object" && value !== null) {
    return String(value.town || value.name || value.label || "").trim();
  }

  return String(value).trim();
}

function communityName(community = {}) {
  return (
    community.name ||
    community.district_label ||
    community.districtLabel ||
    `${bodyLabel(community.body || community.chamber)} District ${formatDistrictNumber(community.district || community.raw_district || "")}`
  );
}

function bodyLabel(value = "") {
  const normalized = String(value).toLowerCase();
  return normalized === "senate" || normalized === "s" ? "Senate" : "House";
}

function representativesFor(community = {}) {
  return community.representatives || community.reps || community.legislators || [];
}

function articlesFor(community = {}) {
  return community.articles || community.relatedArticles || [];
}

function countyMatchesQuery(county = {}, query = "") {
  const needle = query.toLowerCase();
  const towns = [...county.towns];
  const representatives = [...county.representatives.values()];
  const haystack = [
    county.county,
    ...towns,
    ...county.communities.map(communityName),
    ...representatives.map(repName),
  ]
    .filter(Boolean)
    .join(" ")
    .toLowerCase();

  return haystack.includes(needle);
}

function countyProfilePath(county = {}) {
  return `/communities/counties/${encodeURIComponent(county.slug || slugify(county.county))}`;
}

function townProfilePath(town = "") {
  return `/communities/towns/${encodeURIComponent(town)}`;
}

function slugify(value = "") {
  return String(value)
    .toLowerCase()
    .trim()
    .replace(/['']/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function formatDistrictNumber(value = "") {
  const district = String(value).trim();
  if (!district) return "";
  if (/^\d+$/.test(district)) return String(Number(district));
  return district;
}

function cleanApiError(message = "") {
  if (/internal error/i.test(message)) return "Communities are temporarily unavailable.";
  return message;
}

const total = Number(meta.total || meta.count || countyGroups.length);
---

<html lang="en">
  <head>
    <title>Communities | Civic Commons</title>
    <meta
      name="description"
      content="Search New Hampshire communities by county and towns represented."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Communities</p>
        <h1>Explore communities by county.</h1>

        <form class="search" action="/communities" method="get">
          <input
            type="search"
            name="q"
            value={q}
            placeholder="Search town, county, or district"
          />
          <input type="hidden" name="articleLimit" value={articleLimit} />
          <button type="submit">Search</button>
        </form>
      </section>

      <section class="results">
        <div class="results-heading">
          <h2>{countyGroups.length} Counties</h2>
          {q && <a href="/communities">Clear search</a>}
        </div>

        {loadError ? (
          <p class="status-message">{loadError}</p>
        ) : countyGroups.length ? (
          <div class="county-grid">
            {countyGroups.map((countyGroup) => {
              const towns = [...countyGroup.towns].sort((a, b) => a.localeCompare(b));
              const houseDistricts = countyGroup.communities.filter((community) =>
                !String(community.body || community.chamber).toLowerCase().startsWith("s"),
              );
              const previewDistricts = houseDistricts.slice(0, 8);
              const districtTotal = houseDistricts.length;
              const hiddenDistrictCount = Math.max(
                0,
                districtTotal - previewDistricts.length,
              );
              const profileHref = countyProfilePath(countyGroup);
              const imageUrl = countyImageUrl(countyGroup.county);
              const representativeCount = countyGroup.representatives.size;

              return (
              <article class="county-card">
                <a class="county-image" href={profileHref}>
                  {imageUrl && <img src={imageUrl} alt="" loading="lazy" />}
                  <div>
                    <span>County Profile</span>
                    <h3>{countyGroup.county}</h3>
                  </div>
                </a>

                <div class="county-summary">
                  <p>
                    Explore towns, House districts, legislators, candidates, and
                    local updates connected to {countyGroup.county} County.
                  </p>
                  <div class="county-stats">
                    <span><strong>{towns.length}</strong> Towns</span>
                    <span><strong>{districtTotal}</strong> House districts</span>
                    <span><strong>{representativeCount}</strong> Legislators</span>
                    <span><strong>{countyGroup.articles.length}</strong> Updates</span>
                  </div>
                </div>

                {towns.length > 0 && (
                  <div class="towns">
                    {towns.slice(0, 12).map((town) => (
                      <a href={townProfilePath(town)}>{town}</a>
                    ))}
                    {towns.length > 12 && (
                      <a href={profileHref}>+{towns.length - 12} more</a>
                    )}
                  </div>
                )}

                <div class="district-links">
                  <strong>District profiles</strong>
                  {previewDistricts.map((community) => (
                    <a href={communityPath(community)}>{communityName(community)}</a>
                  ))}
                  {hiddenDistrictCount > 0 && (
                    <a href={profileHref}>+{hiddenDistrictCount} more districts</a>
                  )}
                </div>

                {countyGroup.articles.length > 0 && (
                  <div class="articles">
                    <strong>Recent articles</strong>
                    {countyGroup.articles.map((article) => (
                      <a href={article.url}>{cleanText(article.title)}</a>
                    ))}
                  </div>
                )}
              </article>
              );
            })}
          </div>
        ) : (
          <p class="status-message">No counties found.</p>
        )}

      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0 0 24px;
    max-width: 920px;
  }

  .search {
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(0, 1fr) auto;
    max-width: 720px;
  }

  input,
  button {
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-sizing: border-box;
    font: inherit;
    font-weight: 800;
    min-height: 48px;
    padding: 10px 12px;
  }

  button {
    background: #1f2933;
    color: white;
    cursor: pointer;
  }

  .results-heading {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .results-heading h2 {
    font-size: 1.6rem;
    margin: 0;
  }

  .county-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .county-card,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 18px;
  }

  .county-card {
    display: grid;
    gap: 16px;
    overflow: hidden;
    padding: 0;
  }

  .topline,
  .towns,
  .district-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .county-image {
    align-items: end;
    aspect-ratio: 16 / 8;
    background: #1f2933;
    color: white;
    display: grid;
    overflow: hidden;
    position: relative;
    text-decoration: none;
  }

  .county-image::after {
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.1), rgba(15, 23, 42, 0.82)),
      linear-gradient(90deg, rgba(15, 23, 42, 0.7), rgba(15, 23, 42, 0.15));
    content: "";
    inset: 0;
    position: absolute;
    z-index: 1;
  }

  .county-image img {
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
    z-index: 0;
  }

  .county-image div {
    display: grid;
    gap: 6px;
    padding: 18px;
    position: relative;
    z-index: 2;
  }

  .county-image span {
    color: #fde68a;
    font-size: 0.74rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .county-image h3 {
    color: #fffaf1;
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 0.95;
    margin: 0;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.38);
  }

  .county-summary,
  .towns,
  .district-links,
  .articles {
    margin-left: 18px;
    margin-right: 18px;
  }

  .county-summary {
    display: grid;
    gap: 12px;
  }

  .county-summary p {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 0;
  }

  .county-stats {
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .county-stats span {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    color: #4b5563;
    display: grid;
    font-size: 0.75rem;
    font-weight: 900;
    gap: 2px;
    padding: 10px;
    text-transform: uppercase;
  }

  .county-stats strong {
    color: #1f2933;
    font-size: 1.35rem;
    line-height: 1;
  }

  .topline span,
  .towns a,
  .towns span {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 6px 9px;
    text-decoration: none;
  }

  .county-card h3 {
    font-size: 1.6rem;
    margin: 14px 0 12px;
  }

  .county-card p {
    color: #4b5563;
    font-weight: 800;
    margin: 14px 0 0;
  }

  .district-links {
    border-top: 1px solid #d1d5db;
    margin-top: 16px;
    padding-top: 14px;
  }

  .district-links strong {
    color: #6b4f2a;
    flex-basis: 100%;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .district-links a,
  .district-links span {
    background: #eef0f4;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 6px 9px;
    text-decoration: none;
  }

  .articles {
    border-top: 1px solid #d1d5db;
    display: grid;
    gap: 8px;
    margin-top: 16px;
    padding-top: 14px;
    padding-bottom: 18px;
  }

  .articles strong {
    color: #6b4f2a;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .articles a {
    color: #1f2933;
    font-weight: 800;
    line-height: 1.35;
  }

  .show-more,
  .pagination {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    margin-top: 24px;
  }

  .show-more a,
  .pagination a {
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    padding: 10px 14px;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .search {
      grid-template-columns: 1fr;
    }
  }
</style>
