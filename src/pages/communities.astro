---
export const prerender = false;

import { env } from "cloudflare:workers";
import TopNav from "../components/TopNav.astro";

const db = env.cvc;
const q = Astro.url.searchParams.get("q")?.trim() || "";

const houseDistricts = await db
  .prepare(`
    SELECT *
    FROM divisions
    WHERE type = 'house_district'
      AND (
        ? = ''
        OR name LIKE '%' || ? || '%'
        OR county LIKE '%' || ? || '%'
        OR towns_represented LIKE '%' || ? || '%'
      )
    ORDER BY county, district, name
    LIMIT 200
  `)
  .bind(q, q, q, q)
  .all();

function townsFor(district = {}) {
  return String(district.towns_represented || "")
    .split(";")
    .map((town) => town.trim())
    .filter(Boolean);
}
---

<html lang="en">
  <head>
    <title>Communities | Civic Commons</title>
    <meta
      name="description"
      content="Search New Hampshire House districts by towns represented."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Communities</p>
        <h1>Explore House districts by towns represented.</h1>

        <form class="search" action="/communities" method="get">
          <input
            type="search"
            name="q"
            value={q}
            placeholder="Search town, county, or district"
          />
          <button type="submit">Search</button>
        </form>
      </section>

      <section class="results">
        <div class="results-heading">
          <h2>{houseDistricts.results.length} House Districts</h2>
          {q && <a href="/communities">Clear search</a>}
        </div>

        {houseDistricts.results.length ? (
          <div class="district-grid">
            {houseDistricts.results.map((district) => (
              <article class="district-card">
                <div class="topline">
                  <span>{district.county || "NH"}</span>
                  {district.seats && <span>{district.seats} seats</span>}
                </div>
                <h3>
                  <a href={`/nh/${district.slug}`}>{district.name}</a>
                </h3>
                <div class="towns">
                  {townsFor(district).map((town) => (
                    <a href={`/articles?town=${encodeURIComponent(town)}`}>{town}</a>
                  ))}
                </div>
                {district.floterial && (
                  <p>{district.floterial === "True" ? "Floterial district" : "Local district"}</p>
                )}
              </article>
            ))}
          </div>
        ) : (
          <p class="status-message">No districts found.</p>
        )}
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0 0 24px;
    max-width: 920px;
  }

  .search {
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(0, 1fr) auto;
    max-width: 720px;
  }

  input,
  button {
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-sizing: border-box;
    font: inherit;
    font-weight: 800;
    min-height: 48px;
    padding: 10px 12px;
  }

  button {
    background: #1f2933;
    color: white;
    cursor: pointer;
  }

  .results-heading {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .results-heading h2 {
    font-size: 1.6rem;
    margin: 0;
  }

  .district-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .district-card,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 18px;
  }

  .topline,
  .towns {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .topline span,
  .towns a {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 6px 9px;
    text-decoration: none;
  }

  .district-card h3 {
    font-size: 1.3rem;
    margin: 14px 0 12px;
  }

  .district-card p {
    color: #4b5563;
    font-weight: 800;
    margin: 14px 0 0;
  }

  @media (max-width: 640px) {
    .search {
      grid-template-columns: 1fr;
    }
  }
</style>
