---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import { communityPath, getCommunities } from "../lib/communitiesApi";
import { repName, repSlug } from "../lib/repsApi";

const q = Astro.url.searchParams.get("q")?.trim() || "";
const body = Astro.url.searchParams.get("body")?.trim() || "house";
const limit = Number(Astro.url.searchParams.get("limit") || 25);
const offset = Number(Astro.url.searchParams.get("offset") || 0);
const articleLimit = Number(Astro.url.searchParams.get("articleLimit") || 3);

let communities = [];
let meta = {};
let loadError = "";

try {
  const data = await getCommunities({
    q,
    body,
    limit,
    offset,
    articleLimit,
  });
  communities = data.communities || [];
  meta = data.meta || {};
} catch (error) {
  loadError = cleanApiError(error?.message) || "Unable to load communities.";
}

function townsFor(community = {}) {
  const value =
    community.towns ||
    community.towns_represented ||
    community.townsRepresented ||
    community.location_text ||
    "";
  if (Array.isArray(value)) return value.map(cleanTown).filter(Boolean);

  return String(value)
    .split(/;|,/)
    .map(cleanTown)
    .filter(Boolean);
}

function cleanTown(value = "") {
  if (typeof value === "object" && value !== null) {
    return String(value.town || value.name || value.label || "").trim();
  }

  return String(value).trim();
}

function communityName(community = {}) {
  return (
    community.name ||
    community.district_label ||
    community.districtLabel ||
    `${bodyLabel()} District ${formatDistrictNumber(community.district || community.raw_district || "")}`
  );
}

function communityBody(community = {}) {
  return String(community.body || community.chamber || body || "").toLowerCase();
}

function bodyLabel(value = body) {
  return String(value).toLowerCase() === "senate" ? "Senate" : "House";
}

function representativesFor(community = {}) {
  return community.representatives || community.reps || community.legislators || [];
}

function articlesFor(community = {}) {
  return community.articles || community.relatedArticles || [];
}

function formatDistrictNumber(value = "") {
  const district = String(value).trim();
  if (!district) return "";
  if (/^\d+$/.test(district)) return String(Number(district));
  return district;
}

function cleanApiError(message = "") {
  if (/internal error/i.test(message)) return "Communities are temporarily unavailable.";
  return message;
}

function pageUrl(nextOffset) {
  const params = new URLSearchParams();
  if (q) params.set("q", q);
  if (body) params.set("body", body);
  params.set("limit", String(limit));
  params.set("offset", String(nextOffset));
  params.set("articleLimit", String(articleLimit));
  return `/communities?${params.toString()}`;
}

function showMoreUrl() {
  const params = new URLSearchParams();
  if (q) params.set("q", q);
  if (body) params.set("body", body);
  params.set("limit", String(limit + 25));
  params.set("offset", "0");
  params.set("articleLimit", String(articleLimit));
  return `/communities?${params.toString()}`;
}

const total = Number(meta.total || meta.count || communities.length);
const hasPrevious = offset > 0;
const hasNext = communities.length === limit && (!total || offset + limit < total);
---

<html lang="en">
  <head>
    <title>Communities | Civic Commons</title>
    <meta
      name="description"
      content="Search New Hampshire House districts by towns represented."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Communities</p>
        <h1>Explore districts by towns represented.</h1>

        <form class="search" action="/communities" method="get">
          <input
            type="search"
            name="q"
            value={q}
            placeholder="Search town, county, or district"
          />
          <select name="body" aria-label="Legislative body">
            <option value="house" selected={body === "house"}>House</option>
            <option value="senate" selected={body === "senate"}>Senate</option>
          </select>
          <input type="hidden" name="limit" value={limit} />
          <input type="hidden" name="offset" value="0" />
          <input type="hidden" name="articleLimit" value={articleLimit} />
          <button type="submit">Search</button>
        </form>
      </section>

      <section class="results">
        <div class="results-heading">
          <h2>{total || communities.length} {bodyLabel()} Districts</h2>
          {(q || body !== "house") && <a href="/communities">Clear search</a>}
        </div>

        {loadError ? (
          <p class="status-message">{loadError}</p>
        ) : communities.length ? (
          <div class="district-grid">
            {communities.map((community) => {
              const towns = townsFor(community);
              const representatives = representativesFor(community);
              const articles = articlesFor(community);

              const detailHref = communityPath(community);

              return (
              <article class="district-card">
                <div class="topline">
                  <span>{community.county || community.countycode || "NH"}</span>
                  <span>{bodyLabel(communityBody(community))}</span>
                  {representatives.length > 0 && <span>{representatives.length} reps</span>}
                </div>

                <h3>
                  <a href={detailHref}>{communityName(community)}</a>
                </h3>

                {towns.length > 0 && (
                  <div class="towns">
                    {towns.map((town) => (
                      <a href={`/articles?town=${encodeURIComponent(town)}`}>{town}</a>
                    ))}
                  </div>
                )}

                {representatives.length > 0 && (
                  <div class="representatives">
                    {representatives.map((rep) => (
                      <a href={`/people/${repSlug(rep)}`}>{repName(rep)}</a>
                    ))}
                  </div>
                )}

                {articles.length > 0 && (
                  <div class="articles">
                    <strong>Recent articles</strong>
                    {articles.map((article) => (
                      <a href={article.url}>{article.title}</a>
                    ))}
                  </div>
                )}

                <a class="card-link" href={detailHref}>View community profile</a>
              </article>
              );
            })}
          </div>
        ) : (
          <p class="status-message">No districts found.</p>
        )}

        {hasNext && (
          <div class="show-more">
            <a href={showMoreUrl()}>Show more</a>
          </div>
        )}

        {hasPrevious && (
          <div class="pagination">
            {hasPrevious && <a href={pageUrl(Math.max(0, offset - limit))}>Previous</a>}
          </div>
        )}
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0 0 24px;
    max-width: 920px;
  }

  .search {
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(0, 1fr) auto;
    max-width: 720px;
  }

  input,
  select,
  button {
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-sizing: border-box;
    font: inherit;
    font-weight: 800;
    min-height: 48px;
    padding: 10px 12px;
  }

  select {
    background: white;
  }

  button {
    background: #1f2933;
    color: white;
    cursor: pointer;
  }

  .results-heading {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .results-heading h2 {
    font-size: 1.6rem;
    margin: 0;
  }

  .district-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .district-card,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 18px;
  }

  .district-card {
    display: grid;
  }

  .topline,
  .towns,
  .representatives {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .topline span,
  .towns a,
  .representatives a {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 6px 9px;
    text-decoration: none;
  }

  .representatives {
    margin-top: 14px;
  }

  .representatives a {
    background: #eef0f4;
  }

  .district-card h3 {
    font-size: 1.3rem;
    margin: 14px 0 12px;
  }

  .district-card p {
    color: #4b5563;
    font-weight: 800;
    margin: 14px 0 0;
  }

  .card-link {
    align-self: end;
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    display: inline-block;
    justify-self: start;
    margin-top: 18px;
    padding: 10px 14px;
    text-decoration: none;
  }

  .articles {
    border-top: 1px solid #d1d5db;
    display: grid;
    gap: 8px;
    margin-top: 16px;
    padding-top: 14px;
  }

  .articles strong {
    color: #6b4f2a;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .articles a {
    color: #1f2933;
    font-weight: 800;
    line-height: 1.35;
  }

  .show-more,
  .pagination {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    margin-top: 24px;
  }

  .show-more a,
  .pagination a {
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    padding: 10px 14px;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .search {
      grid-template-columns: 1fr;
    }
  }
</style>
