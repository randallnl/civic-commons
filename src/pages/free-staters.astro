---
export const prerender = false;

import CandidateCard from "../components/CandidateCard.astro";
import RepresentativeCard from "../components/RepresentativeCard.astro";
import TopNav from "../components/TopNav.astro";
import { getBillSummaries } from "../lib/billsApi";
import { getCandidates, isLegislativeCandidate } from "../lib/candidatesApi";
import { isFreeStater } from "../lib/civicTags";
import { getRepresentatives, repName } from "../lib/repsApi";
import { getTrackedBills } from "../lib/trackedBills";

const freeStateLogoUrl = organizationAssetUrl("freestateprojectlogo.png");
const filterName = cleanFilter(Astro.url.searchParams.get("q"));
const filterType = cleanFilter(Astro.url.searchParams.get("type")) || "all";
const filterBody = cleanFilter(Astro.url.searchParams.get("body")) || "all";
const filterParty = cleanFilter(Astro.url.searchParams.get("party")) || "all";
const filterCounty = cleanFilter(Astro.url.searchParams.get("county"));
const filterDistrict = cleanFilter(Astro.url.searchParams.get("district"));
const filterTown = cleanFilter(Astro.url.searchParams.get("town"));
let trackedBills = new Map();
let billSummaries = new Map();
let freeStaterLegislators = [];
let freeStaterCandidates = [];
let directoryError = "";

try {
  [trackedBills, billSummaries] = await Promise.all([
    getTrackedBills(),
    getBillSummaries(),
  ]);
} catch (error) {
  console.error(error?.message || "Unable to load vote context.");
}

try {
  const [houseData, senateData, houseGradeData, senateGradeData, candidateData] = await Promise.all([
    getRepresentatives({ body: "house", include: "votes", limit: 500 }),
    getRepresentatives({ body: "senate", include: "votes", limit: 50 }),
    getRepresentatives({ body: "house", limit: 500 }),
    getRepresentatives({ body: "senate", limit: 50 }),
    getCandidates({ electionYear: 2026, limit: 800 }),
  ]);

  const gradeLookup = new Map(
    [
      ...(houseGradeData.representatives || []),
      ...(senateGradeData.representatives || []),
    ].map((rep) => [repKey(rep), rep]),
  );

  freeStaterLegislators = [
    ...(houseData.representatives || []),
    ...(senateData.representatives || []),
  ]
    .map((rep) => {
      const gradeRep = gradeLookup.get(repKey(rep));
      return {
        ...rep,
        alignment_percent:
          rep.alignment_percent ??
          rep.alignmentPercent ??
          gradeRep?.alignment_percent ??
          gradeRep?.alignmentPercent,
      };
    })
    .filter(isFreeStater)
    .sort((a, b) => repName(a).localeCompare(repName(b)));

  freeStaterCandidates = (candidateData.candidates || [])
    .filter((candidate) => isLegislativeCandidate(candidate) && isFreeStater(candidate))
    .sort((a, b) =>
      String(a.name || `${a.candidateFirstName || ""} ${a.candidateLastName || ""}`)
        .localeCompare(String(b.name || `${b.candidateFirstName || ""} ${b.candidateLastName || ""}`)),
    );
} catch (error) {
  directoryError = error?.message || "Unable to load Free Stater directory.";
}

const countyOptions = uniqueOptions([
  ...freeStaterLegislators.map(countyForRep),
  ...freeStaterCandidates.map((candidate) => candidate.county),
]);
const districtOptions = uniqueOptions([
  ...freeStaterLegislators.map(districtForRep),
  ...freeStaterCandidates.map((candidate) => candidate.district && `District ${candidate.district}`),
]);
const townOptions = uniqueOptions([
  ...freeStaterLegislators.flatMap(townsForRep),
  ...freeStaterCandidates.flatMap(townsForCandidate),
]);

const filteredFreeStaterLegislators = freeStaterLegislators.filter(matchesLegislatorFilters);
const filteredFreeStaterCandidates = freeStaterCandidates.filter(matchesCandidateFilters);

function organizationAssetUrl(filename = "") {
  return `/api/organization-assets/${String(filename)
    .split("/")
    .map((part) => encodeURIComponent(part))
    .join("/")}`;
}

function repKey(rep = {}) {
  return String(
    rep.personid ||
      rep.id ||
      rep.employeeno ||
      rep.slug ||
      repName(rep),
  ).toLowerCase();
}

function cleanFilter(value = "") {
  return String(value || "").trim();
}

function matchesLegislatorFilters(rep = {}) {
  if (filterType === "candidates") return false;
  if (!matchesText(repName(rep), filterName)) return false;
  if (!matchesBody(bodyForRep(rep), filterBody)) return false;
  if (!matchesParty(rep.party, filterParty)) return false;
  if (!matchesText(countyForRep(rep), filterCounty)) return false;
  if (!matchesText(districtForRep(rep), filterDistrict)) return false;
  if (filterTown && !townsForRep(rep).some((town) => matchesText(town, filterTown))) return false;
  return true;
}

function matchesCandidateFilters(candidate = {}) {
  if (filterType === "legislators") return false;
  if (!matchesText(candidateDisplayName(candidate), filterName)) return false;
  if (!matchesBody(candidate.office, filterBody)) return false;
  if (!matchesParty(candidate.politicalParty, filterParty)) return false;
  if (!matchesText(candidate.county, filterCounty)) return false;
  if (!matchesText(candidate.district && `District ${candidate.district}`, filterDistrict)) return false;
  if (filterTown && !townsForCandidate(candidate).some((town) => matchesText(town, filterTown))) return false;
  return true;
}

function candidateDisplayName(candidate = {}) {
  return String(candidate.name || `${candidate.candidateFirstName || ""} ${candidate.candidateLastName || ""}`).trim();
}

function bodyForRep(rep = {}) {
  const value = String(rep.chamber || rep.legislativebody || "").toLowerCase();
  if (value.includes("senate") || value === "s") return "senate";
  return "house";
}

function matchesBody(value = "", filter = "all") {
  if (!filter || filter === "all") return true;
  const normalized = String(value || "").toLowerCase();
  if (filter === "house") return normalized.includes("house") || normalized.includes("representative");
  if (filter === "senate") return normalized.includes("senate") || normalized.includes("senator");
  return true;
}

function matchesParty(value = "", filter = "all") {
  if (!filter || filter === "all") return true;
  const normalized = String(value || "").toLowerCase();
  if (filter === "republican") return normalized === "r" || normalized.includes("republican");
  if (filter === "democrat") return normalized === "d" || normalized.includes("democrat");
  if (filter === "independent") return normalized === "i" || normalized.includes("independent");
  return normalized.includes(filter);
}

function countyForRep(rep = {}) {
  return rep.county || rep.county_name || rep.countyName || countyNameFromDistrict(rep.raw_district || rep.district || "");
}

function countyNameFromDistrict(value = "") {
  const prefix = String(value).trim().split(/\s+/)[0]?.toUpperCase();
  const countyMap = {
    BEL: "Belknap",
    CAR: "Carroll",
    CHE: "Cheshire",
    COO: "Coos",
    GRA: "Grafton",
    HIL: "Hillsborough",
    MER: "Merrimack",
    ROC: "Rockingham",
    STR: "Strafford",
    SUL: "Sullivan",
  };
  return countyMap[prefix] || "";
}

function districtForRep(rep = {}) {
  const district = rep.raw_district || rep.district || "";
  if (!district) return "";
  const body = bodyForRep(rep);
  if (body === "senate") return `District ${district}`;
  return String(district).toUpperCase().includes("DISTRICT")
    ? String(district)
    : `District ${district}`;
}

function townsForRep(rep = {}) {
  return uniqueOptions([
    ...splitList(rep.location_text),
    ...splitList(rep.towns_represented),
    ...splitList(rep.townsRepresented),
  ]);
}

function townsForCandidate(candidate = {}) {
  return uniqueOptions([
    candidate.town,
    candidate.city,
    ...splitList(candidate.towns),
    ...splitList(candidate.townsRepresented),
  ]);
}

function splitList(value = "") {
  if (Array.isArray(value)) return value.map(cleanFilter).filter(Boolean);
  return String(value || "")
    .split(/[,;|]/)
    .map((item) => item.trim())
    .filter(Boolean);
}

function matchesText(value = "", filter = "") {
  if (!filter) return true;
  return String(value || "").toLowerCase().includes(filter.toLowerCase());
}

function uniqueOptions(values = []) {
  return [...new Set(values.flat().map(cleanFilter).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }));
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>What Are Free Staters? | NH Deserves Better</title>
    <meta
      name="description"
      content="Learn what the Free State Project is, why it is controversial, and why it matters in New Hampshire politics."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Civic Glossary</p>
          <h1>What Are Free Staters?</h1>
          <p class="lede">
            The Free State Project is a political movement founded in 2001 with
            the goal of encouraging thousands of libertarian-minded people to move
            to New Hampshire and reshape state government.
          </p>
        </div>
        <div class="hero-logo">
          <img src={freeStateLogoUrl} alt="Free State Project logo" />
        </div>
      </section>

      <article class="content-panel">
        <section>
          <h2>The Movement</h2>
          <p>
            Rather than building a national movement, the project's strategy is
            to concentrate supporters in one state where they can have greater
            influence over elections, legislation, and public policy.
          </p>
          <p>
            Today, many of the movement's participants serve in the New
            Hampshire Legislature, local government, and advocacy organizations,
            making it one of the state's most organized political forces.
          </p>
        </section>

        <section>
          <h2>Why Are Free Staters Controversial?</h2>
          <p>
            Critics argue that the movement has had an outsized influence on New
            Hampshire politics and is working to fundamentally change the role
            of government in the state. They point to efforts to:
          </p>

          <ul>
            <li>Cut funding for public education while expanding school voucher programs</li>
            <li>Reduce business and other state taxes, shifting more of the burden onto local property taxpayers</li>
            <li>Roll back environmental regulations and public health protections</li>
            <li>Reduce funding for healthcare and other public services</li>
            <li>Override local control on issues like housing and zoning</li>
            <li>Advance legislation targeting LGBTQ+ rights, particularly transgender people</li>
            <li>Shrink state government by reducing agencies, programs, and regulations</li>
          </ul>

          <p>
            Critics also argue that highly organized Free State activists have
            helped shift legislative priorities away from issues like affordable
            housing, healthcare costs, workforce shortages, and public
            education, toward ideological and culture-war legislation.
          </p>
        </section>

        <section class="callout">
          <h2>Supporters Say...</h2>
          <p>
            Supporters of the Free State Project argue they are simply
            exercising their right to participate in democracy. They believe
            lower taxes, smaller government, fewer regulations, and greater
            individual freedom make New Hampshire a better place to live and do
            business.
          </p>
        </section>

        <section>
          <h2>Why It Matters</h2>
          <p>
            Whether you support or oppose the Free State Project, its influence
            on New Hampshire politics is significant. Understanding which
            elected officials are aligned with the movement can help voters
            better understand the priorities and policies shaping the state's
            future.
          </p>
        </section>

        <section class="source-note">
          <h2>How We Use This Designation</h2>
          <p>
            On NH Deserves Better, Free Stater designations are based on
            candidate endorsements published by the
            <a href="https://www.nhliberty.org/home/2024-2025-biennium-candidate-endorsements-and-results/">
              New Hampshire Liberty Alliance
            </a>.
            The NH Liberty Alliance describes those endorsements as applying to
            2024 New Hampshire State Representative and State Senator candidates,
            with endorsements for current legislators based on Liberty Ratings
            scores and new candidate endorsements based on its candidate survey.
          </p>
        </section>
      </article>

      <section class="directory-section" id="directory">
        <div class="directory-heading">
          <p class="eyebrow">Directory</p>
          <h2>Free Stater Legislators and Candidates</h2>
          <p>
            These are current New Hampshire state legislators and 2026
            legislative candidates marked with a Free Stater designation in the
            site data. Open a profile to see districts, contact details, votes,
            articles, and community updates.
          </p>
        </div>

        {directoryError && <p class="status-message">{directoryError}</p>}

        <div class="directory-summary">
          <article>
            <span>Current Legislators</span>
            <strong>{filteredFreeStaterLegislators.length}</strong>
            <small>{freeStaterLegislators.length} total</small>
          </article>
          <article>
            <span>2026 Legislative Candidates</span>
            <strong>{filteredFreeStaterCandidates.length}</strong>
            <small>{freeStaterCandidates.length} total</small>
          </article>
        </div>

        <form class="directory-filters" action="/free-staters#directory" method="get">
          <label>
            Name
            <input name="q" value={filterName} placeholder="Search by name" />
          </label>

          <label>
            Show
            <select name="type">
              <option value="all" selected={filterType === "all"}>Legislators and candidates</option>
              <option value="legislators" selected={filterType === "legislators"}>Current legislators</option>
              <option value="candidates" selected={filterType === "candidates"}>2026 candidates</option>
            </select>
          </label>

          <label>
            Body / office
            <select name="body">
              <option value="all" selected={filterBody === "all"}>House and Senate</option>
              <option value="house" selected={filterBody === "house"}>House</option>
              <option value="senate" selected={filterBody === "senate"}>Senate</option>
            </select>
          </label>

          <label>
            Party
            <select name="party">
              <option value="all" selected={filterParty === "all"}>All parties</option>
              <option value="republican" selected={filterParty === "republican"}>Republican</option>
              <option value="democrat" selected={filterParty === "democrat"}>Democrat</option>
              <option value="independent" selected={filterParty === "independent"}>Independent</option>
            </select>
          </label>

          <label>
            County
            <input name="county" value={filterCounty} list="freeStaterCountyOptions" placeholder="County" />
            <datalist id="freeStaterCountyOptions">
              {countyOptions.map((option) => <option value={option} />)}
            </datalist>
          </label>

          <label>
            District
            <input name="district" value={filterDistrict} list="freeStaterDistrictOptions" placeholder="District" />
            <datalist id="freeStaterDistrictOptions">
              {districtOptions.map((option) => <option value={option} />)}
            </datalist>
          </label>

          <label>
            Town / city
            <input name="town" value={filterTown} list="freeStaterTownOptions" placeholder="Town or city" />
            <datalist id="freeStaterTownOptions">
              {townOptions.map((option) => <option value={option} />)}
            </datalist>
          </label>

          <div class="filter-actions">
            <button type="submit">Apply Filters</button>
            <a href="/free-staters#directory">Clear</a>
          </div>
        </form>

        <section class="directory-block">
          <div class="section-heading">
            <h3>Current Legislators</h3>
            <p>
              Profiles include district information, contact details, vote
              grades, and recent tracked bill votes where available.
            </p>
          </div>

          {filteredFreeStaterLegislators.length ? (
            <div class="rep-card-list">
              {filteredFreeStaterLegislators.map((rep) => (
                <RepresentativeCard
                  rep={rep}
                  trackedBills={trackedBills}
                  billSummaries={billSummaries}
                />
              ))}
            </div>
          ) : (
            <p class="empty">No current Free Stater legislators match these filters.</p>
          )}
        </section>

        <section class="directory-block">
          <div class="section-heading">
            <h3>2026 Legislative Candidates</h3>
            <p>
              Candidate profiles include office, district, party, fundraising,
              links, and any connected legislator profile.
            </p>
          </div>

          {filteredFreeStaterCandidates.length ? (
            <div class="candidate-card-list">
              {filteredFreeStaterCandidates.map((candidate) => (
                <CandidateCard candidate={candidate} />
              ))}
            </div>
          ) : (
            <p class="empty">No Free Stater legislative candidates match these filters.</p>
          )}
        </section>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 80px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    align-items: center;
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1fr) minmax(180px, 260px);
    padding: 28px 0 20px;
  }

  .hero-logo {
    align-items: center;
    background: white;
    border: 2px solid #1f2933;
    border-radius: 12px;
    box-shadow: 5px 5px 0 #1f2933;
    display: flex;
    justify-content: center;
    padding: 24px;
  }

  .hero-logo img {
    display: block;
    height: auto;
    max-height: 180px;
    object-fit: contain;
    width: 100%;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.35rem, 6vw, 4.5rem);
    line-height: 0.95;
    margin: 0;
  }

  .lede {
    color: #374151;
    font-size: clamp(1.2rem, 2.4vw, 1.55rem);
    font-weight: 750;
    line-height: 1.45;
    margin: 24px 0 0;
    max-width: 820px;
  }

  .content-panel {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 12px;
    box-shadow: 6px 6px 0 #1f2933;
    display: grid;
    gap: 28px;
    padding: clamp(22px, 4vw, 40px);
  }

  .directory-section {
    display: grid;
    gap: 24px;
    margin-top: 34px;
  }

  .directory-heading {
    max-width: 860px;
  }

  .directory-heading h2 {
    margin-bottom: 12px;
  }

  .directory-summary {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .directory-summary article,
  .directory-block,
  .status-message,
  .empty {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 12px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 18px;
  }

  .directory-summary span {
    color: #6b7280;
    display: block;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .directory-summary strong {
    display: block;
    font-size: 2.6rem;
    line-height: 1;
    margin-top: 8px;
  }

  .directory-summary small {
    color: #6b7280;
    display: block;
    font-weight: 850;
    margin-top: 6px;
  }

  .directory-filters {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 12px;
    box-shadow: 4px 4px 0 #1f2933;
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    padding: 18px;
  }

  .directory-filters label {
    color: #374151;
    display: grid;
    font-size: 0.78rem;
    font-weight: 950;
    gap: 7px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .directory-filters input,
  .directory-filters select {
    border: 1px solid #9ca3af;
    border-radius: 10px;
    color: #1f2933;
    font: inherit;
    font-size: 0.96rem;
    font-weight: 750;
    letter-spacing: 0;
    padding: 10px 11px;
    text-transform: none;
    width: 100%;
  }

  .filter-actions {
    align-items: end;
    display: flex;
    gap: 10px;
  }

  .filter-actions button,
  .filter-actions a {
    border: 2px solid #1f2933;
    border-radius: 999px;
    font: inherit;
    font-weight: 950;
    padding: 10px 13px;
    text-decoration: none;
  }

  .filter-actions button {
    background: #1f2933;
    color: white;
    cursor: pointer;
  }

  .filter-actions a {
    background: white;
    color: #1f2933;
  }

  .directory-block {
    display: grid;
    gap: 18px;
  }

  .directory-block + .directory-block,
  .directory-section section + section {
    border-top: 2px solid #1f2933;
    padding-top: 18px;
  }

  .section-heading h3 {
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    line-height: 1.05;
    margin: 0 0 8px;
  }

  .section-heading p,
  .empty,
  .status-message {
    color: #4b5563;
    font-weight: 750;
    line-height: 1.55;
    margin: 0;
  }

  .rep-card-list,
  .candidate-card-list {
    display: grid;
    gap: 18px;
  }

  .candidate-card-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  section + section {
    border-top: 1px solid #d1d5db;
    padding-top: 28px;
  }

  h2 {
    font-size: clamp(1.45rem, 3vw, 2.15rem);
    line-height: 1.05;
    margin: 0 0 14px;
  }

  p,
  li {
    color: #374151;
    font-size: 1.04rem;
    line-height: 1.65;
  }

  p {
    margin: 0;
  }

  p + p,
  ul + p {
    margin-top: 16px;
  }

  ul {
    display: grid;
    gap: 10px;
    margin: 18px 0 0;
    padding-left: 22px;
  }

  li {
    padding-left: 4px;
  }

  .callout {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    padding: 22px;
  }

  .callout + section {
    border-top: 0;
  }

  @media (max-width: 640px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero-logo {
      justify-self: start;
      max-width: 220px;
      padding: 18px;
    }

    .content-panel {
      box-shadow: 4px 4px 0 #1f2933;
    }

    .directory-summary,
    .directory-filters,
    .candidate-card-list {
      grid-template-columns: 1fr;
    }

    .filter-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .filter-actions a,
    .filter-actions button {
      text-align: center;
    }
  }
</style>
