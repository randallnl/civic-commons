---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import profileIcon from "../assets/profile icon.png";
import { getArticles } from "../lib/articlesApi";
import { billDetailPath, getBills } from "../lib/billsApi";
import { communityPath, getCommunities } from "../lib/communitiesApi";
import { profilePhotoUrl } from "../lib/photos";
import { getRepresentatives, repName, repSlug } from "../lib/repsApi";
import { enrichArticlesWithPreviews } from "../lib/articlePreviews";

const runtimeEnv = Astro.locals.runtime?.env;
const q = Astro.url.searchParams.get("q")?.trim() || "";

let communities = [];
let people = [];
let bills = [];
let articles = [];
let searchError = "";

if (q.length > 0) {
  try {
    const [communityResult, repResult, billResult, articleResult] = await Promise.allSettled([
      getCommunities({ q, body: "", limit: 12, articleLimit: 2, runtimeEnv }),
      getRepresentatives({ q, limit: 20, runtimeEnv }),
      getBills({ q, limit: 20, runtimeEnv }),
      getArticles({ q, include: "relations", limit: 20, runtimeEnv }),
    ]);

    const communityData = communityResult.status === "fulfilled" ? communityResult.value : {};
    const repData = repResult.status === "fulfilled" ? repResult.value : {};
    const billData = billResult.status === "fulfilled" ? billResult.value : {};
    const articleData = articleResult.status === "fulfilled" ? articleResult.value : {};

    communities = communityData.communities || [];
    people = repData.representatives || [];
    bills = billData.bills || [];
    articles = articleData.articles || [];
    if ([communityResult, repResult, billResult, articleResult].some((result) => result.status === "rejected")) {
      searchError = "Some API results are temporarily unavailable.";
    }
  } catch (error) {
    searchError = error?.message || "Unable to load search results.";
  }
}

articles = await enrichArticlesWithPreviews(articles, { limit: 20 });

function communityName(community = {}) {
  return (
    community.name ||
    community.district_label ||
    community.districtLabel ||
    `${bodyLabel(community)} District ${community.district || community.raw_district || ""}`
  );
}

function bodyLabel(community = {}) {
  const value = String(community.chamber || community.body || "").toLowerCase();
  if (value === "senate" || value === "s") return "Senate";
  if (value === "house" || value === "h") return "House";
  return "District";
}

function townsFor(community = {}) {
  const value =
    community.townsRepresented ||
    community.towns ||
    community.towns_represented ||
    "";

  if (Array.isArray(value)) {
    return value
      .map((town) =>
        typeof town === "object" && town !== null
          ? town.town || town.name || town.label
          : town,
      )
      .filter(Boolean);
  }

  return String(value)
    .split(/;|,/)
    .map((town) => town.trim())
    .filter(Boolean);
}

function representativesFor(community = {}) {
  return community.representatives || community.reps || community.legislators || [];
}
---

<html lang="en">
  <head>
    <title>Search Civic Commons</title>
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">← Back home</a>

      <section class="hero">
        <h1>Search Civic Commons</h1>

        <form class="search" action="/search" method="get">
          <input type="search" name="q" value={q} placeholder="Search for a legislator, town, bill, or article" />
          <button type="submit">Search</button>
        </form>
      </section>

      {q.length === 0 ? (
        <p class="empty">Enter a search term to begin.</p>
      ) : (
        <section class="results">
          <p class="summary">Showing results for “{q}”</p>
          {searchError && <p class="empty">{searchError}</p>}

          <div class="group">
            <h2>Communities</h2>
            {communities.length === 0 ? (
              <p>No communities found.</p>
            ) : (
              <ul>
                {communities.map((community) => {
                  const towns = townsFor(community);
                  const representatives = representativesFor(community);

                  return (
                    <li>
                      <a href={communityPath(community)}>
                        <span>
                          <strong>{communityName(community)}</strong>
                          <small>
                            {[
                              bodyLabel(community),
                              community.county,
                              towns.slice(0, 4).join(", "),
                              representatives.length ? `${representatives.length} reps` : "",
                            ]
                              .filter(Boolean)
                              .join(" · ")}
                          </small>
                        </span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>

          <div class="group">
            <h2>Legislators</h2>
            {people.length === 0 ? (
              <p>No legislators found.</p>
            ) : (
              <ul>
                {people.map((person) => {
                  const photoUrl = profilePhotoUrl(person.photo || person.photo_url);

                  return (
                    <li>
                      <a href={`/people/${repSlug(person)}`}>
                        <img
                          class:list={[!photoUrl && "profile-icon"]}
                          src={photoUrl || profileIcon.src}
                          alt=""
                        />
                        <span>
                          <strong>{repName(person)}</strong>
                          <small>{[person.chamber, person.party, person.district].filter(Boolean).join(" · ") || "No details listed"}</small>
                        </span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>

          <div class="group">
            <h2>Bills</h2>
            {bills.length === 0 ? (
              <p>No bills found.</p>
            ) : (
              <ul>
                {bills.map((bill) => (
                  <li>
                    <a href={billDetailPath(bill.condensedbillno || bill.bill_number, bill.sessionyear || bill.session_year)}>
                      <span>
                        <strong>{bill.condensedbillno || bill.bill_number}: {bill.name || bill.title || bill.description}</strong>
                        <small>{bill.status || bill.description || "No status listed"}</small>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <div class="group">
            <h2>Articles</h2>
            {articles.length === 0 ? (
              <p>No articles found.</p>
            ) : (
              <ul>
                {articles.map((article) => (
                  <li>
                    <a href={article.url}>
                      <span>
                        <strong>{article.preview?.title || article.title}</strong>
                        <small>{article.preview?.description || article.publisher || article.resource_type || "Article"}</small>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </section>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    width: min(960px, calc(100% - 32px));
    margin: 0 auto;
    padding: 40px 0;
  }

  .back {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    margin: 40px 0;
  }

  h1 {
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 0.95;
    margin: 0 0 24px;
  }

  .search {
    display: flex;
    gap: 12px;
  }

  .search input {
    flex: 1;
    padding: 16px 18px;
    border: 2px solid #1f2933;
    border-radius: 999px;
    font-size: 1rem;
    background: white;
  }

  .search button {
    border: 2px solid #1f2933;
    background: #1f2933;
    color: white;
    padding: 16px 22px;
    border-radius: 999px;
    font-weight: 800;
    cursor: pointer;
  }

  .summary,
  .empty {
    font-size: 1.15rem;
    color: #4b5563;
  }

  .group {
    background: rgba(255, 255, 255, 0.75);
    border: 2px solid #1f2933;
    border-radius: 24px;
    box-shadow: 6px 6px 0 #1f2933;
    padding: 24px;
    margin: 24px 0;
  }

  .group h2 {
    margin-top: 0;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    border-top: 1px solid #d1d5db;
  }

  li:first-child {
    border-top: 0;
  }

  li a {
    display: flex;
    gap: 14px;
    align-items: center;
    padding: 14px 0;
    color: inherit;
    text-decoration: none;
  }

  img {
    width: 52px;
    height: 52px;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid #1f2933;
  }

  .profile-icon {
    background: transparent;
    box-sizing: border-box;
    object-fit: cover;
    padding: 0;
  }

  strong {
    display: block;
  }

  small {
    display: block;
    margin-top: 4px;
    color: #6b7280;
    text-transform: capitalize;
  }

  @media (max-width: 600px) {
    .search {
      flex-direction: column;
    }
  }
</style>
