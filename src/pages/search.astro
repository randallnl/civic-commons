---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import profileIcon from "../assets/profile icon.png";
import { articlePublishDate, articleSourceName, getArticles } from "../lib/articlesApi";
import { billDetailPath, getBills } from "../lib/billsApi";
import { isFreeStater } from "../lib/civicTags";
import { communityPath, getCommunities } from "../lib/communitiesApi";
import { profilePhotoUrl } from "../lib/photos";
import { getRepresentatives, repName, repSlug } from "../lib/repsApi";
import { enrichArticlesWithPreviews } from "../lib/articlePreviews";
import { cleanText } from "../lib/text";
import { getTrackedBills, normalizeBillCode } from "../lib/trackedBills";

const q = Astro.url.searchParams.get("q")?.trim() || "";

let communities = [];
let people = [];
let bills = [];
let articles = [];
let searchError = "";
let trackedBills = new Map();

if (q.length > 0) {
  try {
    const [communityResult, repResult, billResult, articleResult, trackedBillResult] = await Promise.allSettled([
      getCommunities({ q, body: "", limit: 12, articleLimit: 2 }),
      getRepresentatives({ q, limit: 20 }),
      getBills({ q, limit: 20 }),
      getArticles({ q, include: "relations", limit: 20 }),
      getTrackedBills(),
    ]);

    const communityData = communityResult.status === "fulfilled" ? communityResult.value : {};
    const repData = repResult.status === "fulfilled" ? repResult.value : {};
    const billData = billResult.status === "fulfilled" ? billResult.value : {};
    const articleData = articleResult.status === "fulfilled" ? articleResult.value : {};
    trackedBills = trackedBillResult.status === "fulfilled" ? trackedBillResult.value : new Map();

    communities = communityData.communities || [];
    people = repData.representatives || [];
    bills = billData.bills || [];
    articles = articleData.articles || [];
    if ([communityResult, repResult, billResult, articleResult, trackedBillResult].some((result) => result.status === "rejected")) {
      searchError = "Some API results are temporarily unavailable.";
    }
  } catch (error) {
    searchError = error?.message || "Unable to load search results.";
  }
}

articles = await enrichArticlesWithPreviews(articles, { limit: 20 });

function communityName(community = {}) {
  return (
    community.name ||
    community.district_label ||
    community.districtLabel ||
    `${bodyLabel(community)} District ${community.district || community.raw_district || ""}`
  );
}

function bodyLabel(community = {}) {
  const value = String(community.chamber || community.body || "").toLowerCase();
  if (value === "senate" || value === "s") return "Senate";
  if (value === "house" || value === "h") return "House";
  return "District";
}

function townsFor(community = {}) {
  const value =
    community.townsRepresented ||
    community.towns ||
    community.towns_represented ||
    "";

  if (Array.isArray(value)) {
    return value
      .map((town) =>
        typeof town === "object" && town !== null
          ? town.town || town.name || town.label
          : town,
      )
      .filter(Boolean);
  }

  return String(value)
    .split(/;|,/)
    .map((town) => town.trim())
    .filter(Boolean);
}

function representativesFor(community = {}) {
  return community.representatives || community.reps || community.legislators || [];
}

function trackedBillFor(bill = {}) {
  return trackedBills.get(normalizeBillCode(bill.condensedbillno || bill.bill_number));
}

function previewText(text = "", maxLength = 170) {
  const normalized = cleanText(text).replace(/\s+/g, " ").trim();
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trim()}...`;
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/NH%20DB%20Logo.svg" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.svg" />
    <title>Search NH Deserves Better</title>
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <h1>Search NH Deserves Better</h1>

        <form class="search" action="/search" method="get">
          <input type="search" name="q" value={q} placeholder="Search for a legislator, town, bill, or article" />
          <button type="submit">Search</button>
        </form>
      </section>

      {q.length === 0 ? (
        <p class="empty">Enter a search term to begin.</p>
      ) : (
        <section class="results">
          <p class="summary">Showing results for “{q}”</p>
          {searchError && <p class="empty">{searchError}</p>}

          <div class="group">
            <h2>Communities</h2>
            {communities.length === 0 ? (
              <p>No communities found.</p>
            ) : (
              <ul>
                {communities.map((community) => {
                  const towns = townsFor(community);
                  const representatives = representativesFor(community);

                  return (
                    <li>
                      <a href={communityPath(community)}>
                        <span>
                          <strong>{communityName(community)}</strong>
                          <small>
                            {[
                              bodyLabel(community),
                              community.county,
                              towns.slice(0, 4).join(", "),
                              representatives.length ? `${representatives.length} reps` : "",
                            ]
                              .filter(Boolean)
                              .join(" · ")}
                          </small>
                        </span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>

          <div class="group">
            <h2>Legislators</h2>
            {people.length === 0 ? (
              <p>No legislators found.</p>
            ) : (
              <ul>
                {people.map((person) => {
                  const photoUrl = profilePhotoUrl(person.photo || person.photo_url);

                  return (
                    <li>
                      <div class="person-result-row">
                        <a class="person-result-link" href={`/people/${repSlug(person)}`}>
                          <img
                            class:list={[!photoUrl && "profile-icon"]}
                            src={photoUrl || profileIcon.src}
                            alt=""
                          />
                          <span>
                            <strong>{repName(person)}</strong>
                            <small>
                              {[
                                person.chamber,
                                person.party,
                                person.district,
                              ].filter(Boolean).join(" · ") || "No details listed"}
                            </small>
                          </span>
                        </a>
                        {isFreeStater(person) && (
                          <a
                            class="free-stater-inline"
                            href="/free-staters"
                            title="What is a Free Stater?"
                            aria-label="What is a Free Stater?"
                          >
                            Free Stater
                          </a>
                        )}
                      </div>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>

          <div class="group">
            <h2>Bills</h2>
            {bills.length === 0 ? (
              <p>No bills found.</p>
            ) : (
              <ul>
                {bills.map((bill) => {
                  const trackedBill = trackedBillFor(bill);

                  return (
                    <li>
                      <a href={billDetailPath(bill.condensedbillno || bill.bill_number, bill.sessionyear || bill.session_year)}>
                        <span>
                          <strong>
                            {bill.condensedbillno || bill.bill_number}: {bill.name || bill.title || trackedBill?.name || "Tracked bill"}
                          </strong>
                          <small>
                            {previewText(
                              bill.summary ||
                                trackedBill?.summary ||
                                bill.description ||
                                bill.status ||
                                "No tracker summary available yet.",
                            )}
                          </small>
                        </span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>

          <div class="group">
            <h2>Articles</h2>
            {articles.length === 0 ? (
              <p>No articles found.</p>
            ) : (
              <ul>
                {articles.map((article) => (
                  <li>
                    <a href={article.url}>
                      <span>
                        <strong>{cleanText(article.preview?.title || article.title)}</strong>
                        <small>
                          {[articleSourceName(article), articlePublishDate(article)]
                            .filter(Boolean)
                            .join(" - ")}
                        </small>
                        <small>{previewText(article.preview?.description || article.publisher || article.resource_type || "Article")}</small>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </section>
      )}
    </main>
    <SiteFooter />
  </body>
</html>

<style>
  .back {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    margin: 24px 0 40px;
  }

  h1 {
    font-size: clamp(2.15rem, 5.25vw, 3.9rem);
    line-height: 0.95;
    margin: 0 0 24px;
  }

  .search {
    display: flex;
    gap: 12px;
  }

  .search input {
    flex: 1;
    padding: 16px 18px;
    border: 1px solid #e2e8f0;
    border-radius: 999px;
    font-size: 1rem;
    background: white;
  }

  .search button {
    border: 1px solid #e2e8f0;
    background: #1f2933;
    color: white;
    padding: 16px 22px;
    border-radius: 999px;
    font-weight: 800;
    cursor: pointer;
  }

  .summary,
  .empty {
    font-size: 1.15rem;
    color: #4b5563;
  }

  .group {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    box-shadow: none;
    padding: 24px;
    margin: 24px 0;
  }

  .group h2 {
    margin-top: 0;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    border-top: 1px solid #d1d5db;
  }

  li:first-child {
    border-top: 0;
  }

  li a,
  .person-result-row {
    color: inherit;
    text-decoration: none;
  }

  li a,
  .person-result-link {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  li a {
    padding: 14px 0;
  }

  .person-result-row {
    align-items: center;
    display: flex;
    gap: 14px;
    justify-content: space-between;
    padding: 14px 0;
  }

  .person-result-link {
    min-width: 0;
  }

  img {
    width: 52px;
    height: 52px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid #e2e8f0;
  }

  .profile-icon {
    background: transparent;
    box-sizing: border-box;
    object-fit: cover;
    padding: 0;
  }

  strong {
    display: block;
  }

  small {
    display: block;
    margin-top: 4px;
    color: #6b7280;
  }

  .free-stater-inline {
    background: #7f1d1d;
    border: 1px solid #111827;
    border-radius: 999px;
    box-shadow: none;
    color: white;
    display: inline-block;
    font-size: 0.74rem;
    font-weight: 900;
    margin-top: 8px;
    padding: 4px 8px;
    text-decoration: none;
  }

  .free-stater-inline:hover {
    background: #450a0a;
  }

  @media (max-width: 600px) {
    .search {
      flex-direction: column;
    }
  }
</style>
