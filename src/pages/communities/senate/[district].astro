---
export const prerender = false;

import CommunityProfile from "../../../components/CommunityProfile.astro";
import { getCandidates } from "../../../lib/candidatesApi";
import { getSenateCommunity } from "../../../lib/communitiesApi";

const { district = "" } = Astro.params;
const articleLimit = Number(Astro.url.searchParams.get("articleLimit") || 10);

let community = null;
let meta = {};
let error = "";

try {
  const [data, candidateData] = await Promise.all([
    getSenateCommunity(district, { articleLimit }),
    getCandidates({
      office: "State Senate",
      district,
      electionYear: 2026,
      limit: 100,
    }).catch(() => null),
  ]);
  community = normalizeSenateProfile(data.community || data, candidateData?.candidates || []);
  meta = data.meta || {};
} catch (loadError) {
  error = loadError?.message || "Unable to load community profile.";
}

function normalizeSenateProfile(community = {}, directoryCandidates = []) {
  return {
    ...community,
    body: community.body || "S",
    chamber: community.chamber || "Senate",
    profileLabel: community.profileLabel || "Senate District",
    representatives:
      community.representatives ||
      community.reps ||
      community.legislators ||
      community.senators ||
      [],
    candidates: uniqueCandidates([
      ...(community.candidates || []),
      ...directoryCandidates,
      ...(community.candidateSummary?.candidates || []),
      ...(community.groups?.candidates?.senate || []),
      ...(community.groups?.candidates?.house || []),
    ]),
  };
}

function uniqueCandidates(candidates = []) {
  const seen = new Set();

  return candidates.filter((candidate) => {
    if (!candidate || typeof candidate !== "object") return false;
    const key = [
      candidate.slug,
      candidate.filerEntityNumber,
      candidate.name,
      candidate.candidateFirstName,
      candidate.candidateLastName,
      candidate.office,
      candidate.district,
    ]
      .filter(Boolean)
      .join("|");

    if (!key || seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}
---

<CommunityProfile community={community} meta={meta} error={error} />
