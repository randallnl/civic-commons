---
export const prerender = false;

import CommunityProfile from "../../../components/CommunityProfile.astro";
import { getTownCommunity } from "../../../lib/communitiesApi";

const { town = "" } = Astro.params;
const articleLimit = Number(Astro.url.searchParams.get("articleLimit") || 10);
const runtimeEnv = Astro.locals.runtime?.env;

let community = null;
let meta = {};
let error = "";

try {
  const data = await getTownCommunity(town, { articleLimit, runtimeEnv });
  community = normalizeTownProfile(data, town);
  meta = data.meta || {};
} catch (loadError) {
  error = loadError?.message || "Unable to load town profile.";
}

function normalizeTownProfile(data = {}, fallbackTown = "") {
  const townData = data.town || data.community || data;
  const name = townData.name || titleCase(decodeURIComponent(fallbackTown));

  return {
    ...townData,
    name,
    profileLabel: "Town Profile",
    townsRepresented: [name],
    districts: data.districts || townData.districts || [],
    representatives:
      data.representatives ||
      townData.representatives ||
      data.reps ||
      [],
    candidates: candidatesForTown(data, townData),
    relatedArticles:
      data.relatedArticles ||
      data.articles ||
      townData.relatedArticles ||
      townData.articles ||
      [],
    representativeCount:
      data.representativeSummary?.count ||
      data.representatives?.length ||
      townData.representativeCount,
  };
}

function candidatesForTown(data = {}, townData = {}) {
  return uniqueCandidates([
    ...(data.candidates || []),
    ...(townData.candidates || []),
    ...(data.candidateSummary?.candidates || []),
    ...(townData.candidateSummary?.candidates || []),
    ...(data.groups?.candidates?.senate || []),
    ...(data.groups?.candidates?.house || []),
    ...findNestedCandidates(data.groups),
    ...findNestedCandidates(townData.groups),
  ]);
}

function findNestedCandidates(value) {
  if (!value) return [];

  if (Array.isArray(value)) {
    return value.flatMap((item) =>
      looksLikeCandidate(item) ? [item] : findNestedCandidates(item),
    );
  }

  if (typeof value === "object") {
    return Object.values(value).flatMap(findNestedCandidates);
  }

  return [];
}

function uniqueCandidates(candidates = []) {
  const seen = new Set();

  return candidates.filter((candidate) => {
    if (!looksLikeCandidate(candidate)) return false;

    const key = [
      candidate.slug,
      candidate.filerEntityNumber,
      candidate.name,
      candidate.candidateFirstName,
      candidate.candidateLastName,
      candidate.office,
      candidate.district,
    ]
      .filter(Boolean)
      .join("|");

    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

function looksLikeCandidate(value) {
  return !!(
    value &&
    typeof value === "object" &&
    (
      value.slug ||
      value.filerEntityNumber ||
      value.candidateFirstName ||
      value.candidateLastName
    ) &&
    (
      value.office ||
      value.officeType ||
      value.politicalParty ||
      value.electionYear
    )
  );
}

function titleCase(value = "") {
  return String(value)
    .split(/-|_/)
    .filter(Boolean)
    .map((part) => `${part.slice(0, 1).toUpperCase()}${part.slice(1)}`)
    .join(" ");
}
---

<CommunityProfile community={community} meta={meta} error={error} />
