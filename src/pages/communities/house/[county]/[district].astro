---
export const prerender = false;

import CommunityProfile from "../../../../components/CommunityProfile.astro";
import { getCandidates } from "../../../../lib/candidatesApi";
import { getHouseCommunity } from "../../../../lib/communitiesApi";

const { county = "", district = "" } = Astro.params;
const articleLimit = Number(Astro.url.searchParams.get("articleLimit") || 10);

let community = null;
let meta = {};
let error = "";

try {
  const countyName = titleCase(county);
  const [data, candidateData] = await Promise.all([
    getHouseCommunity(county, district, { articleLimit }),
    getCandidates({
      office: "State Representative",
      county: countyName,
      district,
      electionYear: 2026,
      limit: 100,
    }).catch(() => null),
  ]);
  community = normalizeHouseProfile(data.community, candidateData?.candidates || []);
  meta = data.meta || {};
} catch (loadError) {
  error = loadError?.message || "Unable to load community profile.";
}

function normalizeHouseProfile(community = {}, directoryCandidates = []) {
  const senators =
    community.senators ||
    community.senateRepresentatives ||
    community.senate_representatives ||
    [];
  const representatives = [
    ...(community.representatives || []),
    ...senators,
  ];

  return {
    ...community,
    county: community.county || titleCase(county),
    representatives,
    representativeCount:
      representatives.length ||
      community.representativeSummary?.count ||
      community.representativeCount,
    candidates: uniqueCandidates([
      ...(community.candidates || []),
      ...directoryCandidates,
      ...(community.groups?.candidates?.senate || []),
      ...(community.groups?.candidates?.house || []),
    ]),
  };
}

function uniqueCandidates(candidates = []) {
  const seen = new Set();

  return candidates.filter((candidate) => {
    if (!candidate || typeof candidate !== "object") return false;
    const key = [
      candidate.slug,
      candidate.filerEntityNumber,
      candidate.name,
      candidate.candidateFirstName,
      candidate.candidateLastName,
      candidate.office,
      candidate.district,
    ]
      .filter(Boolean)
      .join("|");

    if (!key || seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

function titleCase(value = "") {
  return String(value)
    .split(/-|_/)
    .filter(Boolean)
    .map((part) => `${part.slice(0, 1).toUpperCase()}${part.slice(1)}`)
    .join(" ");
}
---

<CommunityProfile community={community} meta={meta} error={error} />
