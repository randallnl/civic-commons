---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import SiteFooter from "../components/SiteFooter.astro";

const pageUrl = Astro.url.searchParams.get("page") || "";
const submitted = Astro.url.searchParams.get("submitted") === "1";
const error = Astro.url.searchParams.get("error") || "";
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/NH%20DB%20Logo.svg" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.svg" />
    <title>Suggest an Update | NH Deserves Better</title>
    <meta
      name="description"
      content="Suggest an update or correction to a page on NH Deserves Better."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href={pageUrl || "/"}>Back to page</a>

      <section class="hero">
        <p class="eyebrow">Suggest an Update</p>
        <h1>Help keep this page accurate.</h1>
        <p class="lede">
          New Hampshire's large legislature requires an equally large response
          from the community. Send a correction, missing detail, useful source,
          article, social post, image note, or suggested edit. The page URL is
          included automatically so the update can be reviewed in context.
        </p>
      </section>

      {submitted ? (
        <section class="status-panel">
          <h2>Thanks for the suggestion.</h2>
          <p>Your update was sent for review.</p>
          <a href={pageUrl || "/"}>Return to the page</a>
        </section>
      ) : (
        <form class="suggest-form" action="/api/suggest-update" method="post">
          {error && <p class="error-message">{error}</p>}

          <label for="pageUrl">Page</label>
          <input
            id="pageUrl"
            name="pageUrl"
            type="url"
            value={pageUrl}
            readonly
            required
          />

          <label for="suggestion">Suggested update</label>
          <textarea
            id="suggestion"
            name="suggestion"
            rows="8"
            placeholder="What should be changed, corrected, or added?"
            required
          ></textarea>

          <label for="otherInfo">Other info <span>Optional</span></label>
          <input
            id="otherInfo"
            name="otherInfo"
            type="text"
            placeholder="Contact info, context, or anything else helpful"
          />

          <button type="submit">Send suggestion</button>
        </form>
      )}
    </main>
    <SiteFooter />
  </body>
</html>

<style>
  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(860px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 850;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    line-height: 0.95;
    margin: 0;
  }

  h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1;
    margin: 0;
  }

  .lede {
    color: #4b5563;
    font-size: clamp(1.12rem, 2.2vw, 1.35rem);
    font-weight: 750;
    line-height: 1.5;
    margin: 22px 0 0;
    max-width: 760px;
  }

  .suggest-form,
  .status-panel {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    box-shadow: none;
    display: grid;
    gap: 14px;
    padding: clamp(20px, 4vw, 32px);
  }

  label {
    font-size: 0.82rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  label span {
    color: #6b7280;
    font-size: 0.74rem;
    letter-spacing: 0;
    text-transform: none;
  }

  input,
  textarea {
    background: #f8fafc;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    box-sizing: border-box;
    color: #1f2933;
    font: inherit;
    padding: 13px 14px;
    width: 100%;
  }

  input[readonly] {
    color: #4b5563;
  }

  textarea {
    min-height: 180px;
    resize: vertical;
  }

  button {
    background: #1f2933;
    border: 1px solid #e2e8f0;
    border-radius: 999px;
    color: white;
    cursor: pointer;
    font: inherit;
    font-weight: 900;
    justify-self: start;
    padding: 13px 18px;
  }

  .status-panel p,
  .error-message {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 0;
  }

  .error-message {
    background: #fee2e2;
    border: 1px solid #b42318;
    border-radius: 10px;
    color: #7f1d1d;
    padding: 12px;
  }
</style>
