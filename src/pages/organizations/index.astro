---
export const prerender = false;

import TopNav from "../../components/TopNav.astro";
import { getOrganizations, organizationPath } from "../../lib/organizationsApi";

let organizations = [];
let error = "";

try {
  organizations = await getOrganizations();
} catch (loadError) {
  error = loadError?.message || "Unable to load organizations.";
}
---

<html lang="en">
  <head>
    <title>Organizations | Civic Commons</title>
    <meta
      name="description"
      content="Browse Civic Commons partner organizations and their bill comments."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Organizations</p>
        <h1>Partner organizations and public comments.</h1>
      </section>

      {error ? (
        <p class="status-message">{error}</p>
      ) : organizations.length ? (
        <section class="org-grid" aria-label="Organizations">
          {organizations.map((organization) => (
            <article class="org-card">
              <a class="logo-wrap" href={organizationPath(organization)}>
                {organization.logoUrl ? (
                  <img src={organization.logoUrl} alt={`${organization.name} logo`} loading="lazy" />
                ) : (
                  <span>{organization.name.slice(0, 1)}</span>
                )}
              </a>

              <div class="org-copy">
                <p class="eyebrow">{organization.type || "Organization"}</p>
                <h2>
                  <a href={organizationPath(organization)}>{organization.name}</a>
                </h2>
                {organization.shortDescription && <p>{organization.shortDescription}</p>}

                <div class="meta-row">
                  {organization.serviceArea && <span>{organization.serviceArea}</span>}
                  {organization.city && <span>{organization.city}, {organization.state}</span>}
                  <span>{organization.comments.length} comments</span>
                </div>
              </div>
            </article>
          ))}
        </section>
      ) : (
        <p class="status-message">No organizations found.</p>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0;
    max-width: 940px;
  }

  .org-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .org-card,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
  }

  .org-card {
    display: grid;
    gap: 18px;
    grid-template-columns: 104px 1fr;
    padding: 18px;
  }

  .logo-wrap {
    align-items: center;
    aspect-ratio: 1;
    background: #fffaf1;
    border: 2px solid #1f2933;
    border-radius: 8px;
    display: flex;
    justify-content: center;
    overflow: hidden;
    text-decoration: none;
  }

  .logo-wrap img {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .logo-wrap span {
    font-size: 2.5rem;
    font-weight: 950;
  }

  .org-copy h2 {
    font-size: 1.5rem;
    margin: 0;
  }

  .org-copy p {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 10px 0 0;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .meta-row span {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .status-message {
    color: #4b5563;
    font-size: 1.05rem;
    font-weight: 800;
    padding: 18px;
  }

  @media (max-width: 860px) {
    .org-grid,
    .org-card {
      grid-template-columns: 1fr;
    }

    .logo-wrap {
      width: 104px;
    }
  }
</style>
