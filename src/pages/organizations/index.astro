---
export const prerender = false;

import TopNav from "../../components/TopNav.astro";
import { getOrganizations, organizationPath } from "../../lib/organizationsApi";

let organizations = [];
let error = "";
const name = Astro.url.searchParams.get("name")?.trim() || "";
const issue = Astro.url.searchParams.get("issue")?.trim() || "";
const town = Astro.url.searchParams.get("town")?.trim() || "";

try {
  organizations = await getOrganizations();
} catch (loadError) {
  error = loadError?.message || "Unable to load organizations.";
}

const organizationOptions = organizations.map((organization) => organization.name).sort((a, b) =>
  a.localeCompare(b),
);
const issueOptions = uniqueOptions(
  organizations.flatMap((organization) => organization.issueAreas || []),
);
const townOptions = uniqueOptions(
  organizations.flatMap((organization) => organization.towns || []),
);
const filteredOrganizations = organizations.filter((organization) =>
  matchesFilter(organization.name, name) &&
  matchesOption(organization.issueAreas || [], issue) &&
  matchesOption(organization.towns || [], town),
);
const hasFilters = Boolean(name || issue || town);

function uniqueOptions(values = []) {
  return [...new Set(values.map((value) => String(value || "").trim()).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b));
}

function matchesFilter(value = "", filter = "") {
  if (!filter) return true;
  return String(value || "").toLowerCase().includes(filter.toLowerCase());
}

function matchesOption(values = [], selected = "") {
  if (!selected) return true;
  return values.some((value) => String(value).toLowerCase() === selected.toLowerCase());
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>Organizations | NH Deserves Better</title>
    <meta
      name="description"
      content="Browse advocacy organizations and organizations making comments on bills."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Organizations</p>
        <h1>Advocacy organizations and bill comments.</h1>
        <p>
          Browse organizations working on New Hampshire policy issues, plus the
          comments they have published on tracked bills.
        </p>
      </section>

      {error ? (
        <p class="status-message">{error}</p>
      ) : organizations.length ? (
        <>
          <form class="filters" method="get" action="/organizations">
            <label>
              <span>Name</span>
              <input
                type="search"
                name="name"
                value={name}
                list="organizationNames"
                placeholder="Start typing an organization"
              />
              <datalist id="organizationNames">
                {organizationOptions.map((option) => <option value={option} />)}
              </datalist>
            </label>

            <label>
              <span>Issue</span>
              <select name="issue">
                <option value="">All issues</option>
                {issueOptions.map((option) => (
                  <option value={option} selected={option === issue}>{option}</option>
                ))}
              </select>
            </label>

            <label>
              <span>Town</span>
              <select name="town">
                <option value="">All towns</option>
                {townOptions.map((option) => (
                  <option value={option} selected={option === town}>{option}</option>
                ))}
              </select>
            </label>

            <div class="filter-actions">
              <button type="submit">Filter</button>
              {hasFilters && <a href="/organizations">Clear</a>}
            </div>
          </form>

          {filteredOrganizations.length ? (
            <section class="org-grid" aria-label="Organizations">
              {filteredOrganizations.map((organization) => (
                <article class="org-card">
                  <a class="logo-wrap" href={organizationPath(organization)}>
                    {organization.logoUrl ? (
                      <img src={organization.logoUrl} alt={`${organization.name} logo`} loading="lazy" />
                    ) : (
                      <span>{organization.name.slice(0, 1)}</span>
                    )}
                  </a>

                  <div class="org-copy">
                    <p class="eyebrow">{organization.type || "Organization"}</p>
                    <h2>
                      <a href={organizationPath(organization)}>{organization.name}</a>
                    </h2>
                    {organization.shortDescription && <p>{organization.shortDescription}</p>}

                    <div class="meta-row">
                      {organization.serviceArea && <span>{organization.serviceArea}</span>}
                      {organization.city && <span>{organization.city}, {organization.state}</span>}
                      {organization.issueAreas?.slice(0, 2).map((item) => <span>{item}</span>)}
                      <span>{organization.comments.length} comments</span>
                    </div>
                  </div>
                </article>
              ))}
            </section>
          ) : (
            <p class="status-message">No organizations matched those filters.</p>
          )}
        </>
      ) : (
        <p class="status-message">No organizations found.</p>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .hero p:not(.eyebrow) {
    color: #4b5563;
    font-size: 1.08rem;
    font-weight: 800;
    line-height: 1.55;
    margin: 18px 0 0;
    max-width: 780px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0;
    max-width: 940px;
  }

  .filters {
    align-items: end;
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(220px, 1.2fr) minmax(160px, 0.8fr) minmax(160px, 0.8fr) auto;
    margin: 0 0 22px;
    padding: 16px;
  }

  .filters label {
    display: grid;
    gap: 7px;
  }

  .filters span {
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .filters input,
  .filters select {
    appearance: none;
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 6px;
    color: #1f2933;
    font: inherit;
    font-weight: 800;
    min-height: 42px;
    padding: 9px 10px;
    width: 100%;
  }

  .filter-actions {
    align-items: center;
    display: flex;
    gap: 10px;
  }

  .filter-actions button,
  .filter-actions a {
    border-radius: 6px;
    font-weight: 900;
    min-height: 42px;
    padding: 10px 12px;
    text-decoration: none;
  }

  .filter-actions button {
    background: #1f2933;
    border: 2px solid #1f2933;
    color: white;
    cursor: pointer;
  }

  .filter-actions a {
    align-items: center;
    background: #fffaf1;
    border: 1px solid #d1d5db;
    display: inline-flex;
  }

  .org-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .org-card,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
  }

  .org-card {
    display: grid;
    gap: 18px;
    grid-template-columns: 104px 1fr;
    padding: 18px;
  }

  .logo-wrap {
    align-items: center;
    aspect-ratio: 1;
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    display: flex;
    justify-content: center;
    overflow: hidden;
    text-decoration: none;
  }

  .logo-wrap img {
    box-sizing: border-box;
    height: 100%;
    object-fit: contain;
    padding: 8px;
    width: 100%;
  }

  .logo-wrap span {
    font-size: 2.5rem;
    font-weight: 950;
  }

  .org-copy h2 {
    font-size: 1.5rem;
    margin: 0;
  }

  .org-copy p {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 10px 0 0;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .meta-row span {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .status-message {
    color: #4b5563;
    font-size: 1.05rem;
    font-weight: 800;
    padding: 18px;
  }

  @media (max-width: 860px) {
    .filters,
    .org-grid,
    .org-card {
      grid-template-columns: 1fr;
    }

    .logo-wrap {
      width: 104px;
    }
  }
</style>
