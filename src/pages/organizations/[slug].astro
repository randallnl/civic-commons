---
export const prerender = false;

import TopNav from "../../components/TopNav.astro";
import {
  getOrganization,
  normalizeBillCode,
} from "../../lib/organizationsApi";

const { slug = "" } = Astro.params;

let organization = null;
let error = "";

try {
  organization = await getOrganization(slug);
  if (!organization) {
    error = "Organization not found.";
  }
} catch (loadError) {
  error = loadError?.message || "Unable to load organization.";
}

const title = organization?.name || "Organization";
const contactLinks = organization
  ? [
      organization.website && { href: organization.website, label: "Website" },
      organization.email && { href: `mailto:${organization.email}`, label: "Email" },
      organization.facebook && { href: organization.facebook, label: "Facebook" },
      organization.instagram && {
        href: socialUrl(organization.instagram, "https://instagram.com/"),
        label: "Instagram",
      },
      organization.bluesky && {
        href: socialUrl(organization.bluesky, "https://bsky.app/profile/"),
        label: "Bluesky",
      },
    ].filter(Boolean)
  : [];

function socialUrl(value = "", base = "") {
  const text = String(value).trim();
  if (!text) return "";
  if (/^https?:\/\//i.test(text)) return text;
  return `${base}${text.replace(/^@/, "")}`;
}

function positionClass(position = "") {
  const value = String(position).toLowerCase();
  if (value.includes("support")) return "support";
  if (value.includes("oppose")) return "oppose";
  return "neutral";
}
---

<html lang="en">
  <head>
    <title>{title} | Civic Commons</title>
    <meta
      name="description"
      content={`Organization profile and bill comments for ${title}.`}
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/organizations">Back to organizations</a>

      {error ? (
        <p class="status-message">{error}</p>
      ) : organization ? (
        <>
          <section class="hero">
            {organization.bannerImageUrl && (
              <img class="banner" src={organization.bannerImageUrl} alt="" loading="lazy" />
            )}

            <div class="hero-grid">
              <div class="logo-wrap">
                {organization.logoUrl ? (
                  <img src={organization.logoUrl} alt={`${organization.name} logo`} />
                ) : (
                  <span>{organization.name.slice(0, 1)}</span>
                )}
              </div>

              <div>
                <p class="eyebrow">{organization.type || "Organization"}</p>
                <h1>{organization.name}</h1>

                <div class="meta-row">
                  {organization.serviceArea && <span>{organization.serviceArea}</span>}
                  {organization.city && <span>{organization.city}, {organization.state}</span>}
                  {organization.foundedYear && <span>Founded {organization.foundedYear}</span>}
                </div>
              </div>
            </div>
          </section>

          <section class="content-grid">
            <div class="stack">
              <section class="panel">
                <div class="section-heading">
                  <p class="eyebrow">Profile</p>
                  <h2>About</h2>
                </div>

                {organization.mission && <p class="lead">{organization.mission}</p>}
                {organization.shortDescription && <p>{organization.shortDescription}</p>}
              </section>

              <section class="panel">
                <div class="section-heading">
                  <p class="eyebrow">Bill Comments</p>
                  <h2>{organization.comments.length} Comments</h2>
                </div>

                {organization.comments.length ? (
                  <div class="comment-list">
                    {organization.comments.map((comment) => (
                      <article>
                        <div class="comment-topline">
                          <a class="bill-link" href={`/bills/${normalizeBillCode(comment.bill)}`}>
                            {comment.billLabel || comment.bill}
                          </a>
                          {comment.position && (
                            <span class:list={["position-pill", positionClass(comment.position)]}>
                              {comment.position}
                            </span>
                          )}
                        </div>

                        <p>{comment.comment}</p>

                        <div class="comment-meta">
                          {comment.author && <span>{comment.author}</span>}
                          {comment.date && <span>{comment.date}</span>}
                        </div>
                      </article>
                    ))}
                  </div>
                ) : (
                  <p class="empty">No comments have been published yet.</p>
                )}
              </section>
            </div>

            <aside class="panel">
              <div class="section-heading">
                <p class="eyebrow">Contact</p>
                <h2>Organization Links</h2>
              </div>

              {contactLinks.length ? (
                <div class="link-list">
                  {contactLinks.map((link) => (
                    <a href={link.href}>{link.label}</a>
                  ))}
                </div>
              ) : (
                <p class="empty">No public links listed.</p>
              )}

              {organization.phone && (
                <p class="contact-line">
                  <strong>Phone</strong>
                  <span>{organization.phone}</span>
                </p>
              )}
            </aside>
          </section>
        </>
      ) : (
        <p class="status-message">Organization not found.</p>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    display: grid;
    gap: 20px;
    padding: 42px 0 28px;
  }

  .banner {
    aspect-ratio: 4 / 1;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 6px 6px 0 #1f2933;
    display: block;
    object-fit: cover;
    width: 100%;
  }

  .hero-grid {
    align-items: center;
    display: grid;
    gap: 22px;
    grid-template-columns: 132px 1fr;
  }

  .logo-wrap {
    align-items: center;
    aspect-ratio: 1;
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    display: flex;
    justify-content: center;
    overflow: hidden;
  }

  .logo-wrap img {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .logo-wrap span {
    font-size: 3rem;
    font-weight: 950;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.92;
    margin: 0;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .meta-row span,
  .position-pill {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .content-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.38fr);
  }

  .stack,
  .comment-list,
  .link-list {
    display: grid;
    gap: 14px;
  }

  .panel,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 20px;
  }

  .section-heading h2 {
    font-size: 1.45rem;
    margin: 0 0 16px;
  }

  .lead {
    font-size: 1.15rem;
  }

  p,
  .empty,
  .status-message {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  .comment-list article {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 14px;
  }

  .comment-topline {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: space-between;
  }

  .bill-link {
    font-size: 1.05rem;
  }

  .position-pill.support {
    background: #e7f7ec;
    border-color: #86c894;
    color: #166534;
  }

  .position-pill.oppose {
    background: #fee2e2;
    border-color: #fca5a5;
    color: #991b1b;
  }

  .comment-meta {
    color: #6b7280;
    display: flex;
    flex-wrap: wrap;
    font-size: 0.86rem;
    font-weight: 900;
    gap: 10px;
    margin-top: 12px;
  }

  .link-list a {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 10px 12px;
    text-decoration: none;
  }

  .contact-line {
    display: grid;
    gap: 4px;
    margin-top: 18px;
  }

  .contact-line strong {
    color: #1f2933;
  }

  @media (max-width: 820px) {
    .content-grid,
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .logo-wrap {
      width: 132px;
    }
  }
</style>
