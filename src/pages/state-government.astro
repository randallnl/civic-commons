---
export const prerender = false;

import TopNav from "../components/TopNav.astro";
import { getTrackedBills } from "../lib/trackedBills";

let trackedBills = [];
let trackerError = "";
const governmentLevelImages = {
  hero: organizationAssetUrl("Capital banner.png"),
  local: organizationAssetUrl("town landscape.png"),
  school: organizationAssetUrl("school building.png"),
  county: organizationAssetUrl("capital buiulding.png"),
  generalCourt: organizationAssetUrl("nh chamber.jpg"),
  governor: organizationAssetUrl("nh seal.png"),
  congress: organizationAssetUrl("white house.png"),
};

try {
  const billMap = await getTrackedBills();
  const seen = new Set();

  trackedBills = [...billMap.values()]
    .filter((bill) => bill.voteSequence)
    .filter((bill) => {
      const key = `${bill.code}-${bill.voteSequence}`;
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    })
    .slice(0, 4);
} catch (error) {
  trackerError = error?.message || "Unable to load tracked bills.";
}

function organizationAssetUrl(filename = "") {
  return `/api/organization-assets/${String(filename)
    .split("/")
    .map((part) => encodeURIComponent(part))
    .join("/")}`;
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>How New Hampshire State Government Works | NH Deserves Better</title>
    <meta
      name="description"
      content="A plain-language guide to New Hampshire state government, state representatives, state senators, and how their votes affect everyday life."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero" style={`--hero-image: url("${governmentLevelImages.hero}")`}>
        <div class="hero-overlay">
          <p class="eyebrow">Civic Basics</p>
          <h1>New Hampshire state government is closer to your daily life than it looks.</h1>
          <p class="lede">
            Your state representative and state senator vote on schools, housing,
            taxes, healthcare, civil rights, environmental rules, and local
            control. They are also much more accessible than most people realize.
          </p>
          <a class="primary-link" href="/my-state-rep">Find your representatives</a>
        </div>
      </section>

      <section class="levels">
        <div class="section-heading">
          <p class="eyebrow">Levels of Government</p>
          <h2>Who does what?</h2>
        </div>

        <div class="level-grid">
          <article>
            <img class="level-photo" src={governmentLevelImages.local} alt="" loading="lazy" />
            <span>Local</span>
            <h3>Town and city government</h3>
            <p>
              Local officials handle municipal budgets, zoning, roads, public
              safety, libraries, local boards, and many services you see close
              to home.
            </p>
          </article>

          <article>
            <img class="level-photo" src={governmentLevelImages.school} alt="" loading="lazy" />
            <span>School</span>
            <h3>School districts</h3>
            <p>
              School boards and district voters shape local school budgets,
              policies, staffing, facilities, and curriculum decisions.
            </p>
          </article>

          <article>
            <img class="level-photo" src={governmentLevelImages.county} alt="" loading="lazy" />
            <span>County</span>
            <h3>County government</h3>
            <p>
              Counties operate things like nursing homes, correctional
              facilities, sheriffs, registries of deeds, and county budgets.
            </p>
          </article>

          <article class="highlight">
            <img class="level-photo" src={governmentLevelImages.generalCourt} alt="" loading="lazy" />
            <span>State</span>
            <h3>The General Court</h3>
            <p>
              The New Hampshire House and Senate write state law, pass the state
              budget, set statewide rules, and decide how much authority and
              funding flows to local communities.
            </p>
          </article>

          <article>
            <img class="level-photo" src={governmentLevelImages.governor} alt="" loading="lazy" />
            <span>Executive</span>
            <h3>Governor and Executive Council</h3>
            <p>
              The governor signs or vetoes bills. The Executive Council votes on
              major contracts, appointments, and some spending decisions.
            </p>
          </article>

          <article>
            <img class="level-photo" src={governmentLevelImages.congress} alt="" loading="lazy" />
            <span>Federal</span>
            <h3>Congress and federal agencies</h3>
            <p>
              Federal officials handle national laws, federal funding, courts,
              defense, immigration, and programs that operate across states.
            </p>
          </article>
        </div>
      </section>

      <section class="focus-panel">
        <div>
          <p class="eyebrow">Why State Legislators Matter</p>
          <h2>State reps and senators can change your everyday life fast.</h2>
          <p>
            New Hampshire has a large citizen legislature. That means your
            state representative and state senator are often neighbors,
            volunteers, retirees, small business owners, parents, or local
            officials. They usually do not have huge staffs or layers of
            gatekeepers.
          </p>
          <p>
            Their votes can affect property taxes, school funding, rental and
            housing policy, healthcare access, public assistance, environmental
            protections, LGBTQ+ rights, voting rules, and what powers towns and
            cities have to solve local problems.
          </p>
        </div>

        <aside>
          <h3>They are more reachable than you think.</h3>
          <ul>
            <li>Email them about specific bills.</li>
            <li>Ask how they plan to vote before a roll call.</li>
            <li>Submit public testimony from home.</li>
            <li>Attend local forums, town events, or committee hearings.</li>
            <li>Track whether their votes match the priorities they ran on.</li>
          </ul>
        </aside>
      </section>

      <section class="tracked-votes">
        <div class="section-heading">
          <p class="eyebrow">Tracked Votes</p>
          <h2>Recent votes connect state government to real life.</h2>
          <p>
            These examples come from the bill tracker. They show how a roll call
            vote is not just a procedural moment at the State House. It can
            shape public schools, household costs, rights, services, and local
            control.
          </p>
        </div>

        {trackerError ? (
          <p class="status-message">{trackerError}</p>
        ) : (
          <div class="bill-grid">
            {trackedBills.map((bill) => (
              <article>
                <div class="bill-topline">
                  <span>{bill.code}</span>
                  {bill.voteSequence && <span>Vote {bill.voteSequence}</span>}
                </div>
                <h3>{bill.name || bill.code}</h3>
                {bill.summary && <p>{bill.summary}</p>}
                <dl>
                  {bill.preferredStance && (
                    <div>
                      <dt>Preferred stance</dt>
                      <dd>{bill.preferredStance}</dd>
                    </div>
                  )}
                  {bill.yeaInterpretation && (
                    <div>
                      <dt>Yea vote</dt>
                      <dd>{bill.yeaInterpretation}</dd>
                    </div>
                  )}
                  {bill.nayInterpretation && (
                    <div>
                      <dt>Nay vote</dt>
                      <dd>{bill.nayInterpretation}</dd>
                    </div>
                  )}
                </dl>
                {(bill.yeaImpact || bill.nayImpact) && (
                  <div class="impact-box">
                    {bill.yeaImpact && <p><strong>Yea impact:</strong> {bill.yeaImpact}</p>}
                    {bill.nayImpact && <p><strong>Nay impact:</strong> {bill.nayImpact}</p>}
                  </div>
                )}
              </article>
            ))}
          </div>
        )}
      </section>

      <section class="next-step">
        <h2>Start with your own district.</h2>
        <p>
          Once you know your current representatives, you can look at their vote
          grades, recent bill votes, public testimony, related articles, and the
          communities they serve.
        </p>
        <a class="primary-link" href="/my-state-rep">Look up my representatives</a>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 80px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 850;
  }

  .hero {
    align-items: end;
    background:
      linear-gradient(90deg, rgba(17, 24, 39, 0.82), rgba(17, 24, 39, 0.48)),
      var(--hero-image) center / cover;
    border: 2px solid #1f2933;
    border-radius: 12px;
    display: flex;
    min-height: 320px;
    overflow: hidden;
  }

  .hero-overlay {
    padding: clamp(22px, 4.5vw, 40px);
    width: min(980px, 100%);
  }

  .hero .eyebrow,
  .hero h1,
  .hero .lede {
    color: white;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.36);
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.25rem, 5.5vw, 4.5rem);
    line-height: 0.95;
    margin: 0;
    max-width: 1040px;
  }

  h2 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1;
    margin: 0;
  }

  h3 {
    line-height: 1.1;
    margin: 0;
  }

  p,
  li,
  dd {
    color: #374151;
    line-height: 1.58;
  }

  .lede {
    font-size: clamp(1.18rem, 2.4vw, 1.5rem);
    font-weight: 750;
    margin: 24px 0 22px;
    max-width: 860px;
  }

  .primary-link {
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    display: inline-block;
    padding: 14px 20px;
    text-decoration: none;
  }

  .hero .primary-link {
    background: white;
    border-color: white;
    color: #1f2933;
  }

  .levels,
  .focus-panel,
  .tracked-votes,
  .next-step {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 12px;
    box-shadow: 6px 6px 0 #1f2933;
    margin-top: 28px;
    padding: clamp(22px, 4vw, 36px);
  }

  .section-heading {
    margin-bottom: 22px;
    max-width: 820px;
  }

  .section-heading p:last-child {
    font-size: 1.05rem;
    margin: 16px 0 0;
  }

  .level-grid,
  .bill-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, 1fr);
  }

  .level-grid article,
  .bill-grid article,
  .focus-panel aside {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    padding: 18px;
  }

  .level-photo {
    aspect-ratio: 16 / 9;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    display: block;
    margin-bottom: 14px;
    object-fit: cover;
    width: 100%;
  }

  .level-grid article > span,
  .bill-topline span {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #6b4f2a;
    display: inline-block;
    font-size: 0.74rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    margin-bottom: 10px;
    padding: 5px 8px;
    text-transform: uppercase;
  }

  .level-grid .highlight {
    background: #e0f2fe;
    border-color: #0284c7;
  }

  .focus-panel {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
  }

  .focus-panel p {
    font-size: 1.05rem;
  }

  .focus-panel p + p {
    margin-top: 14px;
  }

  .focus-panel ul {
    display: grid;
    gap: 10px;
    margin: 16px 0 0;
    padding-left: 20px;
  }

  .bill-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .bill-grid article > p {
    margin-bottom: 16px;
  }

  dl {
    display: grid;
    gap: 10px;
    margin: 16px 0;
  }

  dt {
    color: #6b7280;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  dd {
    font-weight: 750;
    margin: 2px 0 0;
  }

  .impact-box {
    border-left: 4px solid #1f2933;
    display: grid;
    gap: 8px;
    margin-top: 16px;
    padding-left: 12px;
  }

  .impact-box p {
    margin: 0;
  }

  .status-message {
    color: #4b5563;
    font-weight: 850;
  }

  .next-step p {
    font-size: 1.08rem;
    max-width: 760px;
  }

  @media (max-width: 900px) {
    .level-grid,
    .bill-grid,
    .focus-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
