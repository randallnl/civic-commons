---
export const prerender = false;

import BillPositionSummary from "../../components/BillPositionSummary.astro";
import { getBillDetail, getBillTestimony } from "../../lib/billsApi";

const billCode = Astro.params.bill || "";
const year = Astro.url.searchParams.get("year")?.trim() || "";

let bill = null;
let rollCalls = [];
let testimony = [];
let error = "";

try {
  const [detailData, testimonyData] = await Promise.all([
    getBillDetail(billCode, { year }),
    getBillTestimony(billCode, { year }),
  ]);

  bill = detailData.bill;
  rollCalls = detailData.rollCalls || [];
  testimony = testimonyData.testimony || [];
} catch (loadError) {
  error = loadError?.message || "Unable to load bill details.";
}

function formatDate(value) {
  if (!value) return "";

  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(value));
}

function personName(item) {
  return [item.firstname, item.lastname].filter(Boolean).join(" ");
}

function positionClass(value = "") {
  const position = String(value).toLowerCase();
  if (position === "support") return "support";
  if (position === "oppose") return "oppose";
  return "neutral";
}
---

<html lang="en">
  <head>
    <title>{bill?.condensedbillno || billCode} | Civic Commons</title>
    <meta
      name="description"
      content={`Bill details and testimony for ${bill?.condensedbillno || billCode}.`}
    />
  </head>

  <body>
    <main class="page">
      <a class="back" href="/bills">Back to bills</a>

      {error ? (
        <p class="status-message">{error}</p>
      ) : bill ? (
        <>
          <section class="hero">
            <p class="eyebrow">Bill Detail</p>
            <h1>{bill.condensedbillno}</h1>
            <p>{bill.description || "No status description returned."}</p>

            <div class="hero-meta">
              <span>{bill.sessionyear}</span>
              {bill.legislativebody && <span>{bill.legislativebody}</span>}
              {bill.statusdate && <span>{formatDate(bill.statusdate)}</span>}
            </div>
          </section>

          <section class="summary-grid">
            <article>
              <span>Testimony</span>
              <strong>{bill.testimony_count || 0}</strong>
            </article>
            <article>
              <span>Germane</span>
              <strong>{bill.germane_count || 0}</strong>
            </article>
            <article>
              <span>Non-Germane</span>
              <strong>{bill.nongermane_count || 0}</strong>
            </article>
          </section>

          <section class="panel">
            <div class="section-heading">
              <p class="eyebrow">Position Count</p>
              <h2>Public Testimony Summary</h2>
            </div>
            <BillPositionSummary bill={bill} />
          </section>

          <section class="content-grid">
            <section class="panel">
              <div class="section-heading">
                <p class="eyebrow">Votes</p>
                <h2>Roll Calls</h2>
              </div>

              {rollCalls.length ? (
                <div class="roll-list">
                  {rollCalls.map((rollCall) => (
                    <article>
                      <div class="roll-topline">
                        <strong>{rollCall.question_motion || "Roll call"}</strong>
                        {rollCall.votedate && <span>{formatDate(rollCall.votedate)}</span>}
                      </div>
                      {(rollCall.title1 || rollCall.title2) && (
                        <p>{[rollCall.title1, rollCall.title2].filter(Boolean).join(" ")}</p>
                      )}
                      <div class="roll-counts">
                        <span>Yeas {rollCall.yeas}</span>
                        <span>Nays {rollCall.nays}</span>
                        <span>Present {rollCall.present}</span>
                        <span>Absent {rollCall.absent}</span>
                      </div>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="empty">No roll calls returned.</p>
              )}
            </section>

            <section class="panel">
              <div class="section-heading">
                <p class="eyebrow">Public Input</p>
                <h2>Testimony</h2>
              </div>

              {testimony.length ? (
                <div class="testimony-list">
                  {testimony.map((item) => (
                    <article>
                      <div class="testimony-topline">
                        <strong>{personName(item) || item.whoisname || "Submitted testimony"}</strong>
                        <span class={positionClass(item.expr1)}>{item.expr1 || "neutral"}</span>
                      </div>
                      <p class="testimony-meta">
                        {[item.representing, item.town, item.state]
                          .filter(Boolean)
                          .join(" - ")}
                      </p>
                      {item.committeename && <p>{item.committeename}</p>}
                      {item.committeedate && <small>{formatDate(item.committeedate)}</small>}
                      {item.testimonytext && (
                        <blockquote>{item.testimonytext}</blockquote>
                      )}
                    </article>
                  ))}
                </div>
              ) : (
                <p class="empty">No testimony returned.</p>
              )}
            </section>
          </section>
        </>
      ) : (
        <p class="status-message">Bill not found.</p>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 24px;
  }

  .eyebrow,
  .summary-grid span {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 10px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(3rem, 9vw, 7rem);
    line-height: 0.9;
    margin: 0 0 18px;
  }

  .hero > p {
    color: #4b5563;
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 820px;
  }

  .hero-meta,
  .roll-counts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .hero-meta span,
  .roll-counts span,
  .testimony-topline span {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .summary-grid,
  .content-grid {
    display: grid;
    gap: 18px;
  }

  .summary-grid {
    grid-template-columns: repeat(3, 1fr);
    margin-bottom: 22px;
  }

  .content-grid {
    grid-template-columns: minmax(0, 420px) minmax(0, 1fr);
    margin-top: 22px;
  }

  .summary-grid article,
  .panel,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 20px;
  }

  .summary-grid strong {
    display: block;
    font-size: 2.2rem;
    line-height: 1;
  }

  .section-heading h2 {
    font-size: 1.5rem;
    margin: 0 0 16px;
  }

  .roll-list,
  .testimony-list {
    display: grid;
    gap: 12px;
  }

  .roll-list article,
  .testimony-list article {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 16px;
  }

  .roll-topline,
  .testimony-topline {
    align-items: start;
    display: flex;
    gap: 12px;
    justify-content: space-between;
  }

  .roll-topline span {
    color: #4b5563;
    font-weight: 800;
  }

  .roll-list p,
  .testimony-list p,
  .testimony-meta {
    color: #4b5563;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  .testimony-topline .support {
    background: #e8f3df;
  }

  .testimony-topline .oppose {
    background: #fde8e5;
  }

  .testimony-topline .neutral {
    background: #eef0f4;
  }

  small {
    color: #6b7280;
    display: block;
    font-weight: 800;
    margin-top: 8px;
  }

  blockquote {
    border-left: 4px solid #1f2933;
    color: #1f2933;
    line-height: 1.55;
    margin: 12px 0 0;
    padding-left: 12px;
  }

  .empty {
    color: #4b5563;
    font-weight: 800;
  }

  @media (max-width: 860px) {
    .summary-grid,
    .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
