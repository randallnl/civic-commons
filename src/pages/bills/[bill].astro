---
export const prerender = false;

import BillPositionSummary from "../../components/BillPositionSummary.astro";
import ArticleList from "../../components/ArticleList.astro";
import TopNav from "../../components/TopNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { currentAdminSession } from "../../lib/adminAuth";
import { getBillDetail, getBillTestimony, positionCounts, rollCallPath } from "../../lib/billsApi";
import { getOrganizations, organizationPath } from "../../lib/organizationsApi";
import { cleanText } from "../../lib/text";
import { getTrackedBills, normalizeBillCode } from "../../lib/trackedBills";

const billCode = Astro.params.bill || "";
const year = Astro.url.searchParams.get("year")?.trim() || "";
const adminSession = await currentAdminSession(Astro.request);

let bill = null;
let rollCalls = [];
let testimony = [];
let error = "";
let trackedBill = null;
let relatedArticles = [];
let organizationComments = [];

try {
  const [detailData, testimonyData, trackedBills, organizations] = await Promise.all([
    getBillDetail(billCode, { year }),
    getBillTestimony(billCode, { year }),
    getTrackedBills(),
    getOrganizations(),
  ]);

  bill = detailData.bill;
  rollCalls = detailData.rollCalls || [];
  relatedArticles = detailData.relatedArticles || [];
  testimony = testimonyData.testimony || [];
  trackedBill = trackedBills.get(normalizeBillCode(bill?.condensedbillno || billCode));
  organizationComments = commentsForBill(organizations, bill?.condensedbillno || billCode);
} catch (loadError) {
  error = loadError?.message || "Unable to load bill details.";
}

const testimonyCounts = positionCounts(bill || {});
const sortedRollCalls = [...rollCalls].sort((first, second) => {
  const firstDate = new Date(first.votedate || first.statusdate || 0).getTime() || 0;
  const secondDate = new Date(second.votedate || second.statusdate || 0).getTime() || 0;
  if (firstDate !== secondDate) return secondDate - firstDate;

  return Number(second.votesequencenumber || 0) - Number(first.votesequencenumber || 0);
});
const latestRollCall = sortedRollCalls[0];
const previousRollCalls = sortedRollCalls.slice(1);
const visibleTestimony = testimony.slice(0, 15);
const remainingTestimony = testimony.slice(15);
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;

function formatDate(value) {
  if (!value) return "";

  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(value));
}

function personName(item) {
  const first = cleanNamePart(item.firstname);
  const last = cleanNamePart(item.lastname);
  const lastInitial = last ? `${last.slice(0, 1).toUpperCase()}.` : "";
  return [first, lastInitial].filter(Boolean).join(" ");
}

function positionClass(value = "") {
  const position = String(value).toLowerCase();
  if (position === "support") return "support";
  if (position === "oppose") return "oppose";
  return "neutral";
}

function cleanNamePart(value = "") {
  return String(value).replace(/^[^a-z0-9]+/i, "").trim();
}

function billTitle() {
  return bill?.name || bill?.title || trackedBill?.name || bill?.condensedbillno || billCode;
}

function bodyLabel(value = "") {
  const body = String(value).trim().toUpperCase();
  if (body === "H") return "House";
  if (body === "S") return "Senate";
  return cleanText(value || "Roll call");
}

function rollCallTitle(rollCall = {}) {
  return cleanText(
    rollCall.question_motion ||
      [rollCall.title1, rollCall.title2].filter(Boolean).join(" ") ||
      "Roll call vote",
  );
}

function commentsForBill(organizations = [], code = "") {
  const normalizedCode = normalizeBillCode(code);

  return organizations.flatMap((organization) =>
    (organization.comments || [])
      .filter((comment) => normalizeBillCode(comment.bill || comment.billLabel) === normalizedCode)
      .map((comment) => ({ ...comment, organization })),
  );
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/NH%20DB%20Logo.svg" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.svg" />
    <title>{billTitle()} | NH Deserves Better</title>
    <meta
      name="description"
      content={`Bill details and testimony for ${bill?.condensedbillno || billCode}.`}
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/bills">Back to bills</a>

      {error ? (
        <p class="status-message">{error}</p>
      ) : bill ? (
        <>
          <section class="hero">
            <p class="eyebrow">Bill Detail</p>
            <h1>{bill.condensedbillno}</h1>
            <h2>{billTitle()}</h2>
            {(bill.summary || trackedBill?.summary) && <p>{bill.summary || trackedBill.summary}</p>}

            <div class="hero-meta">
              <span>{bill.sessionyear}</span>
              {bill.legislativebody && <span>{bill.legislativebody}</span>}
              {bill.statusdate && <span>{formatDate(bill.statusdate)}</span>}
            </div>
          </section>

          {adminSession && (
            <section class="panel admin-bill-panel">
              <div class="section-heading">
                <p class="eyebrow">Admin</p>
                <h2>Edit bill text</h2>
              </div>
              <form class="admin-bill-form" action="/api/admin/bills" method="post">
                <input type="hidden" name="redirectTo" value={currentPath} />
                <input type="hidden" name="bill" value={bill.condensedbillno || billCode} />
                <input type="hidden" name="sessionyear" value={bill.sessionyear || year || 2026} />

                <label>
                  Public title
                  <input
                    name="title"
                    value={bill.name || bill.title || trackedBill?.name || ""}
                    placeholder="HB155: Short public-facing title"
                  />
                </label>

                <label>
                  Public summary / description
                  <textarea
                    name="summary"
                    rows="4"
                    placeholder="Plain-language summary shown in previews and bill profiles."
                  >{bill.summary || trackedBill?.summary || ""}</textarea>
                </label>

                <label>
                  Latest action / source description <span>Optional</span>
                  <textarea
                    name="description"
                    rows="3"
                    placeholder="Use only when the D1 source description/latest action needs to be changed."
                  >{bill.description || ""}</textarea>
                </label>

                <div class="admin-form-actions">
                  <button type="submit">Save bill text</button>
                  <a class="secondary-button" href="/admin#bill-admin">Open admin bills</a>
                </div>
              </form>
            </section>
          )}

          <section class="overview-grid">
            <article class="latest-action panel">
              <p class="eyebrow">Latest Action</p>
              <h2>{bill.description || "No action returned."}</h2>
              {bill.statusdate && <span>{formatDate(bill.statusdate)}</span>}
            </article>

            <article class="testimony-total panel">
              <div>
                <span>Testimony</span>
                <strong>{bill.testimony_count || 0}</strong>
              </div>

              <div class="germane-box">
                <span>Germane {bill.germane_count || 0}</span>
                <span>Non-Germane {bill.nongermane_count || 0}</span>
              </div>
            </article>
          </section>

          <section class="vote-summary-grid">
            <section class="panel roll-panel">
              <div class="section-heading">
                <p class="eyebrow">Votes</p>
                <h2>Roll Calls</h2>
              </div>

              {rollCalls.length ? (
                <div class="roll-summary">
                  <a
                    class="roll-card latest-roll"
                    href={rollCallPath(
                      bill.condensedbillno,
                      latestRollCall.votesequencenumber,
                      latestRollCall.sessionyear || bill.sessionyear,
                    )}
                  >
                    <div class="roll-label-row">
                      <span class="roll-badge">Latest roll call</span>
                      <span class="roll-sequence">
                        {bodyLabel(latestRollCall.legislativebody)}
                        {latestRollCall.votesequencenumber && ` #${latestRollCall.votesequencenumber}`}
                      </span>
                    </div>
                    <div class="roll-topline">
                      <strong>{rollCallTitle(latestRollCall)}</strong>
                      {latestRollCall.votedate && <span>{formatDate(latestRollCall.votedate)}</span>}
                    </div>
                    {(latestRollCall.title1 || latestRollCall.title2) && (
                      <p>{[latestRollCall.title1, latestRollCall.title2].filter(Boolean).join(" ")}</p>
                    )}
                    <div class="roll-counts">
                      <span>Yeas {latestRollCall.yeas}</span>
                      <span>Nays {latestRollCall.nays}</span>
                      <span>Present {latestRollCall.present}</span>
                      <span>Absent {latestRollCall.absent}</span>
                    </div>
                    <span class="roll-cta">View roll call history</span>
                  </a>

                  {previousRollCalls.length > 0 && (
                    <details class="roll-details">
                      <summary>
                        <span>See previous roll calls</span>
                        <small>{previousRollCalls.length} older roll call{previousRollCalls.length === 1 ? "" : "s"}</small>
                      </summary>

                      <div class="roll-list">
                        {previousRollCalls.map((rollCall) => (
                          <a
                            class="roll-card"
                            href={rollCallPath(
                              bill.condensedbillno,
                              rollCall.votesequencenumber,
                              rollCall.sessionyear || bill.sessionyear,
                            )}
                          >
                              <div class="roll-label-row">
                                <span class="roll-badge secondary">Roll call</span>
                                <span class="roll-sequence">
                                  {bodyLabel(rollCall.legislativebody)}
                                  {rollCall.votesequencenumber && ` #${rollCall.votesequencenumber}`}
                                </span>
                              </div>
                              <div class="roll-topline">
                                <strong>{rollCallTitle(rollCall)}</strong>
                                {rollCall.votedate && <span>{formatDate(rollCall.votedate)}</span>}
                              </div>
                              {(rollCall.title1 || rollCall.title2) && (
                                <p>{[rollCall.title1, rollCall.title2].filter(Boolean).join(" ")}</p>
                              )}
                              <div class="roll-counts">
                                <span>Yeas {rollCall.yeas}</span>
                                <span>Nays {rollCall.nays}</span>
                                <span>Present {rollCall.present}</span>
                                <span>Absent {rollCall.absent}</span>
                              </div>
                              <span class="roll-cta">View roll call history</span>
                          </a>
                        ))}
                      </div>
                    </details>
                  )}
                </div>
              ) : (
                <p class="empty">No roll calls returned.</p>
              )}
            </section>

            <section class="panel position-panel">
              <div class="section-heading">
                <p class="eyebrow">Position Count</p>
                <h2>Public Testimony Summary</h2>
              </div>
              <BillPositionSummary bill={bill} />
              <div class="testimony-breakdown" aria-label="Public testimony counts">
                <span class="support">
                  <strong>{testimonyCounts.support}</strong>
                  Support
                </span>
                <span class="oppose">
                  <strong>{testimonyCounts.oppose}</strong>
                  Oppose
                </span>
                <span class="neutral">
                  <strong>{testimonyCounts.neutral}</strong>
                  Neutral
                </span>
                <span>
                  <strong>{testimonyCounts.total}</strong>
                  Total
                </span>
              </div>

              <section class="organization-comments-inline">
                <div class="section-heading compact">
                  <p class="eyebrow">Organizations</p>
                  <h2>Organizational Comments</h2>
                </div>

                {organizationComments.length ? (
                  <div class="organization-comment-list">
                    {organizationComments.map((item) => (
                      <article>
                        <div class="organization-comment-topline">
                          <a class="organization-logo" href={organizationPath(item.organization)}>
                            {item.organization.logoUrl ? (
                              <img
                                src={item.organization.logoUrl}
                                alt={`${item.organization.name} logo`}
                                loading="lazy"
                              />
                            ) : (
                              <span>{item.organization.name.slice(0, 1)}</span>
                            )}
                          </a>
                          <div class="organization-comment-heading">
                            <strong>
                              <a href={organizationPath(item.organization)}>
                                {item.organization.name}
                              </a>
                            </strong>
                            <p class="testimony-meta">
                              {[item.author, item.date && formatDate(item.date)]
                                .filter(Boolean)
                                .join(" - ")}
                            </p>
                          </div>
                          <span class={positionClass(item.position)}>{item.position || "neutral"}</span>
                        </div>
                        <p>{item.comment}</p>
                        {item.photoUrl && (
                          <a class="organization-comment-photo" href={item.photoUrl}>
                            <img src={item.photoUrl} alt="" loading="lazy" />
                          </a>
                        )}
                        {item.linkUrl && (
                          <a class="organization-comment-link" href={item.linkUrl}>
                            {item.linkLabel || "Read more"}
                          </a>
                        )}
                      </article>
                    ))}
                  </div>
                ) : (
                  <p class="empty">No organizational comments have been published yet.</p>
                )}
              </section>
            </section>
          </section>

          <section class="content-grid">
            <div class="stack">
              <section class="panel">
                <div class="section-heading">
                  <p class="eyebrow">Articles</p>
                  <h2>Related Coverage</h2>
                </div>

                <ArticleList
                  articles={relatedArticles}
                  compact={true}
                  emptyText="No related articles returned."
                />

                <a
                  class="text-link"
                  href={`/articles?bill=${encodeURIComponent(bill.condensedbillno)}&include=relations`}
                >
                  Browse all bill articles
                </a>
              </section>
            </div>

            <section class="panel">
              <div class="section-heading">
                <p class="eyebrow">Public Input</p>
                <h2>Testimony</h2>
              </div>

              {testimony.length ? (
                <div class="testimony-list">
                  {visibleTestimony.map((item) => (
                    <article>
                      <div class="testimony-topline">
                        <strong>{personName(item) || cleanText(item.whoisname) || "Submitted testimony"}</strong>
                        <span class={positionClass(item.expr1)}>{cleanText(item.expr1 || "neutral")}</span>
                      </div>
                      <p class="testimony-meta">
                        {[item.representing, item.town, item.state].map(cleanText)
                          .filter(Boolean)
                          .join(" - ")}
                      </p>
                      {item.committeename && <p>{cleanText(item.committeename)}</p>}
                      {item.committeedate && <small>{formatDate(item.committeedate)}</small>}
                      {item.testimonytext && (
                        <blockquote>{cleanText(item.testimonytext)}</blockquote>
                      )}
                    </article>
                  ))}

                  {remainingTestimony.length > 0 && (
                    <details class="testimony-more">
                      <summary>
                        <span>Show more testimony</span>
                        <small>{remainingTestimony.length} more submission{remainingTestimony.length === 1 ? "" : "s"}</small>
                      </summary>

                      <div class="testimony-list">
                        {remainingTestimony.map((item) => (
                          <article>
                            <div class="testimony-topline">
                              <strong>{personName(item) || cleanText(item.whoisname) || "Submitted testimony"}</strong>
                              <span class={positionClass(item.expr1)}>{cleanText(item.expr1 || "neutral")}</span>
                            </div>
                            <p class="testimony-meta">
                              {[item.representing, item.town, item.state].map(cleanText)
                                .filter(Boolean)
                                .join(" - ")}
                            </p>
                            {item.committeename && <p>{cleanText(item.committeename)}</p>}
                            {item.committeedate && <small>{formatDate(item.committeedate)}</small>}
                            {item.testimonytext && (
                              <blockquote>{cleanText(item.testimonytext)}</blockquote>
                            )}
                          </article>
                        ))}
                      </div>
                    </details>
                  )}
                </div>
              ) : (
                <p class="empty">No testimony returned.</p>
              )}
            </section>
          </section>
        </>
      ) : (
        <p class="status-message">Bill not found.</p>
      )}
    </main>
    <SiteFooter />
  </body>
</html>

<style>
  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 28px 0 18px;
  }

  .eyebrow,
  .testimony-total span {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 10px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.35rem, 6vw, 4.75rem);
    line-height: 0.9;
    margin: 0 0 18px;
  }

  .hero h2 {
    font-size: clamp(1.65rem, 4vw, 3rem);
    line-height: 1.05;
    margin: 0 0 16px;
    max-width: 960px;
  }

  .hero > p {
    color: #4b5563;
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 820px;
  }

  .hero-meta,
  .roll-counts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .hero-meta span,
  .roll-counts span,
  .testimony-topline span {
    background: #f8fafc;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .overview-grid,
  .vote-summary-grid,
  .content-grid {
    display: grid;
    gap: 18px;
  }

  .overview-grid {
    align-items: stretch;
    grid-template-columns: minmax(0, 1fr) 320px;
    margin-bottom: 22px;
  }

  .content-grid {
    grid-template-columns: minmax(420px, 0.48fr) minmax(0, 0.52fr);
    margin-top: 22px;
  }

  .vote-summary-grid {
    align-items: stretch;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 22px;
  }

  .panel,
  .status-message {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    box-shadow: none;
    padding: 20px;
  }

  .latest-action h2 {
    font-size: 1.35rem;
    line-height: 1.25;
    margin: 0;
  }

  .latest-action span {
    color: #4b5563;
    display: block;
    font-weight: 900;
    margin-top: 14px;
  }

  .testimony-total {
    align-items: end;
    display: grid;
    gap: 14px;
    text-align: right;
  }

  .testimony-total strong {
    display: block;
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
  }

  .germane-box {
    background: #f8fafc;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    display: grid;
    gap: 6px;
    justify-self: end;
    padding: 10px 12px;
    width: min(100%, 220px);
  }

  .germane-box span {
    color: #4b5563;
    font-size: 0.76rem;
    margin: 0;
  }

  .section-heading h2 {
    font-size: 1.5rem;
    margin: 0 0 16px;
  }

  .section-heading.compact h2 {
    font-size: 1.15rem;
    margin-bottom: 12px;
  }

  .admin-bill-panel {
    margin-bottom: 22px;
  }

  .admin-bill-form {
    display: grid;
    gap: 14px;
  }

  .admin-bill-form label {
    color: #1f2933;
    display: grid;
    font-size: 0.88rem;
    font-weight: 900;
    gap: 6px;
  }

  .admin-bill-form label span {
    color: #6b7280;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .admin-bill-form input,
  .admin-bill-form textarea {
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    color: #1f2933;
    font: inherit;
    font-weight: 600;
    padding: 11px 12px;
    width: 100%;
  }

  .admin-bill-form textarea {
    line-height: 1.5;
    resize: vertical;
  }

  .admin-form-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .admin-bill-form button,
  .secondary-button {
    border: 1px solid #e2e8f0;
    border-radius: 999px;
    cursor: pointer;
    font: inherit;
    font-weight: 950;
    padding: 10px 16px;
    text-decoration: none;
  }

  .admin-bill-form button {
    background: #1f2933;
    color: white;
  }

  .secondary-button {
    background: white;
    color: #1f2933;
  }

  .testimony-breakdown {
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 10px;
  }

  .testimony-breakdown span {
    background: #f8fafc;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    color: #4b5563;
    display: grid;
    font-size: 0.78rem;
    font-weight: 900;
    gap: 2px;
    padding: 8px;
    text-align: center;
    text-transform: uppercase;
  }

  .testimony-breakdown strong {
    color: #1f2933;
    font-size: 1.25rem;
    line-height: 1;
  }

  .testimony-breakdown .support {
    background: #dcfce7;
    border-color: #16a34a;
  }

  .testimony-breakdown .oppose {
    background: #fee2e2;
    border-color: #ef4444;
  }

  .testimony-breakdown .neutral {
    background: #dbeafe;
    border-color: #60a5fa;
  }

  .stack,
  .roll-summary,
  .roll-list,
  .testimony-list,
  .organization-comment-list {
    display: grid;
    gap: 12px;
  }

  .roll-panel {
    align-content: start;
  }

  .roll-details {
    display: grid;
    gap: 12px;
  }

  .testimony-more {
    display: grid;
    gap: 12px;
  }

  .roll-details summary {
    align-items: center;
    background: #f8fafc;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    gap: 12px;
    justify-content: space-between;
    list-style: none;
    padding: 14px 16px;
  }

  .testimony-more summary {
    align-items: center;
    background: #1f2933;
    border: 1px solid #1f2933;
    border-radius: 999px;
    color: white;
    cursor: pointer;
    display: flex;
    gap: 12px;
    justify-content: center;
    list-style: none;
    padding: 12px 16px;
  }

  .roll-details summary::-webkit-details-marker {
    display: none;
  }

  .testimony-more summary::-webkit-details-marker {
    display: none;
  }

  .roll-details summary::after {
    content: "+";
    font-size: 1.35rem;
    font-weight: 950;
    line-height: 1;
  }

  .roll-details[open] summary::after {
    content: "-";
  }

  .testimony-more summary::after {
    content: "+";
    font-size: 1.2rem;
    font-weight: 950;
    line-height: 1;
  }

  .testimony-more[open] summary::after {
    content: "-";
  }

  .roll-details summary span {
    color: #1f2933;
    font-weight: 950;
  }

  .testimony-more summary span {
    font-weight: 950;
  }

  .roll-details summary small {
    color: #4b5563;
    display: inline;
    font-size: 0.82rem;
    margin: 0;
  }

  .testimony-more summary small {
    color: #e5e7eb;
    display: inline;
    font-size: 0.82rem;
    margin: 0;
  }

  .roll-details .roll-list {
    margin-top: 12px;
  }

  .testimony-more .testimony-list {
    margin-top: 12px;
  }

  .latest-roll {
    border-color: #9ca3af;
  }

  .roll-card {
    transition:
      box-shadow 140ms ease,
      transform 140ms ease;
  }

  .roll-card:hover,
  .roll-card:focus-visible {
    box-shadow: none;
    transform: translate(-1px, -1px);
