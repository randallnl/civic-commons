---
export const prerender = false;

import BillPositionSummary from "../../components/BillPositionSummary.astro";
import FilterBar from "../../components/FilterBar.astro";
import PageHero from "../../components/PageHero.astro";
import TopNav from "../../components/TopNav.astro";
import { billDetailPath, getBills } from "../../lib/billsApi";
import { getTrackedBills, normalizeBillCode } from "../../lib/trackedBills";

const q = Astro.url.searchParams.get("q")?.trim() || "";
const year = Astro.url.searchParams.get("year")?.trim() || "";

let bills = [];
let meta = {};
let error = "";
let trackedBills = new Map();

try {
  const [data, tracked] = await Promise.all([
    getBills({ q, year, limit: 100 }),
    getTrackedBills(),
  ]);
  bills = data.bills || [];
  meta = data.meta || {};
  trackedBills = tracked;
} catch (loadError) {
  error = loadError?.message || "Unable to load bills.";
}

function formatDate(value) {
  if (!value) return "";

  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(value));
}

function trackedBillFor(bill) {
  return trackedBills.get(normalizeBillCode(bill.condensedbillno));
}

function previewText(text = "", maxLength = 180) {
  const normalized = String(text).replace(/\s+/g, " ").trim();
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trim()}...`;
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>Bills | NH Deserves Better</title>
    <meta
      name="description"
      content="Browse tracked New Hampshire bills and testimony summaries."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <PageHero
        backHref="/"
        backLabel="Back home"
        eyebrow="Tracked Bills"
        title="Browse bills and public testimony."
      >
        <FilterBar
          action="/bills"
          submitLabel="Filter bills"
          clearHref={q || year ? "/bills" : ""}
          columns="dense"
        >
          <label>
            <span>Search</span>
            <input
              type="search"
              name="q"
              value={q}
              placeholder="HB699, education, labor..."
            />
          </label>

          <label>
            <span>Year</span>
            <input
              type="number"
              name="year"
              value={year}
              placeholder="2025"
              min="2020"
              max="2030"
            />
          </label>

        </FilterBar>
      </PageHero>

      {error && <p class="status-message">{error}</p>}

      {!error && (
        <section class="results">
          <div class="results-heading">
            <h2>{meta.count ?? bills.length} Bills</h2>
            {(q || year) && <a href="/bills">Clear filters</a>}
          </div>

          {bills.length ? (
            <div class="bill-grid">
              {bills.map((bill) => {
                const trackedBill = trackedBillFor(bill);

                return (
                  <article class="bill-card">
                    <div class="bill-topline">
                      <strong>{bill.condensedbillno}</strong>
                      <span>{bill.sessionyear}</span>
                    </div>
                    <h3>
                      <a href={billDetailPath(bill.condensedbillno, bill.sessionyear)}>
                        {bill.name || bill.title || trackedBill?.name || bill.condensedbillno}
                      </a>
                    </h3>
                    <p>
                      {previewText(
                        bill.summary ||
                          trackedBill?.summary ||
                          bill.description ||
                          "No summary returned.",
                      )}
                    </p>
                    <BillPositionSummary bill={bill} />
                    <div class="bill-meta">
                      {bill.legislativebody && <span>{bill.legislativebody}</span>}
                      {bill.statusdate && <span>{formatDate(bill.statusdate)}</span>}
                    </div>
                  </article>
                );
              })}
            </div>
          ) : (
            <p class="status-message">No bills found.</p>
          )}
        </section>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  a {
    color: #1f2933;
    font-weight: 800;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.2rem, 5.5vw, 4.25rem);
    line-height: 0.95;
    margin: 0 0 24px;
    max-width: 900px;
  }

  .results-heading {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .results-heading h2 {
    font-size: 1.7rem;
    margin: 0;
  }

  .bill-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .bill-card,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 18px;
  }

  .bill-topline,
  .bill-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: space-between;
  }

  .bill-topline strong {
    font-size: 1.1rem;
  }

  .bill-topline span,
  .bill-meta span {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .bill-card h3 {
    font-size: 1.35rem;
    margin: 14px 0 8px;
  }

  .bill-card p {
    color: #4b5563;
    line-height: 1.55;
    margin: 0 0 14px;
  }

  .bill-meta {
    justify-content: start;
    margin-top: 14px;
  }

</style>
