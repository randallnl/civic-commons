---
export const prerender = false;

import { billDetailPath, getRollCallVotes } from "../../../../lib/billsApi";
import TopNav from "../../../../components/TopNav.astro";
import profileIcon from "../../../../assets/profile icon.png";
import { isFreeStater } from "../../../../lib/civicTags";
import { profilePhotoUrl } from "../../../../lib/photos";
import { cleanText } from "../../../../lib/text";
import { getTrackedBills, normalizeBillCode } from "../../../../lib/trackedBills";

const billCode = Astro.params.bill || "";
const sequence = Astro.params.sequence || "";
const year = Astro.url.searchParams.get("year")?.trim() || "";

let bill = null;
let rollCall = null;
let votes = [];
let trackedBill = null;
let error = "";

try {
  const [data, trackedBills] = await Promise.all([
    getRollCallVotes(billCode, sequence, { year }),
    getTrackedBills(),
  ]);

  bill = data.bill;
  rollCall = data.rollCall;
  votes = data.votes || [];
  trackedBill = trackedBills.get(normalizeBillCode(bill?.condensedbillno || billCode));
} catch (loadError) {
  error = loadError?.message || "Unable to load roll call votes.";
}

const groupedVotes = groupVotes(votes);
const voteFilters = groupedVotes.map((group) => ({
  label: group.label,
  count: group.rows.length,
  key: filterKey(group.label),
}));

function groupVotes(voteRows = []) {
  const groups = new Map();

  for (const vote of voteRows) {
    const key = vote.vote_label || vote.vote || "Not listed";
    if (!groups.has(key)) groups.set(key, []);
    groups.get(key).push(vote);
  }

  return [...groups].map(([label, rows]) => ({ label, rows }));
}

function formatDate(value) {
  if (!value) return "";

  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(value));
}

function partyClass(party = "") {
  const initial = partyInitial(party);
  if (initial === "R") return "republican";
  if (initial === "D") return "democrat";
  if (initial === "I") return "independent";
  return "unknown";
}

function partyLabel(party = "") {
  const value = String(party || "").trim();
  const lower = value.toLowerCase();
  if (value === "R" || lower.includes("republican")) return "Republican";
  if (value === "D" || lower.includes("democrat")) return "Democrat";
  if (value === "I" || lower.includes("independent")) return "Independent";
  return value || "Party not listed";
}

function partyInitial(party = "") {
  const label = partyLabel(party);
  if (label === "Republican") return "R";
  if (label === "Democrat") return "D";
  if (label === "Independent") return "I";
  return String(party || "").trim().charAt(0).toUpperCase() || "";
}

function bodyLabel(value = "") {
  const body = String(value || "").trim().toUpperCase();
  if (body === "H") return "House";
  if (body === "S") return "Senate";
  if (body === "HOUSE") return "House";
  if (body === "SENATE") return "Senate";
  return value || "Legislator";
}

function districtLine(vote = {}) {
  const party = partyInitial(vote.party);
  const chamber = bodyLabel(vote.legislativebody || vote.chamber);
  const district = vote.district || vote.raw_district || "";
  const districtText =
    chamber === "House"
      ? `NH House District ${district || "not listed"}`
      : chamber === "Senate"
        ? `NH Senate District ${district || "not listed"}`
        : district
          ? `${chamber} District ${district}`
          : chamber;

  return [party, districtText].filter(Boolean).join(" - ");
}

function townsLine(vote = {}) {
  return cleanText(vote.towns_represented || vote.townsRepresented || vote.location_text || "");
}

function filterKey(value = "") {
  return String(value || "not listed")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function personHref(vote = {}) {
  return `/people/${vote.slug || slugify(vote.name)}`;
}

function slugify(value = "") {
  return String(value)
    .toLowerCase()
    .trim()
    .replace(/['']/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>
      Roll Call {sequence} | {bill?.condensedbillno || billCode} | NH Deserves Better
    </title>
    <meta
      name="description"
      content={`Roll call votes for ${bill?.condensedbillno || billCode}.`}
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href={billDetailPath(bill?.condensedbillno || billCode, bill?.sessionyear || year)}>
        Back to bill
      </a>

      {error ? (
        <p class="status-message">{error}</p>
      ) : bill && rollCall ? (
        <>
          <section class="hero">
            <p class="eyebrow">Roll Call</p>
            <h1>{bill.condensedbillno}</h1>
            <h2>{trackedBill?.name || rollCall.question_motion || "Roll call vote"}</h2>
            {rollCall.title1 && <p>{rollCall.title1}</p>}
            <div class="hero-meta">
              <span>{rollCall.question_motion || "Motion not listed"}</span>
              {rollCall.votedate && <span>{formatDate(rollCall.votedate)}</span>}
              <span>{votes.length} votes</span>
            </div>
          </section>

          <section class="count-grid">
            <article>
              <span>Yeas</span>
              <strong>{rollCall.yeas}</strong>
            </article>
            <article>
              <span>Nays</span>
              <strong>{rollCall.nays}</strong>
            </article>
            <article>
              <span>Present</span>
              <strong>{rollCall.present}</strong>
            </article>
            <article>
              <span>Absent</span>
              <strong>{rollCall.absent}</strong>
            </article>
          </section>

          <section class="panel vote-browser" data-roll-call-browser>
            <div class="section-heading split-heading">
              <div>
                <p class="eyebrow">Legislator Votes</p>
                <h2>How each legislator voted</h2>
              </div>
              <span class="visible-count" data-visible-count>{votes.length} shown</span>
            </div>

            <div class="filters" aria-label="Filter roll call votes">
              <label>
                <span>Search</span>
                <input
                  type="search"
                  placeholder="Name, party, district..."
                  data-vote-search
                />
              </label>

              <label>
                <span>Vote</span>
                <select data-vote-filter>
                  <option value="">All votes ({votes.length})</option>
                  {voteFilters.map((filter) => (
                    <option value={filter.key}>{filter.label} ({filter.count})</option>
                  ))}
                </select>
              </label>

              <label>
                <span>Party</span>
                <select data-party-filter>
                  <option value="">All parties</option>
                  <option value="R">Republican</option>
                  <option value="D">Democrat</option>
                  <option value="I">Independent</option>
                </select>
              </label>
            </div>

            <div class="vote-list">
              {votes.map((vote) => {
                const voteLabel = vote.vote_label || vote.vote || "Not listed";
                const photoUrl = profilePhotoUrl(vote.photo);
                const searchText = [
                  vote.name,
                  partyLabel(vote.party),
                  vote.party,
                  vote.district,
                  vote.raw_district,
                  vote.chamber,
                  vote.location_text,
                  vote.towns_represented,
                  voteLabel,
                  isFreeStater(vote) ? "free stater" : "",
                ]
                  .filter(Boolean)
                  .join(" ")
                  .toLowerCase();
                const href = personHref(vote);
                const towns = townsLine(vote);

                return (
                  <article
                    class="legislator-card"
                    data-vote-card
                    data-vote={filterKey(voteLabel)}
                    data-party={partyInitial(vote.party)}
                    data-search={searchText}
                  >
                    <div class="card-main">
                      <a class="photo-link" href={href}>
                        <img
                          class:list={["legislator-photo", !photoUrl && "fallback-photo"]}
                          src={photoUrl || profileIcon.src}
                          alt={photoUrl ? `Photo of ${vote.name}` : ""}
                          loading="lazy"
                        />
                      </a>
                      <div class="legislator-info">
                        <strong>
                          <a href={href}>{vote.name || "Legislator not listed"}</a>
                        </strong>
                        <p class="district-line">{districtLine(vote)}</p>
                        {towns && <p class="towns-line"><em>{towns}</em></p>}
                        <div class="tag-row">
                          {isFreeStater(vote) && (
                            <a
                              class="free-stater-pill"
                              href="/free-staters"
                              title="What is a Free Stater?"
                              aria-label="What is a Free Stater?"
                            >
                              Free Stater
                            </a>
                          )}
                        </div>
                      </div>
                      <span class:list={["vote-pill", filterKey(voteLabel)]}>
                        {voteLabel}
                      </span>
                    </div>

                    <div class="card-meta">
                      <span class:list={["party", partyClass(vote.party)]}>
                        {partyLabel(vote.party)}
                      </span>
                      {vote.chamber && <span>{cleanText(vote.chamber)}</span>}
                      {vote.county && <span>{cleanText(vote.county)} County</span>}
                      {vote.employeeno && <span>Employee #{vote.employeeno}</span>}
                      {vote.personid && <span>Person #{vote.personid}</span>}
                    </div>
                  </article>
                );
              })}
            </div>

            <p class="empty" data-empty-state hidden>No legislators match those filters.</p>
          </section>
        </>
      ) : (
        <p class="status-message">Roll call not found.</p>
      )}
    </main>
  </body>
</html>

<script>
  document.querySelectorAll("[data-roll-call-browser]").forEach((browser) => {
    const searchInput = browser.querySelector("[data-vote-search]");
    const voteFilter = browser.querySelector("[data-vote-filter]");
    const partyFilter = browser.querySelector("[data-party-filter]");
    const cards = Array.from(browser.querySelectorAll("[data-vote-card]"));
    const count = browser.querySelector("[data-visible-count]");
    const empty = browser.querySelector("[data-empty-state]");

    function applyFilters() {
      const search = String(searchInput?.value || "").trim().toLowerCase();
      const vote = String(voteFilter?.value || "");
      const party = String(partyFilter?.value || "");
      let visible = 0;

      cards.forEach((card) => {
        const matchesSearch = !search || card.dataset.search?.includes(search);
        const matchesVote = !vote || card.dataset.vote === vote;
        const matchesParty = !party || card.dataset.party === party;
        const show = matchesSearch && matchesVote && matchesParty;

        card.hidden = !show;
        if (show) visible += 1;
      });

      if (count) count.textContent = `${visible} shown`;
      if (empty) empty.hidden = visible !== 0;
    }

    searchInput?.addEventListener("input", applyFilters);
    voteFilter?.addEventListener("change", applyFilters);
    partyFilter?.addEventListener("change", applyFilters);
  });
</script>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 24px;
  }

  .eyebrow,
  .count-grid span {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 10px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(3rem, 9vw, 7rem);
    line-height: 0.9;
    margin: 0 0 16px;
  }

  .hero h2 {
    font-size: clamp(1.6rem, 4vw, 3rem);
    line-height: 1.05;
    margin: 0 0 14px;
  }

  .hero p {
    color: #4b5563;
    line-height: 1.6;
    max-width: 880px;
  }

  .hero-meta,
  .count-grid,
  .vote-list {
    display: grid;
    gap: 14px;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
  }

  .hero-meta span {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .count-grid {
    grid-template-columns: repeat(4, 1fr);
    margin-bottom: 22px;
  }

  .count-grid article,
  .panel,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 18px;
  }

  .count-grid strong {
    font-size: 2.4rem;
    line-height: 1;
  }

  .section-heading h2 {
    font-size: 1.45rem;
    margin: 0 0 14px;
  }

  .split-heading {
    align-items: start;
    display: flex;
    gap: 16px;
    justify-content: space-between;
  }

  .visible-count {
    background: #1f2933;
    border-radius: 999px;
    color: white;
    flex: 0 0 auto;
    font-size: 0.82rem;
    font-weight: 950;
    padding: 8px 11px;
  }

  .filters {
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(220px, 1fr) 180px 180px;
    margin-bottom: 18px;
  }

  .filters label {
    color: #4b5563;
    display: grid;
    font-size: 0.76rem;
    font-weight: 950;
    gap: 7px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .filters input,
  .filters select {
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    box-sizing: border-box;
    color: #1f2933;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 750;
    letter-spacing: 0;
    padding: 11px 12px;
    text-transform: none;
    width: 100%;
  }

  .legislator-card {
    align-items: start;
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    display: grid;
    gap: 12px;
    padding: 16px;
    text-decoration: none;
  }

  .legislator-card a {
    color: #1f2933;
  }

  .legislator-card:hover .legislator-info strong a,
  .legislator-info strong a:hover {
    text-decoration: underline;
  }

  .card-main {
    align-items: start;
    display: grid;
    gap: 14px;
    grid-template-columns: 64px minmax(0, 1fr) auto;
  }

  .legislator-photo {
    aspect-ratio: 4 / 5;
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    height: 80px;
    object-fit: cover;
    object-position: center top;
    width: 64px;
  }

  .photo-link {
    display: block;
    line-height: 0;
  }

  .fallback-photo {
    object-fit: cover;
  }

  .card-main strong {
    display: block;
    font-size: 1.15rem;
    line-height: 1.15;
  }

  .legislator-info {
    min-width: 0;
  }

  .legislator-info p {
    color: #4b5563;
    line-height: 1.45;
    margin: 6px 0 0;
  }

  .district-line {
    font-weight: 850;
  }

  .towns-line {
    color: #374151 !important;
    font-weight: 750;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }

  .free-stater-pill {
    background: #7f1d1d;
    border: 1px solid #450a0a;
    border-radius: 999px;
    color: white !important;
    display: inline-flex;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    padding: 5px 8px;
    text-decoration: none;
    text-transform: uppercase;
  }

  .free-stater-pill:hover {
    background: #991b1b;
    text-decoration: underline;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .card-meta span,
  .party {
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 900;
    padding: 5px 8px;
  }

  .card-meta span {
    background: white;
    border: 1px solid #d1d5db;
    color: #4b5563;
  }

  .party {
    color: white !important;
  }

  .vote-pill {
    border-radius: 999px;
    flex: 0 0 auto;
    font-size: 0.82rem;
    font-weight: 950;
    padding: 8px 10px;
  }

  .vote-pill.yea {
    background: #dcfce7;
    color: #166534;
  }

  .vote-pill.nay {
    background: #fee2e2;
    color: #991b1b;
  }

  .vote-pill.absent,
  .vote-pill.not-voting,
  .vote-pill.present-not-voting,
  .vote-pill.not-counted,
  .vote-pill.unknown {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .republican {
    background: #b42318;
  }

  .democrat {
    background: #1d4ed8;
  }

  .independent,
  .unknown {
    background: #5b616e;
  }

  small {
    color: #4b5563;
    font-weight: 800;
  }

  @media (max-width: 760px) {
    .count-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .filters {
      grid-template-columns: 1fr;
    }

    .split-heading,
    .card-main {
      display: grid;
      grid-template-columns: 56px minmax(0, 1fr);
    }

    .legislator-photo {
      height: 70px;
      width: 56px;
    }

    .visible-count {
      justify-self: start;
    }

    .vote-pill {
      grid-column: 2;
      justify-self: start;
    }
  }
</style>
