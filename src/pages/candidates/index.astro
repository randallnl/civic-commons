---
export const prerender = false;

import CandidateCard from "../../components/CandidateCard.astro";
import TopNav from "../../components/TopNav.astro";
import {
  candidateName,
  candidateOfficePriority,
  getCandidates,
  isLegislativeCandidate,
} from "../../lib/candidatesApi";
import { enrichCandidatesWithLegislators } from "../../lib/candidateLegislators";
import { civicApiBase, civicApiFetch } from "../../lib/civicApi";
import { getCommunities, getTownCommunity } from "../../lib/communitiesApi";

const API_BASE = civicApiBase();

const address = Astro.url.searchParams.get("address")?.trim() || "";
const county = Astro.url.searchParams.get("county")?.trim() || "";
const district = Astro.url.searchParams.get("district")?.trim() || "";
const name = Astro.url.searchParams.get("name")?.trim() || "";
const office = Astro.url.searchParams.get("office")?.trim() || "";
const town = Astro.url.searchParams.get("town")?.trim() || "";
const electionYear = "2026";
const officeOptions = [
  "State Representative",
  "State Senate",
];
const selectedOffice = officeOptions.includes(office) ? office : "";
const countyOptions = [
  "Belknap",
  "Carroll",
  "Cheshire",
  "Coos",
  "Grafton",
  "Hillsborough",
  "Merrimack",
  "Rockingham",
  "Strafford",
  "Sullivan",
];
const districtOptions = Array.from({ length: 50 }, (_, index) => String(index + 1));

let candidates = [];
let meta = {};
let error = "";
let resultContext = "";
let nameOptions = [];
let townOptions = [];

try {
  if (address) {
    const response = await civicApiFetch(`${API_BASE}/reps/lookup`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ address }),
    });

    const data = await response.json();

    if (!response.ok) {
      throw new Error(data.error || "Unable to look up candidates for that address.");
    }

    candidates = candidatesFromLookup(data);
    meta = data.meta || {};
    resultContext = formatAddress(data.normalizedInput) || data.address || address;
  } else if (town) {
    const data = await getTownCommunity(town, { articleLimit: 1 });
    candidates = candidatesFromCommunity(data);
    meta = data.meta || {};
    resultContext = data.town?.name || data.community?.name || town;
  } else {
    const data = await getDirectoryCandidates({
      q: name,
      county,
      district,
      office: selectedOffice,
      electionYear,
      limit: 100,
    });
    candidates = data.candidates || [];
    meta = data.meta || {};
  }
} catch (loadError) {
  error = loadError?.message || "Unable to load candidates.";
}

const visibleCandidates = selectedOffice
  ? filterCandidatesByOffice(candidates, selectedOffice)
  : filterLegislativeCandidates(candidates);
candidates = prioritizeLegislativeCandidates(filterCandidatesByName(visibleCandidates, name));
candidates = await enrichCandidatesWithLegislators(candidates);

try {
  nameOptions = await candidateNameOptions();
} catch (optionsError) {
  nameOptions = uniqueOptions(candidates.map(candidateName));
}

try {
  townOptions = await communityTownOptions();
} catch (optionsError) {
  townOptions = town ? [town] : [];
}

const hasFilters = address || county || district || selectedOffice || town || name;
const resultCount = candidates.length;

async function getDirectoryCandidates({
  q = "",
  county = "",
  district = "",
  office = "",
  electionYear = "",
  limit = 100,
} = {}) {
  if (office) {
    return getCandidates({
      q,
      county,
      district,
      office,
      electionYear,
      limit,
    });
  }

  const [houseData, senateData] = await Promise.all([
    getCandidates({
      q,
      county,
      district,
      office: "State Representative",
      electionYear,
      limit,
    }),
    getCandidates({
      q,
      county,
      district,
      office: "State Senate",
      electionYear,
      limit,
    }),
  ]);

  const candidates = uniqueCandidates([
    ...(houseData.candidates || []),
    ...(senateData.candidates || []),
  ]);

  return {
    candidates,
    meta: {
      count: candidates.length,
    },
  };
}

function candidatesFromLookup(data = {}) {
  const candidateGroups = data.groups?.candidates || {};
  return uniqueCandidates([
    ...(data.candidates || []),
    ...(candidateGroups.senate || []),
    ...(candidateGroups.house || []),
    ...findNestedCandidates(candidateGroups),
  ]);
}

function candidatesFromCommunity(data = {}) {
  const community = data.town || data.community || data;

  return uniqueCandidates([
    ...(data.candidates || []),
    ...(community.candidates || []),
    ...(data.candidateSummary?.candidates || []),
    ...(community.candidateSummary?.candidates || []),
    ...(data.groups?.candidates?.senate || []),
    ...(data.groups?.candidates?.house || []),
    ...findNestedCandidates(data.groups),
    ...findNestedCandidates(community.groups),
  ]);
}

function findNestedCandidates(value) {
  if (!value) return [];

  if (Array.isArray(value)) {
    return value.flatMap((item) =>
      looksLikeCandidate(item) ? [item] : findNestedCandidates(item),
    );
  }

  if (typeof value === "object") {
    return Object.values(value).flatMap(findNestedCandidates);
  }

  return [];
}

function uniqueCandidates(items = []) {
  const seen = new Set();

  return items.filter((candidate) => {
    if (!looksLikeCandidate(candidate)) return false;

    const key = [
      candidate.slug,
      candidate.filerEntityNumber,
      candidate.name,
      candidate.candidateFirstName,
      candidate.candidateLastName,
      candidate.office,
      candidate.county,
      candidate.district,
    ]
      .filter(Boolean)
      .join("|");

    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

function looksLikeCandidate(value) {
  return !!(
    value &&
    typeof value === "object" &&
    (
      value.slug ||
      value.filerEntityNumber ||
      value.candidateFirstName ||
      value.candidateLastName
    ) &&
    (
      value.office ||
      value.officeType ||
      value.politicalParty ||
      value.electionYear
    )
  );
}

function filterCandidatesByOffice(items = [], selectedOffice = "") {
  const officeFilter = selectedOffice.trim().toLowerCase();
  if (!officeFilter) return items;

  return items.filter((candidate) =>
    String(candidate.office || "")
      .trim()
      .toLowerCase()
      .includes(officeFilter),
  );
}

function filterCandidatesByName(items = [], filter = "") {
  const nameFilter = filter.trim().toLowerCase();
  if (!nameFilter) return items;

  return items.filter((candidate) =>
    candidateName(candidate).toLowerCase().includes(nameFilter),
  );
}

function filterLegislativeCandidates(items = []) {
  return items.filter(isLegislativeCandidate);
}

function prioritizeLegislativeCandidates(items = []) {
  return [...items].sort((a, b) => {
    const priorityDelta = candidateOfficePriority(a.office) - candidateOfficePriority(b.office);
    if (priorityDelta) return priorityDelta;

    return [
      String(a.county || "").localeCompare(String(b.county || "")),
      numericSortValue(a.district) - numericSortValue(b.district),
      String(a.candidateLastName || a.name || "").localeCompare(String(b.candidateLastName || b.name || "")),
      String(a.candidateFirstName || "").localeCompare(String(b.candidateFirstName || "")),
    ].find((value) => value !== 0) || 0;
  });
}

function numericSortValue(value = "") {
  const number = Number(value);
  return Number.isFinite(number) ? number : 999;
}

function formatAddress(normalized = {}) {
  return [
    normalized.line1,
    normalized.city,
    normalized.state,
    normalized.zip,
  ]
    .filter(Boolean)
    .join(", ");
}

async function candidateNameOptions() {
  const data = await getDirectoryCandidates({ electionYear, limit: 200 });
  return uniqueOptions(
    filterLegislativeCandidates(data.candidates || []).map(candidateName),
  );
}

async function communityTownOptions() {
  const data = await getCommunities({ body: "house", limit: 500, articleLimit: 0 });
  return uniqueOptions(
    (data.communities || []).flatMap((community) =>
      townsFromValue(
        community.townsRepresented ||
          community.towns ||
          community.towns_represented ||
          community.communities_represented ||
          [],
      ),
    ),
  );
}

function townsFromValue(value = []) {
  if (Array.isArray(value)) {
    return value
      .map((item) =>
        typeof item === "object" && item !== null
          ? item.town || item.name || item.label
          : item,
      )
      .map(normalizeTownOption)
      .filter(Boolean);
  }

  return String(value || "")
    .split(/[,;|]/)
    .map(normalizeTownOption)
    .filter(Boolean);
}

function normalizeTownOption(value = "") {
  return String(value || "")
    .replace(/\s*-\s*Ward\s+\d+$/i, "")
    .trim();
}

function uniqueOptions(values = []) {
  return [...new Set(values.map((value) => String(value || "").trim()).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b));
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>Candidates | NH Deserves Better</title>
    <meta
      name="description"
      content="Browse New Hampshire State Representative and State Senate candidates by address, district, county, and town."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">House and Senate Candidates</p>
        <h1>Browse candidates for the New Hampshire Legislature.</h1>
        <p class="lede">
          NH Deserves Better focuses on State Representative and State Senate
          races because those offices shape state law, local funding, public
          services, and the daily civic decisions closest to most people.
        </p>

        <form class="address-lookup" action="/candidates" method="get">
          <label for="address">Find State House and State Senate candidates for your address</label>

          <div class="address-row">
            <input
              id="address"
              type="text"
              name="address"
              value={address}
              placeholder="72 Concord St, Manchester, NH"
              autocomplete="street-address"
            />
            <button type="submit">Find Legislative Candidates</button>
          </div>
        </form>

        <form class="filters" action="/candidates" method="get">
          <label>
            <span>Name</span>
            <input
              type="search"
              name="name"
              value={name}
              list="candidateNameOptions"
              placeholder="Start typing a candidate"
              autocomplete="off"
            />
            <datalist id="candidateNameOptions">
              {nameOptions.map((option) => <option value={option} />)}
            </datalist>
          </label>
          <label>
            <span>County</span>
            <select name="county">
              <option value="">All counties</option>
              {countyOptions.map((option) => (
                <option value={option} selected={county.toLowerCase() === option.toLowerCase()}>
                  {option}
                </option>
              ))}
            </select>
          </label>
          <label>
            <span>District</span>
            <select name="district">
              <option value="">All districts</option>
              {districtOptions.map((option) => (
                <option value={option} selected={district === option}>{option}</option>
              ))}
            </select>
          </label>
          <label>
            <span>Office</span>
            <select name="office">
              <option value="">State House and Senate</option>
              {officeOptions.map((option) => (
                <option value={option} selected={selectedOffice === option}>{option}</option>
              ))}
            </select>
          </label>
          <label>
            <span>Town</span>
            <input
              type="search"
              name="town"
              value={town}
              list="candidateTownOptions"
              placeholder="Start typing a town"
              autocomplete="off"
            />
            <datalist id="candidateTownOptions">
              {townOptions.map((option) => <option value={option} />)}
            </datalist>
          </label>
          <button type="submit">Filter</button>
        </form>
      </section>

      {error ? (
        <p class="status-message">{error}</p>
      ) : (
        <section class="results">
          <div class="results-heading">
            <div>
              <h2>{resultCount} House and Senate Candidates</h2>
              {resultContext && <p>Showing matches for {resultContext}</p>}
            </div>
            {hasFilters && <a href="/candidates">Clear filters</a>}
          </div>

          {candidates.length ? (
            <div class="candidate-grid">
              {candidates.map((candidate) => (
                <CandidateCard candidate={candidate} />
              ))}
            </div>
          ) : (
            <p class="status-message">No State House or State Senate candidates found.</p>
          )}
        </section>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.6rem, 7vw, 5.25rem);
    line-height: 0.95;
    margin: 0 0 24px;
    max-width: 920px;
  }

  .lede {
    color: #4b5563;
    font-size: clamp(1.08rem, 2vw, 1.25rem);
    font-weight: 750;
    line-height: 1.5;
    margin: -8px 0 22px;
    max-width: 780px;
  }

  .address-lookup,
  .filters {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 16px;
  }

  .address-lookup {
    display: grid;
    gap: 10px;
    margin-bottom: 14px;
  }

  .address-row,
  .filters {
    align-items: end;
    display: grid;
    gap: 12px;
  }

  .address-row {
    grid-template-columns: minmax(0, 1fr) 180px;
  }

  .filters {
    grid-template-columns: repeat(5, minmax(0, 1fr)) 150px;
  }

  label {
    display: grid;
    gap: 6px;
  }

  label span {
    color: #6b7280;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  input,
  select,
  button {
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-sizing: border-box;
    font: inherit;
    font-weight: 800;
    min-height: 48px;
    padding: 10px 12px;
    width: 100%;
  }

  button {
    background: #1f2933;
    color: white;
    cursor: pointer;
  }

  .results-heading {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .results-heading h2 {
    font-size: 1.7rem;
    margin: 0;
  }

  .results-heading p {
    color: #6b7280;
    font-weight: 800;
    margin: 6px 0 0;
  }

  .candidate-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    color: #4b5563;
    font-size: 1.05rem;
    font-weight: 800;
    padding: 18px;
  }

  @media (max-width: 900px) {
    .address-row,
    .filters,
    .candidate-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
