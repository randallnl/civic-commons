---
export const prerender = false;

import CandidateCard from "../../components/CandidateCard.astro";
import TopNav from "../../components/TopNav.astro";
import { getCandidates } from "../../lib/candidatesApi";

const q = Astro.url.searchParams.get("q")?.trim() || "";
const office = Astro.url.searchParams.get("office")?.trim() || "";
const officeType = Astro.url.searchParams.get("officeType")?.trim() || "";
const county = Astro.url.searchParams.get("county")?.trim() || "";
const district = Astro.url.searchParams.get("district")?.trim() || "";
const party = Astro.url.searchParams.get("party")?.trim() || "";
const electionYear = Astro.url.searchParams.get("electionYear")?.trim() || "2026";

let candidates = [];
let meta = {};
let error = "";

try {
  const data = await getCandidates({
    q,
    office,
    officeType,
    county,
    district,
    party,
    electionYear,
    limit: 100,
  });
  candidates = data.candidates || [];
  meta = data.meta || {};
} catch (loadError) {
  error = loadError?.message || "Unable to load candidates.";
}

const hasFilters = q || office || officeType || county || district || party || electionYear !== "2026";
---

<html lang="en">
  <head>
    <title>Candidates | Civic Commons</title>
    <meta
      name="description"
      content="Browse New Hampshire candidates by office, party, district, and election year."
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/">Back home</a>

      <section class="hero">
        <p class="eyebrow">Candidates</p>
        <h1>Browse candidates running in New Hampshire.</h1>

        <form class="filters" action="/candidates" method="get">
          <label>
            <span>Search</span>
            <input type="search" name="q" value={q} placeholder="bergeron..." />
          </label>
          <label>
            <span>Office</span>
            <input type="text" name="office" value={office} placeholder="State Representative" />
          </label>
          <label>
            <span>Office Type</span>
            <input type="text" name="officeType" value={officeType} placeholder="General Court" />
          </label>
          <label>
            <span>County</span>
            <input type="text" name="county" value={county} placeholder="Hillsborough" />
          </label>
          <label>
            <span>District</span>
            <input type="text" name="district" value={district} placeholder="2" />
          </label>
          <label>
            <span>Party</span>
            <input type="text" name="party" value={party} placeholder="Republican Party" />
          </label>
          <label>
            <span>Year</span>
            <input type="number" name="electionYear" value={electionYear} min="2024" max="2030" />
          </label>
          <button type="submit">Filter</button>
        </form>
      </section>

      {error ? (
        <p class="status-message">{error}</p>
      ) : (
        <section class="results">
          <div class="results-heading">
            <h2>{meta.count ?? candidates.length} Candidates</h2>
            {hasFilters && <a href="/candidates">Clear filters</a>}
          </div>

          {candidates.length ? (
            <div class="candidate-grid">
              {candidates.map((candidate) => (
                <CandidateCard candidate={candidate} />
              ))}
            </div>
          ) : (
            <p class="status-message">No candidates found.</p>
          )}
        </section>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    padding: 42px 0 28px;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.6rem, 7vw, 5.25rem);
    line-height: 0.95;
    margin: 0 0 24px;
    max-width: 920px;
  }

  .filters {
    align-items: end;
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  label {
    display: grid;
    gap: 6px;
  }

  label span {
    color: #6b7280;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  input,
  button {
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-sizing: border-box;
    font: inherit;
    font-weight: 800;
    min-height: 48px;
    padding: 10px 12px;
    width: 100%;
  }

  button {
    background: #1f2933;
    color: white;
    cursor: pointer;
  }

  .results-heading {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .results-heading h2 {
    font-size: 1.7rem;
    margin: 0;
  }

  .candidate-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    color: #4b5563;
    font-size: 1.05rem;
    font-weight: 800;
    padding: 18px;
  }

  @media (max-width: 900px) {
    .filters,
    .candidate-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
