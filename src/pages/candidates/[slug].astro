---
export const prerender = false;

import TopNav from "../../components/TopNav.astro";
import {
  candidateName,
  formatCandidateParty,
  getCandidate,
  partyClassName,
} from "../../lib/candidatesApi";

const { slug } = Astro.params;

let apiData = null;

try {
  apiData = await getCandidate(slug);
} catch (error) {
  console.error(error?.message || "Unable to load candidate profile.");
}

const candidate = apiData?.candidate || apiData;

if (!candidate?.filerEntityNumber && !candidate?.name) {
  return Astro.redirect("/404");
}

const name = candidateName(candidate);
const fallbackInitial = name.slice(0, 1) || "C";
const officeParts = [
  candidate.office,
  candidate.county,
  candidate.district ? `District ${candidate.district}` : "",
].filter(Boolean);
const sourceLinks = [
  candidate.candidateWebsite && {
    href: candidate.candidateWebsite,
    label: "Campaign Website",
  },
  candidate.candidateEmail && {
    href: `mailto:${candidate.candidateEmail}`,
    label: "Email Campaign",
  },
].filter(Boolean);

function formatCurrency(value) {
  const amount = Number(value || 0);
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  }).format(amount);
}
---

<html lang="en">
  <head>
    <title>{name} | Civic Commons</title>
    <meta
      name="description"
      content={`Candidate profile and campaign finance summary for ${name}.`}
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/candidates">Back to candidates</a>

      <section class="profile-hero">
        <div class="portrait-card">
          {candidate.photoUrl ? (
            <img src={candidate.photoUrl} alt={name} />
          ) : (
            <div class="portrait-fallback">{fallbackInitial}</div>
          )}
        </div>

        <div class="hero-copy">
          <p class="eyebrow">{candidate.electionCycle || "Candidate"}</p>
          <h1>{name}</h1>

          <div class="hero-meta">
            <span class:list={["meta-pill", partyClassName(candidate.politicalParty)]}>
              {formatCandidateParty(candidate.politicalParty)}
            </span>
            {candidate.officeType && <span class="meta-pill">{candidate.officeType}</span>}
            {candidate.electionYear && <span class="meta-pill">{candidate.electionYear}</span>}
          </div>

          <p class="office-line">{officeParts.join(", ") || "Office not listed"}</p>

          {sourceLinks.length > 0 && (
            <div class="contact-actions">
              {sourceLinks.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </div>
          )}
        </div>
      </section>

      <section class="summary-strip">
        <article>
          <span>Total Raised</span>
          <strong>{formatCurrency(candidate.totalRaised)}</strong>
        </article>
        <article>
          <span>Total Spent</span>
          <strong>{formatCurrency(candidate.totalSpent)}</strong>
        </article>
        <article>
          <span>Filer Entity</span>
          <strong>{candidate.filerEntityNumber || "Not listed"}</strong>
        </article>
      </section>

      <section class="panel">
        <p class="eyebrow">Ballot Details</p>
        <div class="detail-grid">
          <div>
            <span>Office</span>
            <strong>{candidate.office || "Not listed"}</strong>
          </div>
          <div>
            <span>Office Type</span>
            <strong>{candidate.officeType || "Not listed"}</strong>
          </div>
          <div>
            <span>County</span>
            <strong>{candidate.county || "Not listed"}</strong>
          </div>
          <div>
            <span>District</span>
            <strong>{candidate.district || "Not listed"}</strong>
          </div>
          <div>
            <span>Party</span>
            <strong>{candidate.politicalParty || "Not listed"}</strong>
          </div>
          <div>
            <span>Election Year</span>
            <strong>{candidate.electionYear || "Not listed"}</strong>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .profile-hero {
    align-items: start;
    display: grid;
    gap: 28px;
    grid-template-columns: 260px 1fr;
    padding: 42px 0 28px;
  }

  .portrait-card {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 18px;
    box-shadow: 6px 6px 0 #1f2933;
    overflow: hidden;
  }

  .portrait-card img,
  .portrait-fallback {
    aspect-ratio: 4 / 5;
    display: block;
    width: 100%;
  }

  .portrait-card img {
    object-fit: cover;
    object-position: center top;
  }

  .portrait-fallback {
    align-items: center;
    background: #6b4f2a;
    color: white;
    display: flex;
    font-size: 5rem;
    font-weight: 950;
    justify-content: center;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin: 0;
  }

  .hero-meta,
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .meta-pill {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.84rem;
    font-weight: 900;
    padding: 7px 11px;
  }

  .party-democrat {
    background: #dbeafe;
    border-color: #2563eb;
  }

  .party-republican {
    background: #fee2e2;
    border-color: #dc2626;
  }

  .party-libertarian {
    background: #fef3c7;
    border-color: #d97706;
  }

  .office-line {
    color: #4b5563;
    font-size: 1.15rem;
    font-weight: 800;
    line-height: 1.5;
    margin: 18px 0 0;
  }

  .contact-actions a {
    border: 2px solid #1f2933;
    border-radius: 999px;
    padding: 10px 14px;
    text-decoration: none;
  }

  .summary-strip {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, 1fr);
    margin: 24px 0;
  }

  .summary-strip article,
  .panel {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 16px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 18px;
  }

  .summary-strip span,
  .detail-grid span {
    color: #6b7280;
    display: block;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin-bottom: 6px;
    text-transform: uppercase;
  }

  .summary-strip strong {
    display: block;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1;
  }

  .detail-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(3, 1fr);
  }

  .detail-grid div {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    padding: 14px;
  }

  .detail-grid strong {
    overflow-wrap: anywhere;
  }

  @media (max-width: 820px) {
    .profile-hero,
    .summary-strip,
    .detail-grid {
      grid-template-columns: 1fr;
    }

    .portrait-card {
      max-width: 220px;
    }
  }
</style>
