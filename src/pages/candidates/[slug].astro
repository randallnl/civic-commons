---
export const prerender = false;

import TopNav from "../../components/TopNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import ArticleList from "../../components/ArticleList.astro";
import CommunityUpdates from "../../components/CommunityUpdates.astro";
import profileIcon from "../../assets/profile icon.png";
import { getArticles } from "../../lib/articlesApi";
import { currentAdminSession } from "../../lib/adminAuth";
import { getBillSummaries } from "../../lib/billsApi";
import { representativePersonIdForCandidate } from "../../lib/candidateLegislatorLinks";
import {
  candidateName,
  candidateSlug,
  formatCandidateParty,
  getCandidate,
  partyClassName,
} from "../../lib/candidatesApi";
import { enrichCandidateWithLegislator } from "../../lib/candidateLegislators";
import { isFreeStater } from "../../lib/civicTags";
import { profilePhotoUrl } from "../../lib/photos";
import { getRepresentative, getRepresentatives, repName } from "../../lib/repsApi";
import {
  endorsementsForCandidate,
  getOrganizations,
  organizationPath,
} from "../../lib/organizationsApi";
import { representativeGradeFor } from "../../lib/trackedBills";

const { slug } = Astro.params;

let apiData = null;
let organizations = [];
let legislatorOptions = [];
let linkedRepresentativePersonId = "";
let currentLegislator = null;
let currentLegislatorGrade = null;
const adminSession = await currentAdminSession(Astro.request);
const message = Astro.url.searchParams.get("message") || "";
const error = Astro.url.searchParams.get("error") || "";

try {
  apiData = await getCandidate(slug);
} catch (error) {
  console.error(error?.message || "Unable to load candidate profile.");
}

let candidate = apiData?.candidate || apiData;

if (!candidate?.filerEntityNumber && !candidate?.name) {
  return Astro.redirect("/404");
}

candidate = await enrichCandidateWithLegislator(candidate);

if (candidate.currentLegislator && candidate.legislatorPersonId) {
  try {
    const [representativeData, billSummaries] = await Promise.all([
      getRepresentative(candidate.legislatorPersonId, { voteLimit: 200 }),
      getBillSummaries(),
    ]);
    const representative =
      representativeData.representative ||
      representativeData.rep ||
      representativeData.person ||
      representativeData;
    currentLegislator = {
      ...representative,
      voteHistory: representativeData.voteHistory || representative.voteHistory || [],
    };
    currentLegislatorGrade = representativeGradeFor(currentLegislator, new Map(), billSummaries);
  } catch (error) {
    console.error(error?.message || "Unable to load current legislator grade.");
  }
}

const name = candidateName(candidate);
const candidateEntityKey = candidate.filerEntityNumber || slug;
const portraitUrl = profilePhotoUrl(candidate.photoUrl) || profilePhotoUrl(candidate.legislatorPhotoUrl);
const officeTypeLabel =
  String(candidate.officeType || "").trim().toLowerCase() === "general court"
    ? ""
    : candidate.officeType;
const officeParts = [
  candidate.office,
  candidate.county,
  candidate.district ? `District ${candidate.district}` : "",
].filter(Boolean);
const candidateRoles = uniqueCandidateRoles(candidate.candidateRoles?.length ? candidate.candidateRoles : [candidate]);
const hasFreeStaterTag = isFreeStater(candidate) || isFreeStater(currentLegislator);

function externalProfileUrl(entity = {}, names = []) {
  return names
    .map((name) => entity[name])
    .find((value) => typeof value === "string" && value.trim());
}

function ballotpediaUrlForName(value = "") {
  const slug = String(value)
    .trim()
    .replace(/\s+/g, "_")
    .replace(/[^A-Za-z0-9_().-]/g, "");
  return slug ? `https://ballotpedia.org/${slug}` : "";
}

const sourceLinks = [
  candidate.candidateWebsite && {
    href: candidate.candidateWebsite,
    label: "Campaign Website",
  },
  candidate.candidateEmail && {
    href: `mailto:${candidate.candidateEmail}`,
    label: "Email Campaign",
  },
  candidate.legislatorProfileUrl && {
    href: candidate.legislatorProfileUrl,
    label: "Legislator Profile",
  },
  {
    href: "https://cfs.sos.nh.gov/public/cf/reports",
    label: "Search candidate finance filings",
  },
  {
    href:
      externalProfileUrl(candidate, ["ballotpediaUrl", "ballotpedia_url"]) ||
      ballotpediaUrlForName(name),
    label: "Ballotpedia",
  },
  externalProfileUrl(candidate, ["citizensCountUrl", "citizens_count_url", "citizenscount_url"]) && {
    href: externalProfileUrl(candidate, ["citizensCountUrl", "citizens_count_url", "citizenscount_url"]),
    label: "Citizens Count",
  },
].filter(Boolean);

if (adminSession) {
  try {
    const [repData, explicitPersonId] = await Promise.all([
      getRepresentatives({ limit: 700 }),
      representativePersonIdForCandidate(candidate.filerEntityNumber),
    ]);
    legislatorOptions = repData.representatives || [];
    linkedRepresentativePersonId =
      explicitPersonId ||
      candidate.legislatorPersonId ||
      "";
  } catch (error) {
    console.error(error?.message || "Unable to load legislator link options.");
  }
}

try {
  organizations = await getOrganizations();
} catch (error) {
  console.error(error?.message || "Unable to load organization endorsements.");
}

const endorsements = endorsementsForCandidate(organizations, candidate, slug);
let relatedArticles = [];

try {
  const articleRequests = [
    getArticles({
      candidate: candidate.filerEntityNumber || candidate.filer_entity_number || name,
      include: "relations",
      limit: 6,
    }),
  ];

  if (candidate.legislatorPersonId) {
    articleRequests.push(
      getArticles({
        personid: candidate.legislatorPersonId,
        include: "relations",
        limit: 6,
      }),
    );
  }

  const articleResults = await Promise.allSettled(articleRequests);
  relatedArticles = uniqueArticles(
    articleResults
      .filter((result) => result.status === "fulfilled")
      .flatMap((result) => result.value.articles || []),
  ).slice(0, 6);
} catch (error) {
  console.error(error?.message || "Unable to load candidate articles.");
}

function formatCurrency(value) {
  const amount = Number(value || 0);
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  }).format(amount);
}

function formatDate(value) {
  if (!value) return "";

  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(value));
}

function legislatorOptionLabel(rep = {}) {
  return [
    repName(rep),
    rep.chamber || rep.legislativebody,
    rep.district || rep.raw_district,
    rep.party,
  ].filter(Boolean).join(" - ");
}

function uniqueCandidateRoles(roles = []) {
  const seen = new Set();

  return roles.filter((role) => {
    const key = [
      role.filerEntityNumber,
      role.office,
      role.county,
      role.district,
      role.electionYear,
    ]
      .filter(Boolean)
      .join("|");
    if (!key || seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

function roleOfficeLine(role = {}) {
  return [
    role.office,
    role.county,
    role.district ? `District ${role.district}` : "",
  ].filter(Boolean).join(", ");
}

function uniqueArticles(articles = []) {
  const seen = new Set();
  return articles.filter((article) => {
    const key = article.article_id || article.articleId || article.url || article.title;
    if (!key || seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/NH%20DB%20Logo.svg" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.svg" />
    <title>{name} | NH Deserves Better</title>
    <meta
      name="description"
      content={`Candidate profile and campaign finance summary for ${name}.`}
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/candidates">Back to candidates</a>

      {error && <p class="status-message error">{error}</p>}
      {message && <p class="status-message success">{message}</p>}

      <section class="profile-hero">
        <div class="portrait-card">
          {portraitUrl ? (
            <img src={portraitUrl} alt={name} />
          ) : (
            <img class="portrait-fallback" src={profileIcon.src} alt="" />
          )}
        </div>

        <div class="hero-copy">
          <p class="eyebrow">{candidate.electionCycle || "Candidate"}</p>
          <h1>{name}</h1>

          <div class="hero-meta">
            <span class:list={["meta-pill", partyClassName(candidate.politicalParty)]}>
              {formatCandidateParty(candidate.politicalParty)}
            </span>
            {hasFreeStaterTag && (
              <a
                class="meta-pill free-stater-pill"
                href="/free-staters"
                title="What is a Free Stater?"
                aria-label="What is a Free Stater?"
              >
                Free Stater
              </a>
            )}
            {officeTypeLabel && <span class="meta-pill">{officeTypeLabel}</span>}
            {candidate.electionYear && <span class="meta-pill">{candidate.electionYear}</span>}
            {candidate.currentLegislator && <span class="meta-pill">Current Legislator</span>}
            {currentLegislatorGrade && (
              <a
                class:list={["legislator-grade-pill", currentLegislatorGrade.className]}
                href="/vote-grades"
                title="How do we determine this?"
                aria-label={`How do we determine this? ${currentLegislatorGrade.label}`}
              >
                <strong>{currentLegislatorGrade.letter}</strong>
                <span>Legislator Grade</span>
              </a>
            )}
          </div>

          <p class="office-line">{officeParts.join(", ") || "Office not listed"}</p>

          {sourceLinks.length > 0 && (
            <div class="contact-actions">
              {sourceLinks.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </div>
          )}
        </div>
      </section>

      <section class="panel">
        <p class="eyebrow">Ballot Details</p>
        <div class="role-list">
          {candidateRoles.map((role) => (
            <article class="role-card">
              <div>
                <span>Office</span>
                <strong>{roleOfficeLine(role) || "Not listed"}</strong>
              </div>
              <div>
                <span>Party</span>
                <strong>{role.politicalParty || candidate.politicalParty || "Not listed"}</strong>
              </div>
              <div>
                <span>Election Year</span>
                <strong>{role.electionYear || candidate.electionYear || "Not listed"}</strong>
              </div>
            </article>
          ))}
          {(candidate.candidateWebsite || candidate.candidateEmail) && (
            <article class="role-card candidate-contact-details">
              {candidate.candidateWebsite && (
                <div>
                  <span>Campaign Website</span>
                  <strong>
                    <a href={candidate.candidateWebsite}>{candidate.candidateWebsite}</a>
                  </strong>
                </div>
              )}
              {candidate.candidateEmail && (
                <div>
                  <span>Email</span>
                  <strong>
                    <a href={`mailto:${candidate.candidateEmail}`}>{candidate.candidateEmail}</a>
                  </strong>
                </div>
              )}
            </article>
          )}
        </div>
      </section>

      <section class="panel articles-panel">
        <div class="section-heading">
          <p class="eyebrow">Articles</p>
          <h2>Related Coverage</h2>
        </div>

        <ArticleList articles={relatedArticles} emptyText="No related articles returned yet." />
      </section>

      <CommunityUpdates
        entityType="candidate"
        entityKey={candidateEntityKey}
        entityName={name}
        pageUrl={Astro.url.pathname}
      />

      {adminSession && (
        <section class="panel admin-edit-panel">
          <div class="section-heading">
            <p class="eyebrow">Admin</p>
            <h2>Edit Candidate Profile</h2>
            <p>
              These edits update the source candidate row in D1. Refresh after
              saving to see the API-backed profile data.
            </p>
          </div>

          <form class="admin-edit-form" action="/api/admin/profile" method="post">
            <input type="hidden" name="entityType" value="candidate" />
            <input type="hidden" name="entityKey" value={candidate.filerEntityNumber || slug} />
            <input type="hidden" name="redirectTo" value={Astro.url.pathname} />
            <input type="hidden" name="clearFields" value="linkedRepresentativePersonId" />

            <label>
              Name
              <input name="name" value={candidate.name || name} />
            </label>

            <div class="form-grid">
              <label>
                First Name
                <input name="candidateFirstName" value={candidate.candidateFirstName || ""} />
              </label>
              <label>
                Last Name
                <input name="candidateLastName" value={candidate.candidateLastName || ""} />
              </label>
            </div>

            <div class="form-grid">
              <label>
                Party
                <input name="politicalParty" value={candidate.politicalParty || ""} />
              </label>
              <label>
                Free Stater
                <select name="is_free_stater">
                  <option value="">No override</option>
                  <option value="true" selected={candidate.is_free_stater === true}>Yes</option>
                  <option value="false" selected={candidate.is_free_stater === false}>No</option>
                </select>
              </label>
            </div>

            <label>
              Linked Legislator
              <input
                name="linkedRepresentativePersonId"
                list="legislator-link-options"
                value={linkedRepresentativePersonId}
                placeholder="Start typing a legislator name, then select their personid"
              />
              <small class="field-help">
                Saves an explicit candidate-to-legislator link. Use the numeric
                personid shown by the autocomplete option.
              </small>
            </label>
            <datalist id="legislator-link-options">
              {legislatorOptions.map((rep) => (
                <option
                  value={rep.personid || rep.id}
                  label={legislatorOptionLabel(rep)}
                />
              ))}
            </datalist>

            <div class="form-grid">
              <label>
                Office Type
                <input name="officeType" value={candidate.officeType || ""} />
              </label>
              <label>
                Office
                <input name="office" value={candidate.office || ""} />
              </label>
            </div>

            <div class="form-grid">
              <label>
                County
                <input name="county" value={candidate.county || ""} />
              </label>
              <label>
                District
                <input name="district" value={candidate.district || ""} />
              </label>
            </div>

            <div class="form-grid">
              <label>
                Email
                <input name="candidateEmail" type="email" value={candidate.candidateEmail || ""} />
              </label>
              <label>
                Website
                <input name="candidateWebsite" type="url" value={candidate.candidateWebsite || ""} />
              </label>
            </div>

            <label>
              Photo URL
              <input name="photoUrl" type="url" value={candidate.photoUrl || ""} />
            </label>
            <input
              type="hidden"
              name="reviewNote"
              value="Reviewed candidate profile for missing photo, website, or email; no update found."
            />

            <div class="form-grid">
              <label>
                Election Year
                <input name="electionYear" inputmode="numeric" value={candidate.electionYear || ""} />
              </label>
              <label>
                Election Cycle
                <input name="electionCycle" value={candidate.electionCycle || ""} />
              </label>
            </div>

            <div class="form-grid">
              <label>
                Total Raised
                <input name="totalRaised" inputmode="decimal" value={candidate.totalRaised ?? ""} />
              </label>
              <label>
                Total Spent
                <input name="totalSpent" inputmode="decimal" value={candidate.totalSpent ?? ""} />
              </label>
            </div>

            <div class="admin-form-actions">
              <button type="submit">Save Candidate Edits</button>
              <button
                class="secondary-button"
                type="submit"
                name="profileAction"
                value="confirm-reviewed"
              >
                Confirm reviewed, no update found
              </button>
            </div>
          </form>

          <form
            class="admin-edit-form admin-upload-form"
            action="/api/admin/upload"
            method="post"
            enctype="multipart/form-data"
          >
            <input type="hidden" name="entityType" value="candidate" />
            <input type="hidden" name="entityKey" value={candidate.filerEntityNumber || slug} />
            <input type="hidden" name="redirectTo" value={Astro.url.pathname} />

            <div class="section-heading compact-heading">
              <p class="eyebrow">Photo Upload</p>
              <h2>Upload and update candidate photo</h2>
            </div>

            <label>
              R2 key
              <input
                name="key"
                value={`candidates/${candidate.filerEntityNumber || slug}-${slug}.jpg`}
              />
            </label>

            <label>
              Image file
              <input name="file" type="file" accept="image/*" required />
            </label>

            <button type="submit">Upload Candidate Photo</button>
          </form>

          <form class="admin-edit-form admin-remove-form" action="/api/admin/remove" method="post">
            <input type="hidden" name="entityType" value="candidate" />
            <input type="hidden" name="entityKey" value={candidate.filerEntityNumber || slug} />
            <input type="hidden" name="redirectTo" value={Astro.url.pathname} />

            <div class="section-heading compact-heading">
              <p class="eyebrow">Remove</p>
              <h2>Remove candidate from public results</h2>
              <p>This deletes the candidate row from the source D1 table.</p>
            </div>

            <label class="confirm-remove">
              <input name="confirmRemove" type="checkbox" value="yes" required />
              I understand this will remove this candidate from the site.
            </label>

            <button class="danger-button" type="submit">Remove Candidate</button>
          </form>
        </section>
      )}

      <section class="panel endorsements-panel">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Endorsements</p>
            <h2>Organizational Endorsements</h2>
          </div>
          <a class="section-action" href={`/endorsements/submit?candidate=${encodeURIComponent(candidateSlug(candidate))}`}>
            Submit an Endorsement
          </a>
        </div>

        {endorsements.length ? (
          <div class="endorsement-list">
            {endorsements.map((endorsement) => (
              <article>
                <div class="endorsement-topline">
                  <strong>
                    <a href={organizationPath(endorsement.organization)}>
                      {endorsement.organization.name}
                    </a>
                  </strong>
                  {endorsement.position && <span>{endorsement.position}</span>}
                </div>

                {endorsement.statement && <p>{endorsement.statement}</p>}

                <div class="endorsement-meta">
                  {endorsement.office && <span>{endorsement.office}</span>}
                  {endorsement.district && <span>{endorsement.district}</span>}
                  {endorsement.electionYear && <span>{endorsement.electionYear}</span>}
                  {endorsement.date && <span>{formatDate(endorsement.date)}</span>}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p class="empty">No organizational endorsements have been published yet.</p>
        )}
      </section>
    </main>
    <SiteFooter />
  </body>
</html>

<style>
  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .profile-hero {
    align-items: start;
    display: grid;
    gap: 28px;
    grid-template-columns: 260px 1fr;
    margin-top: 24px;
    padding: 32px;
  }

  .portrait-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 18px;
    box-shadow: none;
    overflow: hidden;
  }

  .portrait-card img,
  .portrait-fallback {
    aspect-ratio: 4 / 5;
    display: block;
    width: 100%;
  }

  .portrait-card img {
    object-fit: cover;
    object-position: center top;
  }

  .portrait-card img.portrait-fallback {
    background: transparent;
    box-sizing: border-box;
    object-fit: cover;
    padding: 0;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2.2rem, 5.5vw, 4.25rem);
    line-height: 0.95;
    margin: 0;
  }

  .hero-meta,
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .meta-pill {
    background: #f8fafc;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.84rem;
    font-weight: 900;
    padding: 7px 11px;
  }

  .party-democrat {
    background: #dbeafe;
    border-color: #2563eb;
  }

  .party-republican {
    background: #fee2e2;
    border-color: #dc2626;
  }

  .party-libertarian {
    background: #fef3c7;
    border-color: #d97706;
  }

  .free-stater-pill {
    background: #7f1d1d;
    border-color: #111827;
    box-shadow: none;
    color: white;
  }

  .free-stater-pill:hover {
    background: #450a0a;
  }

  .legislator-grade-pill {
    align-items: center;
    border: 1px solid rgba(31, 41, 51, 0.32);
    border-radius: 12px;
    color: #fefce8;
    display: inline-flex;
    gap: 8px;
    padding: 6px 10px;
    text-decoration: none;
  }

  .legislator-grade-pill strong,
  .legislator-grade-pill span {
    color: #fefce8;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .legislator-grade-pill strong {
    font-size: 1.45rem;
    font-weight: 950;
    line-height: 1;
  }

  .legislator-grade-pill span {
    font-size: 0.64rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .grade-a {
    background: #166534;
  }

  .grade-b {
    background: #65a30d;
  }

  .grade-c {
    background: #ca8a04;
  }

  .grade-d {
    background: #ea580c;
  }

  .grade-f {
    background: #b42318;
  }

  .grade-unknown {
    background: #5b616e;
  }

  .office-line {
    color: #4b5563;
    font-size: 1.15rem;
    font-weight: 800;
    line-height: 1.5;
    margin: 18px 0 0;
  }

  .contact-actions a {
    border: 1px solid #e2e8f0;
    border-radius: 999px;
    padding: 10px 14px;
    text-decoration: none;
  }

  .summary-strip {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, 1fr);
    margin: 24px 0;
  }

  .page > section + section,
  .page > .community-updates + section {
    margin-top: 24px;
  }

  .summary-strip article,
  .panel {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    box-shadow: none;
    padding: 18px;
  }

  .section-heading h2 {
    font-size: 1.45rem;
    margin: 0 0 16px;
  }

  .endorsements-panel .section-heading {
    align-items: start;
    display: flex;
    gap: 16px;
    justify-content: space-between;
  }

  .section-action {
    background: #1f2933;
    border: 1px solid #e2e8f0;
    border-radius: 999px;
    color: white;
    flex: 0 0 auto;
    font-size: 0.84rem;
    padding: 9px 12px;
    text-decoration: none;
  }

  .summary-strip span,
  .detail-grid span,
  .role-card span {
    color: #6b7280;
    display: block;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin-bottom: 6px;
    text-transform: uppercase;
  }

  .summary-strip strong {
    display: block;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1;
  }

