<style is:global>
  :root {
    --nhdb-page-rail: min(1280px, calc(100% - clamp(28px, 4vw, 64px)));
    --nhdb-ink: #1f2933;
    --nhdb-muted: #4b5563;
    --nhdb-soft: #f8fafc;
    --nhdb-panel: #ffffff;
    --nhdb-line: #e2e8f0;
    --nhdb-accent: #dc4d09;
    --nhdb-accent-soft: #fff7ed;
    --nhdb-warm: #fffaf1;
  }

  html {
    background: var(--nhdb-soft);
  }

  body {
    background: var(--nhdb-soft);
    color: var(--nhdb-ink);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    min-width: 0;
  }

  .page {
    box-sizing: border-box;
    margin-inline: auto;
    padding: 40px 0 72px;
    width: var(--nhdb-page-rail);
  }

  .page > .hero:first-child,
  .page > .profile-hero:first-child,
  .page > .article-hero:first-child,
  .page > .nhdb-page-hero:first-child {
    margin-top: 24px;
  }

  .hero,
  .profile-hero,
  .article-hero,
  .nhdb-page-hero {
    box-sizing: border-box;
  }

  .hero:not(:has(img)):not([style*="--hero-image"]),
  .profile-hero,
  .article-hero,
  .nhdb-page-hero,
  .panel,
  .card,
  .filter-card,
  .results-panel,
  .section-card,
  .admin-card,
  .content-card,
  .profile-section,
  .list-card,
  .empty-note {
    border-color: var(--nhdb-line);
    box-shadow: none;
  }

  .hero:not(:has(img)):not([style*="--hero-image"]),
  .profile-hero,
  .article-hero,
  .nhdb-page-hero {
    background: var(--nhdb-panel);
    border: 1px solid var(--nhdb-line);
    border-radius: 10px;
  }

  .hero:not(:has(img)):not([style*="--hero-image"]),
  body .profile-hero,
  body .article-hero,
  body .nhdb-page-hero {
    padding: 32px;
  }

  .panel,
  .card,
  .filter-card,
  .results-panel,
  .section-card,
  .admin-card,
  .content-card,
  .profile-section,
  .list-card,
  .empty-note {
    border-width: 1px;
    border-radius: 10px;
  }

  input,
  select,
  textarea {
    border-color: #cbd5e1;
  }

  button,
  .button,
  .primary-link,
  .secondary-link {
    border-radius: 999px;
  }

  .hero h1,
  .hero h2,
  .profile-hero h1,
  .article-hero h1,
  .nhdb-page-hero h1 {
    line-height: 1.03;
  }

  .eyebrow {
    color: #6b4f2a;
    letter-spacing: 0.12em;
  }

  @media (max-width: 600px) {
    :root {
      --nhdb-page-rail: min(100% - 24px, 1280px);
    }

    .page {
      padding: 24px 0 48px;
    }
  }
</style>
