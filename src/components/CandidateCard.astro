---
import {
  candidateName,
  candidatePath,
  formatCandidateParty,
  partyClassName,
} from "../lib/candidatesApi";
import profileIcon from "../assets/profile icon.png";
import { isFreeStater } from "../lib/civicTags";
import { profilePhotoUrl } from "../lib/photos";

const { candidate } = Astro.props;

const name = candidateName(candidate);
const photoUrl = profilePhotoUrl(candidate.photoUrl);
const officeParts = [
  candidate.office,
  candidate.county,
  candidate.district ? `District ${candidate.district}` : "",
].filter(Boolean);
const contactLinks = [
  candidate.candidateEmail && {
    href: `mailto:${candidate.candidateEmail}`,
    label: "Email",
  },
  candidate.candidateWebsite && {
    href: candidate.candidateWebsite,
    label: "Website",
  },
].filter(Boolean);

function formatCurrency(value) {
  const amount = Number(value || 0);
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  }).format(amount);
}
---

<article class="candidate-card">
  <a class="photo-wrap" href={candidatePath(candidate)}>
    {photoUrl ? (
      <img src={photoUrl} alt={`Photo of ${name}`} loading="lazy" />
    ) : (
      <img class="photo-fallback" src={profileIcon.src} alt="" loading="lazy" />
    )}
  </a>

  <div class="candidate-copy">
    <p class="eyebrow">{candidate.electionYear || "Election"}</p>
    <h3>
      <a href={candidatePath(candidate)}>{name}</a>
    </h3>

    <div class="pill-row">
      <span class:list={["party-pill", partyClassName(candidate.politicalParty)]}>
        {formatCandidateParty(candidate.politicalParty)}
      </span>
      {isFreeStater(candidate) && (
        <a class="free-stater-pill" href="/free-staters">Free Stater</a>
      )}
      {candidate.officeType && <span>{candidate.officeType}</span>}
    </div>

    <p class="office-line">{officeParts.join(", ") || "Office not listed"}</p>

    <dl>
      <div>
        <dt>Raised</dt>
        <dd>{formatCurrency(candidate.totalRaised)}</dd>
      </div>
      <div>
        <dt>Spent</dt>
        <dd>{formatCurrency(candidate.totalSpent)}</dd>
      </div>
    </dl>

    {contactLinks.length > 0 && (
      <div class="actions">
        {contactLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .candidate-card {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 16px;
    box-shadow: 4px 4px 0 #1f2933;
    color: inherit;
    display: grid;
    gap: 16px;
    grid-template-columns: 92px 1fr;
    padding: 16px;
  }

  a {
    color: inherit;
  }

  .photo-wrap,
  .photo-wrap img,
  .photo-fallback {
    width: 92px;
  }

  .photo-wrap img,
  .photo-fallback {
    aspect-ratio: 4 / 5;
    border: 2px solid #1f2933;
    border-radius: 12px;
    box-sizing: border-box;
    height: 115px;
    object-fit: cover;
    object-position: center top;
  }

  .photo-wrap img.photo-fallback {
    background: transparent;
    object-fit: cover;
    padding: 0;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 6px;
    text-transform: uppercase;
  }

  h3 {
    font-size: 1.25rem;
    line-height: 1.1;
    margin: 0;
  }

  .candidate-card:hover h3 a {
    text-decoration: underline;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }

  .pill-row span,
  .pill-row a {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 5px 9px;
    text-decoration: none;
  }

  .pill-row .party-democrat {
    background: #dbeafe;
    border-color: #2563eb;
  }

  .pill-row .party-republican {
    background: #fee2e2;
    border-color: #dc2626;
  }

  .pill-row .party-libertarian {
    background: #fef3c7;
    border-color: #d97706;
  }

  .pill-row .free-stater-pill {
    background: #ecfdf5;
    border-color: #059669;
    color: #064e3b;
  }

  .office-line {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.4;
    margin: 12px 0 0;
  }

  dl {
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 14px 0 0;
  }

  dl div {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    padding: 8px 10px;
  }

  dt {
    color: #6b7280;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  dd {
    font-size: 1rem;
    font-weight: 950;
    margin: 2px 0 0;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .actions a {
    border: 2px solid #1f2933;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 900;
    padding: 7px 10px;
    text-decoration: none;
  }

  @media (max-width: 520px) {
    .candidate-card {
      grid-template-columns: 1fr;
    }
  }
</style>
