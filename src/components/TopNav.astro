---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home", match: (path) => path === "/" },
  { href: "/my-state-rep", label: "My State Rep" },
  { href: "/state-government", label: "State Gov" },
  { href: "/how-bills-become-law", label: "Bill Process" },
  { href: "/communities", label: "Communities" },
  { href: "/candidates", label: "Candidates" },
  { href: "/organizations", label: "Organizations" },
  { href: "/free-staters", label: "Free Staters" },
  { href: "/bills", label: "Bills" },
  { href: "/articles", label: "Articles" },
  { href: "/search", label: "Search" },
];

function isActive(link) {
  if (link.match) return link.match(currentPath);
  return currentPath === link.href || currentPath.startsWith(`${link.href}/`);
}
---

<header class="site-nav">
  <div class="nav-inner">
    <a class="brand" href="/">
      <img src="/NH%20DB%20Logo.png" alt="" width="40" height="40" />
      <span>NH Deserves Better</span>
    </a>

    <nav aria-label="Primary navigation">
      {links.map((link) => (
        <a
          class:list={["nav-link", isActive(link) && "active"]}
          href={link.href}
          aria-current={isActive(link) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-nav {
    background: rgba(247, 244, 238, 0.96);
    border-bottom: 2px solid #1f2933;
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(10px);
  }

  .nav-inner {
    align-items: center;
    display: flex;
    gap: 18px;
    justify-content: space-between;
    margin: 0 auto;
    min-height: 64px;
    padding: 10px 0;
    width: min(1120px, calc(100% - 32px));
  }

  .brand,
  .nav-link {
    color: #1f2933;
    text-decoration: none;
  }

  .brand {
    align-items: center;
    gap: 10px;
    display: inline-flex;
    font-size: 1.02rem;
    font-weight: 950;
    min-height: 40px;
    white-space: nowrap;
  }

  .brand img {
    border-radius: 8px;
    display: block;
    height: 40px;
    object-fit: contain;
    width: 40px;
  }

  nav {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .nav-link {
    border: 1px solid transparent;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 850;
    line-height: 1;
    padding: 10px 12px;
  }

  .nav-link:hover,
  .nav-link.active {
    background: white;
    border-color: #1f2933;
  }

  .nav-link.active {
    box-shadow: 2px 2px 0 #1f2933;
  }

  @media (max-width: 720px) {
    .site-nav {
      position: sticky;
    }

    .nav-inner {
      align-items: start;
      flex-direction: column;
      gap: 6px;
      min-height: 0;
      padding: 8px 0;
    }

    .brand {
      font-size: 0.98rem;
      min-height: 34px;
    }

    .brand img {
      border-radius: 6px;
      height: 34px;
      width: 34px;
    }

    nav {
      flex-wrap: nowrap;
      justify-content: flex-start;
      margin: 0 calc(50% - 50vw);
      overflow-x: auto;
      padding: 2px max(16px, calc(50vw - 560px)) 8px;
      scrollbar-width: none;
      width: 100%;
    }

    nav::-webkit-scrollbar {
      display: none;
    }

    .nav-link {
      flex: 0 0 auto;
      font-size: 0.82rem;
      padding: 8px 10px;
    }
  }
</style>
