---
import GlobalTheme from "./GlobalTheme.astro";

const currentPath = Astro.url.pathname;
const suggestHref = `/suggest-update?page=${encodeURIComponent(Astro.url.href)}`;

const links = [
  { href: "/", label: "Home", match: (path) => path === "/" },
  { href: "/my-state-rep", label: "My Legislator" },
  { href: "/candidates", label: "Candidates" },
  { href: "/search", label: "Search" },
];

const exploreLinks = [
  { href: "/communities", label: "Communities" },
  { href: "/people", label: "Legislators" },
  { href: "/bills", label: "Bills" },
  { href: "/organizations", label: "Organizations" },
  { href: "/articles", label: "Articles" },
];

const guideLinks = [
  { href: "/state-government", label: "State Government" },
  { href: "/how-bills-become-law", label: "How Bills Become Law" },
  { href: "/free-staters", label: "Free Staters" },
];

function isActive(link) {
  if (link.match) return link.match(currentPath);
  return currentPath === link.href || currentPath.startsWith(`${link.href}/`);
}

const isExploreActive = exploreLinks.some(isActive);
const isGuidesActive = guideLinks.some(isActive);
---

<GlobalTheme />

<header class="site-nav" data-site-nav>
  <div class="nav-inner">
    <button
      class="mobile-menu-toggle"
      type="button"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="primary-navigation"
      data-mobile-menu-toggle
    >
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </button>

    <a class="return-link" href="/" data-return-link hidden>Return</a>

    <a class="brand" href="/">
      <img src="/NH%20DB%20Logo.svg" alt="" width="40" height="40" />
      <span>NH Deserves Better</span>
    </a>

    <nav id="primary-navigation" class="primary-nav" aria-label="Primary navigation">
      {links.map((link) => (
        <a
          class:list={["nav-link", isActive(link) && "active"]}
          href={link.href}
          aria-current={isActive(link) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
      <details class:list={["nav-dropdown", isExploreActive && "active"]}>
        <summary class="nav-link" aria-current={isExploreActive ? "page" : undefined}>
          Explore
        </summary>
        <div class="dropdown-menu">
          {exploreLinks.map((link) => (
            <a
              class:list={["dropdown-link", isActive(link) && "active"]}
              href={link.href}
              aria-current={isActive(link) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </details>
      <details class:list={["nav-dropdown", isGuidesActive && "active"]}>
        <summary class="nav-link" aria-current={isGuidesActive ? "page" : undefined}>
          Civic Guides
        </summary>
        <div class="dropdown-menu">
          {guideLinks.map((link) => (
            <a
              class:list={["dropdown-link", isActive(link) && "active"]}
              href={link.href}
              aria-current={isActive(link) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </details>
    </nav>

    <div class="utility-links">
      <a class="suggest-link" href={suggestHref}>Suggest an update</a>
    </div>
  </div>
</header>

<script>
  const returnLink = document.querySelector("[data-return-link]");
  const currentPath = `${window.location.pathname}${window.location.search}${window.location.hash}`;
  const storedCurrent = sessionStorage.getItem("nhdb_current_path") || "";
  const storedPrevious = sessionStorage.getItem("nhdb_previous_path") || "";
  let returnPath = "";

  if (storedCurrent && storedCurrent !== currentPath) {
    returnPath = storedCurrent;
    sessionStorage.setItem("nhdb_previous_path", storedCurrent);
  } else if (storedPrevious && storedPrevious !== currentPath) {
    returnPath = storedPrevious;
  }

  sessionStorage.setItem("nhdb_current_path", currentPath);

  if (
    returnLink instanceof HTMLAnchorElement &&
    returnPath &&
    returnPath !== currentPath &&
    returnPath.startsWith("/")
  ) {
    returnLink.href = returnPath;
    returnLink.hidden = false;
  }

  const siteNav = document.querySelector("[data-site-nav]");
  let lastScrollY = window.scrollY;
  let ticking = false;

  function navHasActiveInteraction() {
    return Boolean(
      siteNav?.matches(":hover, :focus-within") ||
        siteNav?.querySelector(".nav-dropdown[open]"),
    );
  }

  function updateNavVisibility() {
    if (!(siteNav instanceof HTMLElement)) return;

    const currentScrollY = Math.max(window.scrollY, 0);
    const delta = currentScrollY - lastScrollY;

    if (currentScrollY < 80 || delta < -6 || navHasActiveInteraction()) {
      siteNav.classList.remove("is-hidden");
    } else if (delta > 6) {
      siteNav.classList.add("is-hidden");
    }

    lastScrollY = currentScrollY;
    ticking = false;
  }

  window.addEventListener(
    "scroll",
    () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateNavVisibility);
    },
    { passive: true },
  );

  siteNav?.addEventListener("mouseenter", () => siteNav.classList.remove("is-hidden"));
  siteNav?.addEventListener("focusin", () => siteNav.classList.remove("is-hidden"));
  siteNav?.addEventListener("toggle", () => siteNav.classList.remove("is-hidden"), true);

  const navDropdowns = Array.from(document.querySelectorAll(".nav-dropdown"));

  navDropdowns.forEach((dropdown) => {
    dropdown.addEventListener("toggle", () => {
      if (!(dropdown instanceof HTMLDetailsElement) || !dropdown.open) return;

      navDropdowns.forEach((otherDropdown) => {
        if (
          otherDropdown !== dropdown &&
          otherDropdown instanceof HTMLDetailsElement
        ) {
          otherDropdown.open = false;
        }
      });
    });
  });

  document.addEventListener("click", (event) => {
    if (siteNav?.contains(event.target instanceof Node ? event.target : null)) return;

    navDropdowns.forEach((dropdown) => {
      if (dropdown instanceof HTMLDetailsElement) dropdown.open = false;
    });
  });

  const menuToggle = document.querySelector("[data-mobile-menu-toggle]");
  menuToggle?.addEventListener("click", () => {
    if (!(siteNav instanceof HTMLElement) || !(menuToggle instanceof HTMLButtonElement)) return;
    const isOpen = siteNav.classList.toggle("nav-open");
    menuToggle.setAttribute("aria-expanded", String(isOpen));
    siteNav.classList.remove("is-hidden");
  });
</script>

<style>
  .site-nav {
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid #e2e8f0;
    position: sticky;
    top: 0;
    transform: translateY(0);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
    z-index: 20;
    backdrop-filter: blur(10px);
  }

  .site-nav.is-hidden {
    box-shadow: none;
    transform: translateY(-110%);
  }

  .site-nav:focus-within,
  .site-nav:hover,
  .site-nav:has(.nav-dropdown[open]) {
    transform: translateY(0);
  }

  .nav-inner {
    align-items: center;
    display: flex;
    gap: 18px;
    justify-content: space-between;
    margin: 0 auto;
    min-height: 64px;
    padding: 10px 0;
    width: min(1280px, calc(100% - clamp(28px, 4vw, 64px)));
  }

  .mobile-menu-toggle {
    background: transparent;
    border: 0;
    display: none;
    flex: 0 0 auto;
    gap: 3px;
    grid-template-columns: repeat(3, 4px);
    padding: 11px;
  }

  .mobile-menu-toggle span {
    background: #1f2933;
    border-radius: 999px;
    display: block;
    height: 4px;
    width: 4px;
  }

  .brand,
  .return-link,
  .nav-link,
  .dropdown-link,
  .admin-link,
  .suggest-link {
    color: #1f2933;
    text-decoration: none;
  }

  .brand {
    align-items: center;
    gap: 10px;
    display: inline-flex;
    font-size: 1.02rem;
    font-weight: 950;
    min-height: 40px;
    white-space: nowrap;
  }

  .return-link {
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    flex: 0 0 auto;
    font-size: 0.84rem;
    font-weight: 900;
    line-height: 1;
    padding: 10px 11px;
    white-space: nowrap;
  }

  .return-link::before {
    content: "< ";
  }

  .return-link:hover {
    background: #fff7ed;
    border-color: #fed7aa;
  }

  .return-link[hidden] {
    display: none;
  }

  .brand img {
    border-radius: 4px;
    display: block;
    height: 40px;
    object-fit: contain;
    width: 40px;
  }

  .primary-nav {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .nav-link {
    border: 1px solid transparent;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 850;
    line-height: 1;
    padding: 10px 12px;
  }

  .nav-link:hover,
  .nav-link.active,
  .nav-dropdown.active > summary,
  .nav-dropdown[open] > summary,
  .suggest-link:hover {
    background: #fff7ed;
    border-color: #fed7aa;
    color: #b6390a;
  }

  .nav-link.active,
  .nav-dropdown.active > summary {
    box-shadow: inset 3px 0 0 #dc4d09;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown summary {
    align-items: center;
    display: flex;
    gap: 6px;
    list-style: none;
  }

  .nav-dropdown summary::-webkit-details-marker {
    display: none;
  }

  .nav-dropdown summary::after {
    content: "v";
    font-size: 0.7rem;
    line-height: 1;
  }

  .dropdown-menu {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 0 0 10px 10px;
    box-shadow: 0 14px 32px rgba(15, 23, 42, 0.12);
    display: grid;
    gap: 4px;
    min-width: 220px;
    padding: 8px;
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    z-index: 40;
  }

  .dropdown-link {
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 850;
    padding: 10px 12px;
    white-space: nowrap;
  }

  .dropdown-link:hover,
  .dropdown-link.active {
    background: #fff7ed;
    color: #b6390a;
  }

  .utility-links {
    align-items: center;
    display: flex;
    flex: 0 0 auto;
    gap: 8px;
  }

  .admin-link {
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    font-size: 0.84rem;
    font-weight: 900;
    line-height: 1;
    padding: 10px 11px;
    white-space: nowrap;
  }

  .admin-link:hover {
    background: #fff7ed;
    border-color: #fed7aa;
  }

  .suggest-link {
    background: #dc4d09;
    border: 1px solid #dc4d09;
    border-radius: 4px;
    color: white;
    font-size: 0.88rem;
    font-weight: 900;
    line-height: 1;
    padding: 10px 12px;
    white-space: nowrap;
  }

  .suggest-link:hover {
    color: #b6390a;
  }

  @media (max-width: 1040px) {
    .site-nav {
      position: sticky;
    }

    .nav-inner {
      align-items: center;
      display: grid;
      gap: 8px 12px;
      grid-template-columns: auto minmax(0, 1fr) auto;
      min-height: 0;
      padding: 8px 0;
    }

    .mobile-menu-toggle {
      display: grid;
      grid-column: 1;
      grid-row: 1;
      justify-self: start;
      position: relative;
      z-index: 2;
    }

    .brand {
      font-size: 1.04rem;
      grid-column: 1 / -1;
      grid-row: 1;
      justify-self: center;
      min-height: 42px;
      position: relative;
      z-index: 1;
    }

    .return-link {
      font-size: 0.82rem;
      grid-column: 1 / -1;
      grid-row: 2;
      justify-self: start;
      padding: 8px 10px;
    }

    .brand img {
      border-radius: 6px;
      height: 42px;
      width: 42px;
    }

    .primary-nav,
    .utility-links {
      display: none;
      grid-column: 1 / -1;
      justify-content: flex-start;
      width: 100%;
    }

    .site-nav.nav-open .primary-nav {
      align-items: stretch;
      border-top: 1px solid #e2e8f0;
      display: grid;
      gap: 6px;
      grid-row: 3;
      padding-top: 10px;
    }

    .site-nav.nav-open .utility-links {
      display: flex;
      flex-wrap: wrap;
      grid-row: 4;
      padding-bottom: 4px;
    }

    .admin-link,
    .suggest-link {
      font-size: 0.82rem;
      padding: 8px 10px;
    }

    .nav-link {
      flex: 0 0 auto;
      font-size: 0.82rem;
      justify-content: space-between;
      padding: 8px 10px;
    }

    .nav-dropdown {
      flex: 0 0 auto;
    }

    .nav-dropdown[open] {
      width: 100%;
    }

    .dropdown-menu {
      margin-top: 8px;
      min-width: 0;
      position: static;
      width: min(100%, 320px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav {
      transition: none;
    }
  }
</style>
