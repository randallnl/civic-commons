---
const currentPath = Astro.url.pathname;
const suggestHref = `/suggest-update?page=${encodeURIComponent(Astro.url.href)}`;

const links = [
  { href: "/", label: "Home", match: (path) => path === "/" },
  { href: "/my-state-rep", label: "My State Rep" },
  { href: "/candidates", label: "Candidates" },
  { href: "/search", label: "Search" },
];

const exploreLinks = [
  { href: "/communities", label: "Communities" },
  { href: "/people", label: "Legislators" },
  { href: "/bills", label: "Bills" },
  { href: "/organizations", label: "Organizations" },
  { href: "/articles", label: "Articles" },
];

const guideLinks = [
  { href: "/state-government", label: "State Government" },
  { href: "/how-bills-become-law", label: "How Bills Become Law" },
  { href: "/free-staters", label: "Free Staters" },
];

function isActive(link) {
  if (link.match) return link.match(currentPath);
  return currentPath === link.href || currentPath.startsWith(`${link.href}/`);
}

const isExploreActive = exploreLinks.some(isActive);
const isGuidesActive = guideLinks.some(isActive);
---

<header class="site-nav">
  <div class="nav-inner">
    <a class="return-link" href="/" data-return-link hidden>Return</a>

    <a class="brand" href="/">
      <img src="/NH%20DB%20Logo.png" alt="" width="40" height="40" />
      <span>NH Deserves Better</span>
    </a>

    <nav aria-label="Primary navigation">
      {links.map((link) => (
        <a
          class:list={["nav-link", isActive(link) && "active"]}
          href={link.href}
          aria-current={isActive(link) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
      <details class:list={["nav-dropdown", isExploreActive && "active"]}>
        <summary class="nav-link" aria-current={isExploreActive ? "page" : undefined}>
          Explore
        </summary>
        <div class="dropdown-menu">
          {exploreLinks.map((link) => (
            <a
              class:list={["dropdown-link", isActive(link) && "active"]}
              href={link.href}
              aria-current={isActive(link) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </details>
      <details class:list={["nav-dropdown", isGuidesActive && "active"]}>
        <summary class="nav-link" aria-current={isGuidesActive ? "page" : undefined}>
          Civic Guides
        </summary>
        <div class="dropdown-menu">
          {guideLinks.map((link) => (
            <a
              class:list={["dropdown-link", isActive(link) && "active"]}
              href={link.href}
              aria-current={isActive(link) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </details>
    </nav>

    <div class="utility-links">
      <a class="admin-link" href="/admin">Admin</a>
      <a class="suggest-link" href={suggestHref}>Suggest an update</a>
    </div>
  </div>
</header>

<script>
  const returnLink = document.querySelector("[data-return-link]");
  const currentPath = `${window.location.pathname}${window.location.search}${window.location.hash}`;
  const storedCurrent = sessionStorage.getItem("nhdb_current_path") || "";
  const storedPrevious = sessionStorage.getItem("nhdb_previous_path") || "";
  let returnPath = "";

  if (storedCurrent && storedCurrent !== currentPath) {
    returnPath = storedCurrent;
    sessionStorage.setItem("nhdb_previous_path", storedCurrent);
  } else if (storedPrevious && storedPrevious !== currentPath) {
    returnPath = storedPrevious;
  }

  sessionStorage.setItem("nhdb_current_path", currentPath);

  if (
    returnLink instanceof HTMLAnchorElement &&
    returnPath &&
    returnPath !== currentPath &&
    returnPath.startsWith("/")
  ) {
    returnLink.href = returnPath;
    returnLink.hidden = false;
  }
</script>

<style>
  .site-nav {
    background: rgba(247, 244, 238, 0.96);
    border-bottom: 2px solid #1f2933;
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(10px);
  }

  .nav-inner {
    align-items: center;
    display: flex;
    gap: 18px;
    justify-content: space-between;
    margin: 0 auto;
    min-height: 64px;
    padding: 10px 0;
    width: min(1120px, calc(100% - 32px));
  }

  .brand,
  .return-link,
  .nav-link,
  .dropdown-link,
  .admin-link,
  .suggest-link {
    color: #1f2933;
    text-decoration: none;
  }

  .brand {
    align-items: center;
    gap: 10px;
    display: inline-flex;
    font-size: 1.02rem;
    font-weight: 950;
    min-height: 40px;
    white-space: nowrap;
  }

  .return-link {
    border: 1px solid #d1d5db;
    border-radius: 999px;
    flex: 0 0 auto;
    font-size: 0.84rem;
    font-weight: 900;
    line-height: 1;
    padding: 10px 11px;
    white-space: nowrap;
  }

  .return-link::before {
    content: "< ";
  }

  .return-link:hover {
    background: white;
    border-color: #1f2933;
  }

  .return-link[hidden] {
    display: none;
  }

  .brand img {
    border-radius: 8px;
    display: block;
    height: 40px;
    object-fit: contain;
    width: 40px;
  }

  nav {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .nav-link {
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 850;
    line-height: 1;
    padding: 10px 12px;
  }

  .nav-link:hover,
  .nav-link.active,
  .nav-dropdown.active > summary,
  .nav-dropdown[open] > summary,
  .suggest-link:hover {
    background: white;
    border-color: #1f2933;
  }

  .nav-link.active,
  .nav-dropdown.active > summary {
    box-shadow: 2px 2px 0 #1f2933;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown summary {
    align-items: center;
    display: flex;
    gap: 6px;
    list-style: none;
  }

  .nav-dropdown summary::-webkit-details-marker {
    display: none;
  }

  .nav-dropdown summary::after {
    content: "v";
    font-size: 0.7rem;
    line-height: 1;
  }

  .dropdown-menu {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 12px;
    box-shadow: 3px 3px 0 #1f2933;
    display: grid;
    gap: 4px;
    min-width: 220px;
    padding: 8px;
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    z-index: 40;
  }

  .dropdown-link {
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 850;
    padding: 10px 12px;
    white-space: nowrap;
  }

  .dropdown-link:hover,
  .dropdown-link.active {
    background: #f7f4ee;
  }

  .utility-links {
    align-items: center;
    display: flex;
    flex: 0 0 auto;
    gap: 8px;
  }

  .admin-link {
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 900;
    line-height: 1;
    padding: 10px 11px;
    white-space: nowrap;
  }

  .admin-link:hover {
    background: white;
    border-color: #1f2933;
  }

  .suggest-link {
    background: #1f2933;
    border: 1px solid #1f2933;
    border-radius: 999px;
    color: white;
    font-size: 0.88rem;
    font-weight: 900;
    line-height: 1;
    padding: 10px 12px;
    white-space: nowrap;
  }

  .suggest-link:hover {
    color: #1f2933;
  }

  @media (max-width: 720px) {
    .site-nav {
      position: sticky;
    }

    .nav-inner {
      align-items: start;
      flex-direction: column;
      gap: 6px;
      min-height: 0;
      padding: 8px 0;
    }

    .brand {
      font-size: 0.98rem;
      min-height: 34px;
    }

    .return-link {
      font-size: 0.82rem;
      padding: 8px 10px;
    }

    .brand img {
      border-radius: 6px;
      height: 34px;
      width: 34px;
    }

    nav {
      flex-wrap: wrap;
      justify-content: flex-start;
      margin: 0;
      overflow: visible;
      padding: 2px 0 8px;
      scrollbar-width: none;
      width: 100%;
    }

    .utility-links {
      align-self: flex-start;
      flex-wrap: wrap;
    }

    .admin-link,
    .suggest-link {
      font-size: 0.82rem;
      padding: 8px 10px;
    }

    nav::-webkit-scrollbar {
      display: none;
    }

    .nav-link {
      flex: 0 0 auto;
      font-size: 0.82rem;
      padding: 8px 10px;
    }

    .nav-dropdown {
      flex: 0 0 auto;
    }

    .nav-dropdown[open] {
      flex-basis: 100%;
    }

    .dropdown-menu {
      margin-top: 8px;
      min-width: 0;
      position: static;
      width: min(100%, 320px);
    }
  }
</style>
