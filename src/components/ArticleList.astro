---
import { cleanText } from "../lib/text";
import { enrichArticlesWithPreviews } from "../lib/articlePreviews";
import { articlePublishDate, articleSourceName } from "../lib/articlesApi";

const { articles = [], emptyText = "No articles found.", compact = false } = Astro.props;
const previewArticles = await enrichArticlesWithPreviews(articles, { limit: compact ? 8 : 20 });

function previewText(text = "", maxLength = compact ? 140 : 220) {
  const normalized = cleanText(text).replace(/\s+/g, " ").trim();
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trim()}...`;
}

function relationLabels(article = {}) {
  return [
    ...(article.bills || []).map((bill) => bill.condensedbillno).filter(Boolean),
    ...(article.towns || []).map((town) => town.town || town.name || town).filter(Boolean),
    ...(article.legislators || [])
      .map((person) => person.matched_name || person.legislator_name_raw)
      .filter(Boolean),
    ...(article.issueAreas || []).map((issue) => issue.issue_area).filter(Boolean),
  ].map(cleanText).slice(0, compact ? 4 : 8);
}
---

{previewArticles.length ? (
  <div class:list={["article-list", compact && "compact"]}>
    {previewArticles.map((article) => (
      <article class="article-card">
        {article.preview?.imageUrl && (
          <a class="article-image" href={article.url} tabindex="-1" aria-hidden="true">
            <img src={article.preview.imageUrl} alt="" loading="lazy" />
          </a>
        )}
        <div class="article-copy">
        <div class="article-topline">
          {article.resource_type && <span>{cleanText(article.resource_type)}</span>}
          {articleSourceName(article) && <span>Source: {articleSourceName(article)}</span>}
          {articlePublishDate(article) && <span>Published: {articlePublishDate(article)}</span>}
        </div>

        <h3>
          <a href={article.url}>{cleanText(article.preview?.title || article.title)}</a>
        </h3>

        {(article.preview?.description || article.summary) && (
          <p>{previewText(article.preview?.description || article.summary)}</p>
        )}

        {relationLabels(article).length > 0 && (
          <div class="relation-chips">
            {relationLabels(article).map((label) => (
              <span>{label}</span>
            ))}
          </div>
        )}
        </div>
      </article>
    ))}
  </div>
) : (
  <p class="empty">{emptyText}</p>
)}

<style>
  .article-list {
    display: grid;
    gap: 12px;
  }

  .article-card {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    padding: 16px;
  }

  .article-card:has(.article-image) {
    grid-template-columns: 152px minmax(0, 1fr);
    gap: 16px;
  }

  .article-image {
    display: block;
  }

  .article-image img {
    border: 1px solid #d1d5db;
    border-radius: 6px;
    display: block;
    height: 100%;
    max-height: 132px;
    object-fit: cover;
    width: 100%;
  }

  .article-list.compact .article-card {
    padding: 14px;
  }

  .article-topline,
  .relation-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .article-topline span,
  .relation-chips span {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.76rem;
    font-weight: 900;
    padding: 5px 8px;
  }

  h3 {
    font-size: 1.05rem;
    line-height: 1.25;
    margin: 10px 0 6px;
  }

  p {
    color: #4b5563;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  .publisher {
    font-weight: 900;
  }

  .relation-chips {
    margin-top: 12px;
  }

  .empty {
    color: #4b5563;
    font-weight: 800;
    margin: 0;
  }

  @media (max-width: 560px) {
    .article-card:has(.article-image) {
      grid-template-columns: 104px minmax(0, 1fr);
      gap: 12px;
    }
  }
</style>
