---
import { cleanText } from "../lib/text";
import { enrichArticlesWithPreviews } from "../lib/articlePreviews";
import { articleDetailPath, articlePublishDate, articleSourceName } from "../lib/articlesApi";
import { billDetailPath } from "../lib/billsApi";
import { candidatePath } from "../lib/candidatesApi";

const { articles = [], emptyText = "No articles found.", compact = false } = Astro.props;
const previewArticles = await enrichArticlesWithPreviews(articles, {
  limit: compact ? 8 : Math.min(articles.length, 100),
});

function previewText(text = "", maxLength = compact ? 140 : 220) {
  const normalized = cleanText(text).replace(/\s+/g, " ").trim();
  if (normalized.length <= maxLength) return normalized;
  return `${normalized.slice(0, maxLength).trim()}...`;
}

function slugify(value = "") {
  return String(value)
    .toLowerCase()
    .trim()
    .replace(/['']/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function mentionedBills(article = {}) {
  return (article.bills || [])
    .map((bill) => {
      const code = cleanText(bill.condensedbillno || bill.bill_number || bill.code || "");
      if (!code) return null;
      return {
        label: code,
        href: billDetailPath(code, bill.sessionyear || bill.year),
      };
    })
    .filter(Boolean)
    .slice(0, compact ? 3 : 6);
}

function legislatorPath(person = {}) {
  const key =
    person.personid ||
    person.id ||
    person.employeeno ||
    slugify(person.matched_name || person.legislator_name_raw || person.name || "");
  return `/people/${encodeURIComponent(String(key))}`;
}

function mentionedPeople(article = {}) {
  const legislators = (article.legislators || [])
    .map((person) => {
      const label = cleanText(person.matched_name || person.legislator_name_raw || person.name || "");
      if (!label) return null;
      return { label, href: legislatorPath(person) };
    })
    .filter(Boolean);

  const candidates = (article.candidates || [])
    .map((candidate) => {
      const label = cleanText(candidate.name || candidate.candidate_name_raw || "");
      if (!label) return null;
      return { label, href: candidatePath(candidate) };
    })
    .filter(Boolean);

  return [...legislators, ...candidates].slice(0, compact ? 3 : 6);
}

function articleSearchText(article = {}) {
  return cleanText([
    article.preview?.title,
    article.title,
    article.preview?.description,
    article.summary,
    articleSourceName(article),
    article.resource_type,
    article.town,
    article.towns,
    ...(article.bills || []).map((bill) => bill.condensedbillno || bill.bill_number || bill.code),
    ...(article.legislators || []).map((person) => person.matched_name || person.legislator_name_raw || person.name),
    ...(article.candidates || []).map((candidate) => candidate.name || candidate.candidate_name_raw),
  ].flat().filter(Boolean).join(" "));
}

function articleBillText(article = {}) {
  return cleanText((article.bills || [])
    .map((bill) => bill.condensedbillno || bill.bill_number || bill.code)
    .filter(Boolean)
    .join(" "));
}

function articlePeopleText(article = {}) {
  return cleanText(mentionedPeople(article).map((person) => person.label).join(" "));
}

function articleTownText(article = {}) {
  return cleanText([article.town, article.towns, article.community, article.communities]
    .flat()
    .filter(Boolean)
    .join(" "));
}
---

{previewArticles.length ? (
  <div class:list={["article-list", compact && "compact"]}>
    {previewArticles.map((article) => (
      <article
        class="article-card"
        data-fuzzy-item
        data-fuzzy-title={cleanText(article.preview?.title || article.title)}
        data-fuzzy-bill={articleBillText(article)}
        data-fuzzy-people={articlePeopleText(article)}
        data-fuzzy-town={articleTownText(article)}
        data-fuzzy-source={articleSourceName(article)}
        data-fuzzy-text={articleSearchText(article)}
      >
        {article.preview?.imageUrl && (
          <a class="article-image" href={articleDetailPath(article)} tabindex="-1" aria-hidden="true">
            <img src={article.preview.imageUrl} alt="" loading="lazy" />
          </a>
        )}
        <div class="article-copy">
        <div class="article-topline">
          {article.resource_type && <span>{cleanText(article.resource_type)}</span>}
          {articleSourceName(article) && <span>Source: {articleSourceName(article)}</span>}
          {articlePublishDate(article) && <span>Published: {articlePublishDate(article)}</span>}
        </div>

        <h3>
          <a href={articleDetailPath(article)}>{cleanText(article.preview?.title || article.title)}</a>
        </h3>

        {(article.preview?.description || article.summary) && (
          <p>{previewText(article.preview?.description || article.summary)}</p>
        )}

        {(mentionedBills(article).length > 0 || mentionedPeople(article).length > 0) && (
          <div class="relation-groups">
            {mentionedBills(article).length > 0 && (
              <div class="relation-group">
                <span class="relation-heading">Mentioned Bills</span>
                <div class="relation-chips">
                  {mentionedBills(article).map((bill) => (
                    <a href={bill.href}>{bill.label}</a>
                  ))}
                </div>
              </div>
            )}

            {mentionedPeople(article).length > 0 && (
              <div class="relation-group">
                <span class="relation-heading">Mentioned People</span>
                <div class="relation-chips">
                  {mentionedPeople(article).map((person) => (
                    <a href={person.href}>{person.label}</a>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}
        {article.url && <a class="source-link" href={article.url}>Original article</a>}
        </div>
      </article>
    ))}
  </div>
) : (
  <p class="empty">{emptyText}</p>
)}

<style>
  .article-list {
    display: grid;
    gap: 12px;
  }

  .article-card {
    background: #f8fafc;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    padding: 16px;
  }

  .article-card:has(.article-image) {
    grid-template-columns: 152px minmax(0, 1fr);
    gap: 16px;
  }

  .article-image {
    display: block;
  }

  .article-image img {
    border: 1px solid #d1d5db;
    border-radius: 6px;
    display: block;
    height: 100%;
    max-height: 132px;
    object-fit: cover;
    width: 100%;
  }

  .article-list.compact .article-card {
    padding: 14px;
  }

  .article-topline,
  .relation-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .article-topline span,
  .relation-chips a {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.76rem;
    font-weight: 900;
    padding: 5px 8px;
    text-decoration: none;
  }

  .relation-chips a:hover {
    border-color: #dc4d09;
    color: #b6390a;
  }

  h3 {
    font-size: 1.05rem;
    line-height: 1.25;
    margin: 10px 0 6px;
  }

  p {
    color: #4b5563;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  .publisher {
    font-weight: 900;
  }

  .relation-groups {
    display: grid;
    gap: 10px;
    margin-top: 12px;
  }

  .relation-group {
    display: grid;
    gap: 6px;
  }

  .relation-heading {
    color: #6b7280;
    display: block;
    font-size: 0.7rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .source-link {
    display: inline-block;
    font-size: 0.86rem;
    margin-top: 12px;
  }

  .empty {
    color: #4b5563;
    font-weight: 800;
    margin: 0;
  }

  @media (max-width: 560px) {
    .article-card:has(.article-image) {
      grid-template-columns: 104px minmax(0, 1fr);
      gap: 12px;
    }
  }
</style>
