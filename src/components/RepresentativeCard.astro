---
import BillPositionSummary from "./BillPositionSummary.astro";
import profileIcon from "../assets/profile icon.png";
import { billDetailPath } from "../lib/billsApi";
import { isFreeStater } from "../lib/civicTags";
import { profilePhotoUrl } from "../lib/photos";
import { cleanText } from "../lib/text";
import {
  normalizeBillCode,
  representativeGradeFor,
  representativeOnlineTestimonyVotePreviews,
  representativeOnlineTestimonyVoteStance,
  trackedBillForVote,
} from "../lib/trackedBills";

const { rep, trackedBills = new Map(), billSummaries = new Map() } = Astro.props;

function formatParty(party) {
  if (!party) return "Party not listed";
  if (party === "R") return "Republican";
  if (party === "D") return "Democrat";
  if (party === "I") return "Independent";
  return cleanText(party);
}

function slugify(value = "") {
  return String(value)
    .toLowerCase()
    .trim()
    .replace(/['']/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

const name = cleanText(
  rep.name || `${rep.firstname || ""} ${rep.lastname || ""}`.trim(),
);
const profileHref = `/people/${slugify(name)}`;
const photoUrl = profilePhotoUrl(rep.photo);
const voteHistory = representativeOnlineTestimonyVotePreviews(rep, billSummaries, { limit: 3 });
const grade = representativeGradeFor(rep, trackedBills, billSummaries);

function trackedBillFor(vote) {
  return trackedBillForVote(trackedBills, vote);
}

function billSummaryFor(vote) {
  return billSummaries.get(normalizeBillCode(vote.condensedbillno || vote.bill_number));
}

function billPreviewTitle(billSummary = {}, trackedBill = {}) {
  return cleanText(
    billSummary?.name ||
      billSummary?.title ||
      trackedBill?.name ||
      trackedBill?.title ||
      "",
  );
}
---

<article class="rep-card">
  <div class="rep-card-top">
    <a class="photo-wrap" href={profileHref}>
      {photoUrl ? (
        <img
          class="rep-photo"
          src={photoUrl}
          alt={`Photo of ${name}`}
          loading="lazy"
        />
      ) : (
        <img
          class="rep-photo fallback-photo"
          src={profileIcon.src}
          alt=""
          loading="lazy"
        />
      )}
    </a>

    <div class="rep-main">
      <div class="rep-heading">
        <h3><a href={profileHref}>{name}</a></h3>
        <a
          class:list={["rep-grade", grade.className]}
          href="/vote-grades"
          title="How do we determine this?"
          aria-label={`How do we determine this? ${grade.label}`}
        >
          <span>{grade.letter}</span>
          <small>Grade</small>
        </a>
      </div>

      <div class="rep-meta">
        <span>{cleanText(rep.chamber || "Legislator")}</span>
        <span>{formatParty(rep.party)}</span>
        {isFreeStater(rep) && (
          <a
            class="free-stater-pill"
            href="/free-staters"
            title="What is a Free Stater?"
            aria-label="What is a Free Stater?"
          >
            Free Stater
          </a>
        )}
      </div>

      <div class="district-line">
        <strong>District:</strong> {rep.district || "Not listed"}
      </div>

      {rep.location_text && (
        <div class="location-line">
          {cleanText(rep.location_text)}
        </div>
      )}
    </div>
  </div>

  <div class="rep-contact">
    <div>
      <span>Email</span>
      {cleanText(rep.email || "Email not listed")}
    </div>

    <div>
      <span>Phone</span>
      {cleanText(rep.phone || "Phone not listed")}
    </div>

    {rep.notes && (
      <div>
        <span>Notes</span>
        <p>{cleanText(rep.notes)}</p>
      </div>
    )}
  </div>

  <div class="vote-summary">
    <span>Online Testimony Alignment</span>

    {voteHistory.length ? (
      <div class="vote-list">
        {voteHistory.map((preview) => {
          const vote = preview.vote;
          const bill = trackedBillFor(vote);
          const billSummary = preview.billSummary || billSummaryFor(vote);
          const billYear = billSummary?.sessionyear || vote.sessionyear;
          const stance = representativeOnlineTestimonyVoteStance(vote, billSummary);
          const voteImpact = "";
          const summary = billSummary?.summary || bill?.summary || "";
          const billTitle = billPreviewTitle(billSummary, bill);

          return (
            <div class="vote-item">
              <div class="vote-heading">
                <strong>
                  <a href={billDetailPath(bill?.code || vote.condensedbillno, billYear)}>
                    {bill?.code || vote.condensedbillno || "Bill"}
                  </a>
                </strong>
                {billTitle && (
                  <span>{billTitle}</span>
                )}
                {summary && <p class="bill-summary">{cleanText(summary)}</p>}
              </div>
              <div class="vote-copy">
                <div class:list={["vote-interpretation", stance.className]}>
                  <a
                    class:list={["legislator-vote-pill", stance.className]}
                    href="/vote-interpretations"
                    title="How do we determine this?"
                    aria-label={`How do we determine this? ${stance.label}`}
                  >
                    {stance.label}
                  </a>
                  {voteImpact && <p class="vote-impact">{cleanText(voteImpact)}</p>}
                </div>
              </div>
              <div class="vote-pill-stack">
                {billSummary && (
                  <BillPositionSummary bill={billSummary} compact={true} />
                )}
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <p>No scored online testimony vote previews returned.</p>
    )}
  </div>
</article>

<style>
  .rep-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    box-shadow: none;
    color: inherit;
    overflow: hidden;
    padding: 18px;
  }

  .rep-card a {
    color: inherit;
  }

  .rep-card:hover h3 a {
    text-decoration: underline;
  }

  .photo-wrap {
    display: block;
  }

  .rep-card-top {
    align-items: start;
    display: grid;
    gap: 16px;
    grid-template-columns: 96px 1fr;
  }

  .photo-wrap,
  .rep-photo {
    width: 96px;
  }

  .rep-photo {
    aspect-ratio: 4 / 5;
    background: #6b4f2a;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    box-sizing: border-box;
    height: 120px;
    object-fit: cover;
    object-position: center top;
  }

  .fallback-photo {
    background: transparent;
    object-fit: cover;
    padding: 0;
  }

  .rep-main h3 {
    font-size: 1.3rem;
    margin: 0;
  }

  .rep-heading {
    align-items: start;
    display: flex;
    gap: 12px;
    justify-content: space-between;
  }

  .rep-grade,
  .rep-card a.rep-grade {
    border: 1px solid rgba(31, 41, 51, 0.32);
    border-radius: 10px;
    box-shadow: none;
    color: #fefce8;
    display: grid;
    flex: 0 0 auto;
    min-width: 58px;
    padding: 6px 8px;
    text-align: center;
    text-decoration: none;
  }

  .rep-grade span {
    color: #fefce8;
    font-size: 1.85rem;
    font-weight: 950;
    line-height: 1;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .rep-grade small {
    color: #fefce8;
    font-size: 0.62rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    margin-top: 3px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
    text-transform: uppercase;
  }

  .grade-a {
    background: #166534;
  }

  .grade-b {
    background: #65a30d;
  }

  .grade-c {
    background: #ca8a04;
  }

  .grade-d {
    background: #ea580c;
  }

  .grade-f {
    background: #b42318;
  }

  .grade-unknown {
    background: #5b616e;
  }

  .rep-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }

  .rep-meta span,
  .rep-meta a {
    background: #f8fafc;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.8rem;
    font-weight: 800;
    padding: 5px 10px;
    text-decoration: none;
  }

  .rep-meta .free-stater-pill {
    background: #7f1d1d;
    border-color: #111827;
    box-shadow: none;
    color: white;
  }

  .rep-meta .free-stater-pill:hover {
    background: #450a0a;
  }

  .district-line,
  .location-line {
    margin-top: 10px;
  }

  .location-line {
    color: #4b5563;
  }

  .rep-contact,
  .vote-summary {
    border-top: 1px solid #d1d5db;
    margin-top: 16px;
    padding-top: 16px;
  }

  .rep-contact {
    display: grid;
    gap: 12px;
  }

  .rep-contact div {
    color: #1f2933;
    font-weight: 800;
    overflow-wrap: anywhere;
  }

  .rep-contact span,
  .vote-summary > span {
    color: #6b7280;
    display: block;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    margin-bottom: 6px;
    text-transform: uppercase;
  }

  .rep-contact p {
    margin: 0;
  }

  .vote-summary > span {
    margin-bottom: 10px;
  }

  .vote-list {
    display: grid;
    gap: 8px;
  }

  .vote-item {
    align-items: start;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    display: grid;
    gap: 10px;
    grid-template-columns: minmax(0, 1fr) minmax(190px, 220px);
    padding: 10px 12px;
  }

  .vote-heading {
    display: grid;
    gap: 6px;
    grid-column: 1 / -1;
    min-width: 0;
  }

  .vote-copy {
    display: grid;
    gap: 6px;
    min-width: 0;
  }

  .bill-summary {
    color: #4b5563;
    font-size: 0.86rem;
    font-weight: 500;
    line-height: 1.45;
    margin: 0;
  }

  .vote-pill-stack {
    align-items: stretch;
    display: grid;
    gap: 6px;
    justify-items: stretch;
    width: 100%;
  }

  .vote-interpretation {
    background: white;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    display: grid;
    gap: 6px;
    padding: 7px;
  }

  .vote-interpretation.legislator-support {
    background: #dff0d8;
    border-color: #2f7d4f;
  }

  .vote-interpretation.legislator-oppose {
    background: #fde2de;
    border-color: #b42318;
  }

  .vote-interpretation.legislator-neutral {
    background: #dbeafe;
    border-color: #2563eb;
  }

  .vote-impact {
    color: #4b5563;
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.35;
    margin: 0;
    text-align: left;
  }

  .vote-summary p {
    color: #4b5563;
    font-weight: 800;
    margin: 0;
  }

  .legislator-vote-pill {
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.74rem;
    font-weight: 900;
    line-height: 1.2;
    padding: 6px 8px;
    box-sizing: border-box;
    display: block;
    text-align: center;
    text-decoration: none;
    width: 100%;
  }

  .vote-pill-stack :global(.position-summary) {
    width: 100%;
  }

  .vote-pill-stack :global(.position-summary span) {
    box-sizing: border-box;
    text-align: center;
  }

  .legislator-support {
    border-color: #2f7d4f;
  }

  .legislator-oppose {
    border-color: #b42318;
  }

  .legislator-neutral {
    border-color: #2563eb;
  }

  .vote-item span {
    color: #4b5563;
    display: block;
    font-size: 0.85rem;
    font-weight: 800;
    margin-top: 2px;
  }

  @media (max-width: 520px) {
    .rep-card-top {
      grid-template-columns: 1fr;
    }

    .vote-item {
      grid-template-columns: 1fr;
    }

    .vote-pill-stack {
      justify-items: start;
    }
  }
</style>
