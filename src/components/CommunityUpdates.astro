---
import {
  communityUpdateDate,
  getApprovedCommunityUpdates,
} from "../lib/communityUpdates";
import { cleanText } from "../lib/text";

const {
  entityType,
  entityKey,
  entityName,
  pageUrl = Astro.url.pathname,
} = Astro.props;

const updates = await getApprovedCommunityUpdates(entityType, entityKey, { limit: 12 });
const hasInstagramEmbeds = updates.some((update) => instagramPreview(update.linkUrl));

function linkHost(value = "") {
  try {
    const url = new URL(value);
    return url.hostname.replace(/^www\./, "");
  } catch {
    return "";
  }
}

function instagramPreview(value = "") {
  try {
    const url = new URL(value);
    const host = url.hostname.replace(/^www\./, "").toLowerCase();
    if (!["instagram.com", "instagr.am"].includes(host)) return null;

    const parts = url.pathname.split("/").filter(Boolean);
    const first = parts[0]?.toLowerCase() || "";
    const labels = {
      p: "Instagram post",
      reel: "Instagram reel",
      reels: "Instagram reel",
      tv: "Instagram video",
      stories: "Instagram story",
    };
    const label = labels[first] || "Instagram profile";
    const handle =
      first === "stories"
        ? parts[1]
        : labels[first]
          ? ""
          : parts[0] || "";

    return {
      label,
      handle,
      host,
      permalink: instagramPermalink(url),
    };
  } catch {
    return null;
  }
}

function instagramPermalink(url) {
  const cleanUrl = new URL(url.toString());
  cleanUrl.search = "";
  cleanUrl.hash = "";
  return cleanUrl.toString();
}

function mentionParts(comment = "", mentions = []) {
  const text = cleanText(comment);
  const activeMentions = mentions.filter((mention) => mention.name && mention.path);
  if (!text || !activeMentions.length) return [{ text }];

  const pattern = new RegExp(
    `@(${activeMentions.map((mention) => escapeRegExp(mention.name)).join("|")})`,
    "gi",
  );
  const parts = [];
  let lastIndex = 0;

  for (const match of text.matchAll(pattern)) {
    if (match.index > lastIndex) {
      parts.push({ text: text.slice(lastIndex, match.index) });
    }
    const name = cleanText(match[1]);
    const mention = activeMentions.find((item) => item.name.toLowerCase() === name.toLowerCase());
    parts.push({
      text: `@${name}`,
      href: mention?.path,
    });
    lastIndex = match.index + match[0].length;
  }

  if (lastIndex < text.length) parts.push({ text: text.slice(lastIndex) });
  return parts;
}

function escapeRegExp(value = "") {
  return String(value).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}
---

<section class="panel community-updates-panel">
  <div class="section-heading">
    <p class="eyebrow">Community Updates</p>
    <h2>Community context</h2>
    <p>
      Share a local note, article, social post, image, or correction connected
      to this profile. These updates help neighbors understand how public
      decisions affect people and communities. Submissions are reviewed before
      they appear publicly.
    </p>
  </div>

  <details class="community-update-disclosure">
    <summary>
      <span>Suggest a community update or add a photo</span>
      <strong>+</strong>
    </summary>

    <form class="community-update-form" action="/api/community-updates" method="post" enctype="multipart/form-data">
      <input type="hidden" name="entityType" value={entityType} />
      <input type="hidden" name="entityKey" value={entityKey} />
      <input type="hidden" name="entityName" value={entityName} />
      <input type="hidden" name="pageUrl" value={pageUrl} />
      <input type="hidden" name="redirectTo" value={Astro.url.pathname} />

      <label>
        Comment
        <textarea name="comment" rows="4" placeholder="Share a local observation, correction, article context, social post summary, or update."></textarea>
      </label>

      <div class="form-grid">
        <label>
          Name
          <input name="displayName" autocomplete="name" placeholder="Community member" />
        </label>
        <label>
          Email
          <input name="email" type="email" autocomplete="email" placeholder="Used for moderation only" />
        </label>
      </div>

      <label>
        Photo
        <input name="photo" type="file" accept="image/*" />
      </label>

      <label>
        Link
        <input name="linkUrl" type="url" placeholder="https://example.com/context" />
      </label>

      <button type="submit">Submit for Review</button>
    </form>
  </details>

  {updates.length ? (
    <div class="community-update-list">
      {updates.map((update) => (
        <article class:list={["community-update-card", update.photoUrl && "has-photo"]}>
          {update.photoUrl && (
            <div class="community-update-media">
              <button
                class="community-photo-button"
                type="button"
                data-community-photo={update.photoUrl}
                aria-label="Open community update photo"
              >
                <img src={update.photoUrl} alt="" loading="lazy" />
              </button>
              <span>Photo update</span>
            </div>
          )}
          <div class="community-update-copy">
            <div class="community-update-meta">
              <strong>{cleanText(update.displayName || "Community member")}</strong>
              {communityUpdateDate(update.createdAt) && (
                <span>{communityUpdateDate(update.createdAt)}</span>
              )}
            </div>
            {update.comment && (
              <p>
                {mentionParts(update.comment, update.mentions).map((part) =>
                  part.href ? (
                    <a class="comment-mention-link" href={part.href}>{part.text}</a>
                  ) : (
                    part.text
                  ),
                )}
              </p>
            )}
            {update.mentions?.length > 0 && (
              <div class="mention-list" aria-label="Tagged legislators">
                <span>Tagged legislators</span>
                {update.mentions.map((mention) => (
                  <a href={mention.path}>
                    {mention.name}
                    {mention.chamber && <small>{mention.chamber}</small>}
                  </a>
                ))}
              </div>
            )}
            {update.linkUrl && (
              instagramPreview(update.linkUrl) ? (
                <div class="instagram-embed-wrap">
                  <div class="instagram-preview-card">
                    <span class="instagram-icon" aria-hidden="true">IG</span>
                    <span>
                      <strong>{instagramPreview(update.linkUrl)?.label}</strong>
                      <small>
                        {instagramPreview(update.linkUrl)?.handle
                          ? `@${instagramPreview(update.linkUrl)?.handle}`
                          : instagramPreview(update.linkUrl)?.host}
                      </small>
                    </span>
                    <a href={instagramPreview(update.linkUrl)?.permalink || update.linkUrl}>Open</a>
                  </div>
                  <blockquote
                    class="instagram-media"
                    data-instgrm-captioned
                    data-instgrm-permalink={instagramPreview(update.linkUrl)?.permalink}
                    data-instgrm-version="14"
                  >
                    <a href={instagramPreview(update.linkUrl)?.permalink || update.linkUrl}>
                      View this post on Instagram
                    </a>
                  </blockquote>
                </div>
              ) : (
                <a class="community-update-link" href={update.linkUrl}>
                  <span>Open linked context</span>
                  {linkHost(update.linkUrl) && <small>{linkHost(update.linkUrl)}</small>}
                </a>
              )
            )}
          </div>
        </article>
      ))}
    </div>
  ) : (
    <p class="empty">No approved community updates yet.</p>
  )}

  <dialog class="community-photo-dialog" aria-label="Community update photo">
    <form method="dialog">
      <button type="submit" aria-label="Close photo preview">Close</button>
    </form>
    <img src="" alt="" />
  </dialog>
</section>

{hasInstagramEmbeds && <script async src="https://www.instagram.com/embed.js"></script>}

<script>
  document.querySelectorAll(".community-updates-panel").forEach((panel) => {
    const dialog = panel.querySelector(".community-photo-dialog");
    const preview = dialog?.querySelector("img");

    if (!(dialog instanceof HTMLDialogElement) || !(preview instanceof HTMLImageElement)) {
      return;
    }

    panel.querySelectorAll("[data-community-photo]").forEach((button) => {
      button.addEventListener("click", () => {
        const photoUrl = button.getAttribute("data-community-photo");
        if (!photoUrl) return;

        preview.src = photoUrl;
        dialog.showModal();
      });
    });

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });

    dialog.addEventListener("close", () => {
      preview.removeAttribute("src");
    });
  });
</script>

<style>
  .community-updates-panel {
    margin-top: 0;
  }

  .section-heading p:not(.eyebrow) {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  .community-update-disclosure {
    margin-top: 16px;
  }

  .community-update-disclosure summary {
    align-items: center;
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    box-sizing: border-box;
    color: #4b5563;
    cursor: pointer;
    display: flex;
    gap: 12px;
    justify-content: space-between;
    list-style: none;
    padding: 12px 14px;
  }

  .community-update-disclosure summary::-webkit-details-marker {
    display: none;
  }

  .community-update-disclosure summary span {
    font-weight: 800;
  }

  .community-update-disclosure summary strong {
    align-items: center;
    background: #1f2933;
    border-radius: 999px;
    color: #ffffff;
    display: inline-flex;
    flex: 0 0 auto;
    font-size: 1rem;
    height: 24px;
    justify-content: center;
    line-height: 1;
    width: 24px;
  }

  .community-update-disclosure[open] summary strong {
    transform: rotate(45deg);
  }

  .community-update-list {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .community-update-card {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    display: grid;
    gap: 14px;
    padding: 14px;
  }

  .community-update-card.has-photo {
    align-items: stretch;
    grid-template-columns: minmax(160px, 34%) minmax(0, 1fr);
  }

  .community-update-media {
    display: grid;
    gap: 8px;
  }

  .community-update-media span {
    background: #e0f2fe;
    border: 1px solid #7dd3fc;
    border-radius: 999px;
    color: #075985;
    display: inline-flex;
    font-size: 0.72rem;
    font-weight: 950;
    justify-self: start;
    letter-spacing: 0.04em;
    padding: 5px 8px;
    text-transform: uppercase;
  }

  .community-photo-button {
    background: transparent;
    border: 0;
    border-radius: 8px;
    cursor: zoom-in;
    display: block;
    margin: 0 0 12px;
    padding: 0;
    width: 100%;
  }

  .community-photo-button:focus-visible {
    outline: 3px solid #2563eb;
    outline-offset: 3px;
  }

  .community-photo-button img {
    aspect-ratio: 16 / 9;
    background: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    display: block;
    height: 100%;
    min-height: 130px;
    object-fit: cover;
    width: 100%;
  }

  .community-update-copy {
    align-content: start;
    display: grid;
    min-width: 0;
  }

  .community-photo-dialog {
    background: #111827;
    border: 0;
    border-radius: 12px;
    box-shadow: 0 24px 80px rgba(17, 24, 39, 0.35);
    max-height: min(86vh, 820px);
    max-width: min(92vw, 980px);
    padding: 12px;
  }

  .community-photo-dialog::backdrop {
    background: rgba(17, 24, 39, 0.72);
  }

  .community-photo-dialog form {
    display: flex;
    justify-content: end;
    margin: 0 0 10px;
  }

  .community-photo-dialog button {
    background: #ffffff;
    border-color: #ffffff;
    color: #1f2933;
    padding: 8px 12px;
  }

  .community-photo-dialog img {
    background: #ffffff;
    border-radius: 8px;
    display: block;
    max-height: calc(86vh - 68px);
    max-width: calc(92vw - 24px);
    object-fit: contain;
  }

  .community-update-meta {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: space-between;
  }

  .community-update-meta span {
    color: #6b7280;
    font-size: 0.8rem;
    font-weight: 900;
  }

  .community-update-list p,
  .empty {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  .comment-mention-link {
    color: #1d4ed8;
    font-weight: 950;
  }

  .mention-list {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 12px;
  }

  .mention-list > span {
    color: #6b4f2a;
    flex-basis: 100%;
    font-size: 0.68rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mention-list a {
    align-items: center;
    background: #ffffff;
    border: 1px solid #93c5fd;
    border-radius: 999px;
    color: #1e3a8a;
    display: inline-flex;
    gap: 6px;
    font-size: 0.8rem;
    font-weight: 900;
    padding: 6px 9px;
    text-decoration: none;
  }

  .mention-list small {
    color: #64748b;
    font-size: 0.72rem;
    font-weight: 900;
  }

  .community-update-link {
    background: #ffffff;
    border: 1px solid #9ca3af;
    border-radius: 999px;
    color: #1f2933;
    display: inline-flex;
    gap: 8px;
    align-items: center;
    font-weight: 900;
    justify-self: start;
    margin-top: 12px;
    padding: 8px 11px;
    text-decoration: none;
  }

  .community-update-link small {
    color: #6b7280;
    font-size: 0.74rem;
    font-weight: 900;
  }

  .instagram-embed-wrap {
    display: grid;
    gap: 10px;
    margin-top: 12px;
  }

  .instagram-preview-card {
    align-items: center;
    background:
      linear-gradient(#ffffff, #ffffff) padding-box,
      linear-gradient(135deg, #f97316, #db2777, #7c3aed) border-box;
    border: 2px solid transparent;
    border-radius: 14px;
    color: #1f2933;
    display: grid;
    gap: 10px;
    grid-template-columns: auto minmax(0, 1fr) auto;
    padding: 10px 12px;
    text-decoration: none;
  }

  .instagram-icon {
    align-items: center;
    background: linear-gradient(135deg, #f97316, #db2777, #7c3aed);
    border-radius: 10px;
    color: #ffffff;
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 950;
    height: 38px;
    justify-content: center;
    width: 38px;
  }

  .instagram-preview-card strong,
  .instagram-preview-card small {
    display: block;
  }

  .instagram-preview-card strong {
    font-size: 0.96rem;
    line-height: 1.2;
  }

  .instagram-preview-card small {
    color: #6b7280;
    font-size: 0.78rem;
    font-weight: 900;
    margin-top: 2px;
  }

  .instagram-preview-card a {
    color: #db2777;
    font-size: 0.78rem;
    font-weight: 950;
    text-decoration: none;
  }

  .instagram-media {
    background: #ffffff;
    border: 0;
    border-radius: 12px;
    box-shadow: 0 0 1px rgba(0, 0, 0, 0.35), 0 4px 18px rgba(17, 24, 39, 0.12);
    box-sizing: border-box;
    margin: 0;
    max-width: 540px;
    min-width: 0;
    overflow: hidden;
    padding: 14px;
    width: 100%;
  }

  .instagram-media a {
    color: #3897f0;
    font-weight: 900;
    text-decoration: none;
  }

  .community-update-form {
    display: grid;
    gap: 14px;
    padding-top: 14px;
  }

  .form-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, 1fr);
  }

  label {
    color: #374151;
    display: grid;
    font-size: 0.78rem;
    font-weight: 900;
    gap: 7px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  input,
  textarea {
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    box-sizing: border-box;
    color: #1f2933;
    font: inherit;
    font-weight: 750;
    letter-spacing: 0;
    padding: 12px 13px;
    text-transform: none;
    width: 100%;
  }

  textarea {
    resize: vertical;
  }

  button {
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    cursor: pointer;
    font: inherit;
    font-weight: 900;
    justify-self: start;
    padding: 12px 16px;
  }

  @media (max-width: 720px) {
    .community-update-card.has-photo {
      grid-template-columns: 1fr;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
