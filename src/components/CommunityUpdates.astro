---
import {
  communityUpdateDate,
  getApprovedCommunityUpdates,
} from "../lib/communityUpdates";
import { cleanText } from "../lib/text";

const {
  entityType,
  entityKey,
  entityName,
  pageUrl = Astro.url.pathname,
} = Astro.props;

const updates = await getApprovedCommunityUpdates(entityType, entityKey, { limit: 12 });
---

<section class="panel community-updates-panel">
  <div class="section-heading">
    <p class="eyebrow">Community Updates</p>
    <h2>Community context</h2>
    <p>
      Share a local note or photo connected to this profile. Submissions are
      reviewed before they appear publicly.
    </p>
  </div>

  <details class="community-update-disclosure">
    <summary>
      <span>Suggest a community update or add a photo</span>
      <strong>+</strong>
    </summary>

    <form class="community-update-form" action="/api/community-updates" method="post" enctype="multipart/form-data">
      <input type="hidden" name="entityType" value={entityType} />
      <input type="hidden" name="entityKey" value={entityKey} />
      <input type="hidden" name="entityName" value={entityName} />
      <input type="hidden" name="pageUrl" value={pageUrl} />
      <input type="hidden" name="redirectTo" value={Astro.url.pathname} />

      <label>
        Comment
        <textarea name="comment" rows="4" placeholder="Share a local observation, correction, or context."></textarea>
      </label>

      <div class="form-grid">
        <label>
          Name
          <input name="displayName" autocomplete="name" placeholder="Community member" />
        </label>
        <label>
          Email
          <input name="email" type="email" autocomplete="email" placeholder="Used for moderation only" />
        </label>
      </div>

      <label>
        Photo
        <input name="photo" type="file" accept="image/*" />
      </label>

      <label>
        Link
        <input name="linkUrl" type="url" placeholder="https://example.com/context" />
      </label>

      <button type="submit">Submit for Review</button>
    </form>
  </details>

  {updates.length ? (
    <div class="community-update-list">
      {updates.map((update) => (
        <article>
          {update.photoUrl && (
            <button
              class="community-photo-button"
              type="button"
              data-community-photo={update.photoUrl}
              aria-label="Open community update photo"
            >
              <img src={update.photoUrl} alt="" loading="lazy" />
            </button>
          )}
          <div>
            <strong>{cleanText(update.displayName || "Community member")}</strong>
            {communityUpdateDate(update.createdAt) && (
              <span>{communityUpdateDate(update.createdAt)}</span>
            )}
          </div>
          {update.comment && <p>{cleanText(update.comment)}</p>}
          {update.linkUrl && (
            <a class="community-update-link" href={update.linkUrl}>
              Open linked context
            </a>
          )}
        </article>
      ))}
    </div>
  ) : (
    <p class="empty">No approved community updates yet.</p>
  )}

  <dialog class="community-photo-dialog" aria-label="Community update photo">
    <form method="dialog">
      <button type="submit" aria-label="Close photo preview">Close</button>
    </form>
    <img src="" alt="" />
  </dialog>
</section>

<script>
  document.querySelectorAll(".community-updates-panel").forEach((panel) => {
    const dialog = panel.querySelector(".community-photo-dialog");
    const preview = dialog?.querySelector("img");

    if (!(dialog instanceof HTMLDialogElement) || !(preview instanceof HTMLImageElement)) {
      return;
    }

    panel.querySelectorAll("[data-community-photo]").forEach((button) => {
      button.addEventListener("click", () => {
        const photoUrl = button.getAttribute("data-community-photo");
        if (!photoUrl) return;

        preview.src = photoUrl;
        dialog.showModal();
      });
    });

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });

    dialog.addEventListener("close", () => {
      preview.removeAttribute("src");
    });
  });
</script>

<style>
  .community-updates-panel {
    margin-top: 0;
  }

  .section-heading p:not(.eyebrow) {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  .community-update-disclosure {
    margin-top: 16px;
  }

  .community-update-disclosure summary {
    align-items: center;
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    box-sizing: border-box;
    color: #4b5563;
    cursor: pointer;
    display: flex;
    gap: 12px;
    justify-content: space-between;
    list-style: none;
    padding: 12px 14px;
  }

  .community-update-disclosure summary::-webkit-details-marker {
    display: none;
  }

  .community-update-disclosure summary span {
    font-weight: 800;
  }

  .community-update-disclosure summary strong {
    align-items: center;
    background: #1f2933;
    border-radius: 999px;
    color: #ffffff;
    display: inline-flex;
    flex: 0 0 auto;
    font-size: 1rem;
    height: 24px;
    justify-content: center;
    line-height: 1;
    width: 24px;
  }

  .community-update-disclosure[open] summary strong {
    transform: rotate(45deg);
  }

  .community-update-list {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .community-update-list article {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    padding: 14px;
  }

  .community-photo-button {
    background: transparent;
    border: 0;
    border-radius: 8px;
    cursor: zoom-in;
    display: block;
    margin: 0 0 12px;
    padding: 0;
    width: 100%;
  }

  .community-photo-button:focus-visible {
    outline: 3px solid #2563eb;
    outline-offset: 3px;
  }

  .community-photo-button img {
    aspect-ratio: 16 / 9;
    background: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    display: block;
    object-fit: contain;
    width: 100%;
  }

  .community-photo-dialog {
    background: #111827;
    border: 0;
    border-radius: 12px;
    box-shadow: 0 24px 80px rgba(17, 24, 39, 0.35);
    max-height: min(86vh, 820px);
    max-width: min(92vw, 980px);
    padding: 12px;
  }

  .community-photo-dialog::backdrop {
    background: rgba(17, 24, 39, 0.72);
  }

  .community-photo-dialog form {
    display: flex;
    justify-content: end;
    margin: 0 0 10px;
  }

  .community-photo-dialog button {
    background: #ffffff;
    border-color: #ffffff;
    color: #1f2933;
    padding: 8px 12px;
  }

  .community-photo-dialog img {
    background: #ffffff;
    border-radius: 8px;
    display: block;
    max-height: calc(86vh - 68px);
    max-width: calc(92vw - 24px);
    object-fit: contain;
  }

  .community-update-list div {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: space-between;
  }

  .community-update-list span {
    color: #6b7280;
    font-size: 0.8rem;
    font-weight: 900;
  }

  .community-update-list p,
  .empty {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  .community-update-link {
    background: #ffffff;
    border: 1px solid #9ca3af;
    border-radius: 999px;
    color: #1f2933;
    display: inline-flex;
    font-weight: 900;
    margin-top: 12px;
    padding: 8px 11px;
    text-decoration: none;
  }

  .community-update-form {
    display: grid;
    gap: 14px;
    padding-top: 14px;
  }

  .form-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, 1fr);
  }

  label {
    color: #374151;
    display: grid;
    font-size: 0.78rem;
    font-weight: 900;
    gap: 7px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  input,
  textarea {
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    box-sizing: border-box;
    color: #1f2933;
    font: inherit;
    font-weight: 750;
    letter-spacing: 0;
    padding: 12px 13px;
    text-transform: none;
    width: 100%;
  }

  textarea {
    resize: vertical;
  }

  button {
    background: #1f2933;
    border: 2px solid #1f2933;
    border-radius: 999px;
    color: white;
    cursor: pointer;
    font: inherit;
    font-weight: 900;
    justify-self: start;
    padding: 12px 16px;
  }

  @media (max-width: 720px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
