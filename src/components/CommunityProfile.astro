---
import TopNav from "./TopNav.astro";
import communityPlaceholder from "../assets/community_profile_placeholder.png";
import profileIcon from "../assets/profile icon.png";
import { articlePublishDate, articleSourceName } from "../lib/articlesApi";
import { getBillSummaries } from "../lib/billsApi";
import { enrichCandidatesWithLegislators } from "../lib/candidateLegislators";
import { candidateName, candidatePath, isLegislativeCandidate } from "../lib/candidatesApi";
import { isFreeStater } from "../lib/civicTags";
import { countyForCommunity, countyImageUrl } from "../lib/communityImages";
import { communityPath } from "../lib/communitiesApi";
import { profilePhotoUrl } from "../lib/photos";
import { getRepresentative, repName, repSlug } from "../lib/repsApi";
import { cleanText, joinClean } from "../lib/text";
import { enrichArticlesWithPreviews } from "../lib/articlePreviews";
import { getTrackedBills, representativeGradeFor } from "../lib/trackedBills";

const { community, meta = {}, error = "" } = Astro.props;
const PROFILE_PREVIEW_LIMIT = 6;

function townsFor(value = []) {
  const towns =
    community?.townsRepresented ||
    community?.towns ||
    community?.towns_represented ||
    value;

  if (Array.isArray(towns)) return towns.map(cleanTown).filter(Boolean);

  return String(towns)
    .split(/;|,/)
    .map(cleanTown)
    .filter(Boolean);
}

function cleanTown(value = "") {
  if (typeof value === "object" && value !== null) {
    return cleanText(value.town || value.name || value.label || "").trim();
  }

  return cleanText(value).trim();
}

function representativesFor() {
  return uniqueRepresentatives([
    ...(community?.representatives || []),
    ...(community?.reps || []),
    ...(community?.legislators || []),
  ]);
}

function articlesFor() {
  return community?.relatedArticles || community?.articles || [];
}

function districtsFor() {
  return community?.districts || community?.communities || community?.relatedDistricts || [];
}

function candidatesFor() {
  return uniqueCandidates([
    ...(community?.candidates || []),
    ...(community?.candidateSummary?.candidates || []),
    ...(community?.groups?.candidates?.senate || []),
    ...(community?.groups?.candidates?.house || []),
  ]).filter(isLegislativeCandidate);
}

function bodyLabel() {
  const body = String(community?.chamber || community?.body || "").toLowerCase();
  if (body === "senate" || body === "s") return "Senate";
  return "House";
}

function profileLabel() {
  return community?.profileLabel || `${bodyLabel()} District`;
}

function townProfilePath(town = "") {
  return `/communities/towns/${encodeURIComponent(town)}`;
}

function repLocation(rep = {}) {
  return (
    rep.location_text ||
    rep.townsRepresented ||
    rep.towns_represented ||
    rep.towns ||
    community?.townsRepresented ||
    community?.towns ||
    community?.towns_represented ||
    ""
  );
}

function repMeta(rep = {}) {
  return joinClean([
    rep.party,
    rep.chamber,
    rep.district,
    repLocation(rep),
  ]);
}

function articleTitle(article = {}) {
  return cleanText(article.preview?.title || article.title);
}

function articlePublisher(article = {}) {
  return articleSourceName(article);
}

async function hydrateRepresentativePreview(reps = []) {
  return Promise.all(
    reps.map(async (rep) => {
      const slugOrId = rep.personid || rep.id || rep.slug || repName(rep);
      if (!slugOrId) return rep;

      try {
        const data = await getRepresentative(slugOrId);
        return {
          ...rep,
          ...(data.representative || data.rep || data.person || data),
          voteHistory: data.voteHistory || data.votes || data.representative?.voteHistory || rep.voteHistory || [],
        };
      } catch (error) {
        console.error(error?.message || "Unable to hydrate community representative preview.");
        return rep;
      }
    }),
  );
}

function uniqueRepresentatives(items = []) {
  const seen = new Set();

  return items.filter((rep) => {
    if (!rep || typeof rep !== "object") return false;
    const key = rep.personid || rep.id || rep.employeeno || repName(rep);
    if (!key || seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

function uniqueCandidates(items = []) {
  const seen = new Set();

  return items.filter((candidate) => {
    if (!candidate || typeof candidate !== "object") return false;
    const key = [
      candidate.slug,
      candidate.filerEntityNumber,
      candidate.name,
      candidate.candidateFirstName,
      candidate.candidateLastName,
      candidate.office,
      candidate.county,
      candidate.district,
    ]
      .filter(Boolean)
      .join("|");

    if (!key || seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

function communityKind() {
  const label = String(community?.profileLabel || "").toLowerCase();
  const body = String(community?.body || community?.chamber || "").toLowerCase();
  if (label.includes("county")) return "county";
  if (label.includes("town")) return "town";
  if (body === "s" || body === "senate") return "senate";
  return "house";
}

function primaryTown() {
  return towns[0] || "";
}

function communityDistrict() {
  return community?.raw_district || community?.district || "";
}

function peopleDirectoryHref() {
  const params = new URLSearchParams();
  const kind = communityKind();

  if (kind === "town") {
    if (primaryTown()) params.set("town", primaryTown());
  } else if (kind === "county") {
    if (community?.county || community?.name) params.set("county", community.county || community.name);
  } else if (kind === "senate") {
    params.set("body", "senate");
    if (communityDistrict()) params.set("district", communityDistrict());
  } else {
    params.set("body", "house");
    if (community?.county) params.set("county", community.county);
    if (communityDistrict()) params.set("district", communityDistrict());
  }

  const query = params.toString();
  return `/people${query ? `?${query}` : ""}`;
}

function candidateDirectoryHref() {
  const params = new URLSearchParams();
  const kind = communityKind();

  if (kind === "town") {
    if (primaryTown()) params.set("town", primaryTown());
  } else if (kind === "county") {
    if (community?.county || community?.name) params.set("county", community.county || community.name);
  } else if (kind === "senate") {
    params.set("office", "State Senate");
    if (communityDistrict()) params.set("district", communityDistrict());
  } else {
    params.set("office", "State Representative");
    if (community?.county) params.set("county", community.county);
    if (communityDistrict()) params.set("district", communityDistrict());
  }

  const query = params.toString();
  return `/candidates${query ? `?${query}` : ""}`;
}

const towns = townsFor();
const representatives = representativesFor();
const articles = await enrichArticlesWithPreviews(articlesFor(), { limit: 10 });
const districts = districtsFor();
const candidates = candidatesFor();
const representativePreview = await hydrateRepresentativePreview(
  representatives.slice(0, PROFILE_PREVIEW_LIMIT),
);
const candidatePreview = await enrichCandidatesWithLegislators(
  candidates.slice(0, PROFILE_PREVIEW_LIMIT),
);
const allRepresentativesHref = peopleDirectoryHref();
const allCandidatesHref = candidateDirectoryHref();
const heroCounty = countyForCommunity(community || {});
const heroImage = countyImageUrl(heroCounty) || communityPlaceholder.src;
let trackedBills = new Map();
let billSummaries = new Map();

try {
  [trackedBills, billSummaries] = await Promise.all([
    getTrackedBills(),
    getBillSummaries(),
  ]);
} catch (error) {
  console.error(error?.message || "Unable to load tracked bills.");
}
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/NH%20DB%20Logo.png" />
    <link rel="apple-touch-icon" href="/NH%20DB%20Logo.png" />
    <title>{cleanText(community?.name || "Community")} | NH Deserves Better</title>
    <meta
      name="description"
      content={`Community profile for ${community?.name || "a New Hampshire district"}.`}
    />
  </head>

  <body>
    <TopNav />
    <main class="page">
      <a class="back" href="/communities">Back to communities</a>

      {error ? (
        <p class="status-message">{error}</p>
      ) : community ? (
        <>
          <section class="hero">
            <img
              class="hero-image"
              src={heroImage}
              alt=""
              width="2000"
              height="500"
            />

            <div class="hero-copy">
              <p class="eyebrow">{profileLabel()}</p>
              <h1>{cleanText(community.name)}</h1>

              <div class="hero-meta">
                {community.label && <span>{cleanText(community.label)}</span>}
                {community.county && <span>{cleanText(community.county)}</span>}
                {community.seats && <span>{community.seats} seats</span>}
                {community.floterial && <span>Floterial</span>}
                {community.districtCount && <span>{community.districtCount} districts</span>}
                {community.representativeCount && <span>{community.representativeCount} reps</span>}
              </div>
            </div>
          </section>

          <section class="content-grid">
            <div class="stack">
              {districts.length > 0 && (
                <section class="panel">
                  <div class="section-heading">
                    <p class="eyebrow">Districts</p>
                    <h2>District Profiles</h2>
                  </div>

                  <div class="chips">
                    {districts.map((district) => (
                      <a href={communityPath(district)}>{cleanText(district.name || district.label)}</a>
                    ))}
                  </div>
                </section>
              )}

              <section class="panel">
                <div class="section-heading">
                  <p class="eyebrow">Towns</p>
                  <h2>Towns Represented</h2>
                </div>

                {towns.length ? (
                  <div class="chips">
                    {towns.map((town) => (
                      <a href={townProfilePath(town)}>{cleanText(town)}</a>
                    ))}
                  </div>
                ) : (
                  <p class="empty">No towns returned.</p>
                )}
              </section>

              <section class="panel">
                <div class="section-heading split-heading">
                  <div>
                    <p class="eyebrow">Representation</p>
                    <h2>Legislators</h2>
                  </div>
                  <a class="section-action" href={allRepresentativesHref}>
                    See all legislators
                  </a>
                </div>

                {representatives.length ? (
                  <div class="rep-list profile-preview-list">
                    {representativePreview.map((rep) => {
                      const photoUrl = profilePhotoUrl(rep.photo || rep.photo_url);
                      const grade = representativeGradeFor(rep, trackedBills, billSummaries);

                      return (
                      <article>
                        <a class="profile-photo-link" href={`/people/${repSlug(rep)}`}>
                          <img
                            class:list={[!photoUrl && "profile-icon"]}
                            src={photoUrl || profileIcon.src}
                            alt={photoUrl ? `Photo of ${repName(rep)}` : ""}
                            loading="lazy"
                          />
                        </a>
                        <div>
                          <div class="profile-preview-heading">
                            <h3>
                              <a href={`/people/${repSlug(rep)}`}>{cleanText(repName(rep))}</a>
                            </h3>
                            <span class:list={["mini-grade", grade.className]} title={grade.label}>
                              <strong>{grade.letter}</strong>
                              <small>Grade</small>
                            </span>
                          </div>
                          <p>{repMeta(rep)}</p>
                          {isFreeStater(rep) && (
                            <div class="mini-tags">
                              <a
                                href="/free-staters"
                                title="What is a Free Stater?"
                                aria-label="What is a Free Stater?"
                              >
                                Free Stater
                              </a>
                            </div>
                          )}
                        </div>
                      </article>
                      );
                    })}
                  </div>
                ) : (
                  <p class="empty">No representatives returned.</p>
                )}

                <a class="section-footer-action" href={allRepresentativesHref}>
                  See all legislators
                </a>
              </section>

              <section class="panel">
                <div class="section-heading split-heading">
                  <div>
                    <p class="eyebrow">House and Senate Candidates</p>
                    <h2>Current Legislative Candidates</h2>
                  </div>
                  <a class="section-action" href={allCandidatesHref}>
                    See all legislative candidates
                  </a>
                </div>

                {candidates.length ? (
                  <div class="rep-list profile-preview-list">
                    {candidatePreview.map((candidate) => {
                      const photoUrl =
                        profilePhotoUrl(candidate.photoUrl || candidate.photo || candidate.photo_url) ||
                        profilePhotoUrl(candidate.legislatorPhotoUrl);

                      return (
                      <article>
                        <a class="profile-photo-link" href={candidatePath(candidate)}>
                          <img
                            class:list={[!photoUrl && "profile-icon"]}
                            src={photoUrl || profileIcon.src}
                            alt={photoUrl ? `Photo of ${candidateName(candidate)}` : ""}
                            loading="lazy"
                          />
                        </a>
                        <div>
                          <h3>
                            <a href={candidatePath(candidate)}>{cleanText(candidateName(candidate))}</a>
                          </h3>
                          <p>
                            {joinClean([
                              candidate.politicalParty,
                              candidate.office,
                              candidate.district && `District ${candidate.district}`,
                            ])}
                          </p>
                          {candidate.legislatorProfileUrl && (
                            <div class="profile-preview-actions">
                              <a href={candidate.legislatorProfileUrl}>Legislator Profile</a>
                            </div>
                          )}
                          {isFreeStater(candidate) && (
                            <div class="mini-tags">
                              <a
                                href="/free-staters"
                                title="What is a Free Stater?"
                                aria-label="What is a Free Stater?"
                              >
                                Free Stater
                              </a>
                            </div>
                          )}
                        </div>
                      </article>
                      );
                    })}
                  </div>
                ) : (
                  <p class="empty">No State House or State Senate candidates returned.</p>
                )}

                <a class="section-footer-action" href={allCandidatesHref}>
                  See all legislative candidates
                </a>
              </section>
            </div>

            <aside class="panel">
              <div class="section-heading">
                <p class="eyebrow">Articles</p>
                <h2>Related Coverage</h2>
              </div>

              {articles.length ? (
                <div class="article-list">
                  {articles.map((article) => (
                    <article>
                      {article.preview?.imageUrl && <img src={article.preview.imageUrl} alt="" loading="lazy" />}
                      <h3><a href={article.url}>{articleTitle(article)}</a></h3>
                      <div class="article-meta-inline">
                        {articlePublisher(article) && <span>Source: {articlePublisher(article)}</span>}
                        {articlePublishDate(article) && <span>Published: {articlePublishDate(article)}</span>}
                      </div>
                      {article.preview?.description && <p>{cleanText(article.preview.description)}</p>}
                    </article>
                  ))}
                </div>
              ) : (
                <p class="empty">No related articles returned.</p>
              )}

              {meta.articleLimit && (
                <small>Showing up to {meta.articleLimit} articles.</small>
              )}
            </aside>
          </section>
        </>
      ) : (
        <p class="status-message">Community not found.</p>
      )}
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #f7f4ee;
    color: #1f2933;
  }

  .page {
    margin: 0 auto;
    padding: 40px 0 72px;
    width: min(1120px, calc(100% - 32px));
  }

  .back,
  a {
    color: #1f2933;
    font-weight: 800;
  }

  .hero {
    align-items: end;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 6px 6px 0 #1f2933;
    display: grid;
    margin: 42px 0 32px;
    min-height: clamp(280px, 36vw, 420px);
    overflow: hidden;
    position: relative;
  }

  .hero::after {
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.08), rgba(15, 23, 42, 0.86)),
      linear-gradient(90deg, rgba(15, 23, 42, 0.78), rgba(15, 23, 42, 0.22));
    content: "";
    inset: 0;
    position: absolute;
    z-index: 1;
  }

  .hero-image {
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
    z-index: 0;
  }

  .hero-copy {
    color: #fffaf1;
    padding: clamp(24px, 5vw, 42px);
    position: relative;
    z-index: 2;
  }

  .eyebrow {
    color: #6b4f2a;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  .hero .eyebrow {
    color: #fde68a;
  }

  h1 {
    color: #fffaf1;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.92;
    margin: 0 0 18px;
    max-width: 900px;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.38);
  }

  .hero-meta,
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .hero-meta span,
  .chips a {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
    text-decoration: none;
  }

  .hero-meta span {
    background: rgba(255, 250, 241, 0.94);
    border-color: rgba(255, 255, 255, 0.7);
    color: #1f2933;
  }

  .content-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.42fr);
  }

  .stack,
  .rep-list,
  .article-list {
    display: grid;
    gap: 14px;
  }

  .panel,
  .status-message {
    background: white;
    border: 2px solid #1f2933;
    border-radius: 8px;
    box-shadow: 4px 4px 0 #1f2933;
    padding: 20px;
  }

  .section-heading h2 {
    font-size: 1.45rem;
    margin: 0 0 16px;
  }

  .split-heading {
    align-items: start;
    display: flex;
    gap: 14px;
    justify-content: space-between;
  }

  .section-action {
    background: #1f2933;
    border: 1px solid #1f2933;
    border-radius: 999px;
    color: white;
    flex: 0 0 auto;
    font-size: 0.8rem;
    font-weight: 900;
    line-height: 1;
    padding: 9px 11px;
    text-decoration: none;
    white-space: nowrap;
  }

  .section-action:hover {
    background: white;
    color: #1f2933;
  }

  .section-footer-action {
    align-items: center;
    background: #fffaf1;
    border: 1px solid #1f2933;
    border-radius: 8px;
    display: flex;
    font-size: 0.9rem;
    font-weight: 900;
    justify-content: center;
    margin-top: 14px;
    padding: 11px 12px;
    text-decoration: none;
  }

  .section-footer-action:hover {
    background: #1f2933;
    color: white;
  }

  .rep-list article,
  .article-list article {
    background: #fffaf1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 14px;
  }

  .article-list article > img {
    aspect-ratio: 16 / 9;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    display: block;
    margin-bottom: 12px;
    object-fit: cover;
    width: 100%;
  }

  .article-meta-inline {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 6px 0 0;
  }

  .article-meta-inline span {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.72rem;
    font-weight: 900;
    padding: 4px 7px;
  }

  .profile-preview-list article {
    align-items: start;
    display: grid;
    gap: 12px;
    grid-template-columns: 64px 1fr;
  }

  .profile-preview-heading {
    align-items: start;
    display: flex;
    gap: 10px;
    justify-content: space-between;
  }

  .mini-grade {
    border: 1px solid #1f2933;
    border-radius: 10px;
    box-shadow: 2px 2px 0 #1f2933;
    color: #fefce8;
    display: grid;
    flex: 0 0 auto;
    min-width: 48px;
    padding: 5px 7px;
    text-align: center;
  }

  .mini-grade strong {
    font-size: 1.35rem;
    font-weight: 950;
    line-height: 1;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .mini-grade small {
    color: #fefce8;
    font-size: 0.56rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    line-height: 1;
    margin: 2px 0 0;
    text-transform: uppercase;
  }

  .grade-a {
    background: #166534;
  }

  .grade-b {
    background: #65a30d;
  }

  .grade-c {
    background: #ca8a04;
  }

  .grade-d {
    background: #ea580c;
  }

  .grade-f {
    background: #b42318;
  }

  .grade-unknown {
    background: #5b616e;
  }

  .mini-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }

  .profile-preview-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }

  .profile-preview-actions a {
    background: white;
    border: 1px solid #1f2933;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 900;
    padding: 4px 8px;
    text-decoration: none;
  }

  .profile-preview-actions a:hover {
    background: #1f2933;
    color: white;
  }

  .mini-tags a {
    background: #7f1d1d;
    border: 1px solid #111827;
    border-radius: 999px;
    box-shadow: 2px 2px 0 #111827;
    color: white;
    font-size: 0.74rem;
    font-weight: 900;
    padding: 4px 8px;
    text-decoration: none;
  }

  .mini-tags a:hover {
    background: #450a0a;
  }

  .profile-photo-link {
    display: block;
  }

  .profile-photo-link img {
    aspect-ratio: 4 / 5;
    border: 2px solid #1f2933;
    border-radius: 10px;
    box-sizing: border-box;
    display: block;
    height: 80px;
    object-fit: cover;
    object-position: center top;
    width: 64px;
  }

  .profile-photo-link img.profile-icon {
    object-fit: cover;
  }

  h3 {
    font-size: 1rem;
    margin: 0;
  }

  p,
  .empty,
  small {
    color: #4b5563;
    font-weight: 800;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  @media (max-width: 820px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    .split-heading {
      align-items: stretch;
      flex-direction: column;
    }

    .section-action {
      justify-self: start;
      width: fit-content;
    }
  }
</style>
