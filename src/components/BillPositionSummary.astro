---
import { positionCounts } from "../lib/billsApi";

const { bill, compact = false } = Astro.props;
const counts = positionCounts(bill);

function communityClass() {
  if (counts.support > counts.oppose) {
    return "community-support";
  }

  if (counts.oppose > counts.support) {
    return "community-oppose";
  }

  if (counts.support > 0 || counts.oppose > 0) {
    return "community-neutral";
  }

  return "";
}

const className = communityClass();
---

<div class:list={["position-summary", compact && "compact"]}>
  {className ? (
    <>
      <span class:list={["stance-pill", className]}>Remote Testimony</span>
      <span class="support-pill">{counts.support} Support</span>
      <span class="oppose-pill">{counts.oppose} Oppose</span>
    </>
  ) : (
    <span class="stance-pill community-neutral">No remote testimony</span>
  )}
</div>

<style>
  .position-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .position-summary span {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .position-summary.compact span {
    font-size: 0.76rem;
    padding: 5px 8px;
  }

  .stance-pill {
    border-width: 2px;
  }

  .community-support {
    background: #dff0d8;
    border-color: #2f7d4f;
  }

  .community-oppose {
    background: #fde2de;
    border-color: #b42318;
  }

  .community-neutral {
    background: #eef0f4;
    border-color: #5b616e;
  }

  .support-pill {
    background: #e7f7ec;
    border-color: #86c894;
    color: #166534;
  }

  .oppose-pill {
    background: #fee2e2;
    border-color: #fca5a5;
    color: #991b1b;
  }
</style>
