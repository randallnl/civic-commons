---
import { positionCounts } from "../lib/billsApi";

const { bill, compact = false } = Astro.props;
const counts = positionCounts(bill);

function testimonySentiment() {
  const support = Math.max(0, Number(counts.support || 0));
  const oppose = Math.max(0, Number(counts.oppose || 0));
  const total = support + oppose;

  if (!total) {
    return null;
  }

  const difference = Math.abs(support - oppose);
  const margin = difference / total;
  const direction = support > oppose ? "Support" : "Oppose";
  const classDirection = support > oppose ? "support" : "oppose";

  if (total < 50 && margin <= 0.25) {
    return { label: "Neutral", className: "sentiment-neutral" };
  }

  if (margin <= 0.1) {
    return { label: "Divided", className: "sentiment-divided" };
  }

  if (margin <= 0.25) {
    return { label: `Slightly ${direction}`, className: `sentiment-${classDirection}-slight` };
  }

  if (margin <= 0.5) {
    return { label: `Mostly ${direction}`, className: `sentiment-${classDirection}-mostly` };
  }

  return { label: `Overwhelmingly ${direction}`, className: `sentiment-${classDirection}-overwhelming` };
}

const sentiment = testimonySentiment();
const supportCount = Math.max(0, Number(counts.support || 0));
const opposeCount = Math.max(0, Number(counts.oppose || 0));
---

<div class:list={["position-summary", compact && "compact"]}>
  {sentiment ? (
    <>
      <span class="summary-title">Public Testimony</span>
      <div class="summary-pills">
        <span class:list={["sentiment-pill", sentiment.className]}>{sentiment.label}</span>
        <span class="count-pill support-count">{supportCount} Support</span>
        <span class="count-pill oppose-count">{opposeCount} Oppose</span>
      </div>
    </>
  ) : (
    <span class="summary-title community-neutral">No public testimony</span>
  )}
</div>

<style>
  .position-summary {
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    display: grid;
    gap: 7px;
    padding: 8px;
  }

  .summary-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .sentiment-pill {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
    text-align: center;
  }

  .count-pill {
    background: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 6px 9px;
    text-align: center;
  }

  .support-count {
    border-color: #86efac;
    color: #166534;
  }

  .oppose-count {
    border-color: #fca5a5;
    color: #991b1b;
  }

  .position-summary.compact .sentiment-pill,
  .position-summary.compact .count-pill {
    font-size: 0.76rem;
    padding: 5px 8px;
  }

  .position-summary.compact {
    border-radius: 10px;
    gap: 5px;
    padding: 6px;
  }

  .summary-title {
    border-bottom: 1px solid #d1d5db;
    color: #1f2933;
    display: block;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    padding: 0 0 5px;
    text-transform: uppercase;
  }

  .position-summary.compact .summary-title {
    font-size: 0.66rem;
    padding-bottom: 4px;
  }

  .community-neutral {
    color: #475569;
  }

  .sentiment-neutral {
    background: #e2e8f0;
    border-color: #94a3b8;
    color: #334155;
  }

  .sentiment-divided {
    background: #dbeafe;
    border-color: #60a5fa;
    color: #1d4ed8;
  }

  .sentiment-support-slight {
    background: #e0f2fe;
    border-color: #0284c7;
    color: #075985;
  }

  .sentiment-support-mostly {
    background: #dcfce7;
    border-color: #16a34a;
    color: #166534;
  }

  .sentiment-support-overwhelming {
    background: #14532d;
    border-color: #14532d;
    color: #f0fdf4;
  }

  .sentiment-oppose-slight {
    background: #fef3c7;
    border-color: #d97706;
    color: #92400e;
  }

  .sentiment-oppose-mostly {
    background: #fee2e2;
    border-color: #ef4444;
    color: #991b1b;
  }

  .sentiment-oppose-overwhelming {
    background: #7f1d1d;
    border-color: #7f1d1d;
    color: #fef2f2;
  }
</style>
