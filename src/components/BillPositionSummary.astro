---
import { positionCounts } from "../lib/billsApi";

const { bill, compact = false } = Astro.props;
const counts = positionCounts(bill);

function communityClass() {
  if (counts.support > counts.oppose) {
    return "community-support";
  }

  if (counts.oppose > counts.support) {
    return "community-oppose";
  }

  if (counts.support > 0 || counts.oppose > 0) {
    return "community-neutral";
  }

  return "";
}

const className = communityClass();
---

<div class:list={["position-summary", compact && "compact"]}>
  {className ? (
    <>
      <span class:list={["summary-title", className]}>Remote Testimony</span>
      <div class="summary-pills">
        <span class="support-pill">{counts.support} Support</span>
        <span class="oppose-pill">{counts.oppose} Oppose</span>
      </div>
    </>
  ) : (
    <span class="summary-title community-neutral">No remote testimony</span>
  )}
</div>

<style>
  .position-summary {
    background: #fffaf1;
    border: 1px solid #9ca3af;
    border-radius: 12px;
    display: grid;
    gap: 7px;
    padding: 8px;
  }

  .summary-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .summary-pills span {
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 999px;
    color: #1f2933;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 6px 9px;
  }

  .position-summary.compact .summary-pills span {
    font-size: 0.76rem;
    padding: 5px 8px;
  }

  .position-summary.compact {
    border-radius: 10px;
    gap: 5px;
    padding: 6px;
  }

  .summary-title {
    border-bottom: 1px solid #d1d5db;
    color: #1f2933;
    display: block;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    padding: 0 0 5px;
    text-transform: uppercase;
  }

  .position-summary.compact .summary-title {
    font-size: 0.66rem;
    padding-bottom: 4px;
  }

  .community-support {
    color: #166534;
  }

  .community-oppose {
    color: #991b1b;
  }

  .community-neutral {
    color: #475569;
  }

  .support-pill {
    background: #e0f2fe;
    border-color: #0284c7;
    color: #075985;
  }

  .oppose-pill {
    background: #fef3c7;
    border-color: #d97706;
    color: #92400e;
  }
</style>
